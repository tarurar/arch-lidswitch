        'TEST_HYPRCTL_VERSION_JSON={"version":"0.100.0","tag":"unknown"}' \
        || failures=$((failures + 1))
    installer_matches_fixture_expectation \
        'one-external.txt' \
        success \
        'Detected internal output: eDP-1 (enabled)' \
        'a future Hyprland major version should satisfy the minimum-version contract' \
        'TEST_HYPRCTL_VERSION_JSON={"version":"1.2.3","tag":"unknown"}'

    (( failures == 0 ))
}

