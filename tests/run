#!/bin/bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ENV_BIN=$(command -v env)
REAL_SLEEP_BIN=$(command -v sleep)
TIMEOUT_BIN=$(command -v timeout)
LUA_BIN=${LUA_BIN:-$(command -v lua)}
SYSTEMD_ANALYZE_BIN=$(command -v systemd-analyze)
TEST_FILTER=${1:-}

if [[ $# -gt 1 ]]; then
    printf 'usage: %s [test-filter]\n' "$0" >&2
    exit 2
fi

assert_contains() {
    local actual=$1
    local expected=$2
    local message=$3

    if [[ "$actual" != *"$expected"* ]]; then
        printf 'assertion failed: %s\nmissing: %s\nactual:\n%s\n' \
            "$message" "$expected" "$actual" >&2
        return 1
    fi
}

assert_not_contains() {
    local actual=$1
    local unexpected=$2
    local message=$3

    if [[ "$actual" == *"$unexpected"* ]]; then
        printf 'assertion failed: %s\nunexpected: %s\nactual:\n%s\n' \
            "$message" "$unexpected" "$actual" >&2
        return 1
    fi
}

install_safe_path() {
    local fake_bin=$1
    local safe_bin=$2
    local command_name command_path

    mkdir -p "$fake_bin" "$safe_bin"

    for command_name in busctl hyprctl systemctl systemd-inhibit pgrep pkill sleep; do
        ln -s "$ROOT_DIR/tests/fakes/effect" "$fake_bin/$command_name"
    done

    # Only ordinary utilities needed inside the isolated HOME are exposed.
    # Power, compositor, process-signal, and timing commands exist solely as fakes.
    for command_name in awk cat chmod cp cut date dirname grep head mkdir mktemp mv rm sed; do
        command_path=$(command -v "$command_name")
        ln -s "$command_path" "$safe_bin/$command_name"
    done
}

prepare_hyprland_config() {
    local home=$1

    mkdir -p "$home/.config/hypr"
    printf '%s\n' '-- isolated Hyprland Lua test config' \
        > "$home/.config/hypr/hyprland.lua"
}

assert_before() {
    local actual=$1
    local first=$2
    local second=$3
    local message=$4
    local first_prefix second_prefix

    if [[ "$actual" != *"$first"* ]] || [[ "$actual" != *"$second"* ]]; then
        printf 'assertion failed: %s\nrequired ordered values were absent\nactual:\n%s\n' \
            "$message" "$actual" >&2
        return 1
    fi

    first_prefix=${actual%%"$first"*}
    second_prefix=${actual%%"$second"*}
    if (( ${#first_prefix} >= ${#second_prefix} )); then
        printf 'assertion failed: %s\nfirst: %s\nsecond: %s\nactual:\n%s\n' \
            "$message" "$first" "$second" "$actual" >&2
        return 1
    fi
}

installed_cli_handles_documented_open_and_close() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log installed_cli monitor_fixture
    local close_effects open_effects close_output open_output

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    mkdir -p "$home"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1

    installed_cli="$home/.config/hypr/scripts/lid-switch.sh"
    if [[ ! -x "$installed_cli" ]]; then
        printf 'installer did not create an executable lid-switch CLI\n' >&2
        return 1
    fi

    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$installed_cli" close \
        > "$test_root/close.out" 2>&1
    close_effects=$(<"$effect_log")
    close_output=$(<"$test_root/close.out")

    assert_contains "$close_effects" $'monitor\toutput=eDP-1\tdisabled=true' \
        'closing the lid should disable the installed laptop output'
    assert_contains "$close_effects" $'monitor\toutput=DP-2\tmode=preferred\tposition=0x0\tscale=1' \
        'closing the lid should keep the external output at the origin'
    assert_contains "$close_effects" $'pkill\t-x\t-SIGUSR1\twaybar' \
        'closing the lid should safely request the documented Waybar refresh'
    assert_contains "$close_effects" $'sleep\t0.1' \
        'the Waybar refresh delay must use the fake clock boundary'
    assert_not_contains "$close_effects" $'systemctl\t' \
        'a successful docked close must not request a power action'

    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$installed_cli" open \
        > "$test_root/open.out" 2>&1
    open_effects=$(<"$effect_log")
    open_output=$(<"$test_root/open.out")

    assert_contains "$open_effects" $'monitor\toutput=eDP-1\tdisabled=false\tmode=2880x1920@120\tposition=0x0\tscale=2' \
        'opening the lid should enable the installed laptop output'
    assert_contains "$open_effects" $'monitor\toutput=DP-2\tmode=preferred\tposition=auto-right\tscale=1' \
        'opening the lid should restore the documented dual-output placement'
    assert_contains "$open_effects" $'pkill\t-x\t-SIGUSR1\twaybar' \
        'opening the lid should safely request the documented Waybar refresh'
    assert_contains "$open_effects" $'sleep\t0.1' \
        'the Waybar refresh delay must use the fake clock boundary'
    assert_not_contains "$open_effects" $'systemctl\t' \
        'a successful open must not request a power action'

    assert_contains "$close_output" \
        'level=info component=lid-switch event=layout_applied action=close laptop=disabled external=DP-2' \
        'close transition should report a structured success record'
    assert_contains "$open_output" \
        'level=info component=lid-switch event=layout_applied action=open layout=dual external=DP-2' \
        'open transition should report a structured success record'
)

installed_cli_delegates_laptop_only_close_to_logind() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture installed_cli
    local runtime_effects runtime_output runtime_status=0 failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/laptop-only.txt"
    mkdir -p "$home"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1

    installed_cli="$home/.config/hypr/scripts/lid-switch.sh"
    : > "$effect_log"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$installed_cli" close \
        > "$test_root/runtime.out" 2>&1 || runtime_status=$?

    runtime_effects=$(<"$effect_log")
    runtime_output=$(<"$test_root/runtime.out")

    if (( runtime_status != 0 )); then
        printf 'expected delegated close status 0, got %d\nruntime output:\n%s\n' \
            "$runtime_status" "$runtime_output" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$runtime_effects" $'hyprctl\tmonitors' \
        'the installed CLI should inspect the current monitor state' \
        || failures=$((failures + 1))
    assert_not_contains "$runtime_effects" $'systemctl\t' \
        'the display helper must not request a lid power action' \
        || failures=$((failures + 1))
    assert_not_contains "$runtime_effects" $'monitor\t' \
        'a laptop-only close should not mutate display state' \
        || failures=$((failures + 1))
    assert_contains "$runtime_output" \
        'level=info component=lid-switch event=power_delegated owner=systemd-logind action=close reason=no_external_monitor' \
        'the installed CLI should record the single lid-power owner' \
        || failures=$((failures + 1))
    assert_not_contains "$runtime_output" 'event=power_action_requested' \
        'the display helper must not report a repository-owned power request' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installed_doctor_accepts_chosen_logind_policy() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture doctor
    local doctor_output effects doctor_status=0 failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    mkdir -p "$home"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1

    doctor="$home/.config/hypr/scripts/lid-switch-doctor.sh"
    if [[ ! -x "$doctor" ]]; then
        printf 'installer did not create an executable lid-switch doctor\n' >&2
        return 1
    fi
    if ! cmp -s "$ROOT_DIR/runtime/lid-switch-doctor.sh" "$doctor"; then
        printf 'installed doctor differs from the canonical runtime source\n' >&2
        return 1
    fi

    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        "$doctor" \
        > "$test_root/doctor.out" 2>&1 || doctor_status=$?

    doctor_output=$(<"$test_root/doctor.out")
    effects=$(<"$effect_log")

    if (( doctor_status != 0 )); then
        printf 'expected healthy doctor status 0, got %d\ndoctor output:\n%s\n' \
            "$doctor_status" "$doctor_output" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$doctor_output" 'PASS HandleLidSwitch=suspend' \
        'doctor should report the chosen undocked action' \
        || failures=$((failures + 1))
    assert_contains "$doctor_output" 'PASS HandleLidSwitchDocked=ignore' \
        'doctor should report the chosen docked action' \
        || failures=$((failures + 1))
    assert_contains "$doctor_output" \
        'PASS HandleLidSwitchExternalPower=<unset> fallback=HandleLidSwitch' \
        'doctor should report the default external-power fallback' \
        || failures=$((failures + 1))
    assert_contains "$doctor_output" 'PASS handle-lid-switch inhibitors=none' \
        'doctor should prove that no other process owns the lid switch' \
        || failures=$((failures + 1))
    assert_contains "$effects" $'busctl\tget-property\torg.freedesktop.login1\t/org/freedesktop/login1\torg.freedesktop.login1.Manager\tHandleLidSwitchDocked' \
        'doctor should read the effective docked action' \
        || failures=$((failures + 1))
    assert_contains "$effects" $'busctl\tget-property\torg.freedesktop.login1\t/org/freedesktop/login1\torg.freedesktop.login1.Manager\tHandleLidSwitchExternalPower' \
        'doctor should read the effective external-power action' \
        || failures=$((failures + 1))
    assert_contains "$effects" $'systemd-inhibit\t--list\t--what=handle-lid-switch\t--no-pager\t--no-legend' \
        'doctor should inspect low-level lid ownership without taking an inhibitor' \
        || failures=$((failures + 1))

    doctor_status=0
    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_LOGIND_HANDLE_LID_SWITCH_EXTERNAL_POWER=suspend \
        "$doctor" --policy-only \
        > "$test_root/external-power-doctor.out" 2>&1 || doctor_status=$?
    if (( doctor_status != 0 )); then
        printf 'expected explicit suspend policy status 0, got %d\n%s\n' \
            "$doctor_status" "$(<"$test_root/external-power-doctor.out")" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$(<"$test_root/external-power-doctor.out")" \
        'PASS HandleLidSwitchExternalPower=suspend' \
        'doctor should accept an explicit external-power suspend action' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

doctor_accepts_current_host_capability_profile() (
    set -euo pipefail

    local test_root fake_bin safe_bin effect_log doctor_output effects
    local doctor_status=0 failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_LOGIND_CAN_SUSPEND=yes \
        TEST_LOGIND_CAN_HIBERNATE=na \
        /bin/bash "$ROOT_DIR/runtime/lid-switch-doctor.sh" \
        > "$test_root/doctor.out" 2>&1 || doctor_status=$?

    doctor_output=$(<"$test_root/doctor.out")
    effects=$(<"$effect_log")

    if (( doctor_status != 0 )); then
        printf 'expected current host capability profile status 0, got %d\n%s\n' \
            "$doctor_status" "$doctor_output" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$doctor_output" 'PASS CanSuspend=yes' \
        'doctor should verify the delegated suspend action is available' \
        || failures=$((failures + 1))
    assert_contains "$doctor_output" 'INFO CanHibernate=na hibernate=unused' \
        'doctor should report the current unavailable hibernate capability as informational' \
        || failures=$((failures + 1))
    assert_contains "$effects" $'busctl\tcall\torg.freedesktop.login1\t/org/freedesktop/login1\torg.freedesktop.login1.Manager\tCanSuspend' \
        'doctor should read the effective suspend capability' \
        || failures=$((failures + 1))
    assert_contains "$effects" $'busctl\tcall\torg.freedesktop.login1\t/org/freedesktop/login1\torg.freedesktop.login1.Manager\tCanHibernate' \
        'doctor should read the informational hibernate capability' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'systemctl\t' \
        'capability diagnostics must never request a power action' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

doctor_reports_available_hibernate_as_unused() (
    set -euo pipefail

    local test_root fake_bin safe_bin effect_log doctor_output effects
    local doctor_status=0 failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_LOGIND_CAN_SUSPEND=yes \
        TEST_LOGIND_CAN_HIBERNATE=yes \
        /bin/bash "$ROOT_DIR/runtime/lid-switch-doctor.sh" \
        > "$test_root/doctor.out" 2>&1 || doctor_status=$?

    doctor_output=$(<"$test_root/doctor.out")
    effects=$(<"$effect_log")

    if (( doctor_status != 0 )); then
        printf 'expected available-but-unused hibernate status 0, got %d\n%s\n' \
            "$doctor_status" "$doctor_output" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$doctor_output" 'PASS CanSuspend=yes' \
        'verified suspend should remain the selected delegated action' \
        || failures=$((failures + 1))
    assert_contains "$doctor_output" \
        'INFO CanHibernate=yes hibernate=available-but-unused' \
        'an available hibernate capability should not select hibernation' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'systemctl\t' \
        'reporting an available capability must not request hibernation' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installed_cli_refuses_actions_when_monitor_query_fails() (
    set -euo pipefail

    local transition=$1
    local test_root home fake_bin safe_bin effect_log installed_cli
    local install_fixture missing_runtime_fixture runtime_effects runtime_output
    local runtime_output_file runtime_status=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    runtime_output_file="$test_root/runtime.out"
    install_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    missing_runtime_fixture="$test_root/missing-monitors.txt"
    mkdir -p "$home"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$install_fixture" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1

    installed_cli="$home/.config/hypr/scripts/lid-switch.sh"
    : > "$effect_log"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$missing_runtime_fixture" \
        "$installed_cli" "$transition" \
        > "$runtime_output_file" 2>&1 || runtime_status=$?

    runtime_effects=$(<"$effect_log")
    runtime_output=$(<"$runtime_output_file")

    assert_contains "$runtime_effects" $'hyprctl\tmonitors' \
        'the installed CLI should reach the failing monitor-query boundary'
    assert_not_contains "$runtime_effects" $'systemctl\t' \
        'a monitor-query failure must not request a power action'
    assert_not_contains "$runtime_effects" $'monitor\t' \
        'a monitor-query failure must not change monitor state'

    if (( runtime_status != 2 )); then
        printf 'expected query failure status 2, got %d\nruntime output:\n%s\n' \
            "$runtime_status" "$runtime_output" >&2
        return 1
    fi

    assert_contains "$runtime_output" \
        "level=error component=lid-switch event=monitor_query_failed action=$transition" \
        'the query failure should be distinguishable at the journal stream boundary'
    assert_not_contains "$runtime_output" 'event=external_monitor_absent' \
        'a query failure must not be reported as a valid empty topology'
)

installed_cli_refuses_power_when_close_monitor_query_fails() {
    installed_cli_refuses_actions_when_monitor_query_fails close
}

installed_cli_refuses_display_when_open_monitor_query_fails() {
    installed_cli_refuses_actions_when_monitor_query_fails open
}

create_lid_state_fixture() {
    local lid_root=$1
    local scenario=$2

    case "$scenario" in
        lid0)
            mkdir -p "$lid_root/LID0"
            printf '%s\n' 'state: open' > "$lid_root/LID0/state"
            ;;
        lid1)
            mkdir -p "$lid_root/LID1"
            printf '%s\n' 'state: closed' > "$lid_root/LID1/state"
            ;;
        multiple-agreeing)
            mkdir -p "$lid_root/LID0" "$lid_root/LID1"
            printf '%s\n' 'state: open' > "$lid_root/LID0/state"
            printf '%s\n' 'state: open' > "$lid_root/LID1/state"
            ;;
        multiple-conflicting)
            mkdir -p "$lid_root/LID0" "$lid_root/LID1"
            printf '%s\n' 'state: open' > "$lid_root/LID0/state"
            printf '%s\n' 'state: closed' > "$lid_root/LID1/state"
            ;;
        missing)
            ;;
        unreadable)
            mkdir -p "$lid_root/LID0/state"
            ;;
        malformed)
            mkdir -p "$lid_root/LID0"
            printf '%s\n' 'state: ajar' > "$lid_root/LID0/state"
            ;;
        *)
            printf 'unknown lid state fixture: %s\n' "$scenario" >&2
            return 2
            ;;
    esac
}

installed_runtime_reports_through_the_journal_boundary() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture lid_root
    local installed_cli installed_daemon installed_unit runtime_artifacts unit_contents
    local runtime_output daemon_output failures=0 runtime_status=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    lid_root="$test_root/button/lid"
    mkdir -p "$home"
    prepare_hyprland_config "$home"
    create_lid_state_fixture "$lid_root" lid0
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1

    installed_cli="$home/.config/hypr/scripts/lid-switch.sh"
    installed_daemon="$home/.config/hypr/scripts/lid-monitor.sh"
    installed_unit="$home/.config/systemd/user/lid-monitor.service"

    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$test_root/missing-monitors.txt" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$installed_cli" close \
        > "$test_root/runtime.out" 2>&1 || runtime_status=$?

    if (( runtime_status != 2 )); then
        printf 'expected query failure status 2, got %d\n' "$runtime_status" >&2
        failures=$((failures + 1))
    fi

    runtime_output=$(<"$test_root/runtime.out")
    assert_contains "$runtime_output" \
        'level=error component=lid-switch event=monitor_query_failed action=close' \
        'the runtime should expose a useful structured error to the service journal stream' \
        || failures=$((failures + 1))

    runtime_artifacts="$(<"$installed_cli")"$'\n'"$(<"$installed_daemon")"
    assert_not_contains "$runtime_artifacts" '/tmp/' \
        'installed runtime scripts must not contain shared-/tmp paths' \
        || failures=$((failures + 1))
    assert_not_contains "$runtime_artifacts" 'HYPR_LID_SWITCH_LOG_FILE' \
        'installed runtime scripts must not expose a file-log redirection seam' \
        || failures=$((failures + 1))

    unit_contents=$(<"$installed_unit")
    assert_contains "$unit_contents" 'StandardOutput=journal' \
        'the installed unit should route daemon output to the journal' \
        || failures=$((failures + 1))
    assert_contains "$unit_contents" 'StandardError=journal' \
        'the installed unit should route daemon diagnostics to the journal' \
        || failures=$((failures + 1))
    assert_contains "$unit_contents" 'SyslogIdentifier=arch-lidswitch' \
        'the installed unit should give journal records a stable identifier' \
        || failures=$((failures + 1))

    rm -f "$fake_bin/sleep"
    ln -s "$REAL_SLEEP_BIN" "$fake_bin/sleep"
    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        HYPR_LID_STATE_ROOT="$test_root/missing-lid" \
        "$TIMEOUT_BIN" 0.2 "$installed_daemon" \
        > "$test_root/daemon.out" 2>&1 || true
    daemon_output=$(<"$test_root/daemon.out")
    assert_contains "$daemon_output" \
        'level=error component=lid-monitor event=lid_state_observation_failed reason=missing' \
        'the running daemon should expose why lid observation is unavailable to the journal stream' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installed_lid_state_matches_expected_behavior() (
    set -euo pipefail

    local scenario=$1
    local expected_state=$2
    local expected_error=${3:-}
    local test_root home fake_bin safe_bin effect_log monitor_fixture lid_root
    local installed_cli installed_daemon cli_effects daemon_output installer_output
    local cli_status=0 daemon_status=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    lid_root="$test_root/button/lid"
    mkdir -p "$home"
    prepare_hyprland_config "$home"
    create_lid_state_fixture "$lid_root" "$scenario"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    if ! "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1; then
        printf 'installer failed for lid fixture %s:\n%s\n' \
            "$scenario" "$(<"$test_root/installer.out")" >&2
        return 1
    fi
    installer_output=$(<"$test_root/installer.out")

    if [[ "$expected_state" == 'unknown' ]]; then
        assert_contains "$installer_output" 'Could not determine lid state' \
            'installer should report an unavailable lid state without guessing' || return 1
    else
        assert_contains "$installer_output" "Lid state detection working: $expected_state" \
            'installer should use the shared runtime lid observer' || return 1
    fi

    installed_cli="$home/.config/hypr/scripts/lid-switch.sh"
    installed_daemon="$home/.config/hypr/scripts/lid-monitor.sh"

    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$installed_cli" \
        > "$test_root/cli.out" 2> "$test_root/cli.err" || cli_status=$?
    cli_effects=$(<"$effect_log")

    case "$expected_state" in
        open)
            if (( cli_status != 0 )); then
                printf 'expected open CLI status 0, got %d:\n%s\n' \
                    "$cli_status" "$(<"$test_root/cli.err")" >&2
                return 1
            fi
            assert_contains "$cli_effects" $'monitor\toutput=eDP-1\tdisabled=false' \
                'an open lid state should select the installed CLI open transition' || return 1
            assert_contains "$cli_effects" $'monitor\toutput=DP-2\tmode=preferred\tposition=auto-right\tscale=1' \
                'an open lid state should restore the external output placement' || return 1
            ;;
        closed)
            if (( cli_status != 0 )); then
                printf 'expected closed CLI status 0, got %d:\n%s\n' \
                    "$cli_status" "$(<"$test_root/cli.err")" >&2
                return 1
            fi
            assert_contains "$cli_effects" $'monitor\toutput=eDP-1\tdisabled=true' \
                'a closed lid state should select the installed CLI close transition' || return 1
            assert_contains "$cli_effects" $'monitor\toutput=DP-2\tmode=preferred\tposition=0x0\tscale=1' \
                'a closed lid state should retain the external output at the origin' || return 1
            ;;
        unknown)
            if (( cli_status == 0 )); then
                printf 'installed CLI accepted unavailable lid fixture: %s\n' "$scenario" >&2
                return 1
            fi
            if [[ -s "$effect_log" ]]; then
                printf 'unavailable lid state caused external effects:\n%s\n' \
                    "$cli_effects" >&2
                return 1
            fi
            assert_contains "$(<"$test_root/cli.err")" \
                'level=error component=lid-switch event=lid_state_unknown action=auto' \
                'the installed CLI should explain why automatic action was refused at its stderr boundary' \
                || return 1
            ;;
        *)
            printf 'unknown expected lid state: %s\n' "$expected_state" >&2
            return 2
            ;;
    esac

    assert_not_contains "$cli_effects" $'systemctl\t' \
        'lid observation must not request a power action in the docked fixture' || return 1

    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$installed_daemon" --print-state \
        > "$test_root/daemon.out" 2> "$test_root/daemon.err" || daemon_status=$?
    daemon_output=$(<"$test_root/daemon.out")

    if [[ "$expected_state" == 'unknown' ]]; then
        if (( daemon_status == 0 )); then
            printf 'daemon accepted unavailable lid fixture: %s\n' "$scenario" >&2
            return 1
        fi
        if [[ "$daemon_output" != 'unknown' ]]; then
            printf 'expected daemon to report unknown, got: %s\n' "$daemon_output" >&2
            return 1
        fi
        assert_contains "$(<"$test_root/daemon.err")" "$expected_error" \
            'daemon should distinguish the lid observation failure' || return 1
    else
        if (( daemon_status != 0 )); then
            printf 'expected daemon state status 0, got %d:\n%s\n' \
                "$daemon_status" "$(<"$test_root/daemon.err")" >&2
            return 1
        fi
        if [[ "$daemon_output" != "$expected_state" ]]; then
            printf 'expected daemon to report %s, got: %s\n' \
                "$expected_state" "$daemon_output" >&2
            return 1
        fi
    fi
    if [[ -s "$effect_log" ]]; then
        printf 'daemon state diagnostic caused external effects:\n%s\n' \
            "$(<"$effect_log")" >&2
        return 1
    fi
)

installed_lid0_state_drives_cli_and_daemon() {
    installed_lid_state_matches_expected_behavior lid0 open
}

installed_lid1_state_drives_cli_and_daemon() {
    installed_lid_state_matches_expected_behavior lid1 closed
}

installed_agreeing_lid_states_drive_cli_and_daemon() {
    installed_lid_state_matches_expected_behavior multiple-agreeing open
}

installed_conflicting_lid_states_are_refused() {
    installed_lid_state_matches_expected_behavior \
        multiple-conflicting unknown 'Conflicting ACPI lid states'
}

installed_missing_lid_state_is_refused() {
    installed_lid_state_matches_expected_behavior \
        missing unknown 'No ACPI lid state files found'
}

installed_unreadable_lid_state_is_refused() {
    installed_lid_state_matches_expected_behavior \
        unreadable unknown 'Unable to read ACPI lid state'
}

installed_malformed_lid_state_is_refused() {
    installed_lid_state_matches_expected_behavior \
        malformed unknown 'Malformed ACPI lid state'
}

installer_matches_fixture_expectation() (
    set -euo pipefail

    local fixture_name=$1
    local expected_outcome=$2
    local expected_message=$3
    local assertion_message=$4
    local test_root home fake_bin safe_bin effect_log fixture installer_output
    local installer_status=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    fixture="$ROOT_DIR/tests/fixtures/monitors/$fixture_name"
    mkdir -p "$home"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$fixture" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1 || installer_status=$?

    installer_output=$(<"$test_root/installer.out")
    case "$expected_outcome" in
        success)
            if (( installer_status != 0 )); then
                printf 'installer failed for monitor fixture %s:\n%s\n' \
                    "$fixture_name" "$installer_output" >&2
                return 1
            fi
            if [[ ! -x "$home/.config/hypr/scripts/lid-switch.sh" ]]; then
                printf 'installer did not create an executable lid-switch CLI\n' >&2
                return 1
            fi
            ;;
        failure)
            if (( installer_status == 0 )); then
                printf 'installer unexpectedly succeeded for monitor fixture %s\n' \
                    "$fixture_name" >&2
                return 1
            fi
            ;;
        *)
            printf 'unknown installer outcome expectation: %s\n' "$expected_outcome" >&2
            return 2
            ;;
    esac

    assert_contains "$installer_output" "$expected_message" "$assertion_message"
)

installer_succeeds_without_an_external_monitor() {
    installer_matches_fixture_expectation \
        'laptop-only.txt' \
        success \
        'No external monitor currently connected' \
        'an absent external monitor should be reported as an informational state'
}

installer_succeeds_with_one_external_monitor() {
    installer_matches_fixture_expectation \
        'one-external.txt' \
        success \
        'Detected external monitor: DP-2' \
        'the active external monitor should be reported during installation'
}

installer_succeeds_with_multiple_external_monitors() {
    installer_matches_fixture_expectation \
        'multiple-external.txt' \
        success \
        'Detected external monitor:' \
        'multiple external monitors should not abort installation'
}

installer_rejects_a_missing_laptop_monitor() {
    installer_matches_fixture_expectation \
        'no-laptop.txt' \
        failure \
        'Could not detect laptop monitor (eDP-*)' \
        'a missing laptop output should produce the intended explicit error'
}

installer_policy_profile_is_rejected() (
    set -euo pipefail

    local expected_status=$1
    local expected_message=$2
    shift 2

    local test_root home fake_bin safe_bin effect_log monitor_fixture config original
    local installer_output effects installer_status=0 failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    config="$home/.config/hypr/hyprland.lua"
    original='-- user-owned config must remain unchanged on policy conflict'
    mkdir -p "$(dirname "$config")"
    printf '%s\n' "$original" > "$config"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$@" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1 || installer_status=$?

    installer_output=$(<"$test_root/installer.out")
    effects=$(<"$effect_log")

    if (( installer_status != expected_status )); then
        printf 'expected policy-check status %d, got %d\ninstaller output:\n%s\n' \
            "$expected_status" "$installer_status" "$installer_output" >&2
        failures=$((failures + 1))
    fi
    if [[ "$(<"$config")" != "$original" ]]; then
        printf 'policy conflict changed user configuration:\n%s\n' \
            "$(<"$config")" >&2
        failures=$((failures + 1))
    fi
    if [[ -e "$home/.config/hypr/scripts/lid-switch.sh" ]] || \
        [[ -e "$home/.config/systemd/user/lid-monitor.service" ]]; then
        printf 'policy conflict wrote installation artifacts\n' >&2
        failures=$((failures + 1))
    fi
    assert_not_contains "$effects" $'hyprctl\t' \
        'policy validation should run before monitor detection' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'systemctl\t' \
        'policy conflict must not change user-systemd state' \
        || failures=$((failures + 1))
    assert_contains "$installer_output" "$expected_message" \
        'the failed policy profile should explain its exact cause' \
        || failures=$((failures + 1))
    assert_contains "$installer_output" \
        'systemd-analyze cat-config systemd/logind.conf' \
        'the conflict should provide a read-only configuration inspection command' \
        || failures=$((failures + 1))
    assert_contains "$installer_output" \
        'This installer does not modify /etc or systemd-logind policy.' \
        'the conflict should make system-policy ownership explicit' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installer_rejects_conflicting_undocked_lid_policy() {
    installer_policy_profile_is_rejected \
        1 \
        'FAIL HandleLidSwitch=ignore expected=suspend' \
        TEST_LOGIND_HANDLE_LID_SWITCH=ignore
}

installer_rejects_conflicting_docked_lid_policy() {
    installer_policy_profile_is_rejected \
        1 \
        'FAIL HandleLidSwitchDocked=suspend expected=ignore' \
        TEST_LOGIND_HANDLE_LID_SWITCH_DOCKED=suspend
}

installer_rejects_conflicting_external_power_lid_policy() {
    installer_policy_profile_is_rejected \
        1 \
        'FAIL HandleLidSwitchExternalPower=hibernate expected=<unset-or-suspend>' \
        TEST_LOGIND_HANDLE_LID_SWITCH_EXTERNAL_POWER=hibernate
}

installer_rejects_a_low_level_lid_inhibitor() {
    installer_policy_profile_is_rejected \
        1 \
        'FAIL handle-lid-switch inhibitor present: desktop-shell 1000 user 42 shell handle-lid-switch custom handling block' \
        'TEST_LID_SWITCH_INHIBITOR=desktop-shell 1000 user 42 shell handle-lid-switch custom handling block'
}

installer_reports_a_logind_property_diagnostic_failure() {
    installer_policy_profile_is_rejected \
        2 \
        'ERROR Could not read effective logind property HandleLidSwitchDocked.' \
        TEST_BUSCTL_FAIL_PROPERTY=HandleLidSwitchDocked
}

installer_reports_a_lid_inhibitor_diagnostic_failure() {
    installer_policy_profile_is_rejected \
        2 \
        'ERROR Could not inspect handle-lid-switch inhibitors.' \
        TEST_SYSTEMD_INHIBIT_FAIL=1
}

installer_rejects_unavailable_suspend_capabilities() (
    set -euo pipefail

    local capability failures=0

    for capability in na no challenge unexpected; do
        if ! installer_policy_profile_is_rejected \
            1 \
            "FAIL CanSuspend=$capability expected=yes" \
            "TEST_LOGIND_CAN_SUSPEND=$capability"; then
            failures=$((failures + 1))
        fi
    done

    (( failures == 0 ))
)

installer_reports_suspend_capability_query_failure() {
    installer_policy_profile_is_rejected \
        2 \
        'ERROR Could not query login1 capability CanSuspend.' \
        TEST_BUSCTL_FAIL_METHOD=CanSuspend
}

installer_reports_suspend_capability_parse_failure() {
    installer_policy_profile_is_rejected \
        2 \
        'ERROR Unexpected value for login1 capability CanSuspend: malformed' \
        TEST_BUSCTL_MALFORMED_METHOD=CanSuspend
}

installer_warns_when_hibernate_capability_is_unavailable() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture
    local installer_output effects installer_status=0 failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    mkdir -p "$home"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_LOGIND_CAN_SUSPEND=yes \
        TEST_BUSCTL_FAIL_METHOD=CanHibernate \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1 || installer_status=$?

    installer_output=$(<"$test_root/installer.out")
    effects=$(<"$effect_log")

    if (( installer_status != 0 )); then
        printf 'expected optional hibernate diagnostic status 0, got %d\n%s\n' \
            "$installer_status" "$installer_output" >&2
        failures=$((failures + 1))
    fi
    if [[ ! -x "$home/.config/hypr/scripts/lid-switch-doctor.sh" ]]; then
        printf 'installer did not complete after the optional diagnostic warning\n' >&2
        failures=$((failures + 1))
    fi
    assert_contains "$installer_output" \
        'WARN Could not query login1 capability CanHibernate.' \
        'a hibernate query failure should be reported as a warning' \
        || failures=$((failures + 1))
    assert_contains "$installer_output" \
        'WARN CanHibernate=<unavailable> hibernate=unused' \
        'the warning should explain why the missing capability is non-blocking' \
        || failures=$((failures + 1))
    assert_not_contains "$installer_output" \
        'ERROR Could not query login1 capability CanHibernate.' \
        'an unused hibernate diagnostic must not be reported as a blocking error' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'systemctl\thibernate' \
        'the installer must not request hibernation' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'systemctl\tsuspend' \
        'the installer must not request suspension' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installed_session_lifecycle_is_bound_to_hyprland() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture
    local hyprland_config original_config installed_unit installed_target
    local installed_bridge installed_module unit_contents target_contents
    local config_contents effects verification_errors failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    hyprland_config="$home/.config/hypr/hyprland.lua"
    original_config='hl.on("hyprland.start", function() print("existing start") end)'

    mkdir -p "$(dirname "$hyprland_config")"
    printf '%s\n' "$original_config" > "$hyprland_config"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        DISPLAY=:9 \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_CURRENT_DESKTOP=Hyprland \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1

    installed_unit="$home/.config/systemd/user/lid-monitor.service"
    installed_target="$home/.config/systemd/user/hyprland-session.target"
    installed_bridge="$home/.config/hypr/scripts/lid-session-bridge.sh"
    installed_module="$home/.config/hypr/arch_lidswitch/session.lua"

    unit_contents=$(<"$installed_unit")
    assert_contains "$unit_contents" 'PartOf=graphical-session.target' \
        'the installed daemon should stop and restart with the graphical session' \
        || failures=$((failures + 1))
    assert_contains "$unit_contents" 'After=graphical-session.target' \
        'the installed daemon should start after the graphical session target' \
        || failures=$((failures + 1))
    assert_contains "$unit_contents" 'ConditionEnvironment=HYPRLAND_INSTANCE_SIGNATURE' \
        'the installed daemon should require a selected Hyprland instance' \
        || failures=$((failures + 1))
    assert_contains "$unit_contents" 'ConditionEnvironment=WAYLAND_DISPLAY' \
        'the installed daemon should require a Wayland display' \
        || failures=$((failures + 1))
    assert_contains "$unit_contents" "ExecStartPre=$fake_bin/hyprctl monitors" \
        'the service should prove Hyprland reachability with the installed absolute hyprctl path' \
        || failures=$((failures + 1))
    assert_contains "$unit_contents" 'Restart=on-failure' \
        'the session daemon should restart only after failures' \
        || failures=$((failures + 1))
    assert_contains "$unit_contents" 'WantedBy=graphical-session.target' \
        'the installed daemon should be enabled by the graphical session' \
        || failures=$((failures + 1))
    assert_not_contains "$unit_contents" 'Environment="DISPLAY=' \
        'the installed daemon must not hard-code an X11 display' \
        || failures=$((failures + 1))
    assert_not_contains "$unit_contents" 'WantedBy=default.target' \
        'the installed daemon must not start before the graphical session' \
        || failures=$((failures + 1))

    if [[ ! -r "$installed_target" ]]; then
        printf 'installer did not create hyprland-session.target\n' >&2
        failures=$((failures + 1))
    else
        target_contents=$(<"$installed_target")
        assert_contains "$target_contents" 'BindsTo=graphical-session.target' \
            'the Hyprland session target should bind the passive graphical target' \
            || failures=$((failures + 1))
        assert_contains "$target_contents" 'PropagatesStopTo=graphical-session.target' \
            'stopping the Hyprland session should stop graphical-session.target' \
            || failures=$((failures + 1))
    fi

    if ! SYSTEMD_BYPASS_USERDB=1 "$SYSTEMD_ANALYZE_BIN" --user verify "$installed_target" "$installed_unit" \
        > "$test_root/systemd-analyze.out" 2>&1; then
        verification_errors=$(grep -Fv \
            'Failed to turn off SO_PASSRIGHTS on user lookup socket, ignoring: Operation not permitted' \
            "$test_root/systemd-analyze.out" | grep -Fv \
            'Failed to enable SO_PASSCRED on handoff timestamp socket: Operation not permitted' || true)
        if [[ -n "$verification_errors" ]]; then
            printf 'systemd rejected installed session units:\n%s\n' \
                "$verification_errors" >&2
            failures=$((failures + 1))
        fi
    fi

    for installed_artifact in "$installed_bridge" "$installed_module"; do
        if [[ ! -r "$installed_artifact" ]]; then
            printf 'installer did not create session artifact: %s\n' "$installed_artifact" >&2
            failures=$((failures + 1))
        fi
    done

    config_contents=$(<"$hyprland_config")
    assert_contains "$config_contents" "$original_config" \
        'session integration should preserve the existing Hyprland configuration' \
        || failures=$((failures + 1))
    assert_contains "$config_contents" '-- BEGIN arch-lidswitch managed session integration' \
        'the installer should add an owned session-integration block' \
        || failures=$((failures + 1))
    assert_contains "$config_contents" 'pcall(require, "arch_lidswitch.session")' \
        'the owned integration should load the adjacent module without breaking the main config' \
        || failures=$((failures + 1))

    effects=$(<"$effect_log")
    assert_contains "$effects" $'systemctl\t--user\timport-environment\tDISPLAY\tWAYLAND_DISPLAY\tHYPRLAND_INSTANCE_SIGNATURE\tXDG_CURRENT_DESKTOP\tPATH' \
        'current-session activation should synchronously import defined Hyprland variables' \
        || failures=$((failures + 1))
    assert_contains "$effects" $'systemctl\t--user\tstart\thyprland-session.target' \
        'current-session activation should start the Hyprland session target' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installed_session_bridge_orders_start_and_stop() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture bridge
    local effects expected_import start_status=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    mkdir -p "$home"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        DISPLAY=:9 \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_CURRENT_DESKTOP=Hyprland \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1

    bridge="$home/.config/hypr/scripts/lid-session-bridge.sh"
    : > "$effect_log"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        DISPLAY=:10 \
        WAYLAND_DISPLAY=wayland-ordered \
        HYPRLAND_INSTANCE_SIGNATURE=ordered-instance \
        XDG_CURRENT_DESKTOP=Hyprland \
        XDG_SESSION_TYPE=wayland \
        QT_QPA_PLATFORMTHEME=qt6ct \
        XDG_DATA_DIRS=/test/share \
        TEST_EFFECT_LOG="$effect_log" \
        UNRELATED_SECRET=must-not-be-imported \
        "$bridge" start

    effects=$(<"$effect_log")
    expected_import=$'systemctl\t--user\timport-environment\tDISPLAY\tWAYLAND_DISPLAY\tHYPRLAND_INSTANCE_SIGNATURE\tXDG_CURRENT_DESKTOP\tQT_QPA_PLATFORMTHEME\tPATH\tXDG_DATA_DIRS'
    assert_before "$effects" "$expected_import" \
        $'systemctl\t--user\tstart\thyprland-session.target' \
        'the session target must start only after the curated environment import'
    assert_not_contains "$effects" 'XDG_SESSION_TYPE' \
        'the bridge should not expand Hyprland upstream curated environment ownership'
    assert_not_contains "$effects" 'UNRELATED_SECRET' \
        'the bridge should never import unrelated session values'

    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        "$bridge" stop
    effects=$(<"$effect_log")
    assert_before "$effects" \
        $'systemctl\t--user\tstop\thyprland-session.target' \
        $'sleep\t0.1' \
        'normal Hyprland shutdown should synchronously stop the target before the short grace period'
    assert_not_contains "$effects" 'unset-environment' \
        'Hyprland should retain ownership of activation-environment cleanup'

    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-missing-instance \
        TEST_EFFECT_LOG="$effect_log" \
        "$bridge" start \
        > "$test_root/missing.out" 2>&1 || start_status=$?

    if (( start_status == 0 )); then
        printf 'session bridge accepted a missing Hyprland instance signature\n' >&2
        return 1
    fi
    if [[ -s "$effect_log" ]]; then
        printf 'missing session identity caused system effects:\n%s\n' \
            "$(<"$effect_log")" >&2
        return 1
    fi
    assert_contains "$(<"$test_root/missing.out")" 'HYPRLAND_INSTANCE_SIGNATURE' \
        'the bridge should identify the missing required session variable'
)

installed_session_module_registers_isolated_hooks() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture module harness output

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    mkdir -p "$home"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1

    module="$home/.config/hypr/arch_lidswitch/session.lua"
    harness="$test_root/harness.lua"
    printf '%s\n' \
        'local handlers = {}' \
        'hl = {' \
        '  on = function(name, callback) handlers[name] = callback end,' \
        '  exec_cmd = function(command) print("async\t" .. command) end,' \
        '}' \
        'os.execute = function(command) print("sync\t" .. command); return true, "exit", 0 end' \
        'assert(dofile(arg[1]) == true)' \
        'assert(type(handlers["hyprland.start"]) == "function")' \
        'assert(type(handlers["hyprland.shutdown"]) == "function")' \
        'handlers["hyprland.start"]()' \
        'handlers["hyprland.shutdown"]()' \
        > "$harness"

    output=$("$LUA_BIN" "$harness" "$module")
    assert_contains "$output" "async"$'\t'"'$home/.config/hypr/scripts/lid-session-bridge.sh' start" \
        'the Lua start hook should delegate asynchronously to the installed bridge'
    assert_contains "$output" "sync"$'\t'"'$home/.config/hypr/scripts/lid-session-bridge.sh' stop" \
        'the Lua shutdown hook should block on the installed bridge'
)

installer_session_config_integration_is_idempotent() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture config
    local original contents begin_count end_count require_count iteration

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    config="$home/.config/hypr/hyprland.lua"
    original='hl.on("hyprland.start", function() print("keep me") end)'
    mkdir -p "$(dirname "$config")"
    printf '%s\n' "$original" > "$config"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    for iteration in 1 2; do
        "$ENV_BIN" -i \
            HOME="$home" \
            PATH="$fake_bin:$safe_bin" \
            WAYLAND_DISPLAY=wayland-test \
            HYPRLAND_INSTANCE_SIGNATURE=test-instance \
            XDG_SESSION_TYPE=wayland \
            TEST_EFFECT_LOG="$effect_log" \
            TEST_MONITORS_FIXTURE="$monitor_fixture" \
            "$ROOT_DIR/install-hyprland-lid-switch.sh" \
            > "$test_root/installer-$iteration.out" 2>&1
    done

    contents=$(<"$config")
    assert_contains "$contents" "$original" \
        'reinstallation should preserve the user-owned Hyprland callback'
    begin_count=$(grep -Fxc -- '-- BEGIN arch-lidswitch managed session integration' "$config")
    end_count=$(grep -Fxc -- '-- END arch-lidswitch managed session integration' "$config")
    require_count=$(grep -Fxc -- '    local ok, err = pcall(require, "arch_lidswitch.session")' "$config")
    if (( begin_count != 1 || end_count != 1 || require_count != 1 )); then
        printf 'expected one canonical managed block after reinstall; begin=%d end=%d require=%d\n%s\n' \
            "$begin_count" "$end_count" "$require_count" "$contents" >&2
        return 1
    fi
)

installer_refuses_malformed_session_config_ownership() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture config
    local original status=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    config="$home/.config/hypr/hyprland.lua"
    original=$'print("user config")\n-- BEGIN arch-lidswitch managed session integration\nprint("edited partial block")'
    mkdir -p "$(dirname "$config")"
    printf '%s\n' "$original" > "$config"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1 || status=$?

    if (( status == 0 )); then
        printf 'installer accepted malformed session ownership markers\n' >&2
        return 1
    fi
    if [[ "$(<"$config")" != "$original" ]]; then
        printf 'installer changed a malformed user config:\n%s\n' "$(<"$config")" >&2
        return 1
    fi
    if [[ -s "$effect_log" ]]; then
        printf 'malformed config ownership caused external effects:\n%s\n' \
            "$(<"$effect_log")" >&2
        return 1
    fi
    assert_contains "$(<"$test_root/installer.out")" \
        'malformed arch-lidswitch ownership markers' \
        'the refusal should explain the managed-block ownership problem'
)

installer_migrates_only_the_legacy_default_target_service() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture service effects

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    service="$home/.config/systemd/user/lid-monitor.service"
    mkdir -p "$(dirname "$service")"
    prepare_hyprland_config "$home"
    printf '%s\n' '[Install]' 'WantedBy=default.target' > "$service"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_REQUIRED_PATHS_BEFORE_DISABLE="$home/.config/hypr/scripts/lid-state.sh:$home/.config/hypr/scripts/lid-switch.sh:$home/.config/hypr/scripts/lid-switch-doctor.sh:$home/.config/hypr/scripts/lid-monitor.sh:$home/.config/hypr/scripts/lid-session-bridge.sh:$home/.config/hypr/arch_lidswitch/session.lua:$home/.config/systemd/user/hyprland-session.target" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1

    effects=$(<"$effect_log")
    assert_before "$effects" \
        $'systemctl\t--user\tdisable\t--now\tlid-monitor.service' \
        $'systemctl\t--user\tdaemon-reload' \
        'the legacy default-target process should stop before the replacement unit is loaded'
    assert_not_contains "$effects" $'systemctl\t--user\trestart\tlid-monitor.service' \
        'BUG-003 should not absorb the general reinstall restart behavior from BUG-013'
    assert_not_contains "$(<"$service")" 'WantedBy=default.target' \
        'the migrated unit should no longer retain the early-login enablement target'
)

tests_run=0
tests_failed=0
tests_selected=0

run_test() {
    local test_id=$1
    local description=$2
    local test_function=$3
    local output

    if [[ -n "$TEST_FILTER" && "$test_id" != *"$TEST_FILTER"* ]]; then
        return 0
    fi

    tests_selected=$((tests_selected + 1))
    tests_run=$((tests_run + 1))
    if output=$("$test_function" 2>&1); then
        printf 'ok %d - %s\n' "$tests_run" "$description"
    else
        printf 'not ok %d - %s\n' "$tests_run" "$description"
        while IFS= read -r line; do
            printf '# %s\n' "$line"
        done <<< "$output"
        tests_failed=$((tests_failed + 1))
    fi
}

