        'an available hibernate capability should not select hibernation' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'systemctl\t' \
        'reporting an available capability must not request hibernation' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installed_cli_refuses_actions_when_monitor_query_fails() (
    set -euo pipefail

    local transition=$1
    local test_root home fake_bin safe_bin effect_log installed_cli
    local install_fixture runtime_effects runtime_output
    local runtime_output_file runtime_status=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    runtime_output_file="$test_root/runtime.out"
    install_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    mkdir -p "$home"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$install_fixture" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1

    installed_cli="$home/.config/hypr/scripts/lid-switch.sh"
    : > "$effect_log"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$install_fixture" \
        TEST_HYPRCTL_MONITORS_JSON_FAIL=1 \
        "$installed_cli" "$transition" \
        > "$runtime_output_file" 2>&1 || runtime_status=$?

    runtime_effects=$(<"$effect_log")
    runtime_output=$(<"$runtime_output_file")

    assert_contains "$runtime_effects" $'hyprctl\t-j\tmonitors\tall' \
        'the installed CLI should reach the failing monitor-query boundary'
    assert_not_contains "$runtime_effects" $'systemctl\t' \
        'a monitor-query failure must not request a power action'
    assert_not_contains "$runtime_effects" $'monitor\t' \
        'a monitor-query failure must not change monitor state'

    if (( runtime_status != 2 )); then
        printf 'expected query failure status 2, got %d\nruntime output:\n%s\n' \
            "$runtime_status" "$runtime_output" >&2
        return 1
    fi

    assert_contains "$runtime_output" \
        "level=error component=lid-switch event=monitor_query_failed action=$transition" \
        'the query failure should be distinguishable at the journal stream boundary'
    assert_not_contains "$runtime_output" 'event=external_monitor_absent' \
        'a query failure must not be reported as a valid empty topology'
)

installed_cli_refuses_power_when_close_monitor_query_fails() {
    installed_cli_refuses_actions_when_monitor_query_fails close
}

installed_cli_refuses_display_when_open_monitor_query_fails() {
    installed_cli_refuses_actions_when_monitor_query_fails open
}

create_lid_state_fixture() {
    local lid_root=$1
    local scenario=$2

    case "$scenario" in
        lid0)
            mkdir -p "$lid_root/LID0"
            printf '%s\n' 'state: open' > "$lid_root/LID0/state"
            ;;
        lid1)
            mkdir -p "$lid_root/LID1"
            printf '%s\n' 'state: closed' > "$lid_root/LID1/state"
            ;;
        multiple-agreeing)
            mkdir -p "$lid_root/LID0" "$lid_root/LID1"
            printf '%s\n' 'state: open' > "$lid_root/LID0/state"
            printf '%s\n' 'state: open' > "$lid_root/LID1/state"
            ;;
        multiple-conflicting)
            mkdir -p "$lid_root/LID0" "$lid_root/LID1"
            printf '%s\n' 'state: open' > "$lid_root/LID0/state"
            printf '%s\n' 'state: closed' > "$lid_root/LID1/state"
            ;;
        missing)
            ;;
        unreadable)
            mkdir -p "$lid_root/LID0/state"
            ;;
        malformed)
            mkdir -p "$lid_root/LID0"
            printf '%s\n' 'state: ajar' > "$lid_root/LID0/state"
            ;;
        *)
            printf 'unknown lid state fixture: %s\n' "$scenario" >&2
            return 2
            ;;
    esac
}

installed_runtime_reports_through_the_journal_boundary() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture lid_root
    local installed_cli installed_daemon installed_listener installed_unit
    local runtime_artifacts unit_contents
    local runtime_output daemon_output failures=0 runtime_status=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    lid_root="$test_root/button/lid"
    mkdir -p "$home"
    prepare_hyprland_config "$home"
    create_lid_state_fixture "$lid_root" lid0
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1

    installed_cli="$home/.config/hypr/scripts/lid-switch.sh"
    installed_daemon="$home/.config/hypr/scripts/lid-monitor.sh"
    installed_listener="$home/.config/hypr/scripts/lid-resume-monitor.sh"
    installed_unit="$home/.config/systemd/user/lid-monitor.service"

    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON_FAIL=1 \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$installed_cli" close \
        > "$test_root/runtime.out" 2>&1 || runtime_status=$?

    if (( runtime_status != 2 )); then
        printf 'expected query failure status 2, got %d\n' "$runtime_status" >&2
        failures=$((failures + 1))
    fi

    runtime_output=$(<"$test_root/runtime.out")
    assert_contains "$runtime_output" \
        'level=error component=lid-switch event=monitor_query_failed action=close' \
        'the runtime should expose a useful structured error to the service journal stream' \
        || failures=$((failures + 1))

    runtime_artifacts="$(<"$installed_cli")"$'\n'"$(<"$installed_daemon")"$'\n'"$(<"$installed_listener")"
    assert_not_contains "$runtime_artifacts" '/tmp/' \
        'installed runtime scripts must not contain shared-/tmp paths' \
        || failures=$((failures + 1))
    assert_not_contains "$runtime_artifacts" 'HYPR_LID_SWITCH_LOG_FILE' \
        'installed runtime scripts must not expose a file-log redirection seam' \
        || failures=$((failures + 1))

    unit_contents=$(<"$installed_unit")
    assert_contains "$unit_contents" 'StandardOutput=journal' \
        'the installed unit should route daemon output to the journal' \
        || failures=$((failures + 1))
    assert_contains "$unit_contents" 'StandardError=journal' \
        'the installed unit should route daemon diagnostics to the journal' \
        || failures=$((failures + 1))
    assert_contains "$unit_contents" 'SyslogIdentifier=arch-lidswitch' \
        'the installed unit should give journal records a stable identifier' \
        || failures=$((failures + 1))

    rm -f "$fake_bin/sleep"
    ln -s "$REAL_SLEEP_BIN" "$fake_bin/sleep"
    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        HYPR_LID_STATE_ROOT="$test_root/missing-lid" \
        "$TIMEOUT_BIN" 0.2 "$installed_daemon" \
        > "$test_root/daemon.out" 2>&1 || true
    daemon_output=$(<"$test_root/daemon.out")
    assert_contains "$daemon_output" \
        'level=error component=lid-monitor event=lid_state_observation_failed reason=missing' \
        'the running daemon should expose why lid observation is unavailable to the journal stream' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installed_lid_state_matches_expected_behavior() (
    set -euo pipefail

    local scenario=$1
    local expected_state=$2
    local expected_error=${3:-}
    local test_root home fake_bin safe_bin effect_log monitor_fixture lid_root runtime_dir
    local monitor_json disabled_monitor_json runtime_monitor_json
    local installed_cli installed_daemon cli_effects daemon_output installer_output
    local cli_status=0 daemon_status=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    monitor_json=$(<"$ROOT_DIR/tests/fixtures/monitors-json/framework.json")
    disabled_monitor_json=$(jq -c \
        'map(if .name == "eDP-1" then .disabled = true else . end)' \
        <<< "$monitor_json")
    runtime_monitor_json=$monitor_json
    if [[ "$expected_state" == open ]]; then
        runtime_monitor_json=$disabled_monitor_json
    fi
    lid_root="$test_root/button/lid"
    runtime_dir="$test_root/runtime"
    mkdir -m 0700 -p "$home" "$runtime_dir"
    prepare_hyprland_config "$home"
    create_lid_state_fixture "$lid_root" "$scenario"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    if ! "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$monitor_json" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1; then
        printf 'installer failed for lid fixture %s:\n%s\n' \
            "$scenario" "$(<"$test_root/installer.out")" >&2
        return 1
    fi
    installer_output=$(<"$test_root/installer.out")

    if [[ "$expected_state" == 'unknown' ]]; then
        assert_contains "$installer_output" 'Could not determine lid state' \
            'installer should report an unavailable lid state without guessing' || return 1
    else
        assert_contains "$installer_output" "Lid state detection working: $expected_state" \
            'installer should use the shared runtime lid observer' || return 1
    fi

    installed_cli="$home/.config/hypr/scripts/lid-switch.sh"
    installed_daemon="$home/.config/hypr/scripts/lid-monitor.sh"

    if ! "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$monitor_json" \
        "$installed_cli" close \
        > "$test_root/seed-close.out" 2>&1; then
        printf 'could not seed the installed CLI monitor snapshot:\n%s\n' \
            "$(<"$test_root/seed-close.out")" >&2
        return 1
    fi

    rm -f "$effect_log.monitors-state.json" \
        "$effect_log.monitors-state.json.requested"

    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$runtime_monitor_json" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$installed_cli" \
        > "$test_root/cli.out" 2> "$test_root/cli.err" || cli_status=$?
    cli_effects=$(<"$effect_log")

    case "$expected_state" in
        open)
            if (( cli_status != 0 )); then
                printf 'expected open CLI status 0, got %d:\n%s\n' \
                    "$cli_status" "$(<"$test_root/cli.err")" >&2
                return 1
            fi
            assert_contains "$cli_effects" $'monitor\toutput=eDP-1\tdisabled=false' \
                'an open lid state should select the installed CLI open transition' || return 1
            assert_not_contains "$cli_effects" $'monitor\toutput=DP-2' \
                'an open lid state should preserve the external output placement' || return 1
            ;;
        closed)
            if (( cli_status != 0 )); then
                printf 'expected closed CLI status 0, got %d:\n%s\n' \
                    "$cli_status" "$(<"$test_root/cli.err")" >&2
                return 1
            fi
            assert_contains "$cli_effects" $'monitor\toutput=eDP-1\tdisabled=true' \
                'a closed lid state should select the installed CLI close transition' || return 1
            assert_not_contains "$cli_effects" $'monitor\toutput=DP-2' \
                'a closed lid state should preserve the external output placement' || return 1
            ;;
        unknown)
            if (( cli_status == 0 )); then
                printf 'installed CLI accepted unavailable lid fixture: %s\n' "$scenario" >&2
                return 1
            fi
            if [[ -s "$effect_log" ]]; then
                printf 'unavailable lid state caused external effects:\n%s\n' \
                    "$cli_effects" >&2
                return 1
            fi
            assert_contains "$(<"$test_root/cli.err")" \
                'level=error component=lid-switch event=lid_state_unknown action=auto' \
                'the installed CLI should explain why automatic action was refused at its stderr boundary' \
                || return 1
            ;;
        *)
            printf 'unknown expected lid state: %s\n' "$expected_state" >&2
            return 2
            ;;
    esac

    assert_not_contains "$cli_effects" $'systemctl\t' \
        'lid observation must not request a power action in the docked fixture' || return 1

    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$installed_daemon" --print-state \
        > "$test_root/daemon.out" 2> "$test_root/daemon.err" || daemon_status=$?
    daemon_output=$(<"$test_root/daemon.out")

    if [[ "$expected_state" == 'unknown' ]]; then
        if (( daemon_status == 0 )); then
            printf 'daemon accepted unavailable lid fixture: %s\n' "$scenario" >&2
            return 1
        fi
        if [[ "$daemon_output" != 'unknown' ]]; then
            printf 'expected daemon to report unknown, got: %s\n' "$daemon_output" >&2
            return 1
        fi
        assert_contains "$(<"$test_root/daemon.err")" "$expected_error" \
            'daemon should distinguish the lid observation failure' || return 1
    else
        if (( daemon_status != 0 )); then
            printf 'expected daemon state status 0, got %d:\n%s\n' \
                "$daemon_status" "$(<"$test_root/daemon.err")" >&2
            return 1
        fi
        if [[ "$daemon_output" != "$expected_state" ]]; then
            printf 'expected daemon to report %s, got: %s\n' \
                "$expected_state" "$daemon_output" >&2
            return 1
        fi
    fi
    if [[ -s "$effect_log" ]]; then
        printf 'daemon state diagnostic caused external effects:\n%s\n' \
            "$(<"$effect_log")" >&2
        return 1
    fi
)

installed_lid0_state_drives_cli_and_daemon() {
    installed_lid_state_matches_expected_behavior lid0 open
}

installed_lid1_state_drives_cli_and_daemon() {
    installed_lid_state_matches_expected_behavior lid1 closed
}

installed_agreeing_lid_states_drive_cli_and_daemon() {
    installed_lid_state_matches_expected_behavior multiple-agreeing open
}

installed_conflicting_lid_states_are_refused() {
    installed_lid_state_matches_expected_behavior \
        multiple-conflicting unknown 'Conflicting ACPI lid states'
}

installed_missing_lid_state_is_refused() {
    installed_lid_state_matches_expected_behavior \
        missing unknown 'No ACPI lid state files found'
}

installed_unreadable_lid_state_is_refused() {
    installed_lid_state_matches_expected_behavior \
        unreadable unknown 'Unable to read ACPI lid state'
}

installed_malformed_lid_state_is_refused() {
    installed_lid_state_matches_expected_behavior \
        malformed unknown 'Malformed ACPI lid state'
}

installer_matches_fixture_expectation() (
    set -euo pipefail

    local fixture_name=$1
    local expected_outcome=$2
    local expected_message=$3
    local assertion_message=$4
    shift 4
    local test_root home fake_bin safe_bin effect_log fixture monitor_json
    local installer_output effects
    local installer_status=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    fixture="$ROOT_DIR/tests/fixtures/monitors/$fixture_name"
    case "$fixture_name" in
        laptop-only.txt)
            monitor_json='[{"name":"eDP-1","disabled":false}]'
            ;;
        one-external.txt)
            monitor_json=$(<"$ROOT_DIR/tests/fixtures/monitors-json/framework.json")
            ;;
        multiple-external.txt)
            monitor_json='[{"name":"eDP-1","disabled":false},{"name":"DP-2","disabled":false},{"name":"HDMI-A-1","disabled":false}]'
            ;;
        no-laptop.txt)
            monitor_json='[{"name":"DP-2","disabled":false}]'
            ;;
        *)
            printf 'no structured monitor fixture mapping for: %s\n' \
                "$fixture_name" >&2
            return 2
            ;;
    esac
    mkdir -p "$home"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$monitor_json" \
        "$@" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1 || installer_status=$?

    installer_output=$(<"$test_root/installer.out")
    effects=$(<"$effect_log")
    case "$expected_outcome" in
        success)
            if (( installer_status != 0 )); then
                printf 'installer failed for monitor fixture %s:\n%s\n' \
                    "$fixture_name" "$installer_output" >&2
                return 1
            fi
            if [[ ! -x "$home/.config/hypr/scripts/lid-switch.sh" ]]; then
                printf 'installer did not create an executable lid-switch CLI\n' >&2
                return 1
            fi
            assert_contains "$effects" \
                $'hyprctl\teval\tassert(type(hl) == "table" and type(hl.monitor) == "function" and type(hl.dispatch) == "function" and type(hl.dsp) == "table" and type(hl.dsp.dpms) == "function", "required Hyprland Lua APIs unavailable")' \
                'successful installation should prove the typed monitor and DPMS API contract' \
                || return 1
            assert_not_contains "$effects" $'monitor\t' \
                'the Hyprland capability probe must not mutate monitor state' \
                || return 1
            ;;
        failure)
            if (( installer_status == 0 )); then
                printf 'installer unexpectedly succeeded for monitor fixture %s\n' \
                    "$fixture_name" >&2
                return 1
            fi
            ;;
        *)
            printf 'unknown installer outcome expectation: %s\n' "$expected_outcome" >&2
            return 2
            ;;
    esac

    assert_contains "$installer_output" "$expected_message" "$assertion_message"
)

installer_succeeds_without_an_external_monitor() {
    installer_matches_fixture_expectation \
        'laptop-only.txt' \
        success \
        'No external outputs detected' \
        'an absent external monitor should be reported as an informational state'
}

installer_succeeds_with_one_external_monitor() {
    installer_matches_fixture_expectation \
        'one-external.txt' \
        success \
        'Detected external output: DP-2 (enabled)' \
        'the active external monitor should be reported during installation'
}

installer_succeeds_with_multiple_external_monitors() {
    installer_matches_fixture_expectation \
        'multiple-external.txt' \
        success \
        'Detected external output:' \
        'multiple external monitors should not abort installation'
}

installer_detects_explicit_internal_and_nonstandard_externals() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture monitor_json
    local installer_output effects installed_cli installed_daemon installer_status=0
    local failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/no-laptop.txt"
    monitor_json=$(<"$ROOT_DIR/tests/fixtures/monitors-json/nonstandard-mixed.json")
    mkdir -p "$home"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        HYPR_LID_INTERNAL_OUTPUT=DSI-1 \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$monitor_json" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1 || installer_status=$?

    installer_output=$(<"$test_root/installer.out")
    effects=$(<"$effect_log")
    installed_cli="$home/.config/hypr/scripts/lid-switch.sh"
    installed_daemon="$home/.config/hypr/scripts/lid-monitor.sh"

    if (( installer_status != 0 )); then
        printf 'expected explicit structured monitor installation status 0, got %d\n%s\n' \
            "$installer_status" "$installer_output" >&2
        failures=$((failures + 1))
    fi
    if [[ ! -r "$installed_cli" || ! -r "$installed_daemon" ]]; then
        printf 'installer did not create both configured runtime scripts\n' >&2
        failures=$((failures + 1))
    else
        assert_contains "$(<"$installed_cli")" 'LAPTOP_DISPLAY="DSI-1"' \
            'installed CLI should use the explicit internal identity' \
            || failures=$((failures + 1))
        assert_contains "$(<"$installed_daemon")" 'LAPTOP_DISPLAY="DSI-1"' \
            'installed daemon should observe topology for the same internal identity' \
            || failures=$((failures + 1))
    fi
    assert_contains "$installer_output" 'Detected internal output: DSI-1 (inactive)' \
        'installer should see an inactive explicit internal output' \
        || failures=$((failures + 1))
    assert_contains "$installer_output" 'Detected external output: Virtual-2 (inactive)' \
        'installer should classify an inactive nonstandard external by identity difference' \
        || failures=$((failures + 1))
    assert_contains "$installer_output" 'Detected external output: WL-1 (enabled)' \
        'installer should classify an enabled nonstandard external by identity difference' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'hyprctl\tmonitors\n' \
        'installer detection must not fall back to human-readable active monitors' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installer_rejects_ambiguous_or_missing_internal_identity() {
    local failures=0

    installer_matches_fixture_expectation \
        'one-external.txt' \
        failure \
        'Multiple internal output candidates detected; set HYPR_LID_INTERNAL_OUTPUT' \
        'ambiguous structured internal identities should require an explicit choice' \
        'TEST_HYPRCTL_MONITORS_JSON=[{"name":"eDP-1","disabled":false},{"name":"eDP-2","disabled":true}]' \
        || failures=$((failures + 1))
    installer_matches_fixture_expectation \
        'one-external.txt' \
        failure \
        'Configured internal output not found: DSI-9' \
        'an explicit internal identity must exist in the all-output snapshot' \
        HYPR_LID_INTERNAL_OUTPUT=DSI-9 \
        || failures=$((failures + 1))

    (( failures == 0 ))
}

installer_rejects_a_missing_laptop_monitor() {
    installer_matches_fixture_expectation \
        'no-laptop.txt' \
        failure \
        'Could not detect an internal output; set HYPR_LID_INTERNAL_OUTPUT' \
        'a missing laptop output should produce the intended explicit error'
}

installer_rejects_missing_jq_before_writes() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture config original
    local installer_output effects installer_status=0 failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    config="$home/.config/hypr/hyprland.lua"
    original='-- user-owned config must remain unchanged without jq'
    mkdir -p "$(dirname "$config")"
    printf '%s\n' "$original" > "$config"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"
    rm -f "$safe_bin/jq"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1 || installer_status=$?

    installer_output=$(<"$test_root/installer.out")
    effects=$(<"$effect_log")

    if (( installer_status == 0 )); then
        printf 'installer accepted a missing jq dependency\n' >&2
        failures=$((failures + 1))
    fi
    if [[ "$(<"$config")" != "$original" ]]; then
        printf 'missing jq changed user configuration:\n%s\n' "$(<"$config")" >&2
        failures=$((failures + 1))
    fi
    if [[ -e "$home/.config/hypr/scripts/lid-switch.sh" ]] || \
        [[ -e "$home/.config/systemd/user/lid-monitor.service" ]]; then
        printf 'missing jq wrote installation artifacts\n' >&2
        failures=$((failures + 1))
    fi
    assert_not_contains "$effects" $'systemctl\t' \
        'dependency rejection must not change user-systemd state' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'monitor\t' \
        'dependency rejection must not mutate monitor state' \
        || failures=$((failures + 1))
    assert_contains "$installer_output" 'requires jq' \
        'the missing dependency should have an actionable diagnostic' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installer_hyprland_profile_is_rejected() (
    set -euo pipefail

    local expected_message=$1
    shift

    local test_root home fake_bin safe_bin effect_log monitor_fixture config original
    local installer_output effects installer_status=0 failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    config="$home/.config/hypr/hyprland.lua"
    original='-- user-owned config must remain unchanged on compatibility failure'
    mkdir -p "$(dirname "$config")"
    printf '%s\n' "$original" > "$config"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$@" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1 || installer_status=$?

    installer_output=$(<"$test_root/installer.out")
    effects=$(<"$effect_log")

    if (( installer_status == 0 )); then
        printf 'installer accepted an incompatible Hyprland profile\n' >&2
        failures=$((failures + 1))
    fi
    if [[ "$(<"$config")" != "$original" ]]; then
        printf 'compatibility failure changed user configuration:\n%s\n' \
            "$(<"$config")" >&2
        failures=$((failures + 1))
    fi
    if [[ -e "$home/.config/hypr/scripts/lid-switch.sh" ]] || \
        [[ -e "$home/.config/systemd/user/lid-monitor.service" ]]; then
        printf 'compatibility failure wrote installation artifacts\n' >&2
        failures=$((failures + 1))
    fi
    assert_not_contains "$effects" $'systemctl\t' \
        'compatibility rejection must not change user-systemd state' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'monitor\t' \
        'compatibility rejection must not mutate monitor state' \
        || failures=$((failures + 1))
    assert_contains "$installer_output" "$expected_message" \
        'the incompatible profile should explain its exact cause' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installer_rejects_hyprland_before_0_55() {
    installer_hyprland_profile_is_rejected \
        'Hyprland 0.54.0 is unsupported; version 0.55.0 or newer is required' \
        'TEST_HYPRCTL_VERSION_JSON={"version":"0.54.0","tag":"v9.9.9"}'
}

installer_rejects_unreachable_hyprland_version_query() {
    installer_hyprland_profile_is_rejected \
        "Could not query the active Hyprland version with 'hyprctl -j version'" \
        TEST_HYPRCTL_VERSION_FAIL=1
}

installer_rejects_malformed_hyprland_versions() {
    local failures=0

    installer_hyprland_profile_is_rejected \
        'Hyprland returned malformed version JSON or a missing version string' \
        TEST_HYPRCTL_VERSION_JSON=not-json \
        || failures=$((failures + 1))
    installer_hyprland_profile_is_rejected \
        'Hyprland returned a malformed version string: release-55' \
        'TEST_HYPRCTL_VERSION_JSON={"version":"release-55","tag":"v0.55.0"}' \
        || failures=$((failures + 1))
    installer_hyprland_profile_is_rejected \
        'Hyprland returned a malformed version string: 0.55.0-git' \
        'TEST_HYPRCTL_VERSION_JSON={"version":"0.55.0-git","tag":"unknown"}' \
        || failures=$((failures + 1))

    (( failures == 0 ))
}

installer_accepts_a_future_hyprland_version() {
    local failures=0

    installer_matches_fixture_expectation \
        'one-external.txt' \
        success \
        'Detected internal output: eDP-1 (enabled)' \
        'a future Hyprland minor version should satisfy the minimum-version contract' \
        'TEST_HYPRCTL_VERSION_JSON={"version":"0.100.0","tag":"unknown"}' \
        || failures=$((failures + 1))
    installer_matches_fixture_expectation \
        'one-external.txt' \
        success \
        'Detected internal output: eDP-1 (enabled)' \
        'a future Hyprland major version should satisfy the minimum-version contract' \
        'TEST_HYPRCTL_VERSION_JSON={"version":"1.2.3","tag":"unknown"}'

    (( failures == 0 ))
}

installer_rejects_no_running_hyprland_instance() {
    installer_hyprland_profile_is_rejected \
        'Expected exactly one running Hyprland instance, found 0; instance selection is not supported' \
        'TEST_HYPRCTL_INSTANCES_JSON=[]'
}

installer_rejects_ambiguous_or_malformed_hyprland_instances() {
    local failures=0

    installer_hyprland_profile_is_rejected \
        'Expected exactly one running Hyprland instance, found 2; instance selection is not supported' \
        'TEST_HYPRCTL_INSTANCES_JSON=[{"instance":"first"},{"instance":"second"}]' \
        || failures=$((failures + 1))
    installer_hyprland_profile_is_rejected \
        'Hyprland returned a malformed instances array' \
        'TEST_HYPRCTL_INSTANCES_JSON={"instance":"not-an-array"}' \
        || failures=$((failures + 1))

    (( failures == 0 ))
}

installer_rejects_a_mismatched_selected_hyprland_instance() {
    installer_hyprland_profile_is_rejected \
        'Running Hyprland instance=other-instance does not match HYPRLAND_INSTANCE_SIGNATURE=test-instance' \
        'TEST_HYPRCTL_INSTANCES_JSON=[{"instance":"other-instance","wl_socket":"wayland-test"}]'
}

installer_rejects_a_mismatched_selected_wayland_socket() {
    installer_hyprland_profile_is_rejected \
        'Running Hyprland wl_socket=wayland-other does not match WAYLAND_DISPLAY=wayland-test' \
        'TEST_HYPRCTL_INSTANCES_JSON=[{"instance":"test-instance","wl_socket":"wayland-other"}]'
}

installer_rejects_non_lua_hyprland_provider() {
    installer_hyprland_profile_is_rejected \
        'Hyprland configProvider=hyprlang is unsupported; expected lua' \
        'TEST_HYPRCTL_STATUS_JSON={"configProvider":"hyprlang","backend":"drm"}'
}

installer_rejects_non_array_hyprland_monitors() {
    installer_hyprland_profile_is_rejected \
        "Hyprland 'hyprctl -j monitors all' did not return a valid monitor array" \
        'TEST_HYPRCTL_MONITORS_JSON={"name":"eDP-1"}'
}

installer_rejects_unavailable_hl_monitor_api() {
    installer_hyprland_profile_is_rejected \
        'Hyprland Lua capability probe failed: required hl.monitor, hl.dispatch, and hl.dsp.dpms APIs are unavailable' \
        'TEST_HYPRCTL_CAPABILITY_EVAL_OUTPUT=error: hl.monitor unavailable'
}

installer_policy_profile_is_rejected() (
    set -euo pipefail

    local expected_status=$1
    local expected_message=$2
    shift 2

    local test_root home fake_bin safe_bin effect_log monitor_fixture config original
    local installer_output effects installer_status=0 failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    config="$home/.config/hypr/hyprland.lua"
    original='-- user-owned config must remain unchanged on policy conflict'
    mkdir -p "$(dirname "$config")"
    printf '%s\n' "$original" > "$config"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$@" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1 || installer_status=$?

    installer_output=$(<"$test_root/installer.out")
    effects=$(<"$effect_log")

    if (( installer_status != expected_status )); then
        printf 'expected policy-check status %d, got %d\ninstaller output:\n%s\n' \
            "$expected_status" "$installer_status" "$installer_output" >&2
        failures=$((failures + 1))
    fi
    if [[ "$(<"$config")" != "$original" ]]; then
        printf 'policy conflict changed user configuration:\n%s\n' \
            "$(<"$config")" >&2
        failures=$((failures + 1))
    fi
    if [[ -e "$home/.config/hypr/scripts/lid-switch.sh" ]] || \
        [[ -e "$home/.config/systemd/user/lid-monitor.service" ]]; then
        printf 'policy conflict wrote installation artifacts\n' >&2
        failures=$((failures + 1))
    fi
    assert_not_contains "$effects" $'hyprctl\t' \
        'policy validation should run before monitor detection' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'systemctl\t' \
        'policy conflict must not change user-systemd state' \
        || failures=$((failures + 1))
    assert_contains "$installer_output" "$expected_message" \
        'the failed policy profile should explain its exact cause' \
        || failures=$((failures + 1))
    assert_contains "$installer_output" \
        'systemd-analyze cat-config systemd/logind.conf' \
        'the conflict should provide a read-only configuration inspection command' \
        || failures=$((failures + 1))
    assert_contains "$installer_output" \
        'This installer does not modify /etc or systemd-logind policy.' \
        'the conflict should make system-policy ownership explicit' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installer_rejects_conflicting_undocked_lid_policy() {
    installer_policy_profile_is_rejected \
        1 \
        'FAIL HandleLidSwitch=ignore expected=suspend' \
        TEST_LOGIND_HANDLE_LID_SWITCH=ignore
}

installer_rejects_conflicting_docked_lid_policy() {
    installer_policy_profile_is_rejected \
        1 \
        'FAIL HandleLidSwitchDocked=suspend expected=ignore' \
        TEST_LOGIND_HANDLE_LID_SWITCH_DOCKED=suspend
}

installer_rejects_conflicting_external_power_lid_policy() {
    installer_policy_profile_is_rejected \
        1 \
        'FAIL HandleLidSwitchExternalPower=hibernate expected=<unset-or-suspend>' \
        TEST_LOGIND_HANDLE_LID_SWITCH_EXTERNAL_POWER=hibernate
}

installer_rejects_a_low_level_lid_inhibitor() {
    installer_policy_profile_is_rejected \
        1 \
        'FAIL handle-lid-switch inhibitor present: desktop-shell 1000 user 42 shell handle-lid-switch custom handling block' \
        'TEST_LID_SWITCH_INHIBITOR=desktop-shell 1000 user 42 shell handle-lid-switch custom handling block'
}

installer_reports_a_logind_property_diagnostic_failure() {
    installer_policy_profile_is_rejected \
        2 \
        'ERROR Could not read effective logind property HandleLidSwitchDocked.' \
        TEST_BUSCTL_FAIL_PROPERTY=HandleLidSwitchDocked
}

installer_reports_a_lid_inhibitor_diagnostic_failure() {
    installer_policy_profile_is_rejected \
        2 \
        'ERROR Could not inspect handle-lid-switch inhibitors.' \
        TEST_SYSTEMD_INHIBIT_FAIL=1
}

installer_rejects_unavailable_suspend_capabilities() (
    set -euo pipefail

    local capability failures=0

    for capability in na no challenge unexpected; do
        if ! installer_policy_profile_is_rejected \
            1 \
            "FAIL CanSuspend=$capability expected=yes" \
            "TEST_LOGIND_CAN_SUSPEND=$capability"; then
            failures=$((failures + 1))
        fi
    done

    (( failures == 0 ))
)

installer_reports_suspend_capability_query_failure() {
    installer_policy_profile_is_rejected \
        2 \
        'ERROR Could not query login1 capability CanSuspend.' \
        TEST_BUSCTL_FAIL_METHOD=CanSuspend
}

installer_reports_suspend_capability_parse_failure() {
    installer_policy_profile_is_rejected \
        2 \
        'ERROR Unexpected value for login1 capability CanSuspend: malformed' \
        TEST_BUSCTL_MALFORMED_METHOD=CanSuspend
}

installer_warns_when_hibernate_capability_is_unavailable() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture
    local installer_output effects installer_status=0 failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    mkdir -p "$home"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_LOGIND_CAN_SUSPEND=yes \
        TEST_BUSCTL_FAIL_METHOD=CanHibernate \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1 || installer_status=$?

    installer_output=$(<"$test_root/installer.out")
    effects=$(<"$effect_log")

    if (( installer_status != 0 )); then
        printf 'expected optional hibernate diagnostic status 0, got %d\n%s\n' \
            "$installer_status" "$installer_output" >&2
        failures=$((failures + 1))
    fi
    if [[ ! -x "$home/.config/hypr/scripts/lid-switch-doctor.sh" ]]; then
        printf 'installer did not complete after the optional diagnostic warning\n' >&2
        failures=$((failures + 1))
    fi
    assert_contains "$installer_output" \
        'WARN Could not query login1 capability CanHibernate.' \
        'a hibernate query failure should be reported as a warning' \
        || failures=$((failures + 1))
    assert_contains "$installer_output" \
        'WARN CanHibernate=<unavailable> hibernate=unused' \
        'the warning should explain why the missing capability is non-blocking' \
        || failures=$((failures + 1))
    assert_not_contains "$installer_output" \
        'ERROR Could not query login1 capability CanHibernate.' \
        'an unused hibernate diagnostic must not be reported as a blocking error' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'systemctl\thibernate' \
        'the installer must not request hibernation' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'systemctl\tsuspend' \
        'the installer must not request suspension' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installed_session_lifecycle_is_bound_to_hyprland() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture
    local hyprland_config original_config installed_unit installed_resume_unit installed_target
    local installed_bridge installed_module unit_contents target_contents
    local config_contents effects verification_errors failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    hyprland_config="$home/.config/hypr/hyprland.lua"
    original_config='hl.on("hyprland.start", function() print("existing start") end)'

    mkdir -p "$(dirname "$hyprland_config")"
    printf '%s\n' "$original_config" > "$hyprland_config"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        DISPLAY=:9 \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_CURRENT_DESKTOP=Hyprland \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1

    installed_unit="$home/.config/systemd/user/lid-monitor.service"
    installed_resume_unit="$home/.config/systemd/user/lid-resume-monitor.service"
    installed_target="$home/.config/systemd/user/hyprland-session.target"
    installed_bridge="$home/.config/hypr/scripts/lid-session-bridge.sh"
    installed_module="$home/.config/hypr/arch_lidswitch/session.lua"

    unit_contents=$(<"$installed_unit")
    assert_contains "$unit_contents" 'PartOf=graphical-session.target' \
        'the installed daemon should stop and restart with the graphical session' \
        || failures=$((failures + 1))
    assert_contains "$unit_contents" 'After=graphical-session.target' \
        'the installed daemon should start after the graphical session target' \
        || failures=$((failures + 1))
    assert_contains "$unit_contents" 'ConditionEnvironment=HYPRLAND_INSTANCE_SIGNATURE' \
        'the installed daemon should require a selected Hyprland instance' \
        || failures=$((failures + 1))
    assert_contains "$unit_contents" 'ConditionEnvironment=WAYLAND_DISPLAY' \
        'the installed daemon should require a Wayland display' \
        || failures=$((failures + 1))
    assert_contains "$unit_contents" \
        "ExecStartPre=$safe_bin/timeout --kill-after=1s 2s $fake_bin/hyprctl monitors" \
        'the service should bound its Hyprland reachability probe with absolute paths' \
        || failures=$((failures + 1))
    assert_contains "$unit_contents" 'Restart=on-failure' \
        'the session daemon should restart only after failures' \
        || failures=$((failures + 1))
    assert_contains "$unit_contents" 'RestartPreventExitStatus=1' \
        'permanent runtime contract failures must not enter a systemd restart loop' \
        || failures=$((failures + 1))
    assert_contains "$unit_contents" 'WantedBy=graphical-session.target' \
        'the installed daemon should be enabled by the graphical session' \
        || failures=$((failures + 1))
    assert_not_contains "$unit_contents" 'Environment="DISPLAY=' \
        'the installed daemon must not hard-code an X11 display' \
        || failures=$((failures + 1))
    assert_not_contains "$unit_contents" 'WantedBy=default.target' \
        'the installed daemon must not start before the graphical session' \
        || failures=$((failures + 1))

    if [[ ! -r "$installed_target" ]]; then
        printf 'installer did not create hyprland-session.target\n' >&2
        failures=$((failures + 1))
    else
        target_contents=$(<"$installed_target")
        assert_contains "$target_contents" 'BindsTo=graphical-session.target' \
            'the Hyprland session target should bind the passive graphical target' \
            || failures=$((failures + 1))
        assert_contains "$target_contents" 'PropagatesStopTo=graphical-session.target' \
            'stopping the Hyprland session should stop graphical-session.target' \
            || failures=$((failures + 1))
    fi

    if ! SYSTEMD_BYPASS_USERDB=1 "$SYSTEMD_ANALYZE_BIN" --user verify \
        "$installed_target" "$installed_unit" "$installed_resume_unit" \
        > "$test_root/systemd-analyze.out" 2>&1; then
        verification_errors=$(grep -Fv \
            'Failed to turn off SO_PASSRIGHTS on user lookup socket, ignoring: Operation not permitted' \
            "$test_root/systemd-analyze.out" | grep -Fv \
            'Failed to enable SO_PASSCRED on handoff timestamp socket: Operation not permitted' || true)
        if [[ -n "$verification_errors" ]]; then
            printf 'systemd rejected installed session units:\n%s\n' \
                "$verification_errors" >&2
            failures=$((failures + 1))
        fi
    fi

    for installed_artifact in "$installed_bridge" "$installed_module"; do
        if [[ ! -r "$installed_artifact" ]]; then
            printf 'installer did not create session artifact: %s\n' "$installed_artifact" >&2
            failures=$((failures + 1))
        fi
    done

    config_contents=$(<"$hyprland_config")
    assert_contains "$config_contents" "$original_config" \
        'session integration should preserve the existing Hyprland configuration' \
        || failures=$((failures + 1))
    assert_contains "$config_contents" '-- BEGIN arch-lidswitch managed session integration' \
        'the installer should add an owned session-integration block' \
        || failures=$((failures + 1))
    assert_contains "$config_contents" 'pcall(require, "arch_lidswitch.session")' \
        'the owned integration should load the adjacent module without breaking the main config' \
        || failures=$((failures + 1))

    effects=$(<"$effect_log")
    assert_contains "$effects" $'systemctl\t--user\timport-environment\tDISPLAY\tWAYLAND_DISPLAY\tHYPRLAND_INSTANCE_SIGNATURE\tXDG_CURRENT_DESKTOP\tPATH' \
        'current-session activation should synchronously import defined Hyprland variables' \
        || failures=$((failures + 1))
    assert_contains "$effects" $'systemctl\t--user\tstart\thyprland-session.target' \
        'current-session activation should start the Hyprland session target' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installed_session_bridge_orders_start_and_stop() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture bridge
    local effects expected_import start_status=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    mkdir -p "$home"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        DISPLAY=:9 \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_CURRENT_DESKTOP=Hyprland \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1

    bridge="$home/.config/hypr/scripts/lid-session-bridge.sh"
    : > "$effect_log"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        DISPLAY=:10 \
        WAYLAND_DISPLAY=wayland-ordered \
        HYPRLAND_INSTANCE_SIGNATURE=ordered-instance \
        XDG_CURRENT_DESKTOP=Hyprland \
        XDG_SESSION_TYPE=wayland \
        QT_QPA_PLATFORMTHEME=qt6ct \
        XDG_DATA_DIRS=/test/share \
        TEST_EFFECT_LOG="$effect_log" \
        UNRELATED_SECRET=must-not-be-imported \
        "$bridge" start

    effects=$(<"$effect_log")
    expected_import=$'systemctl\t--user\timport-environment\tDISPLAY\tWAYLAND_DISPLAY\tHYPRLAND_INSTANCE_SIGNATURE\tXDG_CURRENT_DESKTOP\tQT_QPA_PLATFORMTHEME\tPATH\tXDG_DATA_DIRS'
    assert_before "$effects" "$expected_import" \
        $'systemctl\t--user\tstart\thyprland-session.target' \
        'the session target must start only after the curated environment import'
    assert_not_contains "$effects" 'XDG_SESSION_TYPE' \
        'the bridge should not expand Hyprland upstream curated environment ownership'
    assert_not_contains "$effects" 'UNRELATED_SECRET' \
        'the bridge should never import unrelated session values'

    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        "$bridge" stop
    effects=$(<"$effect_log")
    assert_before "$effects" \
        $'systemctl\t--user\tstop\thyprland-session.target' \
        $'sleep\t0.1' \
        'normal Hyprland shutdown should synchronously stop the target before the short grace period'
    assert_not_contains "$effects" 'unset-environment' \
        'Hyprland should retain ownership of activation-environment cleanup'

    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-missing-instance \
        TEST_EFFECT_LOG="$effect_log" \
        "$bridge" start \
        > "$test_root/missing.out" 2>&1 || start_status=$?

    if (( start_status == 0 )); then
        printf 'session bridge accepted a missing Hyprland instance signature\n' >&2
        return 1
    fi
    if [[ -s "$effect_log" ]]; then
        printf 'missing session identity caused system effects:\n%s\n' \
            "$(<"$effect_log")" >&2
        return 1
    fi
    assert_contains "$(<"$test_root/missing.out")" 'HYPRLAND_INSTANCE_SIGNATURE' \
        'the bridge should identify the missing required session variable'
)

installed_session_module_registers_isolated_hooks() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture module harness output

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    mkdir -p "$home"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1

    module="$home/.config/hypr/arch_lidswitch/session.lua"
    harness="$test_root/harness.lua"
    printf '%s\n' \
        'local handlers = {}' \
        'hl = {' \
        '  on = function(name, callback) handlers[name] = callback end,' \
        '  exec_cmd = function(command) print("async\t" .. command) end,' \
        '}' \
        'os.execute = function(command) print("sync\t" .. command); return true, "exit", 0 end' \
        'assert(dofile(arg[1]) == true)' \
        'assert(type(handlers["hyprland.start"]) == "function")' \
        'assert(type(handlers["hyprland.shutdown"]) == "function")' \
        'handlers["hyprland.start"]()' \
        'handlers["hyprland.shutdown"]()' \
        > "$harness"

    output=$("$LUA_BIN" "$harness" "$module")
    assert_contains "$output" "async"$'\t'"'$home/.config/hypr/scripts/lid-session-bridge.sh' start" \
        'the Lua start hook should delegate asynchronously to the installed bridge'
    assert_contains "$output" "sync"$'\t'"'$home/.config/hypr/scripts/lid-session-bridge.sh' stop" \
        'the Lua shutdown hook should block on the installed bridge'
)

installer_session_config_integration_is_idempotent() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture config
    local original contents begin_count end_count require_count iteration

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    config="$home/.config/hypr/hyprland.lua"
    original='hl.on("hyprland.start", function() print("keep me") end)'
    mkdir -p "$(dirname "$config")"
    printf '%s\n' "$original" > "$config"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    for iteration in 1 2; do
        "$ENV_BIN" -i \
            HOME="$home" \
            PATH="$fake_bin:$safe_bin" \
            WAYLAND_DISPLAY=wayland-test \
            HYPRLAND_INSTANCE_SIGNATURE=test-instance \
            XDG_SESSION_TYPE=wayland \
            TEST_EFFECT_LOG="$effect_log" \
            TEST_MONITORS_FIXTURE="$monitor_fixture" \
            "$ROOT_DIR/install-hyprland-lid-switch.sh" \
            > "$test_root/installer-$iteration.out" 2>&1
    done

    contents=$(<"$config")
    assert_contains "$contents" "$original" \
        'reinstallation should preserve the user-owned Hyprland callback'
    begin_count=$(grep -Fxc -- '-- BEGIN arch-lidswitch managed session integration' "$config")
    end_count=$(grep -Fxc -- '-- END arch-lidswitch managed session integration' "$config")
    require_count=$(grep -Fxc -- '    local ok, err = pcall(require, "arch_lidswitch.session")' "$config")
    if (( begin_count != 1 || end_count != 1 || require_count != 1 )); then
        printf 'expected one canonical managed block after reinstall; begin=%d end=%d require=%d\n%s\n' \
            "$begin_count" "$end_count" "$require_count" "$contents" >&2
        return 1
    fi
)

installer_refuses_malformed_session_config_ownership() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture config
    local original status=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    config="$home/.config/hypr/hyprland.lua"
    original=$'print("user config")\n-- BEGIN arch-lidswitch managed session integration\nprint("edited partial block")'
    mkdir -p "$(dirname "$config")"
    printf '%s\n' "$original" > "$config"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1 || status=$?

    if (( status == 0 )); then
        printf 'installer accepted malformed session ownership markers\n' >&2
        return 1
    fi
    if [[ "$(<"$config")" != "$original" ]]; then
        printf 'installer changed a malformed user config:\n%s\n' "$(<"$config")" >&2
        return 1
    fi
    if [[ -s "$effect_log" ]]; then
        printf 'malformed config ownership caused external effects:\n%s\n' \
            "$(<"$effect_log")" >&2
        return 1
    fi
    assert_contains "$(<"$test_root/installer.out")" \
        'malformed arch-lidswitch ownership markers' \
        'the refusal should explain the managed-block ownership problem'
)

installer_migrates_only_the_legacy_default_target_service() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture service effects

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    service="$home/.config/systemd/user/lid-monitor.service"
    mkdir -p "$(dirname "$service")"
    prepare_hyprland_config "$home"
    printf '%s\n' '[Install]' 'WantedBy=default.target' > "$service"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1

    effects=$(<"$effect_log")
    assert_before "$effects" \
        $'systemctl\t--user\tdisable\t--now\tlid-monitor.service' \
        $'systemctl\t--user\tdaemon-reload' \
        'the legacy default-target process should stop before the replacement unit is loaded'
    assert_contains "$effects" \
        $'systemctl\t--user\trestart\tlid-monitor.service\tlid-resume-monitor.service' \
        'the migrated installation should activate both units through a fresh restart'
    assert_not_contains "$(<"$service")" 'WantedBy=default.target' \
        'the migrated unit should no longer retain the early-login enablement target'
)

write_monitor_sequence() {
    local sequence_dir=$1
    local sequence_counter=$2
    local sequence_index=0
    local sequence_value final_value

    shift 2
    rm -f "$sequence_dir"/*.json
    for sequence_value in "$@"; do
        printf '%s\n' "$sequence_value" > \
            "$sequence_dir/$sequence_index.json"
        final_value=$sequence_value
        sequence_index=$((sequence_index + 1))
    done
    printf '%s\n' "$final_value" > "$sequence_dir/final.json"
    printf '%s\n' 0 > "$sequence_counter"
}

write_internal_layout_snapshot() {
    local runtime_dir=$1
    local snapshot_dir="$runtime_dir/arch-lidswitch"
    local snapshot_file="$snapshot_dir/internal-layout.json"

    mkdir -m 0700 -p "$snapshot_dir"
    printf '%s\n' \
        '{"output":"eDP-1","mode":"2880x1920@120","position":"0x0","scale":2,"transform":0,"mirror":""}' \
        > "$snapshot_file"
    chmod 0600 "$snapshot_file"
}

installed_cli_verifies_postconditions_and_dpms() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log runtime_dir monitor_fixture
    local sequence_dir sequence_counter framework disabled asleep awake invalid_dpms installed_cli
    local snapshot_file runtime_status output effects query_count command_count failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT
    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    runtime_dir="$test_root/runtime"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    sequence_dir="$test_root/topology-sequence"
    sequence_counter="$test_root/topology-counter"
    framework=$(jq -c 'map(.dpmsStatus = true)' \
        "$ROOT_DIR/tests/fixtures/monitors-json/framework.json")
    disabled=$(jq -c 'map(if .name == "eDP-1" then
        .disabled = true | .dpmsStatus = false else . end)' <<< "$framework")
    asleep=$(jq -c 'map(if .name == "eDP-1" then
        .dpmsStatus = false else . end)' <<< "$framework")
    awake=$framework
    invalid_dpms=$(jq -c 'map(if .name == "eDP-1" then
        .dpmsStatus = "true" else . end)' <<< "$framework")
    snapshot_file="$runtime_dir/arch-lidswitch/internal-layout.json"

    mkdir -m 0700 -p "$home" "$runtime_dir" "$sequence_dir"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"
    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$framework" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1
    installed_cli="$home/.config/hypr/scripts/lid-switch.sh"

    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$invalid_dpms"
    runtime_status=0
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        "$installed_cli" open > "$test_root/invalid-dpms.out" 2>&1 \
        || runtime_status=$?
    if (( runtime_status != 2 )); then
        printf 'non-boolean DPMS evidence should fail 2, got %d\n%s\n' \
            "$runtime_status" "$(<"$test_root/invalid-dpms.out")" >&2
        failures=$((failures + 1))
    fi
    assert_not_contains "$(<"$effect_log")" $'dpms\t' \
        'invalid DPMS evidence must remain nonmutating' \
        || failures=$((failures + 1))

    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$framework" "$framework"
    runtime_status=0
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        "$installed_cli" close > "$test_root/wrong.out" 2>&1 \
        || runtime_status=$?
    output=$(<"$test_root/wrong.out")
    effects=$(<"$effect_log")
    query_count=$(grep -Fxc $'hyprctl\t-j\tmonitors\tall' \
        "$effect_log" || true)
    command_count=$(grep -Fxc \
        $'monitor\toutput=eDP-1\tdisabled=true' "$effect_log" || true)
    if (( runtime_status != 4 || query_count != 2 || command_count != 1 )); then
        printf 'wrong postcondition should fail 4 after one apply/verify, got status=%d queries=%d commands=%d\n%s\n%s\n' \
            "$runtime_status" "$query_count" "$command_count" "$output" "$effects" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$output" 'desired_internal=disabled' \
        'postcondition failure should record the desired internal state' \
        || failures=$((failures + 1))
    assert_contains "$output" 'reason=postcondition_mismatch' \
        'postcondition failure should expose its reason' \
        || failures=$((failures + 1))
    assert_contains "$output" 'topology=' \
        'postcondition failure should retain the verified topology snapshot' \
        || failures=$((failures + 1))
    if [[ ! -f "$snapshot_file" ]]; then
        printf 'failed close verification discarded its recovery snapshot\n' >&2
        failures=$((failures + 1))
    fi

    write_internal_layout_snapshot "$runtime_dir"
    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$disabled" "$awake"
    runtime_status=0
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        "$installed_cli" open > "$test_root/open.out" 2>&1 \
        || runtime_status=$?
    output=$(<"$test_root/open.out")
    effects=$(<"$effect_log")
    if (( runtime_status != 0 )); then
        printf 'targeted open should verify successfully, got %d\n%s\n' \
            "$runtime_status" "$output" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$effects" \
        $'hyprctl\teval\thl.dispatch(hl.dsp.dpms({ action = "enable", monitor = "eDP-1" }))' \
        'explicit open should use the Hyprland 0.55 targeted DPMS Lua API' \
        || failures=$((failures + 1))
    assert_contains "$effects" $'dpms\toutput=eDP-1\tstate=on' \
        'explicit open should target only the internal output for wake' \
        || failures=$((failures + 1))
    assert_contains "$output" 'desired_dpms=true' \
        'successful explicit open should log its verified DPMS postcondition' \
        || failures=$((failures + 1))
    if [[ -e "$snapshot_file" || -L "$snapshot_file" ]]; then
        printf 'verified open did not clean its restored snapshot\n' >&2
        failures=$((failures + 1))
    fi

    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$asleep" "$asleep"
    printf '%s\n' 0 > "$test_root/dpms-counter"
    runtime_status=0
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        TEST_HYPRCTL_DPMS_FAILURES=1 \
        TEST_HYPRCTL_DPMS_COUNTER="$test_root/dpms-counter" \
        "$installed_cli" open > "$test_root/dpms-failed.out" 2>&1 \
        || runtime_status=$?
    effects=$(<"$effect_log")
    query_count=$(grep -Fxc $'hyprctl\t-j\tmonitors\tall' \
        "$effect_log" || true)
    if (( runtime_status != 3 || query_count != 2 )); then
        printf 'failed DPMS command should verify once and fail 3, got status=%d queries=%d\n%s\n' \
            "$runtime_status" "$query_count" \
            "$(<"$test_root/dpms-failed.out")" >&2
        failures=$((failures + 1))
    fi

    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$asleep" "$awake"
    runtime_status=0
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        TEST_HYPRCTL_DPMS_OUTPUT=error \
        "$installed_cli" open > "$test_root/dpms-non-ok.out" 2>&1 \
        || runtime_status=$?
    if (( runtime_status != 3 )); then
        printf 'exit-zero/non-ok DPMS output should fail 3, got %d\n%s\n' \
            "$runtime_status" "$(<"$test_root/dpms-non-ok.out")" >&2
        failures=$((failures + 1))
    fi

    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$framework" "$disabled"
    runtime_status=0
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        TEST_HYPRCTL_EVAL_OUTPUT=error \
        "$installed_cli" close > "$test_root/eval-non-ok.out" 2>&1 \
        || runtime_status=$?
    if (( runtime_status != 3 )); then
        printf 'exit-zero/non-ok monitor output should fail 3, got %d\n%s\n' \
            "$runtime_status" "$(<"$test_root/eval-non-ok.out")" >&2
        failures=$((failures + 1))
    fi

    write_internal_layout_snapshot "$runtime_dir"
    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$disabled" "$disabled"
    runtime_status=0
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        "$installed_cli" open > "$test_root/restore-failed.out" 2>&1 \
        || runtime_status=$?
    if (( runtime_status != 4 )) || [[ ! -f "$snapshot_file" ]]; then
        printf 'failed restore verification should retain snapshot (status=%d exists=%s)\n%s\n' \
            "$runtime_status" "$([[ -f "$snapshot_file" ]] && printf yes || printf no)" \
            "$(<"$test_root/restore-failed.out")" >&2
        failures=$((failures + 1))
    fi

    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$disabled" "$awake"
    runtime_status=0
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        "$installed_cli" open > "$test_root/restore-recovered.out" 2>&1 \
        || runtime_status=$?
    if (( runtime_status != 0 )) || [[ -e "$snapshot_file" || -L "$snapshot_file" ]]; then
        printf 'recovered restore should verify and clean snapshot (status=%d)\n%s\n' \
            "$runtime_status" "$(<"$test_root/restore-recovered.out")" >&2
        failures=$((failures + 1))
    fi
    effects=$(<"$effect_log")
    assert_not_contains "$effects" $'monitor\toutput=DP-2' \
        'BUG-010 recovery must not mutate an external output' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'systemctl\t' \
        'BUG-010 recovery must not request a power action' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installed_daemon_once_bounds_and_recovers_transient_failures() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log runtime_dir lid_root
    local monitor_fixture sequence_dir sequence_counter framework disabled
    local laptop_enabled laptop_disabled installed_daemon
    local runtime_status output effects query_count command_count failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT
    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    runtime_dir="$test_root/runtime"
    lid_root="$test_root/button/lid"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    sequence_dir="$test_root/topology-sequence"
    sequence_counter="$test_root/topology-counter"
    framework=$(jq -c 'map(.dpmsStatus = true)' \
        "$ROOT_DIR/tests/fixtures/monitors-json/framework.json")
    disabled=$(jq -c 'map(if .name == "eDP-1" then
        .disabled = true | .dpmsStatus = false else . end)' <<< "$framework")
    laptop_enabled=$(jq -c '[.[] | select(.name == "eDP-1")]' \
        <<< "$framework")
    laptop_disabled=$(jq -c '[.[] | select(.name == "eDP-1")
        | .disabled = true | .dpmsStatus = false]' <<< "$framework")

    mkdir -m 0700 -p "$home" "$runtime_dir" "$sequence_dir"
    create_lid_state_fixture "$lid_root" lid1
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$framework" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1
    installed_daemon="$home/.config/hypr/scripts/lid-monitor.sh"

    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$framework" "$framework" "$framework" \
        "$framework" "$framework" "$framework" \
        "$framework" "$framework" "$framework"
    runtime_status=0
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$installed_daemon" --once > "$test_root/bounded.out" 2>&1 \
        || runtime_status=$?
    output=$(<"$test_root/bounded.out")
    effects=$(<"$effect_log")
    query_count=$(grep -Fxc $'hyprctl\t-j\tmonitors\tall' \
        "$effect_log" || true)
    command_count=$(grep -Fxc \
        $'monitor\toutput=eDP-1\tdisabled=true' "$effect_log" || true)
    if (( runtime_status != 4 || query_count != 9 || command_count != 3 )); then
        printf '%s\n' "--once should stop after three failed attempts, got status=$runtime_status queries=$query_count commands=$command_count" \
            "$output" "$effects" \
            >&2
        failures=$((failures + 1))
    fi
    assert_contains "$output" 'attempt=3' \
        '--once terminal failure should identify the bounded third attempt' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'sleep\t1' \
        '--once must not enter the unbounded daemon loop' \
        || failures=$((failures + 1))

    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$framework" '__FAIL__' \
        "$framework" "$framework" "$disabled" "$disabled"
    runtime_status=0
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$installed_daemon" --once > "$test_root/query-recovered.out" 2>&1 \
        || runtime_status=$?
    if (( runtime_status != 0 )); then
        printf 'transient query failure did not recover: %d\n%s\n' \
            "$runtime_status" "$(<"$test_root/query-recovered.out")" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$(<"$test_root/query-recovered.out")" 'attempt=2' \
        'query recovery should be recorded on the second attempt' \
        || failures=$((failures + 1))

    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$framework" "$framework" "$framework" \
        "$framework" "$framework" "$disabled" "$disabled"
    printf '%s\n' 0 > "$test_root/eval-counter"
    runtime_status=0
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        TEST_HYPRCTL_EVAL_FAILURES=1 \
        TEST_HYPRCTL_EVAL_COUNTER="$test_root/eval-counter" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$installed_daemon" --once > "$test_root/apply-recovered.out" 2>&1 \
        || runtime_status=$?
    if (( runtime_status != 0 )); then
        printf 'transient apply failure did not recover: %d\n%s\n' \
            "$runtime_status" "$(<"$test_root/apply-recovered.out")" >&2
        failures=$((failures + 1))
    fi

    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$framework" "$framework" "$framework" \
        "$framework" "$framework" "$disabled" "$disabled"
    runtime_status=0
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$installed_daemon" --once > "$test_root/post-recovered.out" 2>&1 \
        || runtime_status=$?
    effects=$(<"$effect_log")
    command_count=$(grep -Fxc \
        $'monitor\toutput=eDP-1\tdisabled=true' "$effect_log" || true)
    if (( runtime_status != 0 || command_count != 2 )); then
        printf 'transient postcondition failure did not recover: status=%d commands=%d\n%s\n' \
            "$runtime_status" "$command_count" \
            "$(<"$test_root/post-recovered.out")" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$(<"$test_root/post-recovered.out")" 'attempt=2' \
        'postcondition recovery should be recorded on the second attempt' \
        || failures=$((failures + 1))

    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$framework" "$framework" "$disabled" "$laptop_disabled" \
        "$laptop_disabled" "$laptop_disabled" \
        "$laptop_enabled" "$laptop_enabled"
    runtime_status=0
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$installed_daemon" --once > "$test_root/policy-race.out" 2>&1 \
        || runtime_status=$?
    output=$(<"$test_root/policy-race.out")
    if (( runtime_status != 0 )); then
        printf 'post-action topology race did not remain pending and recover: %d\n%s\n' \
            "$runtime_status" "$output" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$output" 'reason=post_action_policy_mismatch' \
        'daemon must not mark a stale child postcondition as applied' \
        || failures=$((failures + 1))
    assert_contains "$output" 'trigger=once attempt=2' \
        'post-action policy mismatch should retry with the fresh joint state' \
        || failures=$((failures + 1))
    effects=$(<"$effect_log")
    assert_not_contains "$effects" $'monitor\toutput=DP-2' \
        'bounded retries must never mutate an external output' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'systemctl\t' \
        'bounded retries must never request a power action' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installed_daemon_separates_observed_applied_and_dpms_state() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log runtime_dir lid_root
    local monitor_fixture sequence_dir sequence_counter framework disabled asleep
    local laptop_disabled laptop_awake installed_daemon output command_count
    local apply_count started_count wake_intent_count lid_writer failures=0
    local -a sequence_values=()
    local sequence_index

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT
    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    runtime_dir="$test_root/runtime"
    lid_root="$test_root/button/lid"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    sequence_dir="$test_root/topology-sequence"
    sequence_counter="$test_root/topology-counter"
    framework=$(jq -c 'map(.dpmsStatus = true)' \
        "$ROOT_DIR/tests/fixtures/monitors-json/framework.json")
    disabled=$(jq -c 'map(if .name == "eDP-1" then
        .disabled = true | .dpmsStatus = false else . end)' <<< "$framework")
    asleep=$(jq -c 'map(if .name == "eDP-1" then
        .dpmsStatus = false else . end)' <<< "$framework")
    laptop_disabled=$(jq -c '[.[] | select(.name == "eDP-1")]' \
        <<< "$disabled")
    laptop_awake=$(jq -c '[.[] | select(.name == "eDP-1")]' \
        <<< "$framework")

    mkdir -m 0700 -p "$home" "$runtime_dir" "$sequence_dir"
    create_lid_state_fixture "$lid_root" lid1
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$framework" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1
    installed_daemon="$home/.config/hypr/scripts/lid-monitor.sh"

    # Three status-3 apply failures retry within the same stable generation.
    # After the five-tick cooldown, the fourth mutation and its postconditions
    # succeed without requiring another input edge.
    for ((sequence_index = 0; sequence_index < 19; sequence_index++)); do
        sequence_values+=("$framework")
    done
    sequence_values+=("$disabled" "$disabled")
    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "${sequence_values[@]}"
    printf '%s\n' 0 > "$test_root/eval-counter"
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        TEST_HYPRCTL_EVAL_FAILURES=3 \
        TEST_HYPRCTL_EVAL_COUNTER="$test_root/eval-counter" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$TIMEOUT_BIN" 2 "$installed_daemon" \
        > "$test_root/pending.out" 2>&1 || true
    output=$(<"$test_root/pending.out")
    command_count=$(grep -Fc $'hyprctl\teval\t' "$effect_log" || true)
    apply_count=$(grep -Fxc \
        $'monitor\toutput=eDP-1\tdisabled=true' "$effect_log" || true)
    if (( command_count != 4 || apply_count != 1 )); then
        printf 'same-generation status-3 retries should issue four evals and apply once; got evals=%d applies=%d\n%s\n' \
            "$command_count" "$apply_count" "$output" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$output" \
        'event=reconciliation_cooldown_started ticks=5 reason=mutation_rejected' \
        'three status-3 failures should arm a five-tick cooldown' \
        || failures=$((failures + 1))
    assert_contains "$output" 'event=reconciliation_succeeded' \
        'a pending stable transition should recover without another input edge' \
        || failures=$((failures + 1))
    assert_not_contains "$output" 'event=joint_state_changed' \
        'post-action observation must not masquerade as a new input edge' \
        || failures=$((failures + 1))

    printf '%s\n' 'state: open' > "$lid_root/LID1/state"
    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$framework" "$framework" "$framework" "$framework" \
        "$framework" "$framework" "$framework" "$asleep"
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$TIMEOUT_BIN" 0.6 "$installed_daemon" \
        > "$test_root/dpms-only.out" 2>&1 || true
    output=$(<"$test_root/dpms-only.out")
    started_count=$(grep -Fc 'event=reconciliation_started' \
        "$test_root/dpms-only.out" || true)
    if (( started_count != 1 )); then
        printf 'DPMS-only observation should not reconcile; got %d reconciliations\n%s\n' \
            "$started_count" "$output" >&2
        failures=$((failures + 1))
    fi
    assert_not_contains "$(<"$effect_log")" $'dpms\t' \
        'steady open startup and idle DPMS changes must not wake the panel' \
        || failures=$((failures + 1))

    printf '%s\n' 'state: closed' > "$lid_root/LID1/state"
    # Settle the closed startup first. The first open reconciliation then sees
    # an external disappear at child pre-apply (status 5), restabilizes on the
    # laptop-only topology, and must retain preserve_dpms=false until it wakes.
    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$framework" "$framework" "$framework" "$framework" "$framework" \
        "$disabled" "$disabled" "$disabled" "$disabled" \
        "$disabled" "$disabled" "$disabled" "$disabled" \
        "$laptop_disabled" "$laptop_disabled" "$laptop_disabled" \
        "$laptop_disabled" "$laptop_disabled" "$laptop_disabled" \
        "$laptop_disabled" "$laptop_awake" "$laptop_awake"
    rm -f "$fake_bin/sleep"
    ln -s "$REAL_SLEEP_BIN" "$fake_bin/sleep"
    (
        # Query 7 is the first steady poll after the closed startup action.
        # Waiting until it completes guarantees the lid edge cannot race the
        # startup stability barrier or its post-action observation.
        for ((sequence_index = 0; sequence_index < 400; sequence_index++)); do
            if [[ -r "$sequence_counter" ]] && \
                read -r command_count < "$sequence_counter" && \
                [[ "$command_count" =~ ^[0-9]+$ ]] && \
                (( command_count >= 8 )); then
                break
            fi
            "$REAL_SLEEP_BIN" 0.01
        done
        printf '%s\n' 'state: open' > "$lid_root/LID1/state"
    ) &
    lid_writer=$!
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$TIMEOUT_BIN" 4.5 "$installed_daemon" \
        > "$test_root/open-edge.out" 2>&1 || true
    wait "$lid_writer"
    output=$(<"$test_root/open-edge.out")
    command_count=$(grep -Fxc $'dpms\toutput=eDP-1\tstate=on' \
        "$effect_log" || true)
    if (( command_count != 1 )); then
        printf 'a real closed-to-open edge should wake eDP-1 once, got %d\n%s\n' \
            "$command_count" "$output" >&2
        failures=$((failures + 1))
    fi
    wake_intent_count=$(grep -Fc \
        'state=open preserve_dpms=false commit_generation=true' \
        "$test_root/open-edge.out" || true)
    if (( wake_intent_count != 2 )); then
        printf 'wake intent should survive one generation retry; got %d open attempts\n%s\n' \
            "$wake_intent_count" "$output" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$output" \
        'event=lid_state_changed previous=closed current=open' \
        'daemon should distinguish a real open edge from steady open state' \
        || failures=$((failures + 1))
    assert_contains "$output" 'state=open preserve_dpms=false' \
        'the real open-edge wake intent must be preserved through reconciliation' \
        || failures=$((failures + 1))
    assert_contains "$output" \
        'event=reconciliation_requires_stability trigger=generation status=5' \
        'a generation mismatch should force a fresh barrier without losing wake intent' \
        || failures=$((failures + 1))
    assert_not_contains "$(<"$effect_log")" $'monitor\toutput=DP-2' \
        'a real open edge must not mutate the external output' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installed_daemon_stabilizes_resume_generations() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log runtime_dir lid_root
    local monitor_fixture sequence_dir sequence_counter framework disabled
    local laptop_only laptop_disabled laptop_asleep laptop_awake installed_cli installed_daemon
    local expected_laptop_token runtime_status output effects effects_prefix
    local query_count query_before command_count failures=0
    local -a alternating=() normal_recovery=()
    local sample

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT
    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    runtime_dir="$test_root/runtime"
    lid_root="$test_root/button/lid"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    sequence_dir="$test_root/topology-sequence"
    sequence_counter="$test_root/topology-counter"
    framework=$(jq -c 'map(.dpmsStatus = true)' \
        "$ROOT_DIR/tests/fixtures/monitors-json/framework.json")
    disabled=$(jq -c 'map(if .name == "eDP-1" then
        .disabled = true | .dpmsStatus = false else . end)' <<< "$framework")
    laptop_only=$(jq -c '[.[] | select(.name == "eDP-1")]' <<< "$framework")
    laptop_disabled=$(jq -c '[.[] | select(.name == "eDP-1")
        | .disabled = true | .dpmsStatus = false]' <<< "$framework")
    laptop_asleep=$(jq -c '[.[] | select(.name == "eDP-1")
        | .dpmsStatus = false]' <<< "$framework")
    laptop_awake=$(jq -c '[.[] | select(.name == "eDP-1")]' <<< "$framework")
    expected_laptop_token='{"internal":"eDP-1","externals":[]}'

    mkdir -m 0700 -p "$home" "$runtime_dir" "$sequence_dir"
    create_lid_state_fixture "$lid_root" lid1
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$framework" HYPR_LID_STATE_ROOT="$lid_root" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1
    installed_cli="$home/.config/hypr/scripts/lid-switch.sh"
    installed_daemon="$home/.config/hypr/scripts/lid-monitor.sh"

    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$framework" "$framework"
    runtime_status=0
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        ARCH_LIDSWITCH_EXPECTED_LID=closed \
        ARCH_LIDSWITCH_EXPECTED_POLICY_TOKEN="$expected_laptop_token" \
        "$installed_cli" close > "$test_root/token-mismatch.out" 2>&1 \
        || runtime_status=$?
    if (( runtime_status != 5 )); then
        printf 'generation-token mismatch should fail 5, got %d\n%s\n' \
            "$runtime_status" "$(<"$test_root/token-mismatch.out")" >&2
        failures=$((failures + 1))
    fi
    assert_not_contains "$(<"$effect_log")" $'monitor\t' \
        'pre-apply generation mismatch must not mutate a monitor' \
        || failures=$((failures + 1))

    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$framework" "$framework" "$framework" "$framework" \
        "$laptop_only" \
        "$laptop_only" "$laptop_only" "$laptop_only" "$laptop_only" \
        "$laptop_only" "$laptop_only" "$laptop_only"
    runtime_status=0
    : > "$effect_log"
    "$TIMEOUT_BIN" 2 "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$installed_daemon" --resume-once > "$test_root/restabilized.out" 2>&1 \
        || runtime_status=$?
    output=$(<"$test_root/restabilized.out")
    command_count=$(grep -Fc 'event=stability_verified trigger=resume' \
        "$test_root/restabilized.out" || true)
    if (( runtime_status != 0 || command_count != 2 )); then
        printf 'status5 should force a complete second barrier, status=%d barriers=%d\n%s\n' \
            "$runtime_status" "$command_count" "$output" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$output" 'status=5' \
        'child generation change should be visible before restabilization' \
        || failures=$((failures + 1))
    assert_not_contains "$(<"$effect_log")" $'monitor\t' \
        'status5 must not mutate before the second stability barrier' \
        || failures=$((failures + 1))

    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$laptop_only" "$laptop_only" "$laptop_only" "$framework" \
        "$framework" "$framework" "$framework" "$framework" \
        "$disabled" "$disabled"
    runtime_status=0
    : > "$effect_log"
    "$TIMEOUT_BIN" 2 "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$installed_daemon" --resume-once > "$test_root/stable.out" 2>&1 \
        || runtime_status=$?
    output=$(<"$test_root/stable.out")
    effects=$(<"$effect_log")
    effects_prefix=${effects%%$'monitor\t'*}
    query_before=$(grep -Fxc $'hyprctl\t-j\tmonitors\tall' \
        <<< "$effects_prefix" || true)
    if (( runtime_status != 0 || query_before != 8 )); then
        printf 'final-precommit reset should stabilize before mutation, status=%d pre-effect-queries=%d\n%s\n%s\n' \
            "$runtime_status" "$query_before" "$output" "$effects" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$output" 'event=stability_verified trigger=resume samples=7' \
        'resume should require three matches and an immediate final match' \
        || failures=$((failures + 1))

    alternating=()
    for ((sample = 0; sample < 40; sample++)); do
        if (( sample % 2 == 0 )); then
            alternating+=("$framework")
        else
            alternating+=("$laptop_only")
        fi
    done
    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "${alternating[@]}"
    runtime_status=0
    : > "$effect_log"
    "$TIMEOUT_BIN" 2 "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$installed_daemon" --resume-once > "$test_root/exhausted.out" 2>&1 \
        || runtime_status=$?
    effects=$(<"$effect_log")
    query_count=$(grep -Fxc $'hyprctl\t-j\tmonitors\tall' \
        "$effect_log" || true)
    if (( runtime_status != 2 || query_count != 40 )); then
        printf 'alternating stability should exhaust at 40/status2, got status=%d queries=%d\n%s\n' \
            "$runtime_status" "$query_count" "$(<"$test_root/exhausted.out")" >&2
        failures=$((failures + 1))
    fi
    assert_not_contains "$effects" $'monitor\t' \
        'stability exhaustion must have zero monitor effects' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'dpms\t' \
        'stability exhaustion must have zero DPMS effects' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'systemctl\t' \
        'stability exhaustion must have zero power effects' \
        || failures=$((failures + 1))

    normal_recovery=()
    for ((sample = 0; sample < 40; sample++)); do
        if (( sample % 2 == 0 )); then
            normal_recovery+=("$laptop_only")
        else
            normal_recovery+=("$framework")
        fi
    done
    for ((sample = 0; sample < 10; sample++)); do
        normal_recovery+=("$framework")
    done
    normal_recovery+=("$framework" "$disabled" "$disabled")
    printf '%s\n' 'state: closed' > "$lid_root/LID1/state"
    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "${normal_recovery[@]}"
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$TIMEOUT_BIN" 3 "$installed_daemon" \
        > "$test_root/normal-rearmed.out" 2>&1 || true
    output=$(<"$test_root/normal-rearmed.out")
    assert_contains "$output" \
        'event=reconciliation_cooldown_started ticks=5 reason=stability_exhausted' \
        'normal stability exhaustion should enter a bounded cooldown' \
        || failures=$((failures + 1))
    assert_contains "$output" 'event=reconciliation_succeeded' \
        'normal daemon should converge after cooldown without a new edge' \
        || failures=$((failures + 1))

    printf '%s\n' 'state: open' > "$lid_root/LID1/state"
    write_internal_layout_snapshot "$runtime_dir"
    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$laptop_disabled" "$laptop_disabled" "$laptop_disabled" "$laptop_disabled" \
        "$laptop_disabled" "$laptop_awake" "$laptop_awake"
    runtime_status=0
    : > "$effect_log"
    "$TIMEOUT_BIN" 2 "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$installed_daemon" --resume-once > "$test_root/resume-restore.out" 2>&1 \
        || runtime_status=$?
    effects=$(<"$effect_log")
    if (( runtime_status != 0 )); then
        printf 'open resume restore should converge, got %d\n%s\n' \
            "$runtime_status" "$(<"$test_root/resume-restore.out")" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$effects" $'monitor\toutput=eDP-1\tdisabled=false' \
        'open resume should restore the saved internal layout' \
        || failures=$((failures + 1))
    assert_contains "$effects" $'dpms\toutput=eDP-1\tstate=on' \
        'open resume should target DPMS-on at the internal output' \
        || failures=$((failures + 1))

    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$laptop_asleep" "$laptop_asleep" "$laptop_asleep" "$laptop_asleep" \
        "$laptop_asleep" "$laptop_awake" "$laptop_awake"
    runtime_status=0
    : > "$effect_log"
    "$TIMEOUT_BIN" 2 "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$installed_daemon" --resume-once > "$test_root/resume-asleep.out" 2>&1 \
        || runtime_status=$?
    effects=$(<"$effect_log")
    command_count=$(grep -Fxc $'dpms\toutput=eDP-1\tstate=on' \
        "$effect_log" || true)
    if (( runtime_status != 0 || command_count != 1 )); then
        printf 'unchanged open/asleep resume should wake once, status=%d wakes=%d\n%s\n' \
            "$runtime_status" "$command_count" \
            "$(<"$test_root/resume-asleep.out")" >&2
        failures=$((failures + 1))
    fi
    assert_not_contains "$(<"$test_root/stable.out")" 'desired_dpms=true' \
        'closed docked resume must not request internal DPMS-on' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'monitor\toutput=DP-2' \
        'resume reconciliation must never mutate an external output' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'systemctl\t' \
        'resume reconciliation must never request a power action' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installed_daemon_rejects_transitional_enabled_external_layouts() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log runtime_dir lid_root
    local monitor_fixture sequence_dir sequence_counter framework disabled
    local invalid_width invalid_height invalid_refresh invalid_scale installed_daemon
    local runtime_status=0 effects effects_prefix query_before failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT
    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    runtime_dir="$test_root/runtime"
    lid_root="$test_root/button/lid"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    sequence_dir="$test_root/topology-sequence"
    sequence_counter="$test_root/topology-counter"
    framework=$(jq -c 'map(.dpmsStatus = true)' \
        "$ROOT_DIR/tests/fixtures/monitors-json/framework.json")
    disabled=$(jq -c 'map(if .name == "eDP-1" then
        .disabled = true | .dpmsStatus = false else . end)' <<< "$framework")
    invalid_width=$(jq -c 'map(if .name == "DP-2" then .width = 0 else . end)' \
        <<< "$framework")
    invalid_height=$(jq -c 'map(if .name == "DP-2" then .height = 0 else . end)' \
        <<< "$framework")
    invalid_refresh=$(jq -c 'map(if .name == "DP-2" then
        .refreshRate = 0 else . end)' <<< "$framework")
    invalid_scale=$(jq -c 'map(if .name == "DP-2" then .scale = 0 else . end)' \
        <<< "$framework")

    mkdir -m 0700 -p "$home" "$runtime_dir" "$sequence_dir"
    create_lid_state_fixture "$lid_root" lid1
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$framework" HYPR_LID_STATE_ROOT="$lid_root" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1
    installed_daemon="$home/.config/hypr/scripts/lid-monitor.sh"

    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$invalid_width" "$invalid_height" "$invalid_refresh" "$invalid_scale" \
        "$framework" "$framework" "$framework" "$framework" \
        "$framework" "$disabled" "$disabled"
    : > "$effect_log"
    "$TIMEOUT_BIN" 2 "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$installed_daemon" --resume-once \
        > "$test_root/transitional-external.out" 2>&1 || runtime_status=$?
    effects=$(<"$effect_log")
    effects_prefix=${effects%%$'monitor\t'*}
    query_before=$(grep -Fxc $'hyprctl\t-j\tmonitors\tall' \
        <<< "$effects_prefix" || true)

    if (( runtime_status != 0 || query_before != 9 )); then
        printf 'enabled external layout must become valid and stable before mutation; status=%d pre-effect-queries=%d\n%s\n%s\n' \
            "$runtime_status" "$query_before" \
            "$(<"$test_root/transitional-external.out")" "$effects" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$(<"$test_root/transitional-external.out")" \
        'event=stability_reset trigger=resume' \
        'each incomplete enabled-external layout should reset stabilization' \
        || failures=$((failures + 1))
    assert_not_contains "$effects_prefix" $'dpms\t' \
        'transitional enabled-external samples must not cause a DPMS effect' \
        || failures=$((failures + 1))
    assert_not_contains "$effects_prefix" $'systemctl\t' \
        'transitional enabled-external samples must not cause a power effect' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installed_daemon_retains_resume_signals_during_work() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log runtime_dir lid_root
    local monitor_fixture framework asleep installed_daemon state_file output
    local daemon_pid query_count wake_count disable_count resume_count
    local sample signal_window_seen failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT
    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    runtime_dir="$test_root/runtime"
    lid_root="$test_root/button/lid"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    framework=$(jq -c 'map(.dpmsStatus = true)' \
        "$ROOT_DIR/tests/fixtures/monitors-json/framework.json")
    asleep=$(jq -c 'map(if .name == "eDP-1" then
        .dpmsStatus = false else . end)' <<< "$framework")

    mkdir -m 0700 -p "$home" "$runtime_dir"
    create_lid_state_fixture "$lid_root" lid1
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$framework" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1
    installed_daemon="$home/.config/hypr/scripts/lid-monitor.sh"
    rm -f "$fake_bin/sleep"
    ln -s "$REAL_SLEEP_BIN" "$fake_bin/sleep"

    printf '%s\n' 'state: open' > "$lid_root/LID1/state"
    state_file="$test_root/stability-state.json"
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$asleep" \
        TEST_HYPRCTL_MONITORS_STATE_FILE="$state_file" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$installed_daemon" > "$test_root/during-stability.out" 2>&1 &
    daemon_pid=$!
    signal_window_seen=false
    for ((sample = 0; sample < 50; sample++)); do
        query_count=$(grep -Fxc $'hyprctl\t-j\tmonitors\tall' \
            "$effect_log" || true)
        if (( query_count >= 1 )); then
            signal_window_seen=true
            break
        fi
        "$REAL_SLEEP_BIN" 0.02
    done
    if [[ "$signal_window_seen" == true ]]; then
        kill -USR1 "$daemon_pid" 2>/dev/null || true
    fi
    for ((sample = 0; sample < 50; sample++)); do
        if grep -Fq 'event=reconciliation_succeeded trigger=resume' \
            "$test_root/during-stability.out"; then
            break
        fi
        "$REAL_SLEEP_BIN" 0.1
    done
    kill "$daemon_pid" 2>/dev/null || true
    wait "$daemon_pid" 2>/dev/null || true
    output=$(<"$test_root/during-stability.out")
    wake_count=$(grep -Fxc $'dpms\toutput=eDP-1\tstate=on' \
        "$effect_log" || true)
    resume_count=$(grep -Fc 'event=reconciliation_succeeded trigger=resume' \
        "$test_root/during-stability.out" || true)
    if [[ "$signal_window_seen" != true || $resume_count -ne 1 || \
        $wake_count -ne 1 ]]; then
        printf 'resume during stability was not retained exactly once (window=%s resumes=%d wakes=%d)\n%s\n%s\n' \
            "$signal_window_seen" "$resume_count" "$wake_count" \
            "$output" "$(<"$effect_log")" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$output" 'event=resume_requested coalesced=true' \
        'USR1 during stabilization should be recorded by the early trap' \
        || failures=$((failures + 1))

    printf '%s\n' 'state: closed' > "$lid_root/LID1/state"
    state_file="$test_root/apply-state.json"
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$framework" \
        TEST_HYPRCTL_MONITORS_STATE_FILE="$state_file" \
        TEST_HYPRCTL_EVAL_DELAY_SECONDS=0.5 \
        TEST_REAL_SLEEP_BIN="$REAL_SLEEP_BIN" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$installed_daemon" > "$test_root/during-apply.out" 2>&1 &
    daemon_pid=$!
    signal_window_seen=false
    for ((sample = 0; sample < 100; sample++)); do
        if grep -Fq $'hyprctl\teval\t' "$effect_log"; then
            signal_window_seen=true
            break
        fi
        "$REAL_SLEEP_BIN" 0.02
    done
    if [[ "$signal_window_seen" == true ]]; then
        kill -USR1 "$daemon_pid" 2>/dev/null || true
    fi
    for ((sample = 0; sample < 50; sample++)); do
        if grep -Fq 'event=reconciliation_succeeded trigger=resume' \
            "$test_root/during-apply.out"; then
            break
        fi
        "$REAL_SLEEP_BIN" 0.1
    done
    kill "$daemon_pid" 2>/dev/null || true
    wait "$daemon_pid" 2>/dev/null || true
    output=$(<"$test_root/during-apply.out")
    disable_count=$(grep -Fxc $'monitor\toutput=eDP-1\tdisabled=true' \
        "$effect_log" || true)
    resume_count=$(grep -Fc 'event=reconciliation_succeeded trigger=resume' \
        "$test_root/during-apply.out" || true)
    if [[ "$signal_window_seen" != true || $resume_count -ne 1 || \
        $disable_count -ne 1 ]]; then
        printf 'resume during apply was not retained exactly once (window=%s resumes=%d disables=%d)\n%s\n%s\n' \
            "$signal_window_seen" "$resume_count" "$disable_count" \
            "$output" "$(<"$effect_log")" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$output" 'event=resume_requested coalesced=true' \
        'USR1 during an owned output mutation should remain pending' \
        || failures=$((failures + 1))
    assert_not_contains "$(<"$effect_log")" $'dpms\t' \
        'closed docked resume after an in-flight apply must not wake the internal panel' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installed_resume_listener_streams_sleep_cycles_safely() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture
    local installed_listener listener_status effects notify_count failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT
    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    mkdir -p "$home"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1
    installed_listener="$home/.config/hypr/scripts/lid-resume-monitor.sh"
    if [[ ! -x "$installed_listener" ]]; then
        printf 'installer did not create an executable resume listener\n' >&2
        return 1
    fi
    if ! cmp -s "$ROOT_DIR/runtime/lid-resume-monitor.sh" "$installed_listener"; then
        printf 'installed resume listener differs from canonical runtime source\n' >&2
        failures=$((failures + 1))
    fi

    listener_status=0
    : > "$effect_log"
    "$ENV_BIN" -i HOME="$home" PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_BUSCTL_WAIT_OUTPUT='{"type":"b","data":[true]}' \
        "$installed_listener" --once > "$test_root/true.out" 2>&1 \
        || listener_status=$?
    effects=$(<"$effect_log")
    if (( listener_status != 0 )); then
        printf 'pre-sleep true event should succeed, got %d\n%s\n' \
            "$listener_status" "$(<"$test_root/true.out")" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$effects" \
        $'busctl\t--system\t--json=short\t--limit-messages=1\twait\torg.freedesktop.login1\t/org/freedesktop/login1\torg.freedesktop.login1.Manager\tPrepareForSleep' \
        '--once should subscribe to exactly one typed login1 signal' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'systemctl\t--user\tkill' \
        'PrepareForSleep=true must never notify the main daemon' \
        || failures=$((failures + 1))

    listener_status=0
    : > "$effect_log"
    "$ENV_BIN" -i HOME="$home" PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_BUSCTL_WAIT_OUTPUT='{"type":"b","data":[false]}' \
        "$installed_listener" --once > "$test_root/false.out" 2>&1 \
        || listener_status=$?
    effects=$(<"$effect_log")
    notify_count=$(grep -Fxc \
        $'systemctl\t--user\tkill\t--kill-whom=main\t--signal=USR1\tlid-monitor.service' \
        "$effect_log" || true)
    if (( listener_status != 0 || notify_count != 1 )); then
        printf 'post-resume false event should notify exactly once, status=%d count=%d\n%s\n%s\n' \
            "$listener_status" "$notify_count" \
            "$(<"$test_root/false.out")" "$effects" >&2
        failures=$((failures + 1))
    fi

    listener_status=0
    : > "$effect_log"
    "$ENV_BIN" -i HOME="$home" PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" TEST_BUSCTL_WAIT_OUTPUT=malformed \
        "$installed_listener" --once > "$test_root/malformed.out" 2>&1 \
        || listener_status=$?
    if (( listener_status != 2 )); then
        printf 'malformed resume event should fail 2, got %d\n%s\n' \
            "$listener_status" "$(<"$test_root/malformed.out")" >&2
        failures=$((failures + 1))
    fi
    assert_not_contains "$(<"$effect_log")" $'systemctl\t--user\tkill' \
        'malformed resume event must not notify the main daemon' \
        || failures=$((failures + 1))

    listener_status=0
    : > "$effect_log"
    "$ENV_BIN" -i HOME="$home" PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" TEST_BUSCTL_WAIT_FAIL=1 \
        "$installed_listener" --once > "$test_root/wait-failed.out" 2>&1 \
        || listener_status=$?
    if (( listener_status != 2 )); then
        printf 'failed resume subscription should fail 2, got %d\n%s\n' \
            "$listener_status" "$(<"$test_root/wait-failed.out")" >&2
        failures=$((failures + 1))
    fi

    printf '%s\n' 0 > "$test_root/kill-counter"
    listener_status=0
    : > "$effect_log"
    "$ENV_BIN" -i HOME="$home" PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_BUSCTL_WAIT_OUTPUT='{"type":"b","data":[false]}' \
        TEST_SYSTEMCTL_KILL_FAILURES=2 \
        TEST_SYSTEMCTL_KILL_COUNTER="$test_root/kill-counter" \
        "$installed_listener" --once > "$test_root/notify-retry.out" 2>&1 \
        || listener_status=$?
    notify_count=$(grep -Fxc \
        $'systemctl\t--user\tkill\t--kill-whom=main\t--signal=USR1\tlid-monitor.service' \
        "$effect_log" || true)
    if (( listener_status != 0 || notify_count != 3 )); then
        printf 'resume notification should recover within 3 attempts, status=%d count=%d\n%s\n' \
            "$listener_status" "$notify_count" \
            "$(<"$test_root/notify-retry.out")" >&2
        failures=$((failures + 1))
    fi

    printf '%s\n' 0 > "$test_root/kill-counter"
    listener_status=0
    : > "$effect_log"
    "$ENV_BIN" -i HOME="$home" PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_BUSCTL_WAIT_OUTPUT='{"type":"b","data":[false]}' \
        TEST_SYSTEMCTL_KILL_FAILURES=3 \
        TEST_SYSTEMCTL_KILL_COUNTER="$test_root/kill-counter" \
        "$installed_listener" --once > "$test_root/notify-exhausted.out" 2>&1 \
        || listener_status=$?
    notify_count=$(grep -Fxc \
        $'systemctl\t--user\tkill\t--kill-whom=main\t--signal=USR1\tlid-monitor.service' \
        "$effect_log" || true)
    if (( listener_status != 3 || notify_count != 3 )); then
        printf 'exhausted resume notification should fail after 3 attempts, status=%d count=%d\n%s\n' \
            "$listener_status" "$notify_count" \
            "$(<"$test_root/notify-exhausted.out")" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$(<"$test_root/notify-exhausted.out")" \
        'event=resume_notification_failed attempt=3 status=3' \
        'exhausted main notification should remain visible' \
        || failures=$((failures + 1))

    rm -f "$fake_bin/sleep"
    ln -s "$REAL_SLEEP_BIN" "$fake_bin/sleep"
    : > "$effect_log"
    "$ENV_BIN" -i HOME="$home" PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_BUSCTL_WAIT_OUTPUT=$'{"type":"b","data":[true]}\n{"type":"b","data":[false]}' \
        "$TIMEOUT_BIN" 0.8 "$installed_listener" \
        > "$test_root/lifetime.out" 2>&1 || true
    effects=$(<"$effect_log")
    query_count=$(grep -Fxc \
        $'busctl\t--system\t--json=short\t--limit-messages=infinity\twait\torg.freedesktop.login1\t/org/freedesktop/login1\torg.freedesktop.login1.Manager\tPrepareForSleep' \
        "$effect_log" || true)
    notify_count=$(grep -Fxc \
        $'systemctl\t--user\tkill\t--kill-whom=main\t--signal=USR1\tlid-monitor.service' \
        "$effect_log" || true)
    if (( query_count != 1 || notify_count != 1 )); then
        printf 'lifetime true/false stream should use one subscription/notification, got subscriptions=%d notifications=%d\noutput:\n%s\neffects:\n%s\n' \
            "$query_count" "$notify_count" \
            "$(<"$test_root/lifetime.out")" "$effects" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$(<"$test_root/lifetime.out")" \
        'event=subscription_ended status=2 reason=unexpected_eof' \
        'an unexpected lifetime-stream EOF should be visible before reconnect backoff' \
        || failures=$((failures + 1))

    : > "$effect_log"
    "$ENV_BIN" -i HOME="$home" PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" TEST_BUSCTL_WAIT_OUTPUT=malformed \
        "$TIMEOUT_BIN" 0.8 "$installed_listener" \
        > "$test_root/malformed-loop.out" 2>&1 || true
    query_count=$(grep -Fc $'busctl\t--system\t--json=short\t--limit-messages=infinity\twait' \
        "$effect_log" || true)
    if (( query_count != 1 )); then
        printf 'malformed production stream should abort and back off, got %d subscriptions\n%s\n' \
            "$query_count" "$(<"$effect_log")" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$(<"$test_root/malformed-loop.out")" \
        'event=subscription_aborted status=2' \
        'malformed production input should terminate the unhealthy subscription' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installer_packages_resume_monitor_and_requires_systemd_257() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture
    local main_unit resume_unit main_contents resume_contents effects
    local resume_show_count sleep_count
    local old_home old_fake old_safe old_log installer_status=0 failures=0
    local missing_home missing_fake missing_safe missing_log dependency
    local dependency_status dependency_output

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT
    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    mkdir -p "$home"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" TEST_BUSCTL_VERSION=261 \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1
    main_unit="$home/.config/systemd/user/lid-monitor.service"
    resume_unit="$home/.config/systemd/user/lid-resume-monitor.service"
    if [[ ! -r "$resume_unit" ]]; then
        printf 'installer did not create lid-resume-monitor.service\n' >&2
        failures=$((failures + 1))
    else
        main_contents=$(<"$main_unit")
        resume_contents=$(<"$resume_unit")
        assert_contains "$main_contents" 'Wants=lid-resume-monitor.service' \
            'main daemon should pull in the dedicated resume listener' \
            || failures=$((failures + 1))
        assert_contains "$resume_contents" 'BindsTo=lid-monitor.service' \
            'resume listener should stop if the main daemon exits' \
            || failures=$((failures + 1))
        assert_contains "$resume_contents" 'PartOf=graphical-session.target' \
            'resume listener should stop with the graphical session' \
            || failures=$((failures + 1))
        assert_contains "$resume_contents" \
            'After=graphical-session.target lid-monitor.service' \
            'resume listener should start after the graphical session' \
            || failures=$((failures + 1))
        assert_contains "$resume_contents" \
            "ExecStart=$home/.config/hypr/scripts/lid-resume-monitor.sh" \
            'resume unit should execute the installed listener' \
            || failures=$((failures + 1))
        assert_contains "$resume_contents" 'StandardOutput=journal' \
            'resume listener output should use the journal boundary' \
            || failures=$((failures + 1))
        assert_not_contains "$resume_contents" 'WantedBy=' \
            'the auxiliary listener should be owned by the main daemon, not independently enabled' \
            || failures=$((failures + 1))
    fi
    effects=$(<"$effect_log")
    assert_contains "$effects" $'busctl\t--version' \
        'installer should prove the busctl version before writes' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" \
        $'systemctl\t--user\tenable\tlid-resume-monitor.service' \
        'installer should not independently enable the main-owned resume listener' \
        || failures=$((failures + 1))
    assert_contains "$effects" \
        $'systemctl\t--user\trestart\tlid-monitor.service\tlid-resume-monitor.service' \
        'installer should explicitly restart the main daemon and resume listener' \
        || failures=$((failures + 1))
    resume_show_count=$(grep -Fxc \
        $'systemctl\t--user\tshow\t--no-pager\t--property=LoadState\t--property=ActiveState\t--property=SubState\t--property=MainPID\t--property=InvocationID\tlid-resume-monitor.service' \
        "$effect_log" || true)
    sleep_count=$(grep -Fxc $'sleep\t1.1' "$effect_log" || true)
    if (( resume_show_count != 4 || sleep_count != 2 )); then
        printf 'installer did not stably verify the restarted resume generation; shows=%d sleeps=%d\n' \
            "$resume_show_count" "$sleep_count" >&2
        failures=$((failures + 1))
    fi

    for dependency in stdbuf timeout; do
        missing_home="$test_root/missing-$dependency-home"
        missing_fake="$test_root/missing-$dependency-fake-bin"
        missing_safe="$test_root/missing-$dependency-safe-bin"
        missing_log="$test_root/missing-$dependency-effects.log"
        mkdir -p "$missing_home"
        prepare_hyprland_config "$missing_home"
        : > "$missing_log"
        install_safe_path "$missing_fake" "$missing_safe"
        rm -f "$missing_safe/$dependency"
        dependency_status=0
        "$ENV_BIN" -i \
            HOME="$missing_home" PATH="$missing_fake:$missing_safe" \
            WAYLAND_DISPLAY=wayland-test HYPRLAND_INSTANCE_SIGNATURE=test-instance \
            XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$missing_log" \
            TEST_MONITORS_FIXTURE="$monitor_fixture" \
            "$ROOT_DIR/install-hyprland-lid-switch.sh" \
            > "$test_root/missing-$dependency.out" 2>&1 \
            || dependency_status=$?
        dependency_output=$(<"$test_root/missing-$dependency.out")
        if (( dependency_status == 0 )); then
            printf 'installer accepted missing %s dependency\n' "$dependency" >&2
            failures=$((failures + 1))
        fi
        assert_contains "$dependency_output" "requires $dependency" \
            "missing $dependency should receive an actionable preflight error" \
            || failures=$((failures + 1))
        if [[ -e "$missing_home/.config/hypr/scripts/lid-monitor.sh" || \
            -e "$missing_home/.config/systemd/user/lid-resume-monitor.service" ]]; then
            printf 'missing %s dependency caused installation writes\n' \
                "$dependency" >&2
            failures=$((failures + 1))
        fi
        assert_not_contains "$(<"$missing_log")" $'systemctl\t' \
            "missing $dependency must not change user services" \
            || failures=$((failures + 1))
    done

    old_home="$test_root/old-home"
    old_fake="$test_root/old-fake-bin"
    old_safe="$test_root/old-safe-bin"
    old_log="$test_root/old-effects.log"
    mkdir -p "$old_home"
    prepare_hyprland_config "$old_home"
    : > "$old_log"
    install_safe_path "$old_fake" "$old_safe"
    "$ENV_BIN" -i \
        HOME="$old_home" PATH="$old_fake:$old_safe" \
        WAYLAND_DISPLAY=wayland-test HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$old_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" TEST_BUSCTL_VERSION=256 \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/old-installer.out" 2>&1 || installer_status=$?
    if (( installer_status == 0 )); then
        printf 'installer accepted unsupported busctl/systemd 256\n' >&2
        failures=$((failures + 1))
    fi
    assert_contains "$(<"$test_root/old-installer.out")" \
        'systemd/busctl 257 or newer is required' \
        'unsupported busctl should receive an actionable preflight error' \
        || failures=$((failures + 1))
    if [[ -e "$old_home/.config/hypr/scripts/lid-monitor.sh" || \
        -e "$old_home/.config/systemd/user/lid-resume-monitor.service" ]]; then
        printf 'unsupported busctl version caused installation writes\n' >&2
        failures=$((failures + 1))
    fi
    assert_not_contains "$(<"$old_log")" $'systemctl\t' \
        'unsupported busctl version must not change user services' \
        || failures=$((failures + 1))

    : > "$old_log"
    installer_status=0
    "$ENV_BIN" -i \
        HOME="$old_home" PATH="$old_fake:$old_safe" \
        WAYLAND_DISPLAY=wayland-test HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$old_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" TEST_BUSCTL_VERSION=malformed \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/malformed-version.out" 2>&1 || installer_status=$?
    if (( installer_status == 0 )); then
        printf 'installer accepted malformed busctl/systemd version output\n' >&2
        failures=$((failures + 1))
    fi
    assert_contains "$(<"$test_root/malformed-version.out")" \
        'Could not parse systemd/busctl version' \
        'malformed busctl version output should receive an actionable preflight error' \
        || failures=$((failures + 1))
    if [[ -e "$old_home/.config/hypr/scripts/lid-monitor.sh" || \
        -e "$old_home/.config/systemd/user/lid-resume-monitor.service" ]]; then
        printf 'malformed busctl version caused installation writes\n' >&2
        failures=$((failures + 1))
    fi
    assert_not_contains "$(<"$old_log")" $'systemctl\t' \
        'malformed busctl version must not change user services' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

with_installed_post_layout_hook_fixture() (
    set -euo pipefail

    local test_body=$1
    local test_root home fake_bin safe_bin effect_log runtime_dir lid_root
    local monitor_fixture sequence_dir sequence_counter framework disabled asleep awake
    local installed_cli installed_daemon hook hook_name non_executable_hook

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT
    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    runtime_dir="$test_root/runtime"
    lid_root="$test_root/button/lid"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    sequence_dir="$test_root/topology-sequence"
    sequence_counter="$test_root/topology-counter"
    hook="$test_root/post hook;false;#"
    hook_name=${hook##*/}
    non_executable_hook="$test_root/non-executable-hook"
    framework=$(jq -c 'map(.dpmsStatus = true)' \
        "$ROOT_DIR/tests/fixtures/monitors-json/framework.json")
    disabled=$(jq -c 'map(if .name == "eDP-1" then
        .disabled = true | .dpmsStatus = false else . end)' <<< "$framework")
    asleep=$(jq -c 'map(if .name == "eDP-1" then
        .dpmsStatus = false else . end)' <<< "$framework")
    awake=$framework

    mkdir -m 0700 -p "$home" "$runtime_dir" "$sequence_dir"
    create_lid_state_fixture "$lid_root" lid1
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"
    cp "$ROOT_DIR/tests/fakes/effect" "$hook"
    chmod 0755 "$hook"
    cp "$ROOT_DIR/tests/fakes/effect" "$non_executable_hook"
    chmod 0644 "$non_executable_hook"

    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$framework" HYPR_LID_STATE_ROOT="$lid_root" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1
    installed_cli="$home/.config/hypr/scripts/lid-switch.sh"
    installed_daemon="$home/.config/hypr/scripts/lid-monitor.sh"

    "$test_body"
)

run_post_layout_hook_cli_scenario() {
    local scenario=$1
    local transition=$2
    shift 2

    scenario_status=0
    : > "$effect_log"
    "$TIMEOUT_BIN" 5 "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        HYPR_LID_STATE_ROOT="$lid_root" "$@" \
        "$installed_cli" "$transition" \
        > "$test_root/$scenario.out" 2>&1 || scenario_status=$?
    scenario_output=$(<"$test_root/$scenario.out")
    scenario_effects=$(<"$effect_log")
}

run_post_layout_hook_daemon_scenario() {
    local scenario=$1
    shift

    scenario_status=0
    : > "$effect_log"
    "$TIMEOUT_BIN" 5 "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        HYPR_LID_STATE_ROOT="$lid_root" "$@" \
        "$installed_daemon" --once \
        > "$test_root/$scenario.out" 2>&1 || scenario_status=$?
    scenario_output=$(<"$test_root/$scenario.out")
    scenario_effects=$(<"$effect_log")
}

post_layout_hook_runtime_contract() {
    local scenario_status scenario_output scenario_effects hook_record effects_prefix
    local hook_count query_before failures=0

    rm -rf "$runtime_dir/arch-lidswitch"
    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$framework" "$disabled"
    run_post_layout_hook_cli_scenario default-close close
    if (( scenario_status != 0 )); then
        printf 'default close failed with status %d\n%s\n' \
            "$scenario_status" "$scenario_output" >&2
        failures=$((failures + 1))
    fi
    assert_not_contains "$scenario_effects" $'pgrep\t' \
        'default close must not inspect Waybar or another process' \
        || failures=$((failures + 1))
    assert_not_contains "$scenario_effects" $'pkill\t' \
        'default close must not signal Waybar or another process' \
        || failures=$((failures + 1))

    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$disabled" "$framework"
    run_post_layout_hook_cli_scenario default-open open
    if (( scenario_status != 0 )); then
        printf 'default open failed with status %d\n%s\n' \
            "$scenario_status" "$scenario_output" >&2
        failures=$((failures + 1))
    fi
    assert_not_contains "$scenario_effects" $'pgrep\t' \
        'default open must not inspect Waybar or another process' \
        || failures=$((failures + 1))
    assert_not_contains "$scenario_effects" $'pkill\t' \
        'default open must not signal Waybar or another process' \
        || failures=$((failures + 1))

    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$framework" "$disabled"
    run_post_layout_hook_cli_scenario success-close close \
        "ARCH_LIDSWITCH_POST_LAYOUT_HOOK=$hook"
    hook_record="$hook_name"$'\tclose\tdisabled\teDP-1'
    hook_count=$(grep -Fxc "$hook_record" "$effect_log" || true)
    effects_prefix=${scenario_effects%%"$hook_record"*}
    query_before=$(grep -Fxc $'hyprctl\t-j\tmonitors\tall' \
        <<< "$effects_prefix" || true)
    if (( scenario_status != 0 || hook_count != 1 || query_before != 2 )); then
        printf 'verified close hook contract failed; status=%d hooks=%d pre-hook-queries=%d\n%s\n%s\n' \
            "$scenario_status" "$hook_count" "$query_before" \
            "$scenario_output" "$scenario_effects" >&2
        failures=$((failures + 1))
    fi

    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$disabled" "$disabled"
    run_post_layout_hook_cli_scenario noop-close close \
        "ARCH_LIDSWITCH_POST_LAYOUT_HOOK=$hook"
    if (( scenario_status != 0 )); then
        printf 'layout no-op failed with status %d\n%s\n' \
            "$scenario_status" "$scenario_output" >&2
        failures=$((failures + 1))
    fi
    assert_not_contains "$scenario_effects" "$hook_name"$'\t' \
        'a layout no-op must not run the post-layout hook' \
        || failures=$((failures + 1))

    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$disabled" "$framework"
    run_post_layout_hook_cli_scenario success-open open \
        "ARCH_LIDSWITCH_POST_LAYOUT_HOOK=$hook"
    hook_record="$hook_name"$'\topen\tenabled\teDP-1'
    hook_count=$(grep -Fxc "$hook_record" "$effect_log" || true)
    effects_prefix=${scenario_effects%%"$hook_record"*}
    query_before=$(grep -Fxc $'hyprctl\t-j\tmonitors\tall' \
        <<< "$effects_prefix" || true)
    if (( scenario_status != 0 || hook_count != 1 || query_before != 2 )); then
        printf 'verified open hook contract failed; status=%d hooks=%d pre-hook-queries=%d\n%s\n%s\n' \
            "$scenario_status" "$hook_count" "$query_before" \
            "$scenario_output" "$scenario_effects" >&2
        failures=$((failures + 1))
    fi

    rm -rf "$runtime_dir/arch-lidswitch"
    write_monitor_sequence "$sequence_dir" "$sequence_counter" "$asleep" "$awake"
    run_post_layout_hook_cli_scenario dpms-only open \
        "ARCH_LIDSWITCH_POST_LAYOUT_HOOK=$hook"
    if (( scenario_status != 0 )); then
        printf 'DPMS-only transition failed with status %d\n%s\n' \
            "$scenario_status" "$scenario_output" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$scenario_effects" $'dpms\toutput=eDP-1\tstate=on' \
        'DPMS-only open should still wake the internal output' \
        || failures=$((failures + 1))
    assert_not_contains "$scenario_effects" "$hook_name"$'\t' \
        'a DPMS-only transition must not run the post-layout hook' \
        || failures=$((failures + 1))

    rm -rf "$runtime_dir/arch-lidswitch"
    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$framework" "$framework"
    run_post_layout_hook_cli_scenario apply-failure close \
        "ARCH_LIDSWITCH_POST_LAYOUT_HOOK=$hook" \
        TEST_HYPRCTL_EVAL_FAILURES=1 \
        "TEST_HYPRCTL_EVAL_COUNTER=$test_root/eval-counter"
    if (( scenario_status != 3 )); then
        printf 'display apply failure should return 3, got %d\n%s\n' \
            "$scenario_status" "$scenario_output" >&2
        failures=$((failures + 1))
    fi
    assert_not_contains "$scenario_effects" "$hook_name"$'\t' \
        'a display apply failure must not run the post-layout hook' \
        || failures=$((failures + 1))

    rm -rf "$runtime_dir/arch-lidswitch"
    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$framework" "$framework"
    run_post_layout_hook_cli_scenario postcondition-failure close \
        "ARCH_LIDSWITCH_POST_LAYOUT_HOOK=$hook"
    if (( scenario_status != 4 )); then
        printf 'display postcondition failure should return 4, got %d\n%s\n' \
            "$scenario_status" "$scenario_output" >&2
        failures=$((failures + 1))
    fi
    assert_not_contains "$scenario_effects" "$hook_name"$'\t' \
        'a display postcondition failure must not run the post-layout hook' \
        || failures=$((failures + 1))

    (( failures == 0 ))
}

installed_post_layout_hook_obeys_verified_mutation_contract() {
    with_installed_post_layout_hook_fixture post_layout_hook_runtime_contract
}

post_layout_hook_advisory_contract() {
    local scenario_status scenario_output scenario_effects hook_record
    local hook_count monitor_count attempt_count failures=0

    rm -rf "$runtime_dir/arch-lidswitch"
    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$framework" "$disabled"
    run_post_layout_hook_cli_scenario relative-hook close \
        'ARCH_LIDSWITCH_POST_LAYOUT_HOOK=relative-hook'
    if (( scenario_status != 0 )); then
        printf 'relative advisory hook changed transition status to %d\n%s\n' \
            "$scenario_status" "$scenario_output" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$scenario_output" \
        'event=post_layout_hook_invalid reason=not_absolute' \
        'a relative hook should be rejected explicitly' \
        || failures=$((failures + 1))

    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$disabled" "$framework"
    run_post_layout_hook_cli_scenario missing-hook open \
        "ARCH_LIDSWITCH_POST_LAYOUT_HOOK=$test_root/missing-hook"
    if (( scenario_status != 0 )); then
        printf 'missing advisory hook changed transition status to %d\n%s\n' \
            "$scenario_status" "$scenario_output" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$scenario_output" \
        'event=post_layout_hook_invalid reason=not_regular' \
        'a missing hook should be rejected as non-regular' \
        || failures=$((failures + 1))

    rm -rf "$runtime_dir/arch-lidswitch"
    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$framework" "$disabled"
    run_post_layout_hook_cli_scenario non-executable-hook close \
        "ARCH_LIDSWITCH_POST_LAYOUT_HOOK=$non_executable_hook"
    if (( scenario_status != 0 )); then
        printf 'non-executable advisory hook changed transition status to %d\n%s\n' \
            "$scenario_status" "$scenario_output" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$scenario_output" \
        'event=post_layout_hook_invalid reason=not_executable' \
        'a non-executable hook should be rejected explicitly' \
        || failures=$((failures + 1))

    rm -rf "$runtime_dir/arch-lidswitch"
    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$framework" "$framework" "$disabled" "$disabled"
    run_post_layout_hook_daemon_scenario failed-hook \
        "ARCH_LIDSWITCH_POST_LAYOUT_HOOK=$hook" \
        TEST_POST_LAYOUT_HOOK_MODE=fail
    hook_record="$hook_name"$'\tclose\tdisabled\teDP-1'
    hook_count=$(grep -Fxc "$hook_record" "$effect_log" || true)
    monitor_count=$(grep -Fxc $'monitor\toutput=eDP-1\tdisabled=true' \
        "$effect_log" || true)
    attempt_count=$(grep -Fc 'event=reconciliation_started trigger=once' \
        "$test_root/failed-hook.out" || true)
    if (( scenario_status != 0 || hook_count != 1 || monitor_count != 1 || \
        attempt_count != 1 )); then
        printf 'failed advisory hook retried or failed reconciliation; status=%d hooks=%d monitors=%d attempts=%d\n%s\n%s\n' \
            "$scenario_status" "$hook_count" "$monitor_count" "$attempt_count" \
            "$scenario_output" "$scenario_effects" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$scenario_output" \
        'event=post_layout_hook_failed action=close outcome=disabled internal_output=eDP-1 status=42' \
        'hook failure should be logged without failing display reconciliation' \
        || failures=$((failures + 1))

    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$disabled" "$framework"
    run_post_layout_hook_cli_scenario timed-out-hook open \
        "ARCH_LIDSWITCH_POST_LAYOUT_HOOK=$hook" \
        TEST_POST_LAYOUT_HOOK_MODE=hang \
        "TEST_POST_LAYOUT_HOOK_SLEEP_BIN=$REAL_SLEEP_BIN"
    hook_record="$hook_name"$'\topen\tenabled\teDP-1'
    hook_count=$(grep -Fxc "$hook_record" "$effect_log" || true)
    if (( scenario_status != 0 || hook_count != 1 )); then
        printf 'timed-out advisory hook changed transition result; status=%d hooks=%d\n%s\n%s\n' \
            "$scenario_status" "$hook_count" "$scenario_output" \
            "$scenario_effects" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$scenario_output" \
        'event=post_layout_hook_failed action=open outcome=enabled internal_output=eDP-1 status=124' \
        'hook timeout should be bounded and logged as advisory' \
        || failures=$((failures + 1))

    (( failures == 0 ))
}

installed_post_layout_hook_failures_are_advisory() {
    with_installed_post_layout_hook_fixture post_layout_hook_advisory_contract
}

installer_preserves_post_layout_hook_configuration_and_docs() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture environment_file
    local environment_copy installed_unit unit_contents readme_contents before_mode failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT
    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    environment_file="$home/.config/arch-lidswitch/environment"
    environment_copy="$test_root/environment.before"

    prepare_hyprland_config "$home"
    mkdir -p "${environment_file%/*}"
    printf '%s\n' \
        'ARCH_LIDSWITCH_POST_LAYOUT_HOOK=/user/owned/hook' \
        'USER_OWNED_SENTINEL=preserve-byte-for-byte' > "$environment_file"
    chmod 0640 "$environment_file"
    cp -p "$environment_file" "$environment_copy"
    before_mode=$(stat -c %a "$environment_file")
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1
    installed_unit="$home/.config/systemd/user/lid-monitor.service"
    unit_contents=$(<"$installed_unit")
    assert_contains "$unit_contents" \
        'EnvironmentFile=-%h/.config/arch-lidswitch/environment' \
        'the service should import the optional user-owned hook environment' \
        || failures=$((failures + 1))
    if ! cmp -s "$environment_copy" "$environment_file" || \
        [[ "$(stat -c %a "$environment_file")" != "$before_mode" ]]; then
        printf 'installer changed the user-owned hook environment contents or mode\n' >&2
        failures=$((failures + 1))
    fi

    readme_contents=$(<"$ROOT_DIR/README.md")
    assert_contains "$readme_contents" 'ARCH_LIDSWITCH_POST_LAYOUT_HOOK' \
        'README should document the optional post-layout hook' \
        || failures=$((failures + 1))
    assert_contains "$readme_contents" \
        '~/.config/arch-lidswitch/environment' \
        'README should document the service environment file' \
        || failures=$((failures + 1))
    for stale_waybar_claim in SIGUSR1 SIGUSR2 'pkill -x' 'Waybar Layout Refresh'; do
        assert_not_contains "$readme_contents" "$stale_waybar_claim" \
            "README must remove the stale Waybar signal claim: $stale_waybar_claim" \
            || failures=$((failures + 1))
    done

    (( failures == 0 ))
)

readme_defines_workspace_assignment_scope() (
    set -euo pipefail

    local readme_contents failures=0

    readme_contents=$(<"$ROOT_DIR/README.md")
    assert_contains "$readme_contents" \
        'does not capture or restore workspace-to-monitor assignments' \
        'README should bound layout preservation to monitor geometry' \
        || failures=$((failures + 1))
    assert_contains "$readme_contents" 'Hyprland workspace rules' \
        'README should point deterministic workspace placement to Hyprland' \
        || failures=$((failures + 1))
    assert_not_contains "$readme_contents" 'All workspaces remain accessible' \
        'README must not promise workspace behavior it does not implement' \
        || failures=$((failures + 1))
    assert_not_contains "$readme_contents" 'Maintains your workspace layout' \
        'README must not promise workspace restoration it does not implement' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installer_commits_a_complete_private_transaction() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture state_root
    local manifest backup_dir manifest_count backup_count line hash mode relative
    local destination actual_hash failures=0
    local -a relative_paths destinations

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT
    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    state_root="$home/.local/state/arch-lidswitch"
    mkdir -p "$home"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1

    manifest="$state_root/current.manifest"
    relative_paths=(
        scripts/lid-state.sh scripts/monitor-state.sh scripts/lid-switch.sh
        scripts/lid-switch-doctor.sh scripts/lid-monitor.sh
        scripts/lid-resume-monitor.sh scripts/lid-session-bridge.sh
        arch_lidswitch/session.lua systemd/user/hyprland-session.target
        systemd/user/lid-monitor.service systemd/user/lid-resume-monitor.service
    )
    destinations=(
        "$home/.config/hypr/scripts/lid-state.sh"
        "$home/.config/hypr/scripts/monitor-state.sh"
        "$home/.config/hypr/scripts/lid-switch.sh"
        "$home/.config/hypr/scripts/lid-switch-doctor.sh"
        "$home/.config/hypr/scripts/lid-monitor.sh"
        "$home/.config/hypr/scripts/lid-resume-monitor.sh"
        "$home/.config/hypr/scripts/lid-session-bridge.sh"
        "$home/.config/hypr/arch_lidswitch/session.lua"
        "$home/.config/systemd/user/hyprland-session.target"
        "$home/.config/systemd/user/lid-monitor.service"
        "$home/.config/systemd/user/lid-resume-monitor.service"
    )
    if [[ ! -f "$manifest" ]]; then
        printf 'installer did not commit a current artifact manifest\n' >&2
        return 1
    fi
    manifest_count=$(wc -l < "$manifest")
    if (( manifest_count != 11 )); then
        printf 'expected 11 managed artifacts, manifest has %d:\n%s\n' \
            "$manifest_count" "$(<"$manifest")" >&2
        failures=$((failures + 1))
    fi
    while IFS=$'\t' read -r hash mode relative; do
        destination=""
        for (( manifest_count=0; manifest_count<${#relative_paths[@]}; manifest_count++ )); do
            if [[ "$relative" == "${relative_paths[$manifest_count]}" ]]; then
                destination=${destinations[$manifest_count]}
                break
            fi
        done
        if [[ -z "$destination" || ! -f "$destination" ]]; then
            printf 'manifest contains an unknown artifact: %s\n' "$relative" >&2
            failures=$((failures + 1))
            continue
        fi
        actual_hash=$(sha256sum "$destination")
        actual_hash=${actual_hash%% *}
        if [[ "$hash" != "$actual_hash" || \
            "$mode" != "0$(stat -c %a "$destination")" ]]; then
            printf 'manifest does not match installed artifact: %s\n' "$relative" >&2
            failures=$((failures + 1))
        fi
    done < "$manifest"
    if [[ "$(stat -c %a "$state_root")" != 700 || \
        "$(stat -c %a "$manifest")" != 600 ]]; then
        printf 'transaction state or manifest is not private\n' >&2
        failures=$((failures + 1))
    fi
    backup_dir=$(find "$state_root/backups" -mindepth 1 -maxdepth 1 \
        -type d -print -quit)
    if [[ -z "$backup_dir" || ! -f "$backup_dir/snapshot.tsv" || \
        ! -f "$backup_dir/hyprland.lua" || \
        ! -f "$backup_dir/service-state" ]]; then
        printf 'installer did not retain one complete pre-install snapshot\n' >&2
        failures=$((failures + 1))
    fi

    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/reinstaller.out" 2>&1
    backup_count=$(find "$state_root/backups" -mindepth 1 -maxdepth 1 \
        -type d | wc -l)
    backup_dir=$(find "$state_root/backups" -mindepth 1 -maxdepth 1 \
        -type d -print -quit)
    if (( backup_count != 1 )); then
        printf 'expected exactly one retained rollback set, got %d\n' \
            "$backup_count" >&2
        failures=$((failures + 1))
    fi
    for relative in "${relative_paths[@]}"; do
        if [[ ! -f "$backup_dir/files/$relative" ]]; then
            printf 'rollback set omitted prior artifact: %s\n' "$relative" >&2
            failures=$((failures + 1))
        fi
    done

    (( failures == 0 ))
)

installer_fault_checkpoint_restores_profile() (
    set -euo pipefail

    local profile=$1
    local checkpoint=$2
    local test_root home fake_bin safe_bin effect_log monitor_fixture state_root
    local config original_config installer_status=0 failures=0 index path
    local state_dir transaction_entry backup_entry
    local -a paths expected_contents expected_modes

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT
    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    state_root="$home/.local/state/arch-lidswitch"
    state_dir="$effect_log.systemctl-state"
    config="$home/.config/hypr/hyprland.lua"
    original_config='-- user config before transactional failure'
    paths=(
        "$home/.config/hypr/scripts/lid-state.sh"
        "$home/.config/hypr/scripts/monitor-state.sh"
        "$home/.config/hypr/scripts/lid-switch.sh"
        "$home/.config/hypr/scripts/lid-switch-doctor.sh"
        "$home/.config/hypr/scripts/lid-monitor.sh"
        "$home/.config/hypr/scripts/lid-resume-monitor.sh"
        "$home/.config/hypr/scripts/lid-session-bridge.sh"
        "$home/.config/hypr/arch_lidswitch/session.lua"
        "$home/.config/systemd/user/hyprland-session.target"
        "$home/.config/systemd/user/lid-monitor.service"
        "$home/.config/systemd/user/lid-resume-monitor.service"
    )
    expected_modes=(711 712 713 714 715 716 717 640 641 642 643)
    expected_contents=(
        old-lid-state old-monitor-state old-lid-switch old-doctor
        old-lid-monitor old-resume-monitor old-session-bridge
        old-session-module old-session-target
        $'old-main-service\n[Install]\nWantedBy=default.target'
        old-resume-service
    )

    mkdir -p "$(dirname "$config")"
    printf '%s\n' "$original_config" > "$config"
    chmod 0640 "$config"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    if [[ "$profile" == existing ]]; then
        for (( index=0; index<${#paths[@]}; index++ )); do
            path=${paths[$index]}
            mkdir -p "$(dirname "$path")"
            printf '%s\n' "${expected_contents[$index]}" > "$path"
            chmod "${expected_modes[$index]}" "$path"
        done
        mkdir -p "$state_root"
        printf '%s\n' old-current-manifest > "$state_root/current.manifest"
        chmod 0640 "$state_root/current.manifest"
    fi

    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        ARCH_LIDSWITCH_TEST_FAIL_AFTER="$checkpoint" \
        TEST_SYSTEMCTL_MAIN_ENABLED="$([[ "$profile" == existing ]] && printf 1 || printf 0)" \
        TEST_SYSTEMCTL_MAIN_ACTIVE="$([[ "$profile" == existing ]] && printf 1 || printf 0)" \
        TEST_SYSTEMCTL_RESUME_ACTIVE="$([[ "$profile" == existing ]] && printf 1 || printf 0)" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1 || installer_status=$?

    if (( installer_status == 0 )); then
        printf '%s checkpoint unexpectedly succeeded: %s\n%s\n' \
            "$profile" "$checkpoint" "$(<"$test_root/installer.out")" >&2
        return 1
    fi
    if [[ "$(<"$config")" != "$original_config" || \
        "$(stat -c %a "$config")" != 640 ]]; then
        printf '%s checkpoint changed user config: %s\n' \
            "$checkpoint" "$(<"$config")" >&2
        failures=$((failures + 1))
    fi

    for (( index=0; index<${#paths[@]}; index++ )); do
        path=${paths[$index]}
        if [[ "$profile" == existing ]]; then
            if [[ ! -f "$path" || -L "$path" || \
                "$(<"$path")" != "${expected_contents[$index]}" || \
                "$(stat -c %a "$path")" != "${expected_modes[$index]}" ]]; then
                printf '%s checkpoint did not restore %s\n' "$checkpoint" "$path" >&2
                failures=$((failures + 1))
            fi
        elif [[ -e "$path" || -L "$path" ]]; then
            printf '%s checkpoint left fresh artifact %s\n' "$checkpoint" "$path" >&2
            failures=$((failures + 1))
        fi
    done

    if [[ "$profile" == existing ]]; then
        if [[ ! -f "$state_root/current.manifest" || \
            "$(<"$state_root/current.manifest")" != old-current-manifest || \
            "$(stat -c %a "$state_root/current.manifest")" != 640 ]]; then
            printf '%s checkpoint did not restore the prior manifest\n' "$checkpoint" >&2
            failures=$((failures + 1))
        fi
        for path in \
            "$state_dir/lid-monitor.service.enabled" \
            "$state_dir/lid-monitor.service.active" \
            "$state_dir/lid-resume-monitor.service.active"; do
            if [[ ! -e "$path" ]]; then
                printf '%s checkpoint did not restore service state: %s\n' \
                    "$checkpoint" "$path" >&2
                failures=$((failures + 1))
            fi
        done
    else
        if [[ -e "$state_root/current.manifest" || \
            -e "$state_dir/lid-monitor.service.enabled" || \
            -e "$state_dir/lid-monitor.service.active" || \
            -e "$state_dir/lid-resume-monitor.service.active" ]]; then
            printf '%s checkpoint changed fresh manifest/service state\n' \
                "$checkpoint" >&2
            failures=$((failures + 1))
        fi
    fi

    transaction_entry=$(find "$state_root/transactions" -mindepth 1 \
        -maxdepth 1 -print -quit 2>/dev/null || true)
    backup_entry=$(find "$state_root/backups" -mindepth 1 \
        -maxdepth 1 -print -quit 2>/dev/null || true)
    if [[ -n "$transaction_entry" || -n "$backup_entry" ]]; then
        printf '%s checkpoint retained a completed rollback/backup unexpectedly\n' \
            "$checkpoint" >&2
        failures=$((failures + 1))
    fi

    (( failures == 0 ))
)

installer_rolls_back_every_fault_checkpoint() {
    local checkpoint failures=0
    local -a checkpoints=(
        prepared services-quiesced legacy-stopped
        installed-lid-state installed-monitor-state installed-lid-switch
        installed-lid-switch-doctor installed-lid-monitor
        installed-lid-resume-monitor installed-lid-session-bridge
        installed-session-module installed-session-target
        installed-main-service installed-resume-service manifest-installed
        config-integrated daemon-reloaded main-enabled session-imported
        main-started resume-started health-checked
    )

    for checkpoint in "${checkpoints[@]}"; do
        installer_fault_checkpoint_restores_profile existing "$checkpoint" \
            || failures=$((failures + 1))
        if [[ "$checkpoint" != legacy-stopped ]]; then
            installer_fault_checkpoint_restores_profile fresh "$checkpoint" \
                || failures=$((failures + 1))
        fi
    done

    (( failures == 0 ))
}

installer_preserves_a_concurrent_user_config_edit() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture config marker
    local installer_status=0 expected failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT
    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    config="$home/.config/hypr/hyprland.lua"
    marker="$test_root/config-mutated"
    mkdir -p "$(dirname "$config")"
    printf '%s\n' '-- original user config' > "$config"
    chmod 0640 "$config"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"
    ln -s "$ROOT_DIR/tests/fakes/effect" "$fake_bin/luac"

    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_LUAC_MUTATE_CONFIG="$config" TEST_LUAC_MUTATE_MARKER="$marker" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1 || installer_status=$?

    expected=$'-- original user config\n-- concurrent user edit during installation'
    if (( installer_status == 0 )); then
        printf 'installer committed over a concurrent user config edit\n' >&2
        failures=$((failures + 1))
    fi
    if [[ "$(<"$config")" != "$expected" || \
        "$(stat -c %a "$config")" != 640 ]]; then
        printf 'installer did not preserve concurrent config bytes/mode:\n%s\n' \
            "$(<"$config")" >&2
        failures=$((failures + 1))
    fi
    if [[ -e "$home/.config/hypr/scripts/lid-switch.sh" || \
        -e "$home/.local/state/arch-lidswitch/current.manifest" ]]; then
        printf 'config CAS rejection left a partial installation\n' >&2
        failures=$((failures + 1))
    fi
    assert_contains "$(<"$test_root/installer.out")" \
        'Hyprland config changed during installation' \
        'CAS rejection should explain the concurrent user edit' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installer_rejects_an_independently_enabled_resume_listener() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture resume_unit
    local original installer_status=0 failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT
    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    resume_unit="$home/.config/systemd/user/lid-resume-monitor.service"
    original='old independently enabled resume unit'
    prepare_hyprland_config "$home"
    mkdir -p "$(dirname "$resume_unit")"
    printf '%s\n' "$original" > "$resume_unit"
    chmod 0640 "$resume_unit"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_SYSTEMCTL_RESUME_ENABLED=1 \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1 || installer_status=$?

    if (( installer_status == 0 )); then
        printf 'installer accepted an independently enabled static listener\n' >&2
        failures=$((failures + 1))
    fi
    if [[ "$(<"$resume_unit")" != "$original" || \
        "$(stat -c %a "$resume_unit")" != 640 ]]; then
        printf 'enablement rejection changed the prior resume unit\n' >&2
        failures=$((failures + 1))
    fi
    assert_contains "$(<"$test_root/installer.out")" \
        'Static resume listener is unexpectedly enabled' \
        'resume enablement conflict should be explicit' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installer_restores_a_pre_resume_main_only_install() {
    local checkpoint failures=0

    for checkpoint in services-quiesced health-checked; do
        (
            set -euo pipefail

            local test_root home fake_bin safe_bin effect_log monitor_fixture
            local main_unit original installer_status=0 effects

            test_root=$(mktemp -d)
            trap 'rm -rf "$test_root"' EXIT
            home="$test_root/home"
            fake_bin="$test_root/fake-bin"
            safe_bin="$test_root/safe-bin"
            effect_log="$test_root/effects.log"
            monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
            main_unit="$home/.config/systemd/user/lid-monitor.service"
            original=$'[Install]\nWantedBy=default.target\n# pre-resume-listener unit'
            prepare_hyprland_config "$home"
            mkdir -p "$(dirname "$main_unit")"
            printf '%s\n' "$original" > "$main_unit"
            chmod 0640 "$main_unit"
            : > "$effect_log"
            install_safe_path "$fake_bin" "$safe_bin"

            "$ENV_BIN" -i \
                HOME="$home" PATH="$fake_bin:$safe_bin" \
                WAYLAND_DISPLAY=wayland-test \
                HYPRLAND_INSTANCE_SIGNATURE=test-instance \
                XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
                TEST_MONITORS_FIXTURE="$monitor_fixture" \
                TEST_SYSTEMCTL_MAIN_ENABLED=1 TEST_SYSTEMCTL_MAIN_ACTIVE=1 \
                ARCH_LIDSWITCH_TEST_FAIL_AFTER="$checkpoint" \
                "$ROOT_DIR/install-hyprland-lid-switch.sh" \
                > "$test_root/installer.out" 2>&1 || installer_status=$?

            if (( installer_status == 0 )); then
                printf 'main-only checkpoint unexpectedly succeeded: %s\n' \
                    "$checkpoint" >&2
                exit 1
            fi
            if [[ "$(<"$main_unit")" != "$original" || \
                "$(stat -c %a "$main_unit")" != 640 || \
                ! -e "$effect_log.systemctl-state/lid-monitor.service.enabled" || \
                ! -e "$effect_log.systemctl-state/lid-monitor.service.active" ]]; then
                printf 'main-only checkpoint did not restore prior main state: %s\n' \
                    "$checkpoint" >&2
                exit 1
            fi
            if [[ -e "$home/.config/systemd/user/lid-resume-monitor.service" || \
                -e "$effect_log.systemctl-state/lid-resume-monitor.service.active" ]]; then
                printf 'main-only checkpoint invented a prior resume listener: %s\n' \
                    "$checkpoint" >&2
                exit 1
            fi
            effects=$(<"$effect_log")
            assert_not_contains "$effects" \
                $'systemctl\t--user\tdisable\tlid-resume-monitor.service' \
                'rollback must not disable a previously absent static listener'
        ) || failures=$((failures + 1))
    done

    (( failures == 0 ))
}

installer_retains_recovery_after_rollback_publish_failure() {
    local operation failures=0

    for operation in cp chmod mv; do
        (
            set -euo pipefail

            local test_root home fake_bin safe_bin effect_log monitor_fixture
            local managed_file marker installer_status=0 recovery_snapshot temp_file
            local main_unit resume_unit effects

            test_root=$(mktemp -d)
            trap 'rm -rf "$test_root"' EXIT
            home="$test_root/home"
            fake_bin="$test_root/fake-bin"
            safe_bin="$test_root/safe-bin"
            effect_log="$test_root/effects.log"
            monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
            managed_file="$home/.config/hypr/scripts/lid-state.sh"
            main_unit="$home/.config/systemd/user/lid-monitor.service"
            resume_unit="$home/.config/systemd/user/lid-resume-monitor.service"
            marker="$test_root/rollback-copy-started"
            prepare_hyprland_config "$home"
            mkdir -p "$(dirname "$managed_file")"
            printf '%s\n' old-lid-state > "$managed_file"
            chmod 0711 "$managed_file"
            mkdir -p "$(dirname "$main_unit")"
            printf '%s\n' '[Install]' 'WantedBy=graphical-session.target' \
                > "$main_unit"
            printf '%s\n' '[Service]' 'Type=exec' > "$resume_unit"
            : > "$effect_log"
            install_safe_path "$fake_bin" "$safe_bin"
            ln -s "$ROOT_DIR/tests/fakes/effect" "$fake_bin/cp"
            ln -s "$ROOT_DIR/tests/fakes/effect" "$fake_bin/chmod"
            ln -s "$ROOT_DIR/tests/fakes/effect" "$fake_bin/mv"

            "$ENV_BIN" -i \
                HOME="$home" PATH="$fake_bin:$safe_bin" \
                WAYLAND_DISPLAY=wayland-test \
                HYPRLAND_INSTANCE_SIGNATURE=test-instance \
                XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
                TEST_MONITORS_FIXTURE="$monitor_fixture" \
                ARCH_LIDSWITCH_TEST_FAIL_AFTER=installed-lid-state \
                TEST_ROLLBACK_FILE_FAILURE="$operation" \
                TEST_ROLLBACK_FILE_MARKER="$marker" \
                TEST_MV_REMOVE_SOURCE_BEFORE_CONTEXT=rollback-lid-state \
                TEST_SYSTEMCTL_MAIN_ENABLED=1 TEST_SYSTEMCTL_MAIN_ACTIVE=1 \
                TEST_SYSTEMCTL_RESUME_ACTIVE=1 \
                TEST_REAL_CP_BIN="$(command -v cp)" \
                TEST_REAL_CHMOD_BIN="$(command -v chmod)" \
                TEST_REAL_MV_BIN="$(command -v mv)" \
                "$ROOT_DIR/install-hyprland-lid-switch.sh" \
                > "$test_root/installer.out" 2>&1 || installer_status=$?

            if (( installer_status == 0 )); then
                printf 'rollback %s failure unexpectedly succeeded\n' "$operation" >&2
                exit 1
            fi
            if [[ ! -f "$managed_file" || -L "$managed_file" || \
                "$(<"$managed_file")" != "$(<"$ROOT_DIR/runtime/lid-state.sh")" || \
                "$(stat -c %a "$managed_file")" != 755 ]]; then
                printf 'rollback %s failure changed the complete candidate content/mode\n' \
                    "$operation" >&2
                exit 1
            fi
            recovery_snapshot=$(find \
                "$home/.local/state/arch-lidswitch/transactions" \
                -path '*/before/files/scripts/lid-state.sh' -type f \
                -print -quit 2>/dev/null || true)
            if [[ -z "$recovery_snapshot" || \
                "$(<"$recovery_snapshot")" != old-lid-state || \
                "$(stat -c %a "$recovery_snapshot")" != 711 ]]; then
                printf 'rollback %s failure did not retain the exact snapshot\n' \
                    "$operation" >&2
                exit 1
            fi
            assert_contains "$(<"$test_root/installer.out")" \
                'Rollback incomplete; recovery snapshot retained at' \
                "rollback $operation failure should report retained recovery" \
                || exit 1
            effects=$(<"$effect_log")
            assert_contains "$(<"$test_root/installer.out")" \
                'Services remain stopped because installation content could not be restored coherently' \
                "rollback $operation failure should keep services stopped" \
                || exit 1
            if [[ -e "$effect_log.systemctl-state/lid-monitor.service.active" || \
                -e "$effect_log.systemctl-state/lid-resume-monitor.service.active" ]]; then
                printf 'rollback %s failure restarted a service against mixed files\n' \
                    "$operation" >&2
                exit 1
            fi
            assert_not_contains "$effects" \
                $'systemctl\t--user\tstart\tlid-monitor.service' \
                "rollback $operation failure must not restart the main service" \
                || exit 1
            temp_file=$(find "$(dirname "$managed_file")" -maxdepth 1 \
                -name '.arch-lidswitch.*' -print -quit)
            if [[ -n "$temp_file" && \
                ( ! -f "$temp_file" || -L "$temp_file" || \
                "$(<"$temp_file")" != old-lid-state || \
                "$(stat -c %a "$temp_file")" != 711 ) ]]; then
                printf 'rollback %s failure retained an invalid recovery sibling: %s\n' \
                    "$operation" "$temp_file" >&2
                exit 1
            fi
        ) || failures=$((failures + 1))
    done

    (( failures == 0 ))
}

installer_handles_signals_after_transaction_mutations() {
    local signal_point failures=0
    local -a rollback_points=(
        artifact-lid-state manifest config
    )

    for signal_point in "${rollback_points[@]}" backup-promotion; do
        (
            set -euo pipefail

            local test_root home fake_bin safe_bin effect_log monitor_fixture
            local config installer_status=0 transaction_entry backup_entry
            local original='-- config before deterministic signal'

            test_root=$(mktemp -d)
            trap 'rm -rf "$test_root"' EXIT
            home="$test_root/home"
            fake_bin="$test_root/fake-bin"
            safe_bin="$test_root/safe-bin"
            effect_log="$test_root/effects.log"
            monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
            config="$home/.config/hypr/hyprland.lua"
            mkdir -p "$(dirname "$config")"
            printf '%s\n' "$original" > "$config"
            chmod 0640 "$config"
            : > "$effect_log"
            install_safe_path "$fake_bin" "$safe_bin"

            "$ENV_BIN" -i \
                HOME="$home" PATH="$fake_bin:$safe_bin" \
                WAYLAND_DISPLAY=wayland-test \
                HYPRLAND_INSTANCE_SIGNATURE=test-instance \
                XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
                TEST_MONITORS_FIXTURE="$monitor_fixture" \
                ARCH_LIDSWITCH_TEST_SIGNAL_AFTER_PUBLISH="$signal_point" \
                "$ROOT_DIR/install-hyprland-lid-switch.sh" \
                > "$test_root/installer.out" 2>&1 || installer_status=$?

            if (( installer_status != 143 )); then
                printf 'expected TERM status 143 after %s, got %d\n%s\n' \
                    "$signal_point" "$installer_status" \
                    "$(<"$test_root/installer.out")" >&2
                exit 1
            fi
            transaction_entry=$(find \
                "$home/.local/state/arch-lidswitch/transactions" \
                -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null || true)
            backup_entry=$(find "$home/.local/state/arch-lidswitch/backups" \
                -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null || true)
            if [[ "$signal_point" == backup-promotion ]]; then
                if [[ ! -f "$home/.local/state/arch-lidswitch/current.manifest" || \
                    -z "$backup_entry" || -n "$transaction_entry" || \
                    "$(grep -Fxc -- '-- BEGIN arch-lidswitch managed session integration' "$config")" != 1 ]]; then
                    printf 'backup-promotion signal did not leave one committed installation\n' >&2
                    exit 1
                fi
            else
                if [[ "$(<"$config")" != "$original" || \
                    "$(stat -c %a "$config")" != 640 || \
                    -e "$home/.config/hypr/scripts/lid-state.sh" || \
                    -e "$home/.local/state/arch-lidswitch/current.manifest" || \
                    -n "$backup_entry" || -n "$transaction_entry" ]]; then
                    printf 'signal after %s did not restore exact fresh state\n' \
                        "$signal_point" >&2
                    exit 1
                fi
            fi
        ) || failures=$((failures + 1))
    done

    (( failures == 0 ))
}

installer_rejects_snapshot_copy_races() {
    local raced_kind failures=0

    for raced_kind in managed manifest; do
        (
            set -euo pipefail

            local test_root home fake_bin safe_bin effect_log monitor_fixture
            local config raced_file marker initial expected installer_status=0

            test_root=$(mktemp -d)
            trap 'rm -rf "$test_root"' EXIT
            home="$test_root/home"
            fake_bin="$test_root/fake-bin"
            safe_bin="$test_root/safe-bin"
            effect_log="$test_root/effects.log"
            monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
            config="$home/.config/hypr/hyprland.lua"
            marker="$test_root/copy-race-fired"
            prepare_hyprland_config "$home"
            : > "$effect_log"
            install_safe_path "$fake_bin" "$safe_bin"
            ln -s "$ROOT_DIR/tests/fakes/effect" "$fake_bin/cp"

            case "$raced_kind" in
                managed)
                    raced_file="$home/.config/hypr/scripts/lid-state.sh"
                    initial='old managed file'
                    ;;
                manifest)
                    raced_file="$home/.local/state/arch-lidswitch/current.manifest"
                    initial='old current manifest'
                    ;;
            esac
            mkdir -p "$(dirname "$raced_file")"
            printf '%s\n' "$initial" > "$raced_file"
            chmod 0640 "$raced_file"
            expected="$initial"$'\n-- concurrent edit after snapshot copy'

            "$ENV_BIN" -i \
                HOME="$home" PATH="$fake_bin:$safe_bin" \
                WAYLAND_DISPLAY=wayland-test \
                HYPRLAND_INSTANCE_SIGNATURE=test-instance \
                XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
                TEST_MONITORS_FIXTURE="$monitor_fixture" \
                TEST_CP_MUTATE_SOURCE_AFTER_COPY="$raced_file" \
                TEST_CP_MUTATE_MARKER="$marker" \
                TEST_REAL_CP_BIN="$(command -v cp)" \
                "$ROOT_DIR/install-hyprland-lid-switch.sh" \
                > "$test_root/installer.out" 2>&1 || installer_status=$?

            if (( installer_status == 0 )); then
                printf '%s snapshot copy race unexpectedly committed\n' \
                    "$raced_kind" >&2
                exit 1
            fi
            if [[ "$(<"$raced_file")" != "$expected" || \
                "$(stat -c %a "$raced_file")" != 640 ]]; then
                printf '%s snapshot race did not preserve concurrent bytes/mode\n' \
                    "$raced_kind" >&2
                exit 1
            fi
        ) || failures=$((failures + 1))
    done

    (( failures == 0 ))
}

installer_cas_checks_an_existing_managed_config_block() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture config marker
    local installer_status=0 original expected failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT
    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    config="$home/.config/hypr/hyprland.lua"
    marker="$test_root/config-edit-fired"
    original=$'-- user config\n-- BEGIN arch-lidswitch managed session integration\ndo\n    local ok, err = pcall(require, "arch_lidswitch.session")\n    if not ok then\n        print("arch-lidswitch: failed to load session integration: " .. tostring(err))\n    end\nend\n-- END arch-lidswitch managed session integration'
    expected="$original"$'\n-- concurrent user edit during installation'
    mkdir -p "$(dirname "$config")"
    printf '%s\n' "$original" > "$config"
    chmod 0640 "$config"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"
    ln -s "$ROOT_DIR/tests/fakes/effect" "$fake_bin/luac"

    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_LUAC_MUTATE_CONFIG="$config" TEST_LUAC_MUTATE_MARKER="$marker" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1 || installer_status=$?

    if (( installer_status == 0 )); then
        printf 'installer ignored a concurrent edit to an existing managed block\n' >&2
        failures=$((failures + 1))
    fi
    if [[ "$(<"$config")" != "$expected" || \
        "$(stat -c %a "$config")" != 640 ]]; then
        printf 'existing-block CAS did not preserve concurrent config\n' >&2
        failures=$((failures + 1))
    fi

    (( failures == 0 ))
)

installer_quiesces_units_activated_after_snapshot() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture marker
    local main_unit resume_unit effects failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT
    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    marker="$test_root/post-snapshot-activation"
    main_unit="$home/.config/systemd/user/lid-monitor.service"
    resume_unit="$home/.config/systemd/user/lid-resume-monitor.service"
    prepare_hyprland_config "$home"
    mkdir -p "$(dirname "$main_unit")"
    printf '%s\n' '[Install]' 'WantedBy=graphical-session.target' > "$main_unit"
    printf '%s\n' '[Service]' 'Type=exec' > "$resume_unit"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"
    ln -s "$ROOT_DIR/tests/fakes/effect" "$fake_bin/luac"
    ln -s "$ROOT_DIR/tests/fakes/effect" "$fake_bin/mv"

    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_LUAC_ACTIVATE_UNITS=1 TEST_LUAC_ACTIVATE_MARKER="$marker" \
        TEST_REAL_MV_BIN="$(command -v mv)" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1

    effects=$(<"$effect_log")
    assert_contains "$effects" \
        $'systemctl\t--user\tstop\tlid-resume-monitor.service' \
        'post-snapshot resume activation must be stopped' \
        || failures=$((failures + 1))
    assert_contains "$effects" \
        $'systemctl\t--user\tstop\tlid-monitor.service' \
        'post-snapshot main activation must be stopped' \
        || failures=$((failures + 1))
    assert_before "$effects" \
        $'systemctl\t--user\tis-active\t--quiet\tlid-monitor.service' \
        $'mv-context\tinstall-lid-state' \
        'main inactivity must be verified before first live publication' \
        || failures=$((failures + 1))
    assert_before "$effects" \
        $'systemctl\t--user\tis-active\t--quiet\tlid-resume-monitor.service' \
        $'mv-context\tinstall-lid-state' \
        'resume inactivity must be verified before first live publication' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installer_validates_staged_systemd_units_before_mutation() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture
    local effects installer_status=0 failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT
    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_SYSTEMD_ANALYZE_FAIL=1 \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1 || installer_status=$?

    effects=$(<"$effect_log")
    if (( installer_status == 0 )); then
        printf 'installer accepted failed staged unit verification\n' >&2
        failures=$((failures + 1))
    fi
    assert_contains "$effects" \
        $'systemd-analyze\t--user\t--generators=no\t--man=no\t--recursive-errors=yes\tverify' \
        'installer should verify all staged units through systemd-analyze' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'systemctl\t--user\tstop\t' \
        'unit validation failure must precede service quiescence' \
        || failures=$((failures + 1))
    if [[ -e "$home/.config/hypr/scripts/lid-state.sh" || \
        -e "$home/.config/systemd/user/lid-monitor.service" || \
        -e "$home/.local/state/arch-lidswitch/current.manifest" ]]; then
        printf 'unit validation failure published installation artifacts\n' >&2
        failures=$((failures + 1))
    fi

    (( failures == 0 ))
)

installer_rejects_relative_xdg_state_home() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture
    local installer_status=0 failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT
    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    (
        cd "$test_root"
        "$ENV_BIN" -i \
            HOME="$home" PATH="$fake_bin:$safe_bin" \
            XDG_STATE_HOME=relative-state \
            WAYLAND_DISPLAY=wayland-test \
            HYPRLAND_INSTANCE_SIGNATURE=test-instance \
            XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
            TEST_MONITORS_FIXTURE="$monitor_fixture" \
            "$ROOT_DIR/install-hyprland-lid-switch.sh" \
            > "$test_root/installer.out" 2>&1
    ) || installer_status=$?

    if (( installer_status == 0 )); then
        printf 'installer accepted relative XDG_STATE_HOME\n' >&2
        failures=$((failures + 1))
    fi
    if [[ -e "$test_root/relative-state" || \
        -e "$home/.config/hypr/scripts/lid-state.sh" ]]; then
        printf 'relative state path rejection occurred after installation writes\n' >&2
        failures=$((failures + 1))
    fi
    assert_contains "$(<"$test_root/installer.out")" \
        'XDG_STATE_HOME must be an absolute path' \
        'relative state path should receive an explicit diagnostic' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installer_rolls_back_systemctl_operation_failures() {
    local scenario failures=0

    for scenario in stop daemon-reload restart health stop-mutating restart-mutating; do
        (
            set -euo pipefail

            local test_root home fake_bin safe_bin effect_log monitor_fixture
            local config manifest baseline_config baseline_manifest counter
            local installer_status=0 transaction_entry
            local operation mutate_then_fail=""

            operation=${scenario%-mutating}
            if [[ "$operation" != "$scenario" ]]; then
                mutate_then_fail=$operation
            fi

            test_root=$(mktemp -d)
            trap 'rm -rf "$test_root"' EXIT
            home="$test_root/home"
            fake_bin="$test_root/fake-bin"
            safe_bin="$test_root/safe-bin"
            effect_log="$test_root/effects.log"
            monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
            counter="$test_root/systemctl-failure-count"
            config="$home/.config/hypr/hyprland.lua"
            manifest="$home/.local/state/arch-lidswitch/current.manifest"
            prepare_hyprland_config "$home"
            : > "$effect_log"
            install_safe_path "$fake_bin" "$safe_bin"

            "$ENV_BIN" -i \
                HOME="$home" PATH="$fake_bin:$safe_bin" \
                WAYLAND_DISPLAY=wayland-test \
                HYPRLAND_INSTANCE_SIGNATURE=test-instance \
                XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
                TEST_MONITORS_FIXTURE="$monitor_fixture" \
                "$ROOT_DIR/install-hyprland-lid-switch.sh" \
                > "$test_root/initial-install.out" 2>&1
            baseline_config=$(<"$config")
            baseline_manifest=$(<"$manifest")
            : > "$effect_log"

            "$ENV_BIN" -i \
                HOME="$home" PATH="$fake_bin:$safe_bin" \
                WAYLAND_DISPLAY=wayland-test \
                HYPRLAND_INSTANCE_SIGNATURE=test-instance \
                XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
                TEST_MONITORS_FIXTURE="$monitor_fixture" \
                TEST_SYSTEMCTL_FAIL_OPERATION="$operation" \
                TEST_SYSTEMCTL_MUTATE_THEN_FAIL_OPERATION="$mutate_then_fail" \
                TEST_SYSTEMCTL_FAILURES=1 \
                TEST_SYSTEMCTL_FAILURE_COUNTER="$counter" \
                "$ROOT_DIR/install-hyprland-lid-switch.sh" \
                > "$test_root/failing-install.out" 2>&1 || installer_status=$?

            if (( installer_status == 0 )); then
                printf 'systemctl %s failure unexpectedly committed\n' \
                    "$scenario" >&2
                exit 1
            fi
            if [[ "$(<"$config")" != "$baseline_config" || \
                "$(<"$manifest")" != "$baseline_manifest" || \
                ! -e "$effect_log.systemctl-state/lid-monitor.service.enabled" || \
                ! -e "$effect_log.systemctl-state/lid-monitor.service.active" || \
                ! -e "$effect_log.systemctl-state/lid-resume-monitor.service.active" ]]; then
                printf 'systemctl %s failure did not restore prior state\n' \
                    "$scenario" >&2
                exit 1
            fi
            transaction_entry=$(find \
                "$home/.local/state/arch-lidswitch/transactions" \
                -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null || true)
            if [[ -n "$transaction_entry" ]]; then
                printf 'systemctl %s failure retained a completed rollback\n' \
                    "$scenario" >&2
                exit 1
            fi
            assert_contains "$(<"$test_root/failing-install.out")" \
                'Previous installation state restored' \
                "systemctl $scenario failure should report rollback success"
        ) || failures=$((failures + 1))
    done

    (( failures == 0 ))
}

installer_reconciles_post_mutation_mv_failures() {
    local scenario failures=0

    for scenario in config-exchange backup-promotion; do
        (
            set -euo pipefail

            local test_root home fake_bin safe_bin effect_log monitor_fixture
            local config marker installer_status=0 expected transaction_entry
            local context effects

            test_root=$(mktemp -d)
            trap 'rm -rf "$test_root"' EXIT
            home="$test_root/home"
            fake_bin="$test_root/fake-bin"
            safe_bin="$test_root/safe-bin"
            effect_log="$test_root/effects.log"
            monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
            config="$home/.config/hypr/hyprland.lua"
            marker="$test_root/pre-exchange-edit"
            prepare_hyprland_config "$home"
            : > "$effect_log"
            install_safe_path "$fake_bin" "$safe_bin"
            ln -s "$ROOT_DIR/tests/fakes/effect" "$fake_bin/mv"

            case "$scenario" in
                config-exchange)
                    context=install-config
                    expected=$'-- isolated Hyprland Lua test config\n-- concurrent edit immediately before exchange'
                    ;;
                backup-promotion)
                    context=commit-backup
                    expected='-- unused'
                    ;;
            esac

            "$ENV_BIN" -i \
                HOME="$home" PATH="$fake_bin:$safe_bin" \
                WAYLAND_DISPLAY=wayland-test \
                HYPRLAND_INSTANCE_SIGNATURE=test-instance \
                XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
                TEST_MONITORS_FIXTURE="$monitor_fixture" \
                TEST_REAL_MV_BIN="$(command -v mv)" \
                TEST_MV_MUTATE_THEN_FAIL_CONTEXT="$context" \
                TEST_MV_EDIT_CONFIG_BEFORE_EXCHANGE="$([[ "$scenario" == config-exchange ]] && printf %s "$config" || true)" \
                TEST_MV_EDIT_CONFIG_MARKER="$marker" \
                "$ROOT_DIR/install-hyprland-lid-switch.sh" \
                > "$test_root/installer.out" 2>&1 || installer_status=$?

            effects=$(<"$effect_log")
            assert_contains "$effects" "mv-context"$'\t'"$context" \
                "test must reach post-mutation mv context $context" || exit 1
            assert_contains "$(<"$test_root/installer.out")" \
                "Configured post-mutation mv failure: $context" \
                "test must inject post-mutation mv failure $context" || exit 1
            transaction_entry=$(find \
                "$home/.local/state/arch-lidswitch/transactions" \
                -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null || true)
            if [[ "$scenario" == config-exchange ]]; then
                if (( installer_status == 0 )); then
                    printf 'post-mutation config exchange failure committed\n' >&2
                    exit 1
                fi
                if [[ "$(<"$config")" != "$expected" || \
                    "$(stat -c %a "$config")" != 644 || \
                    -e "$home/.config/hypr/scripts/lid-state.sh" || \
                    -n "$transaction_entry" ]]; then
                    printf 'config exchange failure lost displaced concurrent bytes\n' >&2
                    exit 1
                fi
            else
                if (( installer_status != 0 )); then
                    printf 'reconciled backup promotion returned %d\n%s\n' \
                        "$installer_status" "$(<"$test_root/installer.out")" >&2
                    exit 1
                fi
                if [[ ! -f "$home/.local/state/arch-lidswitch/current.manifest" || \
                    -z "$(find "$home/.local/state/arch-lidswitch/backups" \
                        -mindepth 1 -maxdepth 1 -type d -print -quit)" || \
                    -n "$transaction_entry" ]]; then
                    printf 'backup promotion failure was not reconciled as committed\n' >&2
                    exit 1
                fi
            fi
        ) || failures=$((failures + 1))
    done

    (( failures == 0 ))
}

installer_preserves_atomic_publication_races() {
    local kind prior_state failures=0

    for kind in managed manifest; do
        for prior_state in present absent; do
            (
                set -euo pipefail

                local test_root home fake_bin safe_bin effect_log monitor_fixture
                local raced_file context marker initial concurrent expected mode
                local installer_status=0 transaction_entry sibling_entry

                test_root=$(mktemp -d)
                trap 'rm -rf "$test_root"' EXIT
                home="$test_root/home"
                fake_bin="$test_root/fake-bin"
                safe_bin="$test_root/safe-bin"
                effect_log="$test_root/effects.log"
                monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
                marker="$test_root/publication-race-fired"
                prepare_hyprland_config "$home"
                : > "$effect_log"
                install_safe_path "$fake_bin" "$safe_bin"
                ln -s "$ROOT_DIR/tests/fakes/effect" "$fake_bin/mv"

                case "$kind" in
                    managed)
                        raced_file="$home/.config/hypr/scripts/lid-state.sh"
                        context=install-lid-state
                        ;;
                    manifest)
                        raced_file="$home/.local/state/arch-lidswitch/current.manifest"
                        context=install-manifest
                        ;;
                esac
                initial="old-$kind"
                concurrent="-- concurrent-$kind-$prior_state"
                mode=640
                mkdir -p "$(dirname "$raced_file")"
                if [[ "$prior_state" == present ]]; then
                    printf '%s\n' "$initial" > "$raced_file"
                    chmod 0640 "$raced_file"
                    expected="$initial"$'\n'"$concurrent"
                else
                    expected=$concurrent
                fi

                "$ENV_BIN" -i \
                    HOME="$home" PATH="$fake_bin:$safe_bin" \
                    WAYLAND_DISPLAY=wayland-test \
                    HYPRLAND_INSTANCE_SIGNATURE=test-instance \
                    XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
                    TEST_MONITORS_FIXTURE="$monitor_fixture" \
                    TEST_MV_RACE_CONTEXT="$context" \
                    TEST_MV_RACE_MODE="$([[ "$prior_state" == present ]] && printf append || printf create)" \
                    TEST_MV_RACE_DESTINATION="$raced_file" \
                    TEST_MV_RACE_CONTENT="$concurrent" \
                    TEST_MV_RACE_MODE_BITS=0640 \
                    TEST_MV_RACE_MARKER="$marker" \
                    TEST_REAL_MV_BIN="$(command -v mv)" \
                    "$ROOT_DIR/install-hyprland-lid-switch.sh" \
                    > "$test_root/installer.out" 2>&1 || installer_status=$?

                if (( installer_status == 0 )); then
                    printf '%s %s publication race unexpectedly committed\n' \
                        "$kind" "$prior_state" >&2
                    exit 1
                fi
                if [[ ! -f "$raced_file" || -L "$raced_file" || \
                    "$(<"$raced_file")" != "$expected" || \
                    "$(stat -c %a "$raced_file")" != "$mode" ]]; then
                    printf '%s %s publication race did not preserve concurrent bytes/mode\n' \
                        "$kind" "$prior_state" >&2
                    exit 1
                fi
                transaction_entry=$(find \
                    "$home/.local/state/arch-lidswitch/transactions" \
                    -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null || true)
                sibling_entry=$(find "$(dirname "$raced_file")" -maxdepth 1 \
                    -name '.arch-lidswitch.*' -print -quit)
                if [[ -n "$transaction_entry" || -n "$sibling_entry" ]]; then
                    printf '%s %s publication race left completed rollback state\n' \
                        "$kind" "$prior_state" >&2
                    exit 1
                fi
            ) || failures=$((failures + 1))
        done
    done

    (( failures == 0 ))
}

installer_delivers_signal_during_trap_restoration() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture config
    local installer_status=0 original transaction_entry

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT
    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    config="$home/.config/hypr/hyprland.lua"
    original='-- config before trap restoration signal'
    prepare_hyprland_config "$home"
    printf '%s\n' "$original" > "$config"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        ARCH_LIDSWITCH_TEST_SIGNAL_DURING_TRAP_RESTORE=1 \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1 || installer_status=$?

    if (( installer_status != 143 )); then
        printf 'trap-restoration TERM expected 143, got %d\n%s\n' \
            "$installer_status" "$(<"$test_root/installer.out")" >&2
        exit 1
    fi
    transaction_entry=$(find \
        "$home/.local/state/arch-lidswitch/transactions" \
        -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null || true)
    if [[ "$(<"$config")" != "$original" || \
        -e "$home/.config/hypr/scripts/lid-state.sh" || \
        -e "$home/.local/state/arch-lidswitch/current.manifest" || \
        -n "$transaction_entry" ]]; then
        printf 'trap-restoration TERM was lost or left a partial installation\n' >&2
        exit 1
    fi
    assert_contains "$(<"$test_root/installer.out")" \
        'Delivering deferred installation signal status=143' \
        'trap-restoration TERM should be delivered after both traps are restored'
)

installer_stops_externally_activated_published_units_on_rollback() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture
    local installer_status=0 effects transaction_entry

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT
    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"
    ln -s "$ROOT_DIR/tests/fakes/effect" "$fake_bin/mv"

    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_MV_ACTIVATE_UNITS_AFTER_CONTEXT=install-resume-service \
        TEST_REAL_MV_BIN="$(command -v mv)" \
        ARCH_LIDSWITCH_TEST_FAIL_AFTER=installed-resume-service \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1 || installer_status=$?

    if (( installer_status == 0 )); then
        printf 'externally activated unit rollback unexpectedly committed\n' >&2
        exit 1
    fi
    effects=$(<"$effect_log")
    assert_before "$effects" $'external-activation\tinstall-resume-service' \
        $'systemctl\t--user\tstop\tlid-resume-monitor.service' \
        'rollback should stop an externally activated published resume unit'
    assert_before "$effects" $'external-activation\tinstall-resume-service' \
        $'systemctl\t--user\tstop\tlid-monitor.service' \
        'rollback should stop an externally activated published main unit'
    if [[ -e "$effect_log.systemctl-state/lid-monitor.service.active" || \
        -e "$effect_log.systemctl-state/lid-resume-monitor.service.active" || \
        -e "$home/.config/systemd/user/lid-monitor.service" || \
        -e "$home/.config/systemd/user/lid-resume-monitor.service" ]]; then
        printf 'rollback left externally activated candidate units or files\n' >&2
        exit 1
    fi
    transaction_entry=$(find \
        "$home/.local/state/arch-lidswitch/transactions" \
        -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null || true)
    if [[ -n "$transaction_entry" ]]; then
        printf 'external activation rollback retained completed transaction\n' >&2
        exit 1
    fi
)

installer_preserves_edits_during_rollback_exchange() {
    local scenario failures=0

    for scenario in artifact artifact-fallback config; do
        (
            set -euo pipefail

            local test_root home fake_bin safe_bin effect_log monitor_fixture
            local config managed_file main_unit resume_unit raced_file context
            local checkpoint remove_context="" marker installer_status=0
            local transaction_entry concurrent='-- concurrent rollback edit'

            test_root=$(mktemp -d)
            trap 'rm -rf "$test_root"' EXIT
            home="$test_root/home"
            fake_bin="$test_root/fake-bin"
            safe_bin="$test_root/safe-bin"
            effect_log="$test_root/effects.log"
            monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
            config="$home/.config/hypr/hyprland.lua"
            managed_file="$home/.config/hypr/scripts/lid-state.sh"
            main_unit="$home/.config/systemd/user/lid-monitor.service"
            resume_unit="$home/.config/systemd/user/lid-resume-monitor.service"
            marker="$test_root/rollback-race-fired"
            prepare_hyprland_config "$home"
            mkdir -p "$(dirname "$managed_file")" "$(dirname "$main_unit")"
            printf '%s\n' old-lid-state > "$managed_file"
            chmod 0711 "$managed_file"
            printf '%s\n' '[Install]' 'WantedBy=graphical-session.target' \
                > "$main_unit"
            printf '%s\n' '[Service]' 'Type=exec' > "$resume_unit"
            : > "$effect_log"
            install_safe_path "$fake_bin" "$safe_bin"
            ln -s "$ROOT_DIR/tests/fakes/effect" "$fake_bin/mv"

            case "$scenario" in
                artifact)
                    raced_file=$managed_file
                    context=rollback-lid-state
                    checkpoint=installed-lid-state
                    ;;
                artifact-fallback)
                    raced_file=$managed_file
                    context=rollback-lid-state-fallback
                    checkpoint=installed-lid-state
                    remove_context=rollback-lid-state
                    ;;
                config)
                    raced_file=$config
                    context=rollback-config
                    checkpoint=config-integrated
                    ;;
            esac

            "$ENV_BIN" -i \
                HOME="$home" PATH="$fake_bin:$safe_bin" \
                WAYLAND_DISPLAY=wayland-test \
                HYPRLAND_INSTANCE_SIGNATURE=test-instance \
                XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
                TEST_MONITORS_FIXTURE="$monitor_fixture" \
                TEST_SYSTEMCTL_MAIN_ENABLED=1 TEST_SYSTEMCTL_MAIN_ACTIVE=1 \
                TEST_SYSTEMCTL_RESUME_ACTIVE=1 \
                ARCH_LIDSWITCH_TEST_FAIL_AFTER="$checkpoint" \
                TEST_MV_RACE_CONTEXT="$context" TEST_MV_RACE_MODE=append \
                TEST_MV_RACE_DESTINATION="$raced_file" \
                TEST_MV_RACE_CONTENT="$concurrent" \
                TEST_MV_RACE_MARKER="$marker" \
                TEST_MV_REMOVE_SOURCE_BEFORE_CONTEXT="$remove_context" \
                TEST_REAL_MV_BIN="$(command -v mv)" \
                "$ROOT_DIR/install-hyprland-lid-switch.sh" \
                > "$test_root/installer.out" 2>&1 || installer_status=$?

            if (( installer_status == 0 )); then
                printf '%s rollback race unexpectedly committed\n' \
                    "$scenario" >&2
                exit 1
            fi
            assert_contains "$(<"$raced_file")" "$concurrent" \
                "$scenario rollback should keep the concurrent edit live" \
                || exit 1
            assert_contains "$(<"$test_root/installer.out")" \
                'concurrent content restored' \
                "$scenario rollback should report exchange-back preservation" \
                || exit 1
            if [[ -e "$effect_log.systemctl-state/lid-monitor.service.active" || \
                -e "$effect_log.systemctl-state/lid-resume-monitor.service.active" ]]; then
                printf '%s rollback race restarted services\n' "$scenario" >&2
                exit 1
            fi
            transaction_entry=$(find \
                "$home/.local/state/arch-lidswitch/transactions" \
                -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null || true)
            if [[ -z "$transaction_entry" ]]; then
                printf '%s rollback race discarded recovery state\n' \
                    "$scenario" >&2
                exit 1
            fi
        ) || failures=$((failures + 1))
    done

    (( failures == 0 ))
}

installer_restores_nonregular_publication_races() {
    local kind failures=0

    for kind in artifact config artifact-directory; do
        (
            set -euo pipefail

            local test_root home fake_bin safe_bin effect_log monitor_fixture
            local config managed_file raced_file context marker target
            local race_mode=symlink
            local installer_status=0 transaction_entry

            test_root=$(mktemp -d)
            trap 'rm -rf "$test_root"' EXIT
            home="$test_root/home"
            fake_bin="$test_root/fake-bin"
            safe_bin="$test_root/safe-bin"
            effect_log="$test_root/effects.log"
            monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
            config="$home/.config/hypr/hyprland.lua"
            managed_file="$home/.config/hypr/scripts/lid-state.sh"
            marker="$test_root/nonregular-race-fired"
            target="$test_root/concurrent-symlink-target"
            prepare_hyprland_config "$home"
            mkdir -p "$(dirname "$managed_file")"
            printf '%s\n' old-lid-state > "$managed_file"
            chmod 0711 "$managed_file"
            : > "$effect_log"
            install_safe_path "$fake_bin" "$safe_bin"
            ln -s "$ROOT_DIR/tests/fakes/effect" "$fake_bin/mv"

            case "$kind" in
                artifact)
                    raced_file=$managed_file
                    context=install-lid-state
                    ;;
                config)
                    raced_file=$config
                    context=install-config
                    ;;
                artifact-directory)
                    raced_file=$managed_file
                    context=install-lid-state
                    race_mode=directory
                    ;;
            esac

            "$ENV_BIN" -i \
                HOME="$home" PATH="$fake_bin:$safe_bin" \
                WAYLAND_DISPLAY=wayland-test \
                HYPRLAND_INSTANCE_SIGNATURE=test-instance \
                XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
                TEST_MONITORS_FIXTURE="$monitor_fixture" \
                TEST_MV_RACE_CONTEXT="$context" TEST_MV_RACE_MODE="$race_mode" \
                TEST_MV_RACE_DESTINATION="$raced_file" \
                TEST_MV_RACE_CONTENT="$target" \
                TEST_MV_RACE_MARKER="$marker" \
                TEST_REAL_LN_BIN="$(command -v ln)" \
                TEST_REAL_MV_BIN="$(command -v mv)" \
                "$ROOT_DIR/install-hyprland-lid-switch.sh" \
                > "$test_root/installer.out" 2>&1 || installer_status=$?

            if (( installer_status == 0 )); then
                printf '%s non-regular publication race unexpectedly committed\n' \
                    "$kind" >&2
                exit 1
            fi
            if [[ "$race_mode" == symlink && \
                ( ! -L "$raced_file" || \
                "$(readlink "$raced_file")" != "$target" ) ]] || \
                [[ "$race_mode" == directory && \
                ( -L "$raced_file" || ! -d "$raced_file" || \
                ! -f "$raced_file/concurrent-entry" || \
                "$(<"$raced_file/concurrent-entry")" != "$target" ) ]]; then
                printf '%s non-regular publication race was not restored exactly\n' \
                    "$kind" >&2
                ls -ld -- "$raced_file" >&2 || true
                printf '%s\n' "$(<"$test_root/installer.out")" >&2
                exit 1
            fi
            transaction_entry=$(find \
                "$home/.local/state/arch-lidswitch/transactions" \
                -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null || true)
            if [[ -n "$transaction_entry" ]]; then
                printf '%s non-regular publication race retained completed rollback\n' \
                    "$kind" >&2
                exit 1
            fi
        ) || failures=$((failures + 1))
    done

    (( failures == 0 ))
}

installer_does_not_restart_after_rollback_reload_failure() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture
    local main_unit resume_unit counter installer_status=0 transaction_entry

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT
    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    main_unit="$home/.config/systemd/user/lid-monitor.service"
    resume_unit="$home/.config/systemd/user/lid-resume-monitor.service"
    counter="$test_root/daemon-reload-count"
    prepare_hyprland_config "$home"
    mkdir -p "$(dirname "$main_unit")"
    printf '%s\n' '[Install]' 'WantedBy=graphical-session.target' '# old main' \
        > "$main_unit"
    printf '%s\n' '[Service]' 'Type=exec' '# old resume' > "$resume_unit"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_SYSTEMCTL_MAIN_ENABLED=1 TEST_SYSTEMCTL_MAIN_ACTIVE=1 \
        TEST_SYSTEMCTL_RESUME_ACTIVE=1 \
        TEST_SYSTEMCTL_FAIL_DAEMON_RELOAD_CALL=2 \
        TEST_SYSTEMCTL_FAILURE_COUNTER="$counter" \
        ARCH_LIDSWITCH_TEST_FAIL_AFTER=health-checked \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1 || installer_status=$?

    if (( installer_status == 0 )); then
        printf 'rollback daemon-reload failure unexpectedly committed\n' >&2
        exit 1
    fi
    if [[ "$(<"$counter")" != 2 || \
        -e "$effect_log.systemctl-state/lid-monitor.service.active" || \
        -e "$effect_log.systemctl-state/lid-resume-monitor.service.active" ]]; then
        printf 'rollback daemon-reload failure did not leave both services stopped\n' >&2
        exit 1
    fi
    assert_contains "$(<"$test_root/installer.out")" \
        'Could not reload restored user-systemd unit definitions' \
        'rollback reload failure should explain why restart was skipped'
    assert_contains "$(<"$test_root/installer.out")" \
        'Services remain stopped because restored service state could not be verified' \
        'rollback reload failure should retain a safe stopped state'
    transaction_entry=$(find \
        "$home/.local/state/arch-lidswitch/transactions" \
        -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null || true)
    if [[ -z "$transaction_entry" ]]; then
        printf 'rollback reload failure discarded recovery state\n' >&2
        exit 1
    fi
    if [[ "$(awk -F '\t' '$1 == "systemctl" && $3 == "daemon-reload" { n++ } \
        $1 == "systemctl" && $3 == "start" && n >= 2 { print; exit }' \
        "$effect_log")" != "" ]]; then
        printf 'rollback reload failure started a service after failed reload\n' >&2
        exit 1
    fi
)

installer_rejects_replaced_backup_promotion() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture capture
    local installer_status=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT
    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    capture="$test_root/promoted-snapshot-capture"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"
    ln -s "$ROOT_DIR/tests/fakes/effect" "$fake_bin/mv"

    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_MV_REPLACE_DESTINATION_AFTER_CONTEXT=commit-backup \
        TEST_MV_REPLACED_DESTINATION_CAPTURE="$capture" \
        TEST_REAL_MV_BIN="$(command -v mv)" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1 || installer_status=$?

    if (( installer_status == 0 )); then
        printf 'replaced backup promotion was accepted as committed\n' >&2
        exit 1
    fi
    if [[ ! -f "$capture/snapshot.tsv" || \
        ! -f "$capture/service-state" || ! -f "$capture/hyprland.lua" ]]; then
        printf 'replaced backup promotion lost the original rollback snapshot\n' >&2
        exit 1
    fi
    assert_contains "$(<"$test_root/installer.out")" \
        'Could not verify promoted rollback snapshot identity' \
        'backup promotion must verify the moved source identity'
    assert_not_contains "$(<"$test_root/installer.out")" \
        'Committed artifact transaction' \
        'a replaced backup destination must never be reported committed'
)

installer_rejects_corrupted_promoted_backup_children() {
    local mutation relative failures=0

    for mutation in append delete directory-symlink; do
        (
            set -euo pipefail

            local test_root home fake_bin safe_bin effect_log monitor_fixture
            local config managed_file original installer_status=0 backup_entry
            local directory_capture

            test_root=$(mktemp -d)
            trap 'rm -rf "$test_root"' EXIT
            home="$test_root/home"
            fake_bin="$test_root/fake-bin"
            safe_bin="$test_root/safe-bin"
            effect_log="$test_root/effects.log"
            monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
            config="$home/.config/hypr/hyprland.lua"
            managed_file="$home/.config/hypr/scripts/lid-state.sh"
            directory_capture="$test_root/promoted-files-scripts-capture"
            original='-- config before backup integrity failure'
            case "$mutation" in
                append)
                    relative=hyprland.lua
                    ;;
                delete)
                    relative=service-state
                    ;;
                directory-symlink)
                    relative=files/scripts
                    ;;
            esac
            prepare_hyprland_config "$home"
            printf '%s\n' "$original" > "$config"
            mkdir -p "$(dirname "$managed_file")"
            printf '%s\n' old-lid-state > "$managed_file"
            chmod 0711 "$managed_file"
            : > "$effect_log"
            install_safe_path "$fake_bin" "$safe_bin"
            ln -s "$ROOT_DIR/tests/fakes/effect" "$fake_bin/mv"

            "$ENV_BIN" -i \
                HOME="$home" PATH="$fake_bin:$safe_bin" \
                WAYLAND_DISPLAY=wayland-test \
                HYPRLAND_INSTANCE_SIGNATURE=test-instance \
                XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
                TEST_MONITORS_FIXTURE="$monitor_fixture" \
                TEST_MV_MUTATE_BACKUP_CHILD_AFTER_CONTEXT=commit-backup \
                TEST_MV_BACKUP_CHILD_MUTATION="$mutation" \
                TEST_MV_BACKUP_CHILD_RELATIVE="$relative" \
                TEST_MV_BACKUP_DIRECTORY_CAPTURE="$directory_capture" \
                TEST_REAL_LN_BIN="$(command -v ln)" \
                TEST_REAL_MV_BIN="$(command -v mv)" \
                "$ROOT_DIR/install-hyprland-lid-switch.sh" \
                > "$test_root/installer.out" 2>&1 || installer_status=$?

            if (( installer_status == 0 )); then
                printf 'promoted backup child %s was accepted\n' "$mutation" >&2
                exit 1
            fi
            assert_contains "$(<"$test_root/installer.out")" \
                'Promoted rollback snapshot failed complete integrity verification' \
                "backup child $mutation should fail complete verification" \
                || exit 1
            assert_not_contains "$(<"$test_root/installer.out")" \
                'Committed artifact transaction' \
                "backup child $mutation must not be reported committed" \
                || exit 1
            if [[ "$(<"$config")" != "$original" || \
                ! -f "$managed_file" || -L "$managed_file" || \
                "$(<"$managed_file")" != old-lid-state || \
                "$(stat -c %a "$managed_file")" != 711 || \
                -e "$home/.local/state/arch-lidswitch/current.manifest" ]]; then
                printf 'backup child %s failure did not restore prior state\n' \
                    "$mutation" >&2
                exit 1
            fi
            backup_entry=$(find "$home/.local/state/arch-lidswitch/backups" \
                -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null || true)
            if [[ -n "$backup_entry" ]]; then
                printf 'backup child %s failure retained rejected promotion\n' \
                    "$mutation" >&2
                exit 1
            fi
        ) || failures=$((failures + 1))
    done

    (( failures == 0 ))
}

installer_reinstall_activates_fresh_generations() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture state_dir
    local main_id_before resume_id_before main_id_after resume_id_after
    local main_pid resume_pid manifest manifest_hash output effects
    local main_loaded_hash resume_loaded_hash failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT
    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    state_dir="$effect_log.systemctl-state"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/initial.out" 2>&1

    main_id_before=$(<"$state_dir/lid-monitor.service.invocation-id")
    resume_id_before=$(<"$state_dir/lid-resume-monitor.service.invocation-id")
    ln -s "$ROOT_DIR/tests/fakes/effect" "$fake_bin/mv"
    : > "$effect_log"

    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_MV_ACTIVATE_UNITS_AFTER_CONTEXT=install-lid-state \
        TEST_REAL_MV_BIN="$(command -v mv)" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/reinstall.out" 2>&1

    main_id_after=$(<"$state_dir/lid-monitor.service.invocation-id")
    resume_id_after=$(<"$state_dir/lid-resume-monitor.service.invocation-id")
    main_pid=$(<"$state_dir/lid-monitor.service.main-pid")
    resume_pid=$(<"$state_dir/lid-resume-monitor.service.main-pid")
    main_loaded_hash=$(<"$state_dir/lid-monitor.service.loaded-sha256")
    resume_loaded_hash=$(<"$state_dir/lid-resume-monitor.service.loaded-sha256")
    manifest="$home/.local/state/arch-lidswitch/current.manifest"
    manifest_hash=$(sha256sum "$manifest")
    manifest_hash=${manifest_hash%% *}
    output=$(<"$test_root/reinstall.out")
    effects=$(<"$effect_log")

    if [[ "$main_id_after" == "$main_id_before" || \
        "$resume_id_after" == "$resume_id_before" ]]; then
        printf 'reinstall did not replace both service generations\n' >&2
        failures=$((failures + 1))
    fi
    if [[ ! "$main_id_after" =~ ^[0-9a-f]{32}$ || \
        "$main_id_after" == 00000000000000000000000000000000 || \
        ! "$resume_id_after" =~ ^[0-9a-f]{32}$ || \
        "$resume_id_after" == 00000000000000000000000000000000 || \
        ! "$main_pid" =~ ^[1-9][0-9]*$ || \
        ! "$resume_pid" =~ ^[1-9][0-9]*$ ]]; then
        printf 'reinstall exposed invalid service generation metadata\n' >&2
        failures=$((failures + 1))
    fi
    if [[ "$main_loaded_hash" != \
        "$(sha256sum "$home/.config/hypr/scripts/lid-monitor.sh" | cut -d ' ' -f 1)" || \
        "$resume_loaded_hash" != \
        "$(sha256sum "$home/.config/hypr/scripts/lid-resume-monitor.sh" | cut -d ' ' -f 1)" ]]; then
        printf 'active generations did not load the committed script bytes\n' >&2
        failures=$((failures + 1))
    fi
    assert_contains "$effects" \
        $'systemctl\t--user\trestart\tlid-monitor.service\tlid-resume-monitor.service' \
        'reinstall should explicitly activate fresh main and resume generations' \
        || failures=$((failures + 1))
    assert_before "$effects" $'external-activation\tinstall-lid-state' \
        $'systemctl\t--user\trestart\tlid-monitor.service\tlid-resume-monitor.service' \
        'explicit restart must replace a daemon reactivated during publication' \
        || failures=$((failures + 1))
    assert_contains "$output" "Active installation manifest_sha256=$manifest_hash" \
        'installer should report the exact committed manifest checksum' \
        || failures=$((failures + 1))
    assert_contains "$output" \
        "Active service unit=lid-monitor.service main_pid=$main_pid invocation_id=$main_id_after" \
        'installer should report the verified main generation' \
        || failures=$((failures + 1))
    assert_contains "$output" \
        "Active service unit=lid-resume-monitor.service main_pid=$resume_pid invocation_id=$resume_id_after" \
        'installer should report the verified resume generation' \
        || failures=$((failures + 1))
    assert_before "$output" 'Committed artifact transaction' \
        'Active installation manifest_sha256=' \
        'runtime identity must be reported only after transaction commit' \
        || failures=$((failures + 1))
    if (( $(grep -Fxc $'systemctl\t--user\tshow\t--no-pager\t--property=LoadState\t--property=ActiveState\t--property=SubState\t--property=MainPID\t--property=InvocationID\tlid-monitor.service' "$effect_log" || true) < 3 )) || \
        (( $(grep -Fxc $'sleep\t1.1' "$effect_log" || true) < 2 )); then
        printf 'candidate health was not stable across the bounded restart window\n' >&2
        failures=$((failures + 1))
    fi

    (( failures == 0 ))
)

installer_unhealthy_candidate_restores_old_code_generation() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture state_dir
    local main_script resume_script manifest main_hash resume_hash
    local old_main old_resume old_manifest old_main_id old_resume_id
    local restored_main_id restored_resume_id installer_status=0
    local transaction_entry output failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT
    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    state_dir="$effect_log.systemctl-state"
    main_script="$home/.config/hypr/scripts/lid-monitor.sh"
    resume_script="$home/.config/hypr/scripts/lid-resume-monitor.sh"
    manifest="$home/.local/state/arch-lidswitch/current.manifest"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/initial.out" 2>&1

    printf '%s\n' '# simulated prior main generation' >> "$main_script"
    printf '%s\n' '# simulated prior resume generation' >> "$resume_script"
    main_hash=$(sha256sum "$main_script")
    main_hash=${main_hash%% *}
    resume_hash=$(sha256sum "$resume_script")
    resume_hash=${resume_hash%% *}
    awk -F '\t' -v OFS='\t' -v main_hash="$main_hash" \
        -v resume_hash="$resume_hash" \
        '$3 == "scripts/lid-monitor.sh" {$1 = main_hash} \
         $3 == "scripts/lid-resume-monitor.sh" {$1 = resume_hash} \
         {print}' "$manifest" > "$manifest.updated"
    chmod 0600 "$manifest.updated"
    mv -f "$manifest.updated" "$manifest"

    "$ENV_BIN" -i HOME="$home" PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        "$fake_bin/systemctl" --user restart \
        lid-monitor.service lid-resume-monitor.service
    old_main=$(<"$main_script")
    old_resume=$(<"$resume_script")
    old_manifest=$(<"$manifest")
    old_main_id=$(<"$state_dir/lid-monitor.service.invocation-id")
    old_resume_id=$(<"$state_dir/lid-resume-monitor.service.invocation-id")
    : > "$effect_log"

    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_SYSTEMCTL_UNHEALTHY_RESTART_NUMBER=3 \
        TEST_SYSTEMCTL_UNHEALTHY_MODE=pid-zero \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/reinstall.out" 2>&1 || installer_status=$?

    if (( installer_status == 0 )); then
        printf 'unhealthy candidate generation unexpectedly committed\n' >&2
        failures=$((failures + 1))
    fi
    restored_main_id=$(<"$state_dir/lid-monitor.service.invocation-id")
    restored_resume_id=$(<"$state_dir/lid-resume-monitor.service.invocation-id")
    if [[ "$(<"$main_script")" != "$old_main" || \
        "$(<"$resume_script")" != "$old_resume" || \
        "$(<"$manifest")" != "$old_manifest" ]]; then
        printf 'unhealthy candidate rollback did not restore old files/manifest\n' >&2
        failures=$((failures + 1))
    fi
    if [[ "$restored_main_id" == "$old_main_id" || \
        "$restored_resume_id" == "$old_resume_id" || \
        "$(<"$state_dir/lid-monitor.service.loaded-sha256")" != "$main_hash" || \
        "$(<"$state_dir/lid-resume-monitor.service.loaded-sha256")" != "$resume_hash" || \
        ! -e "$state_dir/lid-monitor.service.active" || \
        ! -e "$state_dir/lid-resume-monitor.service.active" ]]; then
        printf 'rollback did not activate healthy fresh old-code generations\n' >&2
        failures=$((failures + 1))
    fi
    transaction_entry=$(find "$home/.local/state/arch-lidswitch/transactions" \
        -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null || true)
    if [[ -n "$transaction_entry" ]]; then
        printf 'healthy restored generation retained completed recovery state\n' >&2
        failures=$((failures + 1))
    fi
    output=$(<"$test_root/reinstall.out")
    assert_contains "$output" 'Failed to verify fresh lid service generations' \
        'candidate health failure should be explicit' \
        || failures=$((failures + 1))
    assert_contains "$output" 'Previous installation state restored' \
        'candidate health failure should report successful rollback' \
        || failures=$((failures + 1))
    assert_not_contains "$output" 'Active installation manifest_sha256=' \
        'failed candidate must never report a committed active generation' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installer_bounds_candidate_generation_churn() {
    local scenario failures=0

    for scenario in converges bounded-failure; do
        (
            set -euo pipefail

            local test_root home fake_bin safe_bin effect_log monitor_fixture
            local installer_status=0 show_count output transaction_entry
            local churn_shows

            test_root=$(mktemp -d)
            trap 'rm -rf "$test_root"' EXIT
            home="$test_root/home"
            fake_bin="$test_root/fake-bin"
            safe_bin="$test_root/safe-bin"
            effect_log="$test_root/effects.log"
            monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
            churn_shows=$([[ "$scenario" == converges ]] && printf 2 || printf 99)
            prepare_hyprland_config "$home"
            : > "$effect_log"
            install_safe_path "$fake_bin" "$safe_bin"

            "$ENV_BIN" -i \
                HOME="$home" PATH="$fake_bin:$safe_bin" \
                WAYLAND_DISPLAY=wayland-test \
                HYPRLAND_INSTANCE_SIGNATURE=test-instance \
                XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
                TEST_MONITORS_FIXTURE="$monitor_fixture" \
                TEST_SYSTEMCTL_CHURN_RESTART_NUMBER=1 \
                TEST_SYSTEMCTL_CHURN_UNIT=lid-monitor.service \
                TEST_SYSTEMCTL_CHURN_SHOWS="$churn_shows" \
                "$ROOT_DIR/install-hyprland-lid-switch.sh" \
                > "$test_root/installer.out" 2>&1 || installer_status=$?

            show_count=$(grep -Fxc \
                $'systemctl\t--user\tshow\t--no-pager\t--property=LoadState\t--property=ActiveState\t--property=SubState\t--property=MainPID\t--property=InvocationID\tlid-monitor.service' \
                "$effect_log" || true)
            output=$(<"$test_root/installer.out")
            if [[ "$scenario" == converges ]]; then
                if (( installer_status != 0 || show_count != 5 )); then
                    printf 'bounded generation churn did not converge; status=%d shows=%d\n%s\n' \
                        "$installer_status" "$show_count" "$output" >&2
                    exit 1
                fi
                assert_contains "$output" 'Active installation manifest_sha256=' \
                    'converged generation should commit and report identity'
            else
                if (( installer_status == 0 || show_count != 8 )); then
                    printf 'persistent generation churn was not bounded; status=%d shows=%d\n%s\n' \
                        "$installer_status" "$show_count" "$output" >&2
                    exit 1
                fi
                assert_contains "$output" \
                    'Service runtime did not stabilize during candidate verification' \
                    'persistent generation churn should receive a bounded diagnostic'
                assert_not_contains "$output" 'Active installation manifest_sha256=' \
                    'unstable candidate must not report a committed identity'
                transaction_entry=$(find \
                    "$home/.local/state/arch-lidswitch/transactions" \
                    -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null || true)
                if [[ -n "$transaction_entry" || \
                    -e "$home/.config/hypr/scripts/lid-monitor.sh" ]]; then
                    printf 'bounded churn rollback left a partial fresh installation\n' >&2
                    exit 1
                fi
            fi
        ) || failures=$((failures + 1))
    done

    (( failures == 0 ))
}

installer_service_failures_restore_old_generation() {
    local scenario failures=0

    for scenario in restart restart-mutating show signal-restart signal-health; do
        (
            set -euo pipefail

            local test_root home fake_bin safe_bin effect_log monitor_fixture state_dir
            local main_script resume_script manifest main_hash resume_hash
            local old_main old_resume old_manifest old_main_id old_resume_id
            local installer_status=0 expected_status=0 failure_operation=""
            local mutate_operation="" signal_event="" show_restart=""
            local counter show_counter output transaction_entry

            test_root=$(mktemp -d)
            trap 'rm -rf "$test_root"' EXIT
            home="$test_root/home"
            fake_bin="$test_root/fake-bin"
            safe_bin="$test_root/safe-bin"
            effect_log="$test_root/effects.log"
            monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
            state_dir="$effect_log.systemctl-state"
            main_script="$home/.config/hypr/scripts/lid-monitor.sh"
            resume_script="$home/.config/hypr/scripts/lid-resume-monitor.sh"
            manifest="$home/.local/state/arch-lidswitch/current.manifest"
            counter="$test_root/systemctl-failure-count"
            show_counter="$test_root/show-failure-count"
            prepare_hyprland_config "$home"
            : > "$effect_log"
            install_safe_path "$fake_bin" "$safe_bin"

            "$ENV_BIN" -i \
                HOME="$home" PATH="$fake_bin:$safe_bin" \
                WAYLAND_DISPLAY=wayland-test \
                HYPRLAND_INSTANCE_SIGNATURE=test-instance \
                XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
                TEST_MONITORS_FIXTURE="$monitor_fixture" \
                "$ROOT_DIR/install-hyprland-lid-switch.sh" \
                > "$test_root/initial.out" 2>&1

            printf '%s\n' '# prior main bytes for failure rollback' >> "$main_script"
            printf '%s\n' '# prior resume bytes for failure rollback' >> "$resume_script"
            main_hash=$(sha256sum "$main_script")
            main_hash=${main_hash%% *}
            resume_hash=$(sha256sum "$resume_script")
            resume_hash=${resume_hash%% *}
            awk -F '\t' -v OFS='\t' -v main_hash="$main_hash" \
                -v resume_hash="$resume_hash" \
                '$3 == "scripts/lid-monitor.sh" {$1 = main_hash} \
                 $3 == "scripts/lid-resume-monitor.sh" {$1 = resume_hash} \
                 {print}' "$manifest" > "$manifest.updated"
            chmod 0600 "$manifest.updated"
            mv -f "$manifest.updated" "$manifest"
            "$ENV_BIN" -i HOME="$home" PATH="$fake_bin:$safe_bin" \
                TEST_EFFECT_LOG="$effect_log" \
                "$fake_bin/systemctl" --user restart \
                lid-monitor.service lid-resume-monitor.service
            old_main=$(<"$main_script")
            old_resume=$(<"$resume_script")
            old_manifest=$(<"$manifest")
            old_main_id=$(<"$state_dir/lid-monitor.service.invocation-id")
            old_resume_id=$(<"$state_dir/lid-resume-monitor.service.invocation-id")
            : > "$effect_log"

            case "$scenario" in
                restart)
                    failure_operation=restart
                    ;;
                restart-mutating)
                    failure_operation=restart
                    mutate_operation=restart
                    ;;
                show)
                    show_restart=3
                    ;;
                signal-restart)
                    signal_event=restart
                    expected_status=143
                    ;;
                signal-health)
                    signal_event=health-sample
                    expected_status=143
                    ;;
            esac

            "$ENV_BIN" -i \
                HOME="$home" PATH="$fake_bin:$safe_bin" \
                WAYLAND_DISPLAY=wayland-test \
                HYPRLAND_INSTANCE_SIGNATURE=test-instance \
                XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
                TEST_MONITORS_FIXTURE="$monitor_fixture" \
                TEST_SYSTEMCTL_FAIL_OPERATION="$failure_operation" \
                TEST_SYSTEMCTL_FAILURES=1 \
                TEST_SYSTEMCTL_FAILURE_COUNTER="$counter" \
                TEST_SYSTEMCTL_MUTATE_THEN_FAIL_OPERATION="$mutate_operation" \
                TEST_SYSTEMCTL_FAIL_SHOW_RESTART_NUMBER="$show_restart" \
                TEST_SYSTEMCTL_SHOW_FAILURES=1 \
                TEST_SYSTEMCTL_SHOW_FAILURE_COUNTER="$show_counter" \
                ARCH_LIDSWITCH_TEST_SIGNAL_AFTER_SERVICE_EVENT="$signal_event" \
                "$ROOT_DIR/install-hyprland-lid-switch.sh" \
                > "$test_root/reinstall.out" 2>&1 || installer_status=$?

            if (( installer_status == 0 )) || \
                (( expected_status != 0 && installer_status != expected_status )); then
                printf '%s failure returned unexpected status=%d\n%s\n' \
                    "$scenario" "$installer_status" \
                    "$(<"$test_root/reinstall.out")" >&2
                exit 1
            fi
            if [[ "$(<"$main_script")" != "$old_main" || \
                "$(<"$resume_script")" != "$old_resume" || \
                "$(<"$manifest")" != "$old_manifest" || \
                "$(<"$state_dir/lid-monitor.service.loaded-sha256")" != \
                    "$main_hash" || \
                "$(<"$state_dir/lid-resume-monitor.service.loaded-sha256")" != \
                    "$resume_hash" || \
                "$(<"$state_dir/lid-monitor.service.invocation-id")" == \
                    "$old_main_id" || \
                "$(<"$state_dir/lid-resume-monitor.service.invocation-id")" == \
                    "$old_resume_id" ]]; then
                printf '%s failure did not restore healthy old-code generations\n' \
                    "$scenario" >&2
                exit 1
            fi
            transaction_entry=$(find \
                "$home/.local/state/arch-lidswitch/transactions" \
                -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null || true)
            if [[ -n "$transaction_entry" ]]; then
                printf '%s failure retained completed recovery state\n' \
                    "$scenario" >&2
                exit 1
            fi
            output=$(<"$test_root/reinstall.out")
            assert_contains "$output" 'Previous installation state restored' \
                "$scenario should report successful old-generation rollback" \
                || exit 1
            assert_not_contains "$output" 'Active installation manifest_sha256=' \
                "$scenario must not report a failed candidate as committed" \
                || exit 1
        ) || failures=$((failures + 1))
    done

    (( failures == 0 ))
}

installer_rejects_generation_change_after_backup_promotion() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture
    local installer_status=0 output transaction_entry backup_entry show_count

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT
    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_SYSTEMCTL_REPLACE_ON_SHOW_CALL=4 \
        TEST_SYSTEMCTL_REPLACE_ON_SHOW_UNIT=lid-monitor.service \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1 || installer_status=$?

    if (( installer_status == 0 )); then
        printf 'post-promotion generation replacement unexpectedly committed\n' >&2
        exit 1
    fi
    show_count=$(grep -Fxc \
        $'systemctl\t--user\tshow\t--no-pager\t--property=LoadState\t--property=ActiveState\t--property=SubState\t--property=MainPID\t--property=InvocationID\tlid-monitor.service' \
        "$effect_log" || true)
    if (( show_count != 4 )); then
        printf 'post-promotion identity seam fired at wrong sample: %d\n' \
            "$show_count" >&2
        exit 1
    fi
    output=$(<"$test_root/installer.out")
    assert_contains "$output" \
        'Candidate service generation changed before transaction commit' \
        'commit must revalidate the exact stable generation identity'
    assert_not_contains "$output" 'Committed artifact transaction' \
        'changed post-promotion generation must not be marked committed'
    assert_not_contains "$output" 'Active installation manifest_sha256=' \
        'changed post-promotion generation must not be reported active'
    transaction_entry=$(find "$home/.local/state/arch-lidswitch/transactions" \
        -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null || true)
    backup_entry=$(find "$home/.local/state/arch-lidswitch/backups" \
        -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null || true)
    if [[ -n "$transaction_entry" || -n "$backup_entry" || \
        -e "$home/.config/hypr/scripts/lid-monitor.sh" || \
        -e "$effect_log.systemctl-state/lid-monitor.service.active" ]]; then
        printf 'post-promotion identity rollback left fresh candidate state\n' >&2
        exit 1
    fi
)

installer_requires_systemd_analyze_before_transaction_writes() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture
    local installer_status=0 failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT
    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"
    rm -f "$fake_bin/systemd-analyze" "$safe_bin/systemd-analyze"

    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1 || installer_status=$?

    if (( installer_status == 0 )); then
        printf 'installer accepted missing systemd-analyze\n' >&2
        failures=$((failures + 1))
    fi
    if [[ -e "$home/.local/state/arch-lidswitch" || \
        -e "$home/.config/hypr/scripts/lid-state.sh" ]]; then
        printf 'missing systemd-analyze caused transaction writes\n' >&2
        failures=$((failures + 1))
    fi
    assert_contains "$(<"$test_root/installer.out")" \
        'requires systemd-analyze for transactional installation' \
        'missing systemd-analyze should receive an explicit diagnostic' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

readme_documents_complete_transaction_uninstall() {
    local readme_contents failures=0 path
    local -a managed_paths=(
        lid-state.sh monitor-state.sh lid-switch.sh lid-switch-doctor.sh
        lid-monitor.sh lid-resume-monitor.sh lid-session-bridge.sh session.lua
        hyprland-session.target lid-monitor.service lid-resume-monitor.service
    )

    readme_contents=$(<"$ROOT_DIR/README.md")
    for path in "${managed_paths[@]}"; do
        if [[ "$readme_contents" != *"rm -f "*"$path"* ]]; then
            printf 'uninstall docs omit managed artifact: %s\n' "$path" >&2
            failures=$((failures + 1))
        fi
    done
    assert_contains "$readme_contents" \
        'rm -rf "${XDG_STATE_HOME:-$HOME/.local/state}/arch-lidswitch"' \
        'uninstall docs should remove manifest and retained rollback state' \
        || failures=$((failures + 1))
    assert_contains "$readme_contents" \
        'BEGIN arch-lidswitch managed session integration' \
        'uninstall docs should identify the owned config block' \
        || failures=$((failures + 1))
    assert_contains "$readme_contents" \
        'best-effort attempt to prune older complete rollback sets' \
        'backup pruning policy should distinguish cleanup from commit' \
        || failures=$((failures + 1))

    (( failures == 0 ))
}

tests_run=0
tests_failed=0
tests_selected=0

run_test() {
    local test_id=$1
    local description=$2
    local test_function=$3
    local output

    if [[ -n "$TEST_FILTER" && "$test_id" != *"$TEST_FILTER"* ]]; then
        return 0
    fi

    tests_selected=$((tests_selected + 1))
    tests_run=$((tests_run + 1))
    if output=$("$test_function" 2>&1); then
        printf 'ok %d - %s\n' "$tests_run" "$description"
    else
        printf 'not ok %d - %s\n' "$tests_run" "$description"
        while IFS= read -r line; do
            printf '# %s\n' "$line"
        done <<< "$output"
        tests_failed=$((tests_failed + 1))
    fi
}

