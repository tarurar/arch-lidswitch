    installer_hyprland_profile_is_rejected \
        'Hyprland Lua capability probe failed: required hl.monitor, hl.dispatch, and hl.dsp.dpms APIs are unavailable' \
        'TEST_HYPRCTL_CAPABILITY_EVAL_OUTPUT=error: hl.monitor unavailable'
}

installer_policy_profile_is_rejected() (
    set -euo pipefail

    local expected_status=$1
    local expected_message=$2
    shift 2

    local test_root home fake_bin safe_bin effect_log monitor_fixture config original
    local installer_output effects installer_status=0 failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    config="$home/.config/hypr/hyprland.lua"
    original='-- user-owned config must remain unchanged on policy conflict'
    mkdir -p "$(dirname "$config")"
    printf '%s\n' "$original" > "$config"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$@" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1 || installer_status=$?

    installer_output=$(<"$test_root/installer.out")
    effects=$(<"$effect_log")

    if (( installer_status != expected_status )); then
        printf 'expected policy-check status %d, got %d\ninstaller output:\n%s\n' \
            "$expected_status" "$installer_status" "$installer_output" >&2
        failures=$((failures + 1))
    fi
    if [[ "$(<"$config")" != "$original" ]]; then
        printf 'policy conflict changed user configuration:\n%s\n' \
            "$(<"$config")" >&2
        failures=$((failures + 1))
    fi
    if [[ -e "$home/.config/hypr/scripts/lid-switch.sh" ]] || \
        [[ -e "$home/.config/systemd/user/lid-monitor.service" ]]; then
        printf 'policy conflict wrote installation artifacts\n' >&2
        failures=$((failures + 1))
    fi
    assert_not_contains "$effects" $'hyprctl\t' \
        'policy validation should run before monitor detection' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'systemctl\t' \
        'policy conflict must not change user-systemd state' \
        || failures=$((failures + 1))
    assert_contains "$installer_output" "$expected_message" \
        'the failed policy profile should explain its exact cause' \
        || failures=$((failures + 1))
    assert_contains "$installer_output" \
        'systemd-analyze cat-config systemd/logind.conf' \
        'the conflict should provide a read-only configuration inspection command' \
        || failures=$((failures + 1))
    assert_contains "$installer_output" \
        'This installer does not modify /etc or systemd-logind policy.' \
        'the conflict should make system-policy ownership explicit' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installer_rejects_conflicting_undocked_lid_policy() {
    installer_policy_profile_is_rejected \
        1 \
        'FAIL HandleLidSwitch=ignore expected=suspend' \
        TEST_LOGIND_HANDLE_LID_SWITCH=ignore
}

installer_rejects_conflicting_docked_lid_policy() {
    installer_policy_profile_is_rejected \
        1 \
        'FAIL HandleLidSwitchDocked=suspend expected=ignore' \
        TEST_LOGIND_HANDLE_LID_SWITCH_DOCKED=suspend
}

installer_rejects_conflicting_external_power_lid_policy() {
    installer_policy_profile_is_rejected \
        1 \
        'FAIL HandleLidSwitchExternalPower=hibernate expected=<unset-or-suspend>' \
        TEST_LOGIND_HANDLE_LID_SWITCH_EXTERNAL_POWER=hibernate
}

installer_rejects_a_low_level_lid_inhibitor() {
    installer_policy_profile_is_rejected \
        1 \
        'FAIL handle-lid-switch inhibitor present: desktop-shell 1000 user 42 shell handle-lid-switch custom handling block' \
        'TEST_LID_SWITCH_INHIBITOR=desktop-shell 1000 user 42 shell handle-lid-switch custom handling block'
}

installer_reports_a_logind_property_diagnostic_failure() {
    installer_policy_profile_is_rejected \
        2 \
        'ERROR Could not read effective logind property HandleLidSwitchDocked.' \
        TEST_BUSCTL_FAIL_PROPERTY=HandleLidSwitchDocked
}

installer_reports_a_lid_inhibitor_diagnostic_failure() {
    installer_policy_profile_is_rejected \
        2 \
        'ERROR Could not inspect handle-lid-switch inhibitors.' \
        TEST_SYSTEMD_INHIBIT_FAIL=1
}

installer_rejects_unavailable_suspend_capabilities() (
    set -euo pipefail

    local capability failures=0

    for capability in na no challenge unexpected; do
        if ! installer_policy_profile_is_rejected \
            1 \
            "FAIL CanSuspend=$capability expected=yes" \
            "TEST_LOGIND_CAN_SUSPEND=$capability"; then
            failures=$((failures + 1))
        fi
    done

    (( failures == 0 ))
)

installer_reports_suspend_capability_query_failure() {
    installer_policy_profile_is_rejected \
        2 \
        'ERROR Could not query login1 capability CanSuspend.' \
        TEST_BUSCTL_FAIL_METHOD=CanSuspend
}

installer_reports_suspend_capability_parse_failure() {
    installer_policy_profile_is_rejected \
        2 \
        'ERROR Unexpected value for login1 capability CanSuspend: malformed' \
        TEST_BUSCTL_MALFORMED_METHOD=CanSuspend
}

installer_warns_when_hibernate_capability_is_unavailable() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture
    local installer_output effects installer_status=0 failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    mkdir -p "$home"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_LOGIND_CAN_SUSPEND=yes \
        TEST_BUSCTL_FAIL_METHOD=CanHibernate \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1 || installer_status=$?

    installer_output=$(<"$test_root/installer.out")
    effects=$(<"$effect_log")

    if (( installer_status != 0 )); then
        printf 'expected optional hibernate diagnostic status 0, got %d\n%s\n' \
            "$installer_status" "$installer_output" >&2
        failures=$((failures + 1))
    fi
    if [[ ! -x "$home/.config/hypr/scripts/lid-switch-doctor.sh" ]]; then
        printf 'installer did not complete after the optional diagnostic warning\n' >&2
        failures=$((failures + 1))
    fi
    assert_contains "$installer_output" \
        'WARN Could not query login1 capability CanHibernate.' \
        'a hibernate query failure should be reported as a warning' \
        || failures=$((failures + 1))
    assert_contains "$installer_output" \
        'WARN CanHibernate=<unavailable> hibernate=unused' \
        'the warning should explain why the missing capability is non-blocking' \
        || failures=$((failures + 1))
    assert_not_contains "$installer_output" \
        'ERROR Could not query login1 capability CanHibernate.' \
        'an unused hibernate diagnostic must not be reported as a blocking error' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'systemctl\thibernate' \
        'the installer must not request hibernation' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'systemctl\tsuspend' \
        'the installer must not request suspension' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installed_session_lifecycle_is_bound_to_hyprland() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture
    local hyprland_config original_config installed_unit installed_target
    local installed_bridge installed_module unit_contents target_contents
    local config_contents effects verification_errors failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    hyprland_config="$home/.config/hypr/hyprland.lua"
    original_config='hl.on("hyprland.start", function() print("existing start") end)'

    mkdir -p "$(dirname "$hyprland_config")"
    printf '%s\n' "$original_config" > "$hyprland_config"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        DISPLAY=:9 \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_CURRENT_DESKTOP=Hyprland \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1

    installed_unit="$home/.config/systemd/user/lid-monitor.service"
    installed_target="$home/.config/systemd/user/hyprland-session.target"
    installed_bridge="$home/.config/hypr/scripts/lid-session-bridge.sh"
    installed_module="$home/.config/hypr/arch_lidswitch/session.lua"

    unit_contents=$(<"$installed_unit")
    assert_contains "$unit_contents" 'PartOf=graphical-session.target' \
        'the installed daemon should stop and restart with the graphical session' \
        || failures=$((failures + 1))
    assert_contains "$unit_contents" 'After=graphical-session.target' \
        'the installed daemon should start after the graphical session target' \
        || failures=$((failures + 1))
    assert_contains "$unit_contents" 'ConditionEnvironment=HYPRLAND_INSTANCE_SIGNATURE' \
        'the installed daemon should require a selected Hyprland instance' \
        || failures=$((failures + 1))
    assert_contains "$unit_contents" 'ConditionEnvironment=WAYLAND_DISPLAY' \
        'the installed daemon should require a Wayland display' \
        || failures=$((failures + 1))
    assert_contains "$unit_contents" "ExecStartPre=$fake_bin/hyprctl monitors" \
        'the service should prove Hyprland reachability with the installed absolute hyprctl path' \
        || failures=$((failures + 1))
    assert_contains "$unit_contents" 'Restart=on-failure' \
        'the session daemon should restart only after failures' \
        || failures=$((failures + 1))
    assert_contains "$unit_contents" 'RestartPreventExitStatus=1' \
        'permanent runtime contract failures must not enter a systemd restart loop' \
        || failures=$((failures + 1))
    assert_contains "$unit_contents" 'WantedBy=graphical-session.target' \
        'the installed daemon should be enabled by the graphical session' \
        || failures=$((failures + 1))
    assert_not_contains "$unit_contents" 'Environment="DISPLAY=' \
        'the installed daemon must not hard-code an X11 display' \
        || failures=$((failures + 1))
    assert_not_contains "$unit_contents" 'WantedBy=default.target' \
        'the installed daemon must not start before the graphical session' \
        || failures=$((failures + 1))

    if [[ ! -r "$installed_target" ]]; then
        printf 'installer did not create hyprland-session.target\n' >&2
        failures=$((failures + 1))
    else
        target_contents=$(<"$installed_target")
        assert_contains "$target_contents" 'BindsTo=graphical-session.target' \
            'the Hyprland session target should bind the passive graphical target' \
            || failures=$((failures + 1))
        assert_contains "$target_contents" 'PropagatesStopTo=graphical-session.target' \
            'stopping the Hyprland session should stop graphical-session.target' \
            || failures=$((failures + 1))
    fi

    if ! SYSTEMD_BYPASS_USERDB=1 "$SYSTEMD_ANALYZE_BIN" --user verify "$installed_target" "$installed_unit" \
        > "$test_root/systemd-analyze.out" 2>&1; then
        verification_errors=$(grep -Fv \
            'Failed to turn off SO_PASSRIGHTS on user lookup socket, ignoring: Operation not permitted' \
            "$test_root/systemd-analyze.out" | grep -Fv \
            'Failed to enable SO_PASSCRED on handoff timestamp socket: Operation not permitted' || true)
        if [[ -n "$verification_errors" ]]; then
            printf 'systemd rejected installed session units:\n%s\n' \
                "$verification_errors" >&2
            failures=$((failures + 1))
        fi
    fi

    for installed_artifact in "$installed_bridge" "$installed_module"; do
        if [[ ! -r "$installed_artifact" ]]; then
            printf 'installer did not create session artifact: %s\n' "$installed_artifact" >&2
            failures=$((failures + 1))
        fi
    done

    config_contents=$(<"$hyprland_config")
    assert_contains "$config_contents" "$original_config" \
        'session integration should preserve the existing Hyprland configuration' \
        || failures=$((failures + 1))
    assert_contains "$config_contents" '-- BEGIN arch-lidswitch managed session integration' \
        'the installer should add an owned session-integration block' \
        || failures=$((failures + 1))
    assert_contains "$config_contents" 'pcall(require, "arch_lidswitch.session")' \
        'the owned integration should load the adjacent module without breaking the main config' \
        || failures=$((failures + 1))

    effects=$(<"$effect_log")
    assert_contains "$effects" $'systemctl\t--user\timport-environment\tDISPLAY\tWAYLAND_DISPLAY\tHYPRLAND_INSTANCE_SIGNATURE\tXDG_CURRENT_DESKTOP\tPATH' \
        'current-session activation should synchronously import defined Hyprland variables' \
        || failures=$((failures + 1))
    assert_contains "$effects" $'systemctl\t--user\tstart\thyprland-session.target' \
        'current-session activation should start the Hyprland session target' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installed_session_bridge_orders_start_and_stop() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture bridge
    local effects expected_import start_status=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    mkdir -p "$home"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        DISPLAY=:9 \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_CURRENT_DESKTOP=Hyprland \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1

    bridge="$home/.config/hypr/scripts/lid-session-bridge.sh"
    : > "$effect_log"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        DISPLAY=:10 \
        WAYLAND_DISPLAY=wayland-ordered \
        HYPRLAND_INSTANCE_SIGNATURE=ordered-instance \
        XDG_CURRENT_DESKTOP=Hyprland \
        XDG_SESSION_TYPE=wayland \
        QT_QPA_PLATFORMTHEME=qt6ct \
        XDG_DATA_DIRS=/test/share \
        TEST_EFFECT_LOG="$effect_log" \
        UNRELATED_SECRET=must-not-be-imported \
        "$bridge" start

    effects=$(<"$effect_log")
    expected_import=$'systemctl\t--user\timport-environment\tDISPLAY\tWAYLAND_DISPLAY\tHYPRLAND_INSTANCE_SIGNATURE\tXDG_CURRENT_DESKTOP\tQT_QPA_PLATFORMTHEME\tPATH\tXDG_DATA_DIRS'
    assert_before "$effects" "$expected_import" \
        $'systemctl\t--user\tstart\thyprland-session.target' \
        'the session target must start only after the curated environment import'
    assert_not_contains "$effects" 'XDG_SESSION_TYPE' \
        'the bridge should not expand Hyprland upstream curated environment ownership'
    assert_not_contains "$effects" 'UNRELATED_SECRET' \
        'the bridge should never import unrelated session values'

    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        "$bridge" stop
    effects=$(<"$effect_log")
    assert_before "$effects" \
        $'systemctl\t--user\tstop\thyprland-session.target' \
        $'sleep\t0.1' \
        'normal Hyprland shutdown should synchronously stop the target before the short grace period'
    assert_not_contains "$effects" 'unset-environment' \
        'Hyprland should retain ownership of activation-environment cleanup'

    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-missing-instance \
        TEST_EFFECT_LOG="$effect_log" \
        "$bridge" start \
        > "$test_root/missing.out" 2>&1 || start_status=$?

    if (( start_status == 0 )); then
        printf 'session bridge accepted a missing Hyprland instance signature\n' >&2
        return 1
    fi
    if [[ -s "$effect_log" ]]; then
        printf 'missing session identity caused system effects:\n%s\n' \
            "$(<"$effect_log")" >&2
        return 1
    fi
    assert_contains "$(<"$test_root/missing.out")" 'HYPRLAND_INSTANCE_SIGNATURE' \
        'the bridge should identify the missing required session variable'
)

installed_session_module_registers_isolated_hooks() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture module harness output

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    mkdir -p "$home"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1

    module="$home/.config/hypr/arch_lidswitch/session.lua"
    harness="$test_root/harness.lua"
    printf '%s\n' \
        'local handlers = {}' \
        'hl = {' \
        '  on = function(name, callback) handlers[name] = callback end,' \
        '  exec_cmd = function(command) print("async\t" .. command) end,' \
        '}' \
        'os.execute = function(command) print("sync\t" .. command); return true, "exit", 0 end' \
        'assert(dofile(arg[1]) == true)' \
        'assert(type(handlers["hyprland.start"]) == "function")' \
        'assert(type(handlers["hyprland.shutdown"]) == "function")' \
        'handlers["hyprland.start"]()' \
        'handlers["hyprland.shutdown"]()' \
        > "$harness"

    output=$("$LUA_BIN" "$harness" "$module")
    assert_contains "$output" "async"$'\t'"'$home/.config/hypr/scripts/lid-session-bridge.sh' start" \
        'the Lua start hook should delegate asynchronously to the installed bridge'
    assert_contains "$output" "sync"$'\t'"'$home/.config/hypr/scripts/lid-session-bridge.sh' stop" \
        'the Lua shutdown hook should block on the installed bridge'
)

installer_session_config_integration_is_idempotent() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture config
    local original contents begin_count end_count require_count iteration

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    config="$home/.config/hypr/hyprland.lua"
    original='hl.on("hyprland.start", function() print("keep me") end)'
    mkdir -p "$(dirname "$config")"
    printf '%s\n' "$original" > "$config"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    for iteration in 1 2; do
        "$ENV_BIN" -i \
            HOME="$home" \
            PATH="$fake_bin:$safe_bin" \
            WAYLAND_DISPLAY=wayland-test \
            HYPRLAND_INSTANCE_SIGNATURE=test-instance \
            XDG_SESSION_TYPE=wayland \
            TEST_EFFECT_LOG="$effect_log" \
            TEST_MONITORS_FIXTURE="$monitor_fixture" \
            "$ROOT_DIR/install-hyprland-lid-switch.sh" \
            > "$test_root/installer-$iteration.out" 2>&1
    done

    contents=$(<"$config")
    assert_contains "$contents" "$original" \
        'reinstallation should preserve the user-owned Hyprland callback'
    begin_count=$(grep -Fxc -- '-- BEGIN arch-lidswitch managed session integration' "$config")
    end_count=$(grep -Fxc -- '-- END arch-lidswitch managed session integration' "$config")
    require_count=$(grep -Fxc -- '    local ok, err = pcall(require, "arch_lidswitch.session")' "$config")
    if (( begin_count != 1 || end_count != 1 || require_count != 1 )); then
        printf 'expected one canonical managed block after reinstall; begin=%d end=%d require=%d\n%s\n' \
            "$begin_count" "$end_count" "$require_count" "$contents" >&2
        return 1
    fi
)

installer_refuses_malformed_session_config_ownership() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture config
    local original status=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    config="$home/.config/hypr/hyprland.lua"
    original=$'print("user config")\n-- BEGIN arch-lidswitch managed session integration\nprint("edited partial block")'
    mkdir -p "$(dirname "$config")"
    printf '%s\n' "$original" > "$config"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1 || status=$?

    if (( status == 0 )); then
        printf 'installer accepted malformed session ownership markers\n' >&2
        return 1
    fi
    if [[ "$(<"$config")" != "$original" ]]; then
        printf 'installer changed a malformed user config:\n%s\n' "$(<"$config")" >&2
        return 1
    fi
    if [[ -s "$effect_log" ]]; then
        printf 'malformed config ownership caused external effects:\n%s\n' \
            "$(<"$effect_log")" >&2
        return 1
    fi
    assert_contains "$(<"$test_root/installer.out")" \
        'malformed arch-lidswitch ownership markers' \
        'the refusal should explain the managed-block ownership problem'
)

installer_migrates_only_the_legacy_default_target_service() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture service effects

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    service="$home/.config/systemd/user/lid-monitor.service"
    mkdir -p "$(dirname "$service")"
    prepare_hyprland_config "$home"
    printf '%s\n' '[Install]' 'WantedBy=default.target' > "$service"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_REQUIRED_PATHS_BEFORE_DISABLE="$home/.config/hypr/scripts/lid-state.sh:$home/.config/hypr/scripts/monitor-state.sh:$home/.config/hypr/scripts/lid-switch.sh:$home/.config/hypr/scripts/lid-switch-doctor.sh:$home/.config/hypr/scripts/lid-monitor.sh:$home/.config/hypr/scripts/lid-session-bridge.sh:$home/.config/hypr/arch_lidswitch/session.lua:$home/.config/systemd/user/hyprland-session.target" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1

    effects=$(<"$effect_log")
    assert_before "$effects" \
        $'systemctl\t--user\tdisable\t--now\tlid-monitor.service' \
        $'systemctl\t--user\tdaemon-reload' \
        'the legacy default-target process should stop before the replacement unit is loaded'
    assert_not_contains "$effects" $'systemctl\t--user\trestart\tlid-monitor.service' \
        'BUG-003 should not absorb the general reinstall restart behavior from BUG-013'
    assert_not_contains "$(<"$service")" 'WantedBy=default.target' \
        'the migrated unit should no longer retain the early-login enablement target'
)

write_monitor_sequence() {
    local sequence_dir=$1
    local sequence_counter=$2
    local sequence_index=0
    local sequence_value final_value

    shift 2
    rm -f "$sequence_dir"/*.json
    for sequence_value in "$@"; do
        printf '%s\n' "$sequence_value" > \
            "$sequence_dir/$sequence_index.json"
        final_value=$sequence_value
        sequence_index=$((sequence_index + 1))
    done
    printf '%s\n' "$final_value" > "$sequence_dir/final.json"
    printf '%s\n' 0 > "$sequence_counter"
}

write_internal_layout_snapshot() {
    local runtime_dir=$1
    local snapshot_dir="$runtime_dir/arch-lidswitch"
    local snapshot_file="$snapshot_dir/internal-layout.json"

    mkdir -m 0700 -p "$snapshot_dir"
    printf '%s\n' \
        '{"output":"eDP-1","mode":"2880x1920@120","position":"0x0","scale":2,"transform":0,"mirror":""}' \
        > "$snapshot_file"
    chmod 0600 "$snapshot_file"
}

installed_cli_verifies_postconditions_and_dpms() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log runtime_dir monitor_fixture
    local sequence_dir sequence_counter framework disabled asleep awake invalid_dpms installed_cli
    local snapshot_file runtime_status output effects query_count command_count failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT
    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    runtime_dir="$test_root/runtime"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    sequence_dir="$test_root/topology-sequence"
    sequence_counter="$test_root/topology-counter"
    framework=$(jq -c 'map(.dpmsStatus = true)' \
        "$ROOT_DIR/tests/fixtures/monitors-json/framework.json")
    disabled=$(jq -c 'map(if .name == "eDP-1" then
        .disabled = true | .dpmsStatus = false else . end)' <<< "$framework")
    asleep=$(jq -c 'map(if .name == "eDP-1" then
        .dpmsStatus = false else . end)' <<< "$framework")
    awake=$framework
    invalid_dpms=$(jq -c 'map(if .name == "eDP-1" then
        .dpmsStatus = "true" else . end)' <<< "$framework")
    snapshot_file="$runtime_dir/arch-lidswitch/internal-layout.json"

    mkdir -m 0700 -p "$home" "$runtime_dir" "$sequence_dir"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"
    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$framework" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1
    installed_cli="$home/.config/hypr/scripts/lid-switch.sh"

    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$invalid_dpms"
    runtime_status=0
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        "$installed_cli" open > "$test_root/invalid-dpms.out" 2>&1 \
        || runtime_status=$?
    if (( runtime_status != 2 )); then
        printf 'non-boolean DPMS evidence should fail 2, got %d\n%s\n' \
            "$runtime_status" "$(<"$test_root/invalid-dpms.out")" >&2
        failures=$((failures + 1))
    fi
    assert_not_contains "$(<"$effect_log")" $'dpms\t' \
        'invalid DPMS evidence must remain nonmutating' \
        || failures=$((failures + 1))

    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$framework" "$framework"
    runtime_status=0
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        "$installed_cli" close > "$test_root/wrong.out" 2>&1 \
        || runtime_status=$?
    output=$(<"$test_root/wrong.out")
    effects=$(<"$effect_log")
    query_count=$(grep -Fxc $'hyprctl\t-j\tmonitors\tall' \
        "$effect_log" || true)
    command_count=$(grep -Fxc \
        $'monitor\toutput=eDP-1\tdisabled=true' "$effect_log" || true)
    if (( runtime_status != 4 || query_count != 2 || command_count != 1 )); then
        printf 'wrong postcondition should fail 4 after one apply/verify, got status=%d queries=%d commands=%d\n%s\n%s\n' \
            "$runtime_status" "$query_count" "$command_count" "$output" "$effects" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$output" 'desired_internal=disabled' \
        'postcondition failure should record the desired internal state' \
        || failures=$((failures + 1))
    assert_contains "$output" 'reason=postcondition_mismatch' \
        'postcondition failure should expose its reason' \
        || failures=$((failures + 1))
    assert_contains "$output" 'topology=' \
        'postcondition failure should retain the verified topology snapshot' \
        || failures=$((failures + 1))
    if [[ ! -f "$snapshot_file" ]]; then
        printf 'failed close verification discarded its recovery snapshot\n' >&2
        failures=$((failures + 1))
    fi

    write_internal_layout_snapshot "$runtime_dir"
    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$disabled" "$awake"
    runtime_status=0
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        "$installed_cli" open > "$test_root/open.out" 2>&1 \
        || runtime_status=$?
    output=$(<"$test_root/open.out")
    effects=$(<"$effect_log")
    if (( runtime_status != 0 )); then
        printf 'targeted open should verify successfully, got %d\n%s\n' \
            "$runtime_status" "$output" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$effects" \
        $'hyprctl\teval\thl.dispatch(hl.dsp.dpms({ action = "enable", monitor = "eDP-1" }))' \
        'explicit open should use the Hyprland 0.55 targeted DPMS Lua API' \
        || failures=$((failures + 1))
    assert_contains "$effects" $'dpms\toutput=eDP-1\tstate=on' \
        'explicit open should target only the internal output for wake' \
        || failures=$((failures + 1))
    assert_contains "$output" 'desired_dpms=true' \
        'successful explicit open should log its verified DPMS postcondition' \
        || failures=$((failures + 1))
    if [[ -e "$snapshot_file" || -L "$snapshot_file" ]]; then
        printf 'verified open did not clean its restored snapshot\n' >&2
        failures=$((failures + 1))
    fi

    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$asleep" "$asleep"
    printf '%s\n' 0 > "$test_root/dpms-counter"
    runtime_status=0
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        TEST_HYPRCTL_DPMS_FAILURES=1 \
        TEST_HYPRCTL_DPMS_COUNTER="$test_root/dpms-counter" \
        "$installed_cli" open > "$test_root/dpms-failed.out" 2>&1 \
        || runtime_status=$?
    effects=$(<"$effect_log")
    query_count=$(grep -Fxc $'hyprctl\t-j\tmonitors\tall' \
        "$effect_log" || true)
    if (( runtime_status != 3 || query_count != 2 )); then
        printf 'failed DPMS command should verify once and fail 3, got status=%d queries=%d\n%s\n' \
            "$runtime_status" "$query_count" \
            "$(<"$test_root/dpms-failed.out")" >&2
        failures=$((failures + 1))
    fi

    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$asleep" "$awake"
    runtime_status=0
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        TEST_HYPRCTL_DPMS_OUTPUT=error \
        "$installed_cli" open > "$test_root/dpms-non-ok.out" 2>&1 \
        || runtime_status=$?
    if (( runtime_status != 3 )); then
        printf 'exit-zero/non-ok DPMS output should fail 3, got %d\n%s\n' \
            "$runtime_status" "$(<"$test_root/dpms-non-ok.out")" >&2
        failures=$((failures + 1))
    fi

    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$framework" "$disabled"
    runtime_status=0
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        TEST_HYPRCTL_EVAL_OUTPUT=error \
        "$installed_cli" close > "$test_root/eval-non-ok.out" 2>&1 \
        || runtime_status=$?
    if (( runtime_status != 3 )); then
        printf 'exit-zero/non-ok monitor output should fail 3, got %d\n%s\n' \
            "$runtime_status" "$(<"$test_root/eval-non-ok.out")" >&2
        failures=$((failures + 1))
    fi

    write_internal_layout_snapshot "$runtime_dir"
    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$disabled" "$disabled"
    runtime_status=0
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        "$installed_cli" open > "$test_root/restore-failed.out" 2>&1 \
        || runtime_status=$?
    if (( runtime_status != 4 )) || [[ ! -f "$snapshot_file" ]]; then
        printf 'failed restore verification should retain snapshot (status=%d exists=%s)\n%s\n' \
            "$runtime_status" "$([[ -f "$snapshot_file" ]] && printf yes || printf no)" \
            "$(<"$test_root/restore-failed.out")" >&2
        failures=$((failures + 1))
    fi

    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$disabled" "$awake"
    runtime_status=0
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        "$installed_cli" open > "$test_root/restore-recovered.out" 2>&1 \
        || runtime_status=$?
    if (( runtime_status != 0 )) || [[ -e "$snapshot_file" || -L "$snapshot_file" ]]; then
        printf 'recovered restore should verify and clean snapshot (status=%d)\n%s\n' \
            "$runtime_status" "$(<"$test_root/restore-recovered.out")" >&2
        failures=$((failures + 1))
    fi
    effects=$(<"$effect_log")
    assert_not_contains "$effects" $'monitor\toutput=DP-2' \
        'BUG-010 recovery must not mutate an external output' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'systemctl\t' \
        'BUG-010 recovery must not request a power action' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installed_daemon_once_bounds_and_recovers_transient_failures() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log runtime_dir lid_root
    local monitor_fixture sequence_dir sequence_counter framework disabled
    local laptop_enabled laptop_disabled installed_daemon
    local runtime_status output effects query_count command_count failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT
    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    runtime_dir="$test_root/runtime"
    lid_root="$test_root/button/lid"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    sequence_dir="$test_root/topology-sequence"
    sequence_counter="$test_root/topology-counter"
    framework=$(jq -c 'map(.dpmsStatus = true)' \
        "$ROOT_DIR/tests/fixtures/monitors-json/framework.json")
    disabled=$(jq -c 'map(if .name == "eDP-1" then
        .disabled = true | .dpmsStatus = false else . end)' <<< "$framework")
    laptop_enabled=$(jq -c '[.[] | select(.name == "eDP-1")]' \
        <<< "$framework")
    laptop_disabled=$(jq -c '[.[] | select(.name == "eDP-1")
        | .disabled = true | .dpmsStatus = false]' <<< "$framework")

    mkdir -m 0700 -p "$home" "$runtime_dir" "$sequence_dir"
    create_lid_state_fixture "$lid_root" lid1
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$framework" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1
    installed_daemon="$home/.config/hypr/scripts/lid-monitor.sh"

    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$framework" "$framework" "$framework" \
        "$framework" "$framework" "$framework" \
        "$framework" "$framework" "$framework"
    runtime_status=0
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$installed_daemon" --once > "$test_root/bounded.out" 2>&1 \
        || runtime_status=$?
    output=$(<"$test_root/bounded.out")
    effects=$(<"$effect_log")
    query_count=$(grep -Fxc $'hyprctl\t-j\tmonitors\tall' \
        "$effect_log" || true)
    command_count=$(grep -Fxc \
        $'monitor\toutput=eDP-1\tdisabled=true' "$effect_log" || true)
    if (( runtime_status != 4 || query_count != 9 || command_count != 3 )); then
        printf '%s\n' "--once should stop after three failed attempts, got status=$runtime_status queries=$query_count commands=$command_count" \
            "$output" "$effects" \
            >&2
        failures=$((failures + 1))
    fi
    assert_contains "$output" 'attempt=3' \
        '--once terminal failure should identify the bounded third attempt' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'sleep\t1' \
        '--once must not enter the unbounded daemon loop' \
        || failures=$((failures + 1))

    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$framework" '__FAIL__' \
        "$framework" "$framework" "$disabled" "$disabled"
    runtime_status=0
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$installed_daemon" --once > "$test_root/query-recovered.out" 2>&1 \
        || runtime_status=$?
    if (( runtime_status != 0 )); then
        printf 'transient query failure did not recover: %d\n%s\n' \
            "$runtime_status" "$(<"$test_root/query-recovered.out")" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$(<"$test_root/query-recovered.out")" 'attempt=2' \
        'query recovery should be recorded on the second attempt' \
        || failures=$((failures + 1))

    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$framework" "$framework" "$framework" \
        "$framework" "$framework" "$disabled" "$disabled"
    printf '%s\n' 0 > "$test_root/eval-counter"
    runtime_status=0
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        TEST_HYPRCTL_EVAL_FAILURES=1 \
        TEST_HYPRCTL_EVAL_COUNTER="$test_root/eval-counter" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$installed_daemon" --once > "$test_root/apply-recovered.out" 2>&1 \
        || runtime_status=$?
    if (( runtime_status != 0 )); then
        printf 'transient apply failure did not recover: %d\n%s\n' \
            "$runtime_status" "$(<"$test_root/apply-recovered.out")" >&2
        failures=$((failures + 1))
    fi

    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$framework" "$framework" "$framework" \
        "$framework" "$framework" "$disabled" "$disabled"
    runtime_status=0
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$installed_daemon" --once > "$test_root/post-recovered.out" 2>&1 \
        || runtime_status=$?
    effects=$(<"$effect_log")
    command_count=$(grep -Fxc \
        $'monitor\toutput=eDP-1\tdisabled=true' "$effect_log" || true)
    if (( runtime_status != 0 || command_count != 2 )); then
        printf 'transient postcondition failure did not recover: status=%d commands=%d\n%s\n' \
            "$runtime_status" "$command_count" \
            "$(<"$test_root/post-recovered.out")" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$(<"$test_root/post-recovered.out")" 'attempt=2' \
        'postcondition recovery should be recorded on the second attempt' \
        || failures=$((failures + 1))

    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$framework" "$framework" "$disabled" "$laptop_disabled" \
        "$laptop_disabled" "$laptop_disabled" \
        "$laptop_enabled" "$laptop_enabled"
    runtime_status=0
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$installed_daemon" --once > "$test_root/policy-race.out" 2>&1 \
        || runtime_status=$?
    output=$(<"$test_root/policy-race.out")
    if (( runtime_status != 0 )); then
        printf 'post-action topology race did not remain pending and recover: %d\n%s\n' \
            "$runtime_status" "$output" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$output" 'reason=post_action_policy_mismatch' \
        'daemon must not mark a stale child postcondition as applied' \
        || failures=$((failures + 1))
    assert_contains "$output" 'trigger=once attempt=2' \
        'post-action policy mismatch should retry with the fresh joint state' \
        || failures=$((failures + 1))
    effects=$(<"$effect_log")
    assert_not_contains "$effects" $'monitor\toutput=DP-2' \
        'bounded retries must never mutate an external output' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'systemctl\t' \
        'bounded retries must never request a power action' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installed_daemon_separates_observed_applied_and_dpms_state() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log runtime_dir lid_root
    local monitor_fixture sequence_dir sequence_counter framework disabled asleep
    local installed_daemon output command_count started_count lid_writer failures=0
    local -a sequence_values=()
    local sequence_index

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT
    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    runtime_dir="$test_root/runtime"
    lid_root="$test_root/button/lid"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    sequence_dir="$test_root/topology-sequence"
    sequence_counter="$test_root/topology-counter"
    framework=$(jq -c 'map(.dpmsStatus = true)' \
        "$ROOT_DIR/tests/fixtures/monitors-json/framework.json")
    disabled=$(jq -c 'map(if .name == "eDP-1" then
        .disabled = true | .dpmsStatus = false else . end)' <<< "$framework")
    asleep=$(jq -c 'map(if .name == "eDP-1" then
        .dpmsStatus = false else . end)' <<< "$framework")

    mkdir -m 0700 -p "$home" "$runtime_dir" "$sequence_dir"
    create_lid_state_fixture "$lid_root" lid1
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$framework" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1
    installed_daemon="$home/.config/hypr/scripts/lid-monitor.sh"

    for ((sequence_index = 0; sequence_index < 16; sequence_index++)); do
        sequence_values+=("$framework")
    done
    sequence_values+=("$disabled" "$disabled")
    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "${sequence_values[@]}"
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$TIMEOUT_BIN" 0.4 "$installed_daemon" \
        > "$test_root/pending.out" 2>&1 || true
    output=$(<"$test_root/pending.out")
    command_count=$(grep -Fxc \
        $'monitor\toutput=eDP-1\tdisabled=true' "$effect_log" || true)
    if (( command_count != 4 )); then
        printf 'stable pending reconciliation should retry 3, cool down, then recover; got %d applies\n%s\n' \
            "$command_count" "$output" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$output" 'event=reconciliation_cooldown_started ticks=5' \
        'three normal-daemon failures should arm a five-tick cooldown' \
        || failures=$((failures + 1))
    assert_contains "$output" 'event=reconciliation_succeeded' \
        'a pending stable transition should recover without another input edge' \
        || failures=$((failures + 1))
    assert_not_contains "$output" 'event=joint_state_changed' \
        'post-action observation must not masquerade as a new input edge' \
        || failures=$((failures + 1))

    printf '%s\n' 'state: open' > "$lid_root/LID1/state"
    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$framework" "$framework" "$framework" "$framework" "$asleep"
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$TIMEOUT_BIN" 0.3 "$installed_daemon" \
        > "$test_root/dpms-only.out" 2>&1 || true
    output=$(<"$test_root/dpms-only.out")
    started_count=$(grep -Fc 'event=reconciliation_started' \
        "$test_root/dpms-only.out" || true)
    if (( started_count != 1 )); then
        printf 'DPMS-only observation should not reconcile; got %d reconciliations\n%s\n' \
            "$started_count" "$output" >&2
        failures=$((failures + 1))
    fi
    assert_not_contains "$(<"$effect_log")" $'dpms\t' \
        'steady open startup and idle DPMS changes must not wake the panel' \
        || failures=$((failures + 1))

    printf '%s\n' 'state: closed' > "$lid_root/LID1/state"
    write_monitor_sequence "$sequence_dir" "$sequence_counter" \
        "$framework" "$framework" "$disabled" "$disabled" "$disabled" \
        "$disabled" "$disabled" "$framework" "$framework"
    rm -f "$fake_bin/sleep"
    ln -s "$REAL_SLEEP_BIN" "$fake_bin/sleep"
    (
        "$REAL_SLEEP_BIN" 0.2
        printf '%s\n' 'state: open' > "$lid_root/LID1/state"
    ) &
    lid_writer=$!
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$TIMEOUT_BIN" 1.4 "$installed_daemon" \
        > "$test_root/open-edge.out" 2>&1 || true
    wait "$lid_writer"
    output=$(<"$test_root/open-edge.out")
    command_count=$(grep -Fxc $'dpms\toutput=eDP-1\tstate=on' \
        "$effect_log" || true)
    if (( command_count != 1 )); then
        printf 'a real closed-to-open edge should wake eDP-1 once, got %d\n%s\n' \
            "$command_count" "$output" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$output" \
        'event=lid_state_changed previous=closed current=open' \
        'daemon should distinguish a real open edge from steady open state' \
        || failures=$((failures + 1))
    assert_contains "$output" 'state=open preserve_dpms=false' \
        'the real open-edge wake intent must be preserved through reconciliation' \
        || failures=$((failures + 1))
    assert_not_contains "$(<"$effect_log")" $'monitor\toutput=DP-2' \
        'a real open edge must not mutate the external output' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

tests_run=0
tests_failed=0
tests_selected=0

run_test() {
    local test_id=$1
    local description=$2
    local test_function=$3
    local output

    if [[ -n "$TEST_FILTER" && "$test_id" != *"$TEST_FILTER"* ]]; then
        return 0
    fi

    tests_selected=$((tests_selected + 1))
    tests_run=$((tests_run + 1))
    if output=$("$test_function" 2>&1); then
        printf 'ok %d - %s\n' "$tests_run" "$description"
    else
        printf 'not ok %d - %s\n' "$tests_run" "$description"
        while IFS= read -r line; do
            printf '# %s\n' "$line"
        done <<< "$output"
        tests_failed=$((tests_failed + 1))
    fi
}

