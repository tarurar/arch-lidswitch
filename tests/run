    installer_migrates_only_the_legacy_default_target_service

if (( tests_selected == 0 )); then
    printf 'No tests matched filter: %s\n' "$TEST_FILTER" >&2
    exit 2
fi

printf '1..%d\n' "$tests_run"

if (( tests_failed > 0 )); then
    exit 1
fi
