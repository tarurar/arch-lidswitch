#!/bin/bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ENV_BIN=$(command -v env)
REAL_SLEEP_BIN=$(command -v sleep)
TIMEOUT_BIN=$(command -v timeout)
LUA_BIN=${LUA_BIN:-$(command -v lua)}
SYSTEMD_ANALYZE_BIN=$(command -v systemd-analyze)
TEST_FILTER=${1:-}

if [[ $# -gt 1 ]]; then
    printf 'usage: %s [test-filter]\n' "$0" >&2
    exit 2
fi

assert_contains() {
    local actual=$1
    local expected=$2
    local message=$3

    if [[ "$actual" != *"$expected"* ]]; then
        printf 'assertion failed: %s\nmissing: %s\nactual:\n%s\n' \
            "$message" "$expected" "$actual" >&2
        return 1
    fi
}

assert_not_contains() {
    local actual=$1
    local unexpected=$2
    local message=$3

    if [[ "$actual" == *"$unexpected"* ]]; then
        printf 'assertion failed: %s\nunexpected: %s\nactual:\n%s\n' \
            "$message" "$unexpected" "$actual" >&2
        return 1
    fi
}

install_safe_path() {
    local fake_bin=$1
    local safe_bin=$2
    local command_name command_path

    mkdir -p "$fake_bin" "$safe_bin"

    for command_name in busctl hyprctl systemctl systemd-inhibit pgrep pkill sleep; do
        ln -s "$ROOT_DIR/tests/fakes/effect" "$fake_bin/$command_name"
    done

    # Only ordinary utilities needed inside the isolated HOME are exposed.
    # Power, compositor, process-signal, and timing commands exist solely as fakes.
    for command_name in awk cat chmod cp cut date dirname grep head jq mkdir mktemp mv rm sed; do
        command_path=$(command -v "$command_name")
        ln -s "$command_path" "$safe_bin/$command_name"
    done
}

prepare_hyprland_config() {
    local home=$1

    mkdir -p "$home/.config/hypr"
    printf '%s\n' '-- isolated Hyprland Lua test config' \
        > "$home/.config/hypr/hyprland.lua"
}

assert_before() {
    local actual=$1
    local first=$2
    local second=$3
    local message=$4
    local first_prefix second_prefix

    if [[ "$actual" != *"$first"* ]] || [[ "$actual" != *"$second"* ]]; then
        printf 'assertion failed: %s\nrequired ordered values were absent\nactual:\n%s\n' \
            "$message" "$actual" >&2
        return 1
    fi

    first_prefix=${actual%%"$first"*}
    second_prefix=${actual%%"$second"*}
    if (( ${#first_prefix} >= ${#second_prefix} )); then
        printf 'assertion failed: %s\nfirst: %s\nsecond: %s\nactual:\n%s\n' \
            "$message" "$first" "$second" "$actual" >&2
        return 1
    fi
}

installed_cli_handles_documented_open_and_close() {
    installed_cli_round_trips_framework_layout
}

installed_cli_round_trips_internal_layout_profile() (
    set -euo pipefail

    local profile=$1
    local expected_mode=$2
    local expected_position=$3
    local expected_scale=$4
    local expected_transform=$5
    local expected_mirror=$6
    local test_root home fake_bin safe_bin effect_log monitor_fixture
    local runtime_dir monitor_json disabled_monitor_json installed_cli installed_state snapshot_file
    local close_effects open_effects close_output open_output
    local close_status=0 open_status=0 failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    runtime_dir="$test_root/runtime"
    monitor_json=$(<"$ROOT_DIR/tests/fixtures/monitors-json/$profile.json")
    disabled_monitor_json=$(jq -c \
        'map(if .name == "eDP-1" then .disabled = true else . end)' \
        <<< "$monitor_json")
    mkdir -m 0700 -p "$home" "$runtime_dir"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$monitor_json" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1

    installed_cli="$home/.config/hypr/scripts/lid-switch.sh"
    installed_state="$home/.config/hypr/scripts/monitor-state.sh"
    snapshot_file="$runtime_dir/arch-lidswitch/internal-layout.json"

    if [[ ! -x "$installed_state" ]]; then
        printf 'installer did not create an executable monitor-state module\n' >&2
        failures=$((failures + 1))
    elif ! cmp -s "$ROOT_DIR/runtime/monitor-state.sh" "$installed_state"; then
        printf 'installed monitor-state module differs from canonical source\n' >&2
        failures=$((failures + 1))
    fi

    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$monitor_json" \
        "$installed_cli" close \
        > "$test_root/close.out" 2>&1 || close_status=$?

    close_effects=$(<"$effect_log")
    close_output=$(<"$test_root/close.out")
    if (( close_status != 0 )); then
        printf 'expected %s close status 0, got %d\n%s\n' \
            "$profile" "$close_status" "$close_output" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$close_effects" $'hyprctl\t-j\tmonitors\tall' \
        'close should capture the structured internal layout before mutation' \
        || failures=$((failures + 1))
    assert_contains "$close_effects" $'monitor\toutput=eDP-1\tdisabled=true' \
        'close should disable only the installed internal output' \
        || failures=$((failures + 1))
    assert_not_contains "$close_effects" $'monitor\toutput=DP-2' \
        'close must preserve every external monitor property' \
        || failures=$((failures + 1))

    if [[ ! -f "$snapshot_file" ]]; then
        printf 'close did not create the internal layout snapshot: %s\n' \
            "$snapshot_file" >&2
        failures=$((failures + 1))
    else
        if [[ "$(stat -c %a "$runtime_dir/arch-lidswitch")" != 700 ]]; then
            printf 'monitor state directory was not mode 0700\n' >&2
            failures=$((failures + 1))
        fi
        if [[ "$(stat -c %a "$snapshot_file")" != 600 ]]; then
            printf 'monitor snapshot was not mode 0600\n' >&2
            failures=$((failures + 1))
        fi
        if ! jq -e \
            --arg mode "$expected_mode" \
            --arg position "$expected_position" \
            --argjson scale "$expected_scale" \
            --argjson transform "$expected_transform" \
            --arg mirror "$expected_mirror" \
            '. == {output:"eDP-1", mode:$mode, position:$position, scale:$scale, transform:$transform, mirror:$mirror}' \
            "$snapshot_file" >/dev/null; then
            printf 'snapshot did not preserve the %s internal layout:\n%s\n' \
                "$profile" "$(<"$snapshot_file")" >&2
            failures=$((failures + 1))
        fi
    fi

    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$disabled_monitor_json" \
        "$installed_cli" open \
        > "$test_root/open.out" 2>&1 || open_status=$?

    open_effects=$(<"$effect_log")
    open_output=$(<"$test_root/open.out")
    if (( open_status != 0 )); then
        printf 'expected %s open status 0, got %d\n%s\n' \
            "$profile" "$open_status" "$open_output" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$open_effects" \
        "monitor"$'\t'"output=eDP-1"$'\t'"disabled=false"$'\t'"mode=$expected_mode"$'\t'"position=$expected_position"$'\t'"scale=$expected_scale"$'\t'"transform=$expected_transform"$'\t'"mirror=$expected_mirror" \
        'open should restore every captured internal monitor property' \
        || failures=$((failures + 1))
    assert_not_contains "$open_effects" $'monitor\toutput=DP-2' \
        'open must preserve every external monitor property' \
        || failures=$((failures + 1))
    if [[ -e "$snapshot_file" || -L "$snapshot_file" ]]; then
        printf 'successful restore left a stale internal layout snapshot\n' >&2
        failures=$((failures + 1))
    fi

    (( failures == 0 ))
)

installed_cli_round_trips_framework_layout() {
    installed_cli_round_trips_internal_layout_profile \
        framework '2880x1920@120' '0x0' 2 0 ''
}

installed_cli_round_trips_rotated_fractional_layout() {
    installed_cli_round_trips_internal_layout_profile \
        rotated-fractional '2256x1504@59.998' '-1504x120' 1.25 1 'DP-2'
}

installed_cli_noops_open_when_internal_is_enabled() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log runtime_dir monitor_fixture
    local monitor_json installed_cli runtime_output effects runtime_status=0 failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    runtime_dir="$test_root/runtime"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/multiple-external.txt"
    monitor_json=$(<"$ROOT_DIR/tests/fixtures/monitors-json/framework.json")
    mkdir -m 0700 -p "$home" "$runtime_dir"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$monitor_json" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1

    installed_cli="$home/.config/hypr/scripts/lid-switch.sh"
    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$monitor_json" \
        "$installed_cli" open \
        > "$test_root/runtime.out" 2>&1 || runtime_status=$?

    runtime_output=$(<"$test_root/runtime.out")
    effects=$(<"$effect_log")
    if (( runtime_status != 0 )); then
        printf 'expected enabled-internal open status 0, got %d\n%s\n' \
            "$runtime_status" "$runtime_output" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$effects" $'hyprctl\t-j\tmonitors\tall' \
        'open should inspect one structured all-output topology' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'hyprctl\tmonitors' \
        'open must not use the human-readable active-output query' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'monitor\t' \
        'open hotplug must not rewrite an already-enabled internal or any external' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'pkill\t' \
        'an open no-op must not refresh Waybar' \
        || failures=$((failures + 1))
    assert_contains "$runtime_output" \
        'event=layout_noop action=open reason=internal_already_enabled' \
        'open should explain why topology changes require no mutation' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installed_cli_reconciles_closed_topology_without_external_mutation() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log runtime_dir monitor_fixture
    local framework docked_disabled undocked_disabled inactive_external mixed_external
    local installed_cli runtime_status runtime_output effects query_count failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    runtime_dir="$test_root/runtime"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/multiple-external.txt"
    framework=$(<"$ROOT_DIR/tests/fixtures/monitors-json/framework.json")
    docked_disabled=$(jq -c \
        'map(if .name == "eDP-1" then .disabled = true else . end)' \
        <<< "$framework")
    undocked_disabled=$(jq -c \
        '[.[] | select(.name == "eDP-1") | .disabled = true]' \
        <<< "$framework")
    inactive_external=$(jq -cn --argjson monitors "$framework" '
        [($monitors[] | select(.name == "eDP-1")),
         {name:"WL-1", disabled:true, dpmsStatus:true}]
    ')
    mixed_external=$(jq -cn --argjson monitors "$framework" '
        [($monitors[] | select(.name == "eDP-1")),
         {name:"Virtual-2", disabled:true, dpmsStatus:true},
         {name:"WL-1", disabled:false, dpmsStatus:false},
         {name:"USB-Custom", disabled:false, dpmsStatus:true}]
    ')
    mkdir -m 0700 -p "$home" "$runtime_dir"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$framework" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1
    installed_cli="$home/.config/hypr/scripts/lid-switch.sh"

    run_closed_profile() {
        local label=$1
        local topology=$2

        runtime_status=0
        : > "$effect_log"
        "$ENV_BIN" -i \
            HOME="$home" \
            PATH="$fake_bin:$safe_bin" \
            XDG_RUNTIME_DIR="$runtime_dir" \
            TEST_EFFECT_LOG="$effect_log" \
            TEST_MONITORS_FIXTURE="$monitor_fixture" \
            TEST_HYPRCTL_MONITORS_JSON="$topology" \
            "$installed_cli" close \
            > "$test_root/$label.out" 2>&1 || runtime_status=$?
        runtime_output=$(<"$test_root/$label.out")
        effects=$(<"$effect_log")
        query_count=$(grep -Fxc \
            $'hyprctl\t-j\tmonitors\tall' "$effect_log" || true)
        if (( runtime_status != 0 )); then
            printf 'expected %s closed status 0, got %d\n%s\n' \
                "$label" "$runtime_status" "$runtime_output" >&2
            return 1
        fi
        if (( query_count != 2 )); then
            printf 'expected %s to use pre/post topology queries, got %d\n%s\n' \
                "$label" "$query_count" "$effects" >&2
            return 1
        fi
        assert_not_contains "$effects" $'hyprctl\tmonitors' \
            "$label must not use human-readable monitor discovery" || return 1
        assert_not_contains "$effects" $'monitor\toutput=DP-2' \
            "$label must not mutate DP-2" || return 1
        assert_not_contains "$effects" $'monitor\toutput=WL-1' \
            "$label must not mutate WL-1" || return 1
        assert_not_contains "$effects" $'monitor\toutput=USB-Custom' \
            "$label must not mutate USB-Custom" || return 1
    }

    run_closed_profile docked-enabled "$framework" \
        || failures=$((failures + 1))
    assert_contains "$effects" $'monitor\toutput=eDP-1\tdisabled=true' \
        'closed with an enabled external should capture then disable the internal' \
        || failures=$((failures + 1))

    run_closed_profile docked-already-disabled "$docked_disabled" \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'monitor\t' \
        'closed with internal already disabled and an enabled external should no-op' \
        || failures=$((failures + 1))
    assert_contains "$runtime_output" \
        'event=layout_noop action=close reason=internal_already_disabled' \
        'repeated closed topology should report its no-op' \
        || failures=$((failures + 1))

    run_closed_profile undocked-disabled "$undocked_disabled" \
        || failures=$((failures + 1))
    assert_contains "$effects" $'monitor\toutput=eDP-1\tdisabled=false' \
        'undock while closed should restore a disabled internal before delegation' \
        || failures=$((failures + 1))
    assert_contains "$runtime_output" \
        'event=power_delegated owner=systemd-logind action=close reason=no_enabled_external' \
        'undocked closed state should delegate power after restoring the internal' \
        || failures=$((failures + 1))

    run_closed_profile external-inactive "$inactive_external" \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'monitor\t' \
        'an inactive external must not count as enabled' \
        || failures=$((failures + 1))
    assert_contains "$runtime_output" \
        'event=power_delegated owner=systemd-logind action=close reason=no_enabled_external' \
        'closed with only inactive externals should delegate power' \
        || failures=$((failures + 1))

    run_closed_profile external-activated "$mixed_external" \
        || failures=$((failures + 1))
    assert_contains "$effects" $'monitor\toutput=eDP-1\tdisabled=true' \
        'activating any external while closed should disable an enabled internal' \
        || failures=$((failures + 1))
    assert_contains "$runtime_output" 'enabled_external_count=2' \
        'mixed multiple externals should count only enabled records' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installed_daemon_observes_joint_lid_and_topology_changes() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log runtime_dir lid_root
    local monitor_fixture installed_daemon sequence_dir sequence_counter
    local framework internal external_enabled external_inactive docked docked_disabled inactive
    local undocked_enabled undocked_disabled daemon_output effects
    local disable_count restore_count failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    runtime_dir="$test_root/runtime"
    lid_root="$test_root/button/lid"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    sequence_dir="$test_root/topology-sequence"
    sequence_counter="$test_root/topology-counter"
    framework=$(<"$ROOT_DIR/tests/fixtures/monitors-json/framework.json")
    internal=$(jq -c '.[] | select(.name == "eDP-1")' <<< "$framework")
    external_enabled='{"name":"WL-1","disabled":false,"dpmsStatus":false}'
    external_inactive='{"name":"WL-1","disabled":true,"dpmsStatus":true}'
    docked=$(jq -cn --argjson internal "$internal" \
        --argjson external "$external_enabled" '[$internal, $external]')
    docked_disabled=$(jq -cn --argjson internal "$internal" \
        --argjson external "$external_enabled" \
        '[($internal | .disabled = true), $external]')
    inactive=$(jq -cn --argjson internal "$internal" \
        --argjson external "$external_inactive" '[$internal, $external]')
    undocked_enabled=$(jq -cn --argjson internal "$internal" '[$internal]')
    undocked_disabled=$(jq -cn --argjson internal "$internal" \
        '[($internal | .disabled = true)]')

    mkdir -m 0700 -p "$home" "$runtime_dir" "$sequence_dir"
    create_lid_state_fixture "$lid_root" lid1
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$docked" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1
    installed_daemon="$home/.config/hypr/scripts/lid-monitor.sh"

    # Startup and every changed joint state receive a child pre/post query and
    # a daemon post-action observation. The failed poll stays pending without
    # consuming or corrupting the later topology transitions.
    printf '%s\n' "$undocked_enabled" > "$sequence_dir/0.json"
    printf '%s\n' "$undocked_enabled" > "$sequence_dir/1.json"
    printf '%s\n' "$undocked_enabled" > "$sequence_dir/2.json"
    printf '%s\n' "$undocked_enabled" > "$sequence_dir/3.json"
    printf '%s\n' '__FAIL__' > "$sequence_dir/4.json"
    printf '%s\n' "$inactive" > "$sequence_dir/5.json"
    printf '%s\n' "$inactive" > "$sequence_dir/6.json"
    printf '%s\n' "$inactive" > "$sequence_dir/7.json"
    printf '%s\n' "$inactive" > "$sequence_dir/8.json"
    printf '%s\n' "$docked" > "$sequence_dir/9.json"
    printf '%s\n' "$docked" > "$sequence_dir/10.json"
    printf '%s\n' "$docked_disabled" > "$sequence_dir/11.json"
    printf '%s\n' "$docked_disabled" > "$sequence_dir/12.json"
    printf '%s\n' "$undocked_disabled" > "$sequence_dir/13.json"
    printf '%s\n' "$undocked_disabled" > "$sequence_dir/14.json"
    printf '%s\n' "$undocked_enabled" > "$sequence_dir/15.json"
    printf '%s\n' "$undocked_enabled" > "$sequence_dir/16.json"
    printf '%s\n' "$undocked_enabled" > "$sequence_dir/final.json"
    printf '%s\n' 0 > "$sequence_counter"

    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$TIMEOUT_BIN" 0.5 "$installed_daemon" \
        > "$test_root/daemon.out" 2>&1 || true

    daemon_output=$(<"$test_root/daemon.out")
    effects=$(<"$effect_log")
    disable_count=$(grep -Fxc \
        $'monitor\toutput=eDP-1\tdisabled=true' "$effect_log" || true)
    restore_count=$(grep -Fc \
        $'monitor\toutput=eDP-1\tdisabled=false' "$effect_log" || true)

    if (( disable_count != 1 || restore_count != 1 )); then
        printf 'expected one internal disable and restore, got disable=%d restore=%d\n%s\n' \
            "$disable_count" "$restore_count" "$effects" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$daemon_output" \
        'event=topology_observation_failed reason=monitor_query_failed' \
        'daemon should expose and retain a failed topology observation' \
        || failures=$((failures + 1))
    assert_contains "$daemon_output" 'event=joint_state_changed' \
        'daemon should react while the lid remains closed and topology changes' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'monitor\toutput=WL-1' \
        'daemon-triggered transitions must never mutate the external output' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'systemctl\t' \
        'daemon topology reconciliation must not request repository-owned power actions' \
        || failures=$((failures + 1))
    if [[ -e "$runtime_dir/arch-lidswitch/internal-layout.json" ]]; then
        printf 'daemon round trip left a stale internal layout snapshot\n' >&2
        failures=$((failures + 1))
    fi

    (( failures == 0 ))
)

installed_daemon_once_reconciles_closed_docked_startup() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log runtime_dir lid_root
    local monitor_fixture monitor_json installed_daemon runtime_output effects
    local runtime_status=0 failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    runtime_dir="$test_root/runtime"
    lid_root="$test_root/button/lid"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    monitor_json=$(<"$ROOT_DIR/tests/fixtures/monitors-json/framework.json")
    mkdir -m 0700 -p "$home" "$runtime_dir"
    create_lid_state_fixture "$lid_root" lid1
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$monitor_json" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1
    installed_daemon="$home/.config/hypr/scripts/lid-monitor.sh"

    : > "$effect_log"
    "$TIMEOUT_BIN" 0.2 "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$monitor_json" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$installed_daemon" --once \
        > "$test_root/runtime.out" 2>&1 || runtime_status=$?

    runtime_output=$(<"$test_root/runtime.out")
    effects=$(<"$effect_log")
    if (( runtime_status != 0 )); then
        printf 'expected --once status 0, got %d\n%s\n' \
            "$runtime_status" "$runtime_output" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$effects" $'monitor\toutput=eDP-1\tdisabled=true' \
        '--once should reconcile an initially closed docked laptop without a lid edge' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'monitor\toutput=DP-2' \
        '--once must retain the existing external layout' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'systemctl\t' \
        '--once must not request a repository-owned power action' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'sleep\t1' \
        '--once should exit before entering the monitor loop' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installed_daemon_once_reconciles_supported_initial_states() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log runtime_dir lid_root lid_state_file
    local monitor_fixture framework laptop_only installed_daemon
    local runtime_status runtime_output effects failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    runtime_dir="$test_root/runtime"
    lid_root="$test_root/button/lid"
    lid_state_file="$lid_root/LID0/state"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    framework=$(<"$ROOT_DIR/tests/fixtures/monitors-json/framework.json")
    laptop_only=$(jq -c '[.[] | select(.name == "eDP-1")]' <<< "$framework")
    mkdir -m 0700 -p "$home" "$runtime_dir" "$lid_root/LID0"
    printf '%s\n' 'state: open' > "$lid_state_file"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$framework" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1
    installed_daemon="$home/.config/hypr/scripts/lid-monitor.sh"

    run_initial_profile() {
        local label=$1
        local lid_state=$2
        local topology=$3
        local expected_record=$4

        runtime_status=0
        printf 'state: %s\n' "$lid_state" > "$lid_state_file"
        : > "$effect_log"
        "$TIMEOUT_BIN" 1 "$ENV_BIN" -i \
            HOME="$home" \
            PATH="$fake_bin:$safe_bin" \
            XDG_RUNTIME_DIR="$runtime_dir" \
            TEST_EFFECT_LOG="$effect_log" \
            TEST_MONITORS_FIXTURE="$monitor_fixture" \
            TEST_HYPRCTL_MONITORS_JSON="$topology" \
            HYPR_LID_STATE_ROOT="$lid_root" \
            "$installed_daemon" --once \
            > "$test_root/$label.out" 2>&1 || runtime_status=$?
        runtime_output=$(<"$test_root/$label.out")
        effects=$(<"$effect_log")

        if (( runtime_status != 0 )); then
            printf 'expected %s --once status 0, got %d\n%s\n' \
                "$label" "$runtime_status" "$runtime_output" >&2
            return 1
        fi
        assert_contains "$runtime_output" "$expected_record" \
            "$label should report the selected initial-state outcome" || return 1
        assert_not_contains "$effects" $'monitor\t' \
            "$label should preserve an already-safe internal layout" || return 1
        assert_not_contains "$effects" $'systemctl\t' \
            "$label must not request repository-owned power" || return 1
        assert_not_contains "$effects" $'sleep\t1' \
            "$label --once must not enter the monitor loop" || return 1
    }

    run_initial_profile open-external open "$framework" \
        'event=layout_noop action=open reason=internal_already_enabled enabled_external_count=1' \
        || failures=$((failures + 1))
    run_initial_profile open-laptop open "$laptop_only" \
        'event=layout_noop action=open reason=internal_already_enabled enabled_external_count=0' \
        || failures=$((failures + 1))
    run_initial_profile closed-laptop closed "$laptop_only" \
        'event=power_delegated owner=systemd-logind action=close reason=no_enabled_external' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installed_daemon_once_refuses_invalid_joint_observations() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log runtime_dir lid_root
    local monitor_fixture framework installed_daemon sequence_dir sequence_counter
    local runtime_status runtime_output effects query_count failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    runtime_dir="$test_root/runtime"
    lid_root="$test_root/button/lid"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    framework=$(<"$ROOT_DIR/tests/fixtures/monitors-json/framework.json")
    sequence_dir="$test_root/topology-sequence"
    sequence_counter="$test_root/topology-counter"
    mkdir -m 0700 -p "$home" "$runtime_dir" "$sequence_dir"
    create_lid_state_fixture "$lid_root" lid1
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$framework" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1
    installed_daemon="$home/.config/hypr/scripts/lid-monitor.sh"

    runtime_status=0
    : > "$effect_log"
    "$TIMEOUT_BIN" 1 "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_HYPRCTL_MONITORS_JSON="$framework" \
        HYPR_LID_STATE_ROOT="$test_root/missing-lid" \
        "$installed_daemon" --once \
        > "$test_root/missing-lid.out" 2>&1 || runtime_status=$?
    runtime_output=$(<"$test_root/missing-lid.out")
    if (( runtime_status == 0 || runtime_status == 124 )); then
        printf 'expected missing lid observation failure, got status %d\n%s\n' \
            "$runtime_status" "$runtime_output" >&2
        failures=$((failures + 1))
    fi
    assert_not_contains "$(<"$effect_log")" $'hyprctl\t' \
        'missing lid retries must not query or mutate the compositor' \
        || failures=$((failures + 1))
    assert_not_contains "$(<"$effect_log")" $'systemctl\t' \
        'missing lid retries must not request power' \
        || failures=$((failures + 1))

    printf '%s\n' "$framework" > "$sequence_dir/0.json"
    printf '%s\n' '__FAIL__' > "$sequence_dir/1.json"
    printf '%s\n' '__FAIL__' > "$sequence_dir/final.json"
    printf '%s\n' 0 > "$sequence_counter"
    runtime_status=0
    : > "$effect_log"
    "$TIMEOUT_BIN" 1 "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_DIR="$sequence_dir" \
        TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER="$sequence_counter" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$installed_daemon" --once \
        > "$test_root/query-failure.out" 2>&1 || runtime_status=$?
    runtime_output=$(<"$test_root/query-failure.out")
    effects=$(<"$effect_log")
    query_count=$(grep -Fxc $'hyprctl\t-j\tmonitors\tall' "$effect_log" || true)
    if (( runtime_status != 2 )); then
        printf 'expected child monitor-query status 2, got %d\n%s\n' \
            "$runtime_status" "$runtime_output" >&2
        failures=$((failures + 1))
    fi
    if (( query_count != 4 )); then
        printf 'expected the bounded joint/child query attempts, got %d\n%s\n' \
            "$query_count" "$effects" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$runtime_output" \
        'event=reconciliation_failed trigger=once attempt=1 state=closed status=2' \
        '--once should expose the installed lid-switch failure status' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'monitor\t' \
        'a failed child query must not mutate monitor state' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'pkill\t' \
        'a failed child query must not refresh Waybar' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'systemctl\t' \
        'a failed child query must not request power' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'sleep\t1' \
        'a failed --once attempt must not retry or enter the loop' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installed_normal_daemon_reconciles_before_first_edge() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log runtime_dir lid_root
    local monitor_fixture monitor_json installed_daemon runtime_output effects
    local runtime_status=0 disable_count failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    runtime_dir="$test_root/runtime"
    lid_root="$test_root/button/lid"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    monitor_json=$(<"$ROOT_DIR/tests/fixtures/monitors-json/framework.json")
    mkdir -m 0700 -p "$home" "$runtime_dir"
    create_lid_state_fixture "$lid_root" lid1
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$monitor_json" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1
    installed_daemon="$home/.config/hypr/scripts/lid-monitor.sh"

    rm -f "$fake_bin/sleep"
    ln -s "$REAL_SLEEP_BIN" "$fake_bin/sleep"
    : > "$effect_log"
    "$TIMEOUT_BIN" 0.4 "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$monitor_json" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$installed_daemon" \
        > "$test_root/runtime.out" 2>&1 || runtime_status=$?

    runtime_output=$(<"$test_root/runtime.out")
    effects=$(<"$effect_log")
    disable_count=$(grep -Fxc \
        $'monitor\toutput=eDP-1\tdisabled=true' "$effect_log" || true)
    if (( runtime_status != 124 )); then
        printf 'expected running daemon timeout status 124, got %d\n%s\n' \
            "$runtime_status" "$runtime_output" >&2
        failures=$((failures + 1))
    fi
    if (( disable_count != 1 )); then
        printf 'expected one startup disable before any edge, got %d\n%s\n' \
            "$disable_count" "$effects" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$runtime_output" \
        'event=reconciliation_succeeded trigger=startup attempt=1 state=closed' \
        'normal daemon startup should report successful immediate reconciliation' \
        || failures=$((failures + 1))
    assert_not_contains "$runtime_output" 'event=joint_state_changed' \
        'startup reconciliation must not require a lid or topology edge' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'systemctl\t' \
        'normal startup must not request repository-owned power' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installed_daemon_once_is_outcome_idempotent() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log runtime_dir lid_root
    local monitor_fixture framework disabled_framework installed_daemon
    local first_status=0 second_status=0 first_effects second_effects second_output failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    runtime_dir="$test_root/runtime"
    lid_root="$test_root/button/lid"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    framework=$(<"$ROOT_DIR/tests/fixtures/monitors-json/framework.json")
    disabled_framework=$(jq -c \
        'map(if .name == "eDP-1" then .disabled = true else . end)' \
        <<< "$framework")
    mkdir -m 0700 -p "$home" "$runtime_dir"
    create_lid_state_fixture "$lid_root" lid1
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$framework" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1
    installed_daemon="$home/.config/hypr/scripts/lid-monitor.sh"

    : > "$effect_log"
    "$TIMEOUT_BIN" 1 "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$framework" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$installed_daemon" --once \
        > "$test_root/first.out" 2>&1 || first_status=$?
    first_effects=$(<"$effect_log")

    : > "$effect_log"
    "$TIMEOUT_BIN" 1 "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$disabled_framework" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$installed_daemon" --once \
        > "$test_root/second.out" 2>&1 || second_status=$?
    second_effects=$(<"$effect_log")
    second_output=$(<"$test_root/second.out")

    if (( first_status != 0 || second_status != 0 )); then
        printf 'expected repeated --once statuses 0/0, got %d/%d\nfirst:\n%s\nsecond:\n%s\n' \
            "$first_status" "$second_status" \
            "$(<"$test_root/first.out")" "$second_output" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$first_effects" $'monitor\toutput=eDP-1\tdisabled=true' \
        'the first reconciliation should reach clamshell state' \
        || failures=$((failures + 1))
    assert_not_contains "$second_effects" $'monitor\t' \
        'restarting reconciliation in the achieved state should be a safe no-op' \
        || failures=$((failures + 1))
    assert_contains "$second_output" \
        'event=layout_noop action=close reason=internal_already_disabled' \
        'the repeated reconciliation should report its idempotent outcome' \
        || failures=$((failures + 1))
    assert_not_contains "$second_effects" $'systemctl\t' \
        'repeated reconciliation must not request repository-owned power' \
        || failures=$((failures + 1))
    assert_not_contains "$second_effects" $'sleep\t1' \
        'repeated --once must still exit before the monitor loop' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installed_cli_snapshot_failure_is_safe() (
    set -euo pipefail

    local scenario=$1
    local transition=$2
    local expected_event=$3
    local expected_reason=$4
    local test_root home fake_bin safe_bin effect_log monitor_fixture runtime_dir
    local installed_cli runtime_output effects runtime_status=0 disabled_topology
    local -a scenario_environment=()

    test_root=$(mktemp -d)
    trap 'chmod 0700 "$test_root/runtime" 2>/dev/null || true; rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    runtime_dir="$test_root/runtime"
    mkdir -m 0700 -p "$home" "$runtime_dir"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"
    disabled_topology=$(jq -c \
        'map(if .name == "eDP-1" then .disabled = true else . end)' \
        "$ROOT_DIR/tests/fixtures/monitors-json/framework.json")

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1

    installed_cli="$home/.config/hypr/scripts/lid-switch.sh"
    case "$scenario" in
        capture-missing)
            scenario_environment=('TEST_HYPRCTL_MONITORS_JSON=[]')
            ;;
        capture-malformed)
            scenario_environment=('TEST_HYPRCTL_MONITORS_JSON={not-json')
            ;;
        capture-query-failure)
            scenario_environment=('TEST_HYPRCTL_MONITORS_JSON_FAIL=1')
            ;;
        capture-unwritable)
            chmod 0500 "$runtime_dir"
            ;;
        restore-missing)
            scenario_environment=("TEST_HYPRCTL_MONITORS_JSON=$disabled_topology")
            ;;
        restore-malformed)
            scenario_environment=("TEST_HYPRCTL_MONITORS_JSON=$disabled_topology")
            mkdir -m 0700 "$runtime_dir/arch-lidswitch"
            printf '%s\n' '{"output":"DP-2","mode":"unsafe"}' \
                > "$runtime_dir/arch-lidswitch/internal-layout.json"
            chmod 0600 "$runtime_dir/arch-lidswitch/internal-layout.json"
            ;;
        *)
            printf 'unknown snapshot failure scenario: %s\n' "$scenario" >&2
            return 2
            ;;
    esac

    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "${scenario_environment[@]}" \
        "$installed_cli" "$transition" \
        > "$test_root/runtime.out" 2>&1 || runtime_status=$?

    runtime_output=$(<"$test_root/runtime.out")
    effects=$(<"$effect_log")
    if (( runtime_status != 2 )); then
        printf 'expected %s status 2, got %d\n%s\n' \
            "$scenario" "$runtime_status" "$runtime_output" >&2
        return 1
    fi
    assert_contains "$runtime_output" \
        "event=$expected_event action=$transition reason=$expected_reason" \
        'snapshot failure should be visible at the installed CLI boundary'
    assert_not_contains "$effects" $'monitor\t' \
        'snapshot failure must not mutate any monitor'
    assert_not_contains "$effects" $'pkill\t' \
        'snapshot failure must not run the post-layout Waybar workaround'
)

installed_cli_refuses_close_without_a_valid_snapshot() (
    set -euo pipefail

    local scenario event reason failures=0
    while IFS='|' read -r scenario event reason; do
        if ! installed_cli_snapshot_failure_is_safe \
            "$scenario" close "$event" "$reason"; then
            failures=$((failures + 1))
        fi
    done <<'EOF'
capture-missing|monitor_query_failed|monitor_topology_invalid
capture-malformed|monitor_query_failed|monitor_topology_invalid
capture-query-failure|monitor_query_failed|monitor_query_failed
capture-unwritable|layout_snapshot_failed|snapshot_directory_unwritable
EOF

    (( failures == 0 ))
)

installed_cli_refuses_open_without_a_valid_snapshot() (
    set -euo pipefail

    local scenario event reason failures=0
    while IFS='|' read -r scenario event reason; do
        if ! installed_cli_snapshot_failure_is_safe \
            "$scenario" open "$event" "$reason"; then
            failures=$((failures + 1))
        fi
    done <<'EOF'
restore-missing|layout_snapshot_failed|snapshot_missing
restore-malformed|layout_snapshot_failed|snapshot_invalid
EOF

    (( failures == 0 ))
)

installed_cli_delegates_laptop_only_close_to_logind() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture monitor_json installed_cli
    local runtime_effects runtime_output runtime_status=0 failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/laptop-only.txt"
    monitor_json=$(jq -c '[.[] | select(.name == "eDP-1")]' \
        "$ROOT_DIR/tests/fixtures/monitors-json/framework.json")
    mkdir -p "$home"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$monitor_json" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1

    installed_cli="$home/.config/hypr/scripts/lid-switch.sh"
    : > "$effect_log"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$monitor_json" \
        "$installed_cli" close \
        > "$test_root/runtime.out" 2>&1 || runtime_status=$?

    runtime_effects=$(<"$effect_log")
    runtime_output=$(<"$test_root/runtime.out")

    if (( runtime_status != 0 )); then
        printf 'expected delegated close status 0, got %d\nruntime output:\n%s\n' \
            "$runtime_status" "$runtime_output" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$runtime_effects" $'hyprctl\t-j\tmonitors\tall' \
        'the installed CLI should inspect the current monitor state' \
        || failures=$((failures + 1))
    assert_not_contains "$runtime_effects" $'systemctl\t' \
        'the display helper must not request a lid power action' \
        || failures=$((failures + 1))
    assert_not_contains "$runtime_effects" $'monitor\t' \
        'a laptop-only close should not mutate display state' \
        || failures=$((failures + 1))
    assert_contains "$runtime_output" \
        'level=info component=lid-switch event=power_delegated owner=systemd-logind action=close reason=no_enabled_external' \
        'the installed CLI should record the single lid-power owner' \
        || failures=$((failures + 1))
    assert_not_contains "$runtime_output" 'event=power_action_requested' \
        'the display helper must not report a repository-owned power request' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installed_doctor_accepts_chosen_logind_policy() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture doctor
    local doctor_output effects doctor_status=0 failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    mkdir -p "$home"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1

    doctor="$home/.config/hypr/scripts/lid-switch-doctor.sh"
    if [[ ! -x "$doctor" ]]; then
        printf 'installer did not create an executable lid-switch doctor\n' >&2
        return 1
    fi
    if ! cmp -s "$ROOT_DIR/runtime/lid-switch-doctor.sh" "$doctor"; then
        printf 'installed doctor differs from the canonical runtime source\n' >&2
        return 1
    fi

    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        "$doctor" \
        > "$test_root/doctor.out" 2>&1 || doctor_status=$?

    doctor_output=$(<"$test_root/doctor.out")
    effects=$(<"$effect_log")

    if (( doctor_status != 0 )); then
        printf 'expected healthy doctor status 0, got %d\ndoctor output:\n%s\n' \
            "$doctor_status" "$doctor_output" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$doctor_output" 'PASS HandleLidSwitch=suspend' \
        'doctor should report the chosen undocked action' \
        || failures=$((failures + 1))
    assert_contains "$doctor_output" 'PASS HandleLidSwitchDocked=ignore' \
        'doctor should report the chosen docked action' \
        || failures=$((failures + 1))
    assert_contains "$doctor_output" \
        'PASS HandleLidSwitchExternalPower=<unset> fallback=HandleLidSwitch' \
        'doctor should report the default external-power fallback' \
        || failures=$((failures + 1))
    assert_contains "$doctor_output" 'PASS handle-lid-switch inhibitors=none' \
        'doctor should prove that no other process owns the lid switch' \
        || failures=$((failures + 1))
    assert_contains "$effects" $'busctl\tget-property\torg.freedesktop.login1\t/org/freedesktop/login1\torg.freedesktop.login1.Manager\tHandleLidSwitchDocked' \
        'doctor should read the effective docked action' \
        || failures=$((failures + 1))
    assert_contains "$effects" $'busctl\tget-property\torg.freedesktop.login1\t/org/freedesktop/login1\torg.freedesktop.login1.Manager\tHandleLidSwitchExternalPower' \
        'doctor should read the effective external-power action' \
        || failures=$((failures + 1))
    assert_contains "$effects" $'systemd-inhibit\t--list\t--what=handle-lid-switch\t--no-pager\t--no-legend' \
        'doctor should inspect low-level lid ownership without taking an inhibitor' \
        || failures=$((failures + 1))

    doctor_status=0
    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_LOGIND_HANDLE_LID_SWITCH_EXTERNAL_POWER=suspend \
        "$doctor" --policy-only \
        > "$test_root/external-power-doctor.out" 2>&1 || doctor_status=$?
    if (( doctor_status != 0 )); then
        printf 'expected explicit suspend policy status 0, got %d\n%s\n' \
            "$doctor_status" "$(<"$test_root/external-power-doctor.out")" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$(<"$test_root/external-power-doctor.out")" \
        'PASS HandleLidSwitchExternalPower=suspend' \
        'doctor should accept an explicit external-power suspend action' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

doctor_accepts_current_host_capability_profile() (
    set -euo pipefail

    local test_root fake_bin safe_bin effect_log doctor_output effects
    local doctor_status=0 failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_LOGIND_CAN_SUSPEND=yes \
        TEST_LOGIND_CAN_HIBERNATE=na \
        /bin/bash "$ROOT_DIR/runtime/lid-switch-doctor.sh" \
        > "$test_root/doctor.out" 2>&1 || doctor_status=$?

    doctor_output=$(<"$test_root/doctor.out")
    effects=$(<"$effect_log")

    if (( doctor_status != 0 )); then
        printf 'expected current host capability profile status 0, got %d\n%s\n' \
            "$doctor_status" "$doctor_output" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$doctor_output" 'PASS CanSuspend=yes' \
        'doctor should verify the delegated suspend action is available' \
        || failures=$((failures + 1))
    assert_contains "$doctor_output" 'INFO CanHibernate=na hibernate=unused' \
        'doctor should report the current unavailable hibernate capability as informational' \
        || failures=$((failures + 1))
    assert_contains "$effects" $'busctl\tcall\torg.freedesktop.login1\t/org/freedesktop/login1\torg.freedesktop.login1.Manager\tCanSuspend' \
        'doctor should read the effective suspend capability' \
        || failures=$((failures + 1))
    assert_contains "$effects" $'busctl\tcall\torg.freedesktop.login1\t/org/freedesktop/login1\torg.freedesktop.login1.Manager\tCanHibernate' \
        'doctor should read the informational hibernate capability' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'systemctl\t' \
        'capability diagnostics must never request a power action' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

doctor_reports_available_hibernate_as_unused() (
    set -euo pipefail

    local test_root fake_bin safe_bin effect_log doctor_output effects
    local doctor_status=0 failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_LOGIND_CAN_SUSPEND=yes \
        TEST_LOGIND_CAN_HIBERNATE=yes \
        /bin/bash "$ROOT_DIR/runtime/lid-switch-doctor.sh" \
        > "$test_root/doctor.out" 2>&1 || doctor_status=$?

    doctor_output=$(<"$test_root/doctor.out")
    effects=$(<"$effect_log")

    if (( doctor_status != 0 )); then
        printf 'expected available-but-unused hibernate status 0, got %d\n%s\n' \
            "$doctor_status" "$doctor_output" >&2
        failures=$((failures + 1))
    fi
    assert_contains "$doctor_output" 'PASS CanSuspend=yes' \
        'verified suspend should remain the selected delegated action' \
        || failures=$((failures + 1))
    assert_contains "$doctor_output" \
        'INFO CanHibernate=yes hibernate=available-but-unused' \
        'an available hibernate capability should not select hibernation' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'systemctl\t' \
        'reporting an available capability must not request hibernation' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installed_cli_refuses_actions_when_monitor_query_fails() (
    set -euo pipefail

    local transition=$1
    local test_root home fake_bin safe_bin effect_log installed_cli
    local install_fixture runtime_effects runtime_output
    local runtime_output_file runtime_status=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    runtime_output_file="$test_root/runtime.out"
    install_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    mkdir -p "$home"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$install_fixture" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1

    installed_cli="$home/.config/hypr/scripts/lid-switch.sh"
    : > "$effect_log"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$install_fixture" \
        TEST_HYPRCTL_MONITORS_JSON_FAIL=1 \
        "$installed_cli" "$transition" \
        > "$runtime_output_file" 2>&1 || runtime_status=$?

    runtime_effects=$(<"$effect_log")
    runtime_output=$(<"$runtime_output_file")

    assert_contains "$runtime_effects" $'hyprctl\t-j\tmonitors\tall' \
        'the installed CLI should reach the failing monitor-query boundary'
    assert_not_contains "$runtime_effects" $'systemctl\t' \
        'a monitor-query failure must not request a power action'
    assert_not_contains "$runtime_effects" $'monitor\t' \
        'a monitor-query failure must not change monitor state'

    if (( runtime_status != 2 )); then
        printf 'expected query failure status 2, got %d\nruntime output:\n%s\n' \
            "$runtime_status" "$runtime_output" >&2
        return 1
    fi

    assert_contains "$runtime_output" \
        "level=error component=lid-switch event=monitor_query_failed action=$transition" \
        'the query failure should be distinguishable at the journal stream boundary'
    assert_not_contains "$runtime_output" 'event=external_monitor_absent' \
        'a query failure must not be reported as a valid empty topology'
)

installed_cli_refuses_power_when_close_monitor_query_fails() {
    installed_cli_refuses_actions_when_monitor_query_fails close
}

installed_cli_refuses_display_when_open_monitor_query_fails() {
    installed_cli_refuses_actions_when_monitor_query_fails open
}

create_lid_state_fixture() {
    local lid_root=$1
    local scenario=$2

    case "$scenario" in
        lid0)
            mkdir -p "$lid_root/LID0"
            printf '%s\n' 'state: open' > "$lid_root/LID0/state"
            ;;
        lid1)
            mkdir -p "$lid_root/LID1"
            printf '%s\n' 'state: closed' > "$lid_root/LID1/state"
            ;;
        multiple-agreeing)
            mkdir -p "$lid_root/LID0" "$lid_root/LID1"
            printf '%s\n' 'state: open' > "$lid_root/LID0/state"
            printf '%s\n' 'state: open' > "$lid_root/LID1/state"
            ;;
        multiple-conflicting)
            mkdir -p "$lid_root/LID0" "$lid_root/LID1"
            printf '%s\n' 'state: open' > "$lid_root/LID0/state"
            printf '%s\n' 'state: closed' > "$lid_root/LID1/state"
            ;;
        missing)
            ;;
        unreadable)
            mkdir -p "$lid_root/LID0/state"
            ;;
        malformed)
            mkdir -p "$lid_root/LID0"
            printf '%s\n' 'state: ajar' > "$lid_root/LID0/state"
            ;;
        *)
            printf 'unknown lid state fixture: %s\n' "$scenario" >&2
            return 2
            ;;
    esac
}

installed_runtime_reports_through_the_journal_boundary() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture lid_root
    local installed_cli installed_daemon installed_unit runtime_artifacts unit_contents
    local runtime_output daemon_output failures=0 runtime_status=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    lid_root="$test_root/button/lid"
    mkdir -p "$home"
    prepare_hyprland_config "$home"
    create_lid_state_fixture "$lid_root" lid0
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1

    installed_cli="$home/.config/hypr/scripts/lid-switch.sh"
    installed_daemon="$home/.config/hypr/scripts/lid-monitor.sh"
    installed_unit="$home/.config/systemd/user/lid-monitor.service"

    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON_FAIL=1 \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$installed_cli" close \
        > "$test_root/runtime.out" 2>&1 || runtime_status=$?

    if (( runtime_status != 2 )); then
        printf 'expected query failure status 2, got %d\n' "$runtime_status" >&2
        failures=$((failures + 1))
    fi

    runtime_output=$(<"$test_root/runtime.out")
    assert_contains "$runtime_output" \
        'level=error component=lid-switch event=monitor_query_failed action=close' \
        'the runtime should expose a useful structured error to the service journal stream' \
        || failures=$((failures + 1))

    runtime_artifacts="$(<"$installed_cli")"$'\n'"$(<"$installed_daemon")"
    assert_not_contains "$runtime_artifacts" '/tmp/' \
        'installed runtime scripts must not contain shared-/tmp paths' \
        || failures=$((failures + 1))
    assert_not_contains "$runtime_artifacts" 'HYPR_LID_SWITCH_LOG_FILE' \
        'installed runtime scripts must not expose a file-log redirection seam' \
        || failures=$((failures + 1))

    unit_contents=$(<"$installed_unit")
    assert_contains "$unit_contents" 'StandardOutput=journal' \
        'the installed unit should route daemon output to the journal' \
        || failures=$((failures + 1))
    assert_contains "$unit_contents" 'StandardError=journal' \
        'the installed unit should route daemon diagnostics to the journal' \
        || failures=$((failures + 1))
    assert_contains "$unit_contents" 'SyslogIdentifier=arch-lidswitch' \
        'the installed unit should give journal records a stable identifier' \
        || failures=$((failures + 1))

    rm -f "$fake_bin/sleep"
    ln -s "$REAL_SLEEP_BIN" "$fake_bin/sleep"
    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        HYPR_LID_STATE_ROOT="$test_root/missing-lid" \
        "$TIMEOUT_BIN" 0.2 "$installed_daemon" \
        > "$test_root/daemon.out" 2>&1 || true
    daemon_output=$(<"$test_root/daemon.out")
    assert_contains "$daemon_output" \
        'level=error component=lid-monitor event=lid_state_observation_failed reason=missing' \
        'the running daemon should expose why lid observation is unavailable to the journal stream' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installed_lid_state_matches_expected_behavior() (
    set -euo pipefail

    local scenario=$1
    local expected_state=$2
    local expected_error=${3:-}
    local test_root home fake_bin safe_bin effect_log monitor_fixture lid_root runtime_dir
    local monitor_json disabled_monitor_json runtime_monitor_json
    local installed_cli installed_daemon cli_effects daemon_output installer_output
    local cli_status=0 daemon_status=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    monitor_json=$(<"$ROOT_DIR/tests/fixtures/monitors-json/framework.json")
    disabled_monitor_json=$(jq -c \
        'map(if .name == "eDP-1" then .disabled = true else . end)' \
        <<< "$monitor_json")
    runtime_monitor_json=$monitor_json
    if [[ "$expected_state" == open ]]; then
        runtime_monitor_json=$disabled_monitor_json
    fi
    lid_root="$test_root/button/lid"
    runtime_dir="$test_root/runtime"
    mkdir -m 0700 -p "$home" "$runtime_dir"
    prepare_hyprland_config "$home"
    create_lid_state_fixture "$lid_root" "$scenario"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    if ! "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$monitor_json" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1; then
        printf 'installer failed for lid fixture %s:\n%s\n' \
            "$scenario" "$(<"$test_root/installer.out")" >&2
        return 1
    fi
    installer_output=$(<"$test_root/installer.out")

    if [[ "$expected_state" == 'unknown' ]]; then
        assert_contains "$installer_output" 'Could not determine lid state' \
            'installer should report an unavailable lid state without guessing' || return 1
    else
        assert_contains "$installer_output" "Lid state detection working: $expected_state" \
            'installer should use the shared runtime lid observer' || return 1
    fi

    installed_cli="$home/.config/hypr/scripts/lid-switch.sh"
    installed_daemon="$home/.config/hypr/scripts/lid-monitor.sh"

    if ! "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$monitor_json" \
        "$installed_cli" close \
        > "$test_root/seed-close.out" 2>&1; then
        printf 'could not seed the installed CLI monitor snapshot:\n%s\n' \
            "$(<"$test_root/seed-close.out")" >&2
        return 1
    fi

    rm -f "$effect_log.monitors-state.json" \
        "$effect_log.monitors-state.json.requested"

    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        XDG_RUNTIME_DIR="$runtime_dir" \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$runtime_monitor_json" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$installed_cli" \
        > "$test_root/cli.out" 2> "$test_root/cli.err" || cli_status=$?
    cli_effects=$(<"$effect_log")

    case "$expected_state" in
        open)
            if (( cli_status != 0 )); then
                printf 'expected open CLI status 0, got %d:\n%s\n' \
                    "$cli_status" "$(<"$test_root/cli.err")" >&2
                return 1
            fi
            assert_contains "$cli_effects" $'monitor\toutput=eDP-1\tdisabled=false' \
                'an open lid state should select the installed CLI open transition' || return 1
            assert_not_contains "$cli_effects" $'monitor\toutput=DP-2' \
                'an open lid state should preserve the external output placement' || return 1
            ;;
        closed)
            if (( cli_status != 0 )); then
                printf 'expected closed CLI status 0, got %d:\n%s\n' \
                    "$cli_status" "$(<"$test_root/cli.err")" >&2
                return 1
            fi
            assert_contains "$cli_effects" $'monitor\toutput=eDP-1\tdisabled=true' \
                'a closed lid state should select the installed CLI close transition' || return 1
            assert_not_contains "$cli_effects" $'monitor\toutput=DP-2' \
                'a closed lid state should preserve the external output placement' || return 1
            ;;
        unknown)
            if (( cli_status == 0 )); then
                printf 'installed CLI accepted unavailable lid fixture: %s\n' "$scenario" >&2
                return 1
            fi
            if [[ -s "$effect_log" ]]; then
                printf 'unavailable lid state caused external effects:\n%s\n' \
                    "$cli_effects" >&2
                return 1
            fi
            assert_contains "$(<"$test_root/cli.err")" \
                'level=error component=lid-switch event=lid_state_unknown action=auto' \
                'the installed CLI should explain why automatic action was refused at its stderr boundary' \
                || return 1
            ;;
        *)
            printf 'unknown expected lid state: %s\n' "$expected_state" >&2
            return 2
            ;;
    esac

    assert_not_contains "$cli_effects" $'systemctl\t' \
        'lid observation must not request a power action in the docked fixture' || return 1

    : > "$effect_log"
    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        TEST_EFFECT_LOG="$effect_log" \
        HYPR_LID_STATE_ROOT="$lid_root" \
        "$installed_daemon" --print-state \
        > "$test_root/daemon.out" 2> "$test_root/daemon.err" || daemon_status=$?
    daemon_output=$(<"$test_root/daemon.out")

    if [[ "$expected_state" == 'unknown' ]]; then
        if (( daemon_status == 0 )); then
            printf 'daemon accepted unavailable lid fixture: %s\n' "$scenario" >&2
            return 1
        fi
        if [[ "$daemon_output" != 'unknown' ]]; then
            printf 'expected daemon to report unknown, got: %s\n' "$daemon_output" >&2
            return 1
        fi
        assert_contains "$(<"$test_root/daemon.err")" "$expected_error" \
            'daemon should distinguish the lid observation failure' || return 1
    else
        if (( daemon_status != 0 )); then
            printf 'expected daemon state status 0, got %d:\n%s\n' \
                "$daemon_status" "$(<"$test_root/daemon.err")" >&2
            return 1
        fi
        if [[ "$daemon_output" != "$expected_state" ]]; then
            printf 'expected daemon to report %s, got: %s\n' \
                "$expected_state" "$daemon_output" >&2
            return 1
        fi
    fi
    if [[ -s "$effect_log" ]]; then
        printf 'daemon state diagnostic caused external effects:\n%s\n' \
            "$(<"$effect_log")" >&2
        return 1
    fi
)

installed_lid0_state_drives_cli_and_daemon() {
    installed_lid_state_matches_expected_behavior lid0 open
}

installed_lid1_state_drives_cli_and_daemon() {
    installed_lid_state_matches_expected_behavior lid1 closed
}

installed_agreeing_lid_states_drive_cli_and_daemon() {
    installed_lid_state_matches_expected_behavior multiple-agreeing open
}

installed_conflicting_lid_states_are_refused() {
    installed_lid_state_matches_expected_behavior \
        multiple-conflicting unknown 'Conflicting ACPI lid states'
}

installed_missing_lid_state_is_refused() {
    installed_lid_state_matches_expected_behavior \
        missing unknown 'No ACPI lid state files found'
}

installed_unreadable_lid_state_is_refused() {
    installed_lid_state_matches_expected_behavior \
        unreadable unknown 'Unable to read ACPI lid state'
}

installed_malformed_lid_state_is_refused() {
    installed_lid_state_matches_expected_behavior \
        malformed unknown 'Malformed ACPI lid state'
}

installer_matches_fixture_expectation() (
    set -euo pipefail

    local fixture_name=$1
    local expected_outcome=$2
    local expected_message=$3
    local assertion_message=$4
    shift 4
    local test_root home fake_bin safe_bin effect_log fixture monitor_json
    local installer_output effects
    local installer_status=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    fixture="$ROOT_DIR/tests/fixtures/monitors/$fixture_name"
    case "$fixture_name" in
        laptop-only.txt)
            monitor_json='[{"name":"eDP-1","disabled":false}]'
            ;;
        one-external.txt)
            monitor_json=$(<"$ROOT_DIR/tests/fixtures/monitors-json/framework.json")
            ;;
        multiple-external.txt)
            monitor_json='[{"name":"eDP-1","disabled":false},{"name":"DP-2","disabled":false},{"name":"HDMI-A-1","disabled":false}]'
            ;;
        no-laptop.txt)
            monitor_json='[{"name":"DP-2","disabled":false}]'
            ;;
        *)
            printf 'no structured monitor fixture mapping for: %s\n' \
                "$fixture_name" >&2
            return 2
            ;;
    esac
    mkdir -p "$home"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$monitor_json" \
        "$@" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1 || installer_status=$?

    installer_output=$(<"$test_root/installer.out")
    effects=$(<"$effect_log")
    case "$expected_outcome" in
        success)
            if (( installer_status != 0 )); then
                printf 'installer failed for monitor fixture %s:\n%s\n' \
                    "$fixture_name" "$installer_output" >&2
                return 1
            fi
            if [[ ! -x "$home/.config/hypr/scripts/lid-switch.sh" ]]; then
                printf 'installer did not create an executable lid-switch CLI\n' >&2
                return 1
            fi
            assert_contains "$effects" \
                $'hyprctl\teval\tassert(type(hl) == "table" and type(hl.monitor) == "function" and type(hl.dispatch) == "function" and type(hl.dsp) == "table" and type(hl.dsp.dpms) == "function", "required Hyprland Lua APIs unavailable")' \
                'successful installation should prove the typed monitor and DPMS API contract' \
                || return 1
            assert_not_contains "$effects" $'monitor\t' \
                'the Hyprland capability probe must not mutate monitor state' \
                || return 1
            ;;
        failure)
            if (( installer_status == 0 )); then
                printf 'installer unexpectedly succeeded for monitor fixture %s\n' \
                    "$fixture_name" >&2
                return 1
            fi
            ;;
        *)
            printf 'unknown installer outcome expectation: %s\n' "$expected_outcome" >&2
            return 2
            ;;
    esac

    assert_contains "$installer_output" "$expected_message" "$assertion_message"
)

installer_succeeds_without_an_external_monitor() {
    installer_matches_fixture_expectation \
        'laptop-only.txt' \
        success \
        'No external outputs detected' \
        'an absent external monitor should be reported as an informational state'
}

installer_succeeds_with_one_external_monitor() {
    installer_matches_fixture_expectation \
        'one-external.txt' \
        success \
        'Detected external output: DP-2 (enabled)' \
        'the active external monitor should be reported during installation'
}

installer_succeeds_with_multiple_external_monitors() {
    installer_matches_fixture_expectation \
        'multiple-external.txt' \
        success \
        'Detected external output:' \
        'multiple external monitors should not abort installation'
}

installer_detects_explicit_internal_and_nonstandard_externals() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture monitor_json
    local installer_output effects installed_cli installed_daemon installer_status=0
    local failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/no-laptop.txt"
    monitor_json=$(<"$ROOT_DIR/tests/fixtures/monitors-json/nonstandard-mixed.json")
    mkdir -p "$home"
    prepare_hyprland_config "$home"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        HYPR_LID_INTERNAL_OUTPUT=DSI-1 \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        TEST_HYPRCTL_MONITORS_JSON="$monitor_json" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1 || installer_status=$?

    installer_output=$(<"$test_root/installer.out")
    effects=$(<"$effect_log")
    installed_cli="$home/.config/hypr/scripts/lid-switch.sh"
    installed_daemon="$home/.config/hypr/scripts/lid-monitor.sh"

    if (( installer_status != 0 )); then
        printf 'expected explicit structured monitor installation status 0, got %d\n%s\n' \
            "$installer_status" "$installer_output" >&2
        failures=$((failures + 1))
    fi
    if [[ ! -r "$installed_cli" || ! -r "$installed_daemon" ]]; then
        printf 'installer did not create both configured runtime scripts\n' >&2
        failures=$((failures + 1))
    else
        assert_contains "$(<"$installed_cli")" 'LAPTOP_DISPLAY="DSI-1"' \
            'installed CLI should use the explicit internal identity' \
            || failures=$((failures + 1))
        assert_contains "$(<"$installed_daemon")" 'LAPTOP_DISPLAY="DSI-1"' \
            'installed daemon should observe topology for the same internal identity' \
            || failures=$((failures + 1))
    fi
    assert_contains "$installer_output" 'Detected internal output: DSI-1 (inactive)' \
        'installer should see an inactive explicit internal output' \
        || failures=$((failures + 1))
    assert_contains "$installer_output" 'Detected external output: Virtual-2 (inactive)' \
        'installer should classify an inactive nonstandard external by identity difference' \
        || failures=$((failures + 1))
    assert_contains "$installer_output" 'Detected external output: WL-1 (enabled)' \
        'installer should classify an enabled nonstandard external by identity difference' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'hyprctl\tmonitors\n' \
        'installer detection must not fall back to human-readable active monitors' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installer_rejects_ambiguous_or_missing_internal_identity() {
    local failures=0

    installer_matches_fixture_expectation \
        'one-external.txt' \
        failure \
        'Multiple internal output candidates detected; set HYPR_LID_INTERNAL_OUTPUT' \
        'ambiguous structured internal identities should require an explicit choice' \
        'TEST_HYPRCTL_MONITORS_JSON=[{"name":"eDP-1","disabled":false},{"name":"eDP-2","disabled":true}]' \
        || failures=$((failures + 1))
    installer_matches_fixture_expectation \
        'one-external.txt' \
        failure \
        'Configured internal output not found: DSI-9' \
        'an explicit internal identity must exist in the all-output snapshot' \
        HYPR_LID_INTERNAL_OUTPUT=DSI-9 \
        || failures=$((failures + 1))

    (( failures == 0 ))
}

installer_rejects_a_missing_laptop_monitor() {
    installer_matches_fixture_expectation \
        'no-laptop.txt' \
        failure \
        'Could not detect an internal output; set HYPR_LID_INTERNAL_OUTPUT' \
        'a missing laptop output should produce the intended explicit error'
}

installer_rejects_missing_jq_before_writes() (
    set -euo pipefail

    local test_root home fake_bin safe_bin effect_log monitor_fixture config original
    local installer_output effects installer_status=0 failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    config="$home/.config/hypr/hyprland.lua"
    original='-- user-owned config must remain unchanged without jq'
    mkdir -p "$(dirname "$config")"
    printf '%s\n' "$original" > "$config"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"
    rm -f "$safe_bin/jq"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1 || installer_status=$?

    installer_output=$(<"$test_root/installer.out")
    effects=$(<"$effect_log")

    if (( installer_status == 0 )); then
        printf 'installer accepted a missing jq dependency\n' >&2
        failures=$((failures + 1))
    fi
    if [[ "$(<"$config")" != "$original" ]]; then
        printf 'missing jq changed user configuration:\n%s\n' "$(<"$config")" >&2
        failures=$((failures + 1))
    fi
    if [[ -e "$home/.config/hypr/scripts/lid-switch.sh" ]] || \
        [[ -e "$home/.config/systemd/user/lid-monitor.service" ]]; then
        printf 'missing jq wrote installation artifacts\n' >&2
        failures=$((failures + 1))
    fi
    assert_not_contains "$effects" $'systemctl\t' \
        'dependency rejection must not change user-systemd state' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'monitor\t' \
        'dependency rejection must not mutate monitor state' \
        || failures=$((failures + 1))
    assert_contains "$installer_output" 'requires jq' \
        'the missing dependency should have an actionable diagnostic' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installer_hyprland_profile_is_rejected() (
    set -euo pipefail

    local expected_message=$1
    shift

    local test_root home fake_bin safe_bin effect_log monitor_fixture config original
    local installer_output effects installer_status=0 failures=0

    test_root=$(mktemp -d)
    trap 'rm -rf "$test_root"' EXIT

    home="$test_root/home"
    fake_bin="$test_root/fake-bin"
    safe_bin="$test_root/safe-bin"
    effect_log="$test_root/effects.log"
    monitor_fixture="$ROOT_DIR/tests/fixtures/monitors/one-external.txt"
    config="$home/.config/hypr/hyprland.lua"
    original='-- user-owned config must remain unchanged on compatibility failure'
    mkdir -p "$(dirname "$config")"
    printf '%s\n' "$original" > "$config"
    : > "$effect_log"
    install_safe_path "$fake_bin" "$safe_bin"

    "$ENV_BIN" -i \
        HOME="$home" \
        PATH="$fake_bin:$safe_bin" \
        WAYLAND_DISPLAY=wayland-test \
        HYPRLAND_INSTANCE_SIGNATURE=test-instance \
        XDG_SESSION_TYPE=wayland \
        TEST_EFFECT_LOG="$effect_log" \
        TEST_MONITORS_FIXTURE="$monitor_fixture" \
        "$@" \
        "$ROOT_DIR/install-hyprland-lid-switch.sh" \
        > "$test_root/installer.out" 2>&1 || installer_status=$?

    installer_output=$(<"$test_root/installer.out")
    effects=$(<"$effect_log")

    if (( installer_status == 0 )); then
        printf 'installer accepted an incompatible Hyprland profile\n' >&2
        failures=$((failures + 1))
    fi
    if [[ "$(<"$config")" != "$original" ]]; then
        printf 'compatibility failure changed user configuration:\n%s\n' \
            "$(<"$config")" >&2
        failures=$((failures + 1))
    fi
    if [[ -e "$home/.config/hypr/scripts/lid-switch.sh" ]] || \
        [[ -e "$home/.config/systemd/user/lid-monitor.service" ]]; then
        printf 'compatibility failure wrote installation artifacts\n' >&2
        failures=$((failures + 1))
    fi
    assert_not_contains "$effects" $'systemctl\t' \
        'compatibility rejection must not change user-systemd state' \
        || failures=$((failures + 1))
    assert_not_contains "$effects" $'monitor\t' \
        'compatibility rejection must not mutate monitor state' \
        || failures=$((failures + 1))
    assert_contains "$installer_output" "$expected_message" \
        'the incompatible profile should explain its exact cause' \
        || failures=$((failures + 1))

    (( failures == 0 ))
)

installer_rejects_hyprland_before_0_55() {
    installer_hyprland_profile_is_rejected \
        'Hyprland 0.54.0 is unsupported; version 0.55.0 or newer is required' \
        'TEST_HYPRCTL_VERSION_JSON={"version":"0.54.0","tag":"v9.9.9"}'
}

installer_rejects_unreachable_hyprland_version_query() {
    installer_hyprland_profile_is_rejected \
        "Could not query the active Hyprland version with 'hyprctl -j version'" \
        TEST_HYPRCTL_VERSION_FAIL=1
}

installer_rejects_malformed_hyprland_versions() {
    local failures=0

    installer_hyprland_profile_is_rejected \
        'Hyprland returned malformed version JSON or a missing version string' \
        TEST_HYPRCTL_VERSION_JSON=not-json \
        || failures=$((failures + 1))
    installer_hyprland_profile_is_rejected \
        'Hyprland returned a malformed version string: release-55' \
        'TEST_HYPRCTL_VERSION_JSON={"version":"release-55","tag":"v0.55.0"}' \
        || failures=$((failures + 1))
    installer_hyprland_profile_is_rejected \
        'Hyprland returned a malformed version string: 0.55.0-git' \
        'TEST_HYPRCTL_VERSION_JSON={"version":"0.55.0-git","tag":"unknown"}' \
        || failures=$((failures + 1))

    (( failures == 0 ))
}

