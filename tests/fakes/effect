#!/bin/bash

set -u

command_name=${0##*/}
: "${TEST_EFFECT_LOG:?TEST_EFFECT_LOG must name the fake-effects log}"

log_command() {
    {
        printf '%s' "$command_name"
        printf '\t%s' "$@"
        printf '\n'
    } >> "$TEST_EFFECT_LOG"
}

property_value() {
    local expression=$1
    local property=$2
    local pattern

    pattern="$property"'[[:space:]]*=[[:space:]]*"([^"]*)"'
    if [[ "$expression" =~ $pattern ]]; then
        printf '%s\n' "${BASH_REMATCH[1]}"
        return 0
    fi

    pattern="$property"'[[:space:]]*=[[:space:]]*([^,}[:space:]]+)'
    if [[ "$expression" =~ $pattern ]]; then
        printf '%s\n' "${BASH_REMATCH[1]}"
        return 0
    fi

    return 1
}

emit_monitor_effect() {
    local expression=$1
    local output property value

    if ! output=$(property_value "$expression" output); then
        printf 'Fake could not identify a monitor output in: %s\n' "$expression" >&2
        return 96
    fi

    printf 'monitor\toutput=%s' "$output" >> "$TEST_EFFECT_LOG"
    for property in disabled mode position scale; do
        if value=$(property_value "$expression" "$property"); then
            printf '\t%s=%s' "$property" "$value" >> "$TEST_EFFECT_LOG"
        fi
    done
    printf '\n' >> "$TEST_EFFECT_LOG"
}

case "$command_name" in
    busctl)
        log_command "$@"
        if [[ "${1:-}" != "get-property" ]]; then
            printf 'Unsupported fake busctl operation: %s\n' "${1:-}" >&2
            exit 98
        fi
        property=${5:-}
        if [[ -n "${TEST_BUSCTL_FAIL_PROPERTY:-}" && \
            "$property" == "$TEST_BUSCTL_FAIL_PROPERTY" ]]; then
            printf 'Configured busctl failure for property: %s\n' "$property" >&2
            exit 94
        fi
        case "$property" in
            HandleLidSwitch)
                printf 's "%s"\n' "${TEST_LOGIND_HANDLE_LID_SWITCH:-suspend}"
                ;;
            HandleLidSwitchDocked)
                printf 's "%s"\n' "${TEST_LOGIND_HANDLE_LID_SWITCH_DOCKED:-ignore}"
                ;;
            HandleLidSwitchExternalPower)
                printf 's "%s"\n' "${TEST_LOGIND_HANDLE_LID_SWITCH_EXTERNAL_POWER:-}"
                ;;
            *)
                printf 'Unsupported fake logind property: %s\n' "$property" >&2
                exit 98
                ;;
        esac
        ;;
    systemd-inhibit)
        log_command "$@"
        if [[ "${TEST_SYSTEMD_INHIBIT_FAIL:-0}" == 1 ]]; then
            printf 'Configured systemd-inhibit failure\n' >&2
            exit 93
        fi
        if [[ "${1:-}" != "--list" ]]; then
            printf 'Unsupported fake systemd-inhibit operation: %s\n' "${1:-}" >&2
            exit 98
        fi
        if [[ -n "${TEST_LID_SWITCH_INHIBITOR:-}" ]]; then
            printf '%s\n' "$TEST_LID_SWITCH_INHIBITOR"
        fi
        ;;
    hyprctl)
        if [[ "${1:-}" == "monitors" ]]; then
            log_command "$@"
            if [[ -z "${TEST_MONITORS_FIXTURE:-}" || ! -r "$TEST_MONITORS_FIXTURE" ]]; then
                printf 'Monitor fixture is not readable: %s\n' \
                    "${TEST_MONITORS_FIXTURE:-<unset>}" >&2
                exit 99
            fi
            cat "$TEST_MONITORS_FIXTURE"
        elif [[ "${1:-}" == "eval" ]]; then
            IFS=';' read -r -a monitor_expressions <<< "${2:-}"
            for expression in "${monitor_expressions[@]}"; do
                emit_monitor_effect "$expression"
            done
            printf '%s\n' ok
        else
            log_command "$@"
            printf 'Unsupported fake hyprctl operation: %s\n' "${1:-}" >&2
            exit 98
        fi
        ;;
    systemctl)
        log_command "$@"
        if [[ "${1:-}" == "--user" && "${2:-}" == "disable" && "${3:-}" == "--now" && \
            -n "${TEST_REQUIRED_PATHS_BEFORE_DISABLE:-}" ]]; then
            IFS=':' read -r -a required_paths <<< "$TEST_REQUIRED_PATHS_BEFORE_DISABLE"
            for required_path in "${required_paths[@]}"; do
                if [[ ! -e "$required_path" ]]; then
                    printf 'Required preparation was missing before service disable: %s\n' \
                        "$required_path" >&2
                    exit 95
                fi
            done
        fi
        for argument in "$@"; do
            case "$argument" in
                hibernate|hybrid-sleep|poweroff|reboot|suspend|suspend-then-hibernate)
                    printf 'Refusing real or simulated power action: %s\n' "$argument" >&2
                    exit 97
                    ;;
            esac
        done
        ;;
    pgrep)
        log_command "$@"
        # Model a running Waybar so its refresh path is exercised safely.
        exit 0
        ;;
    pkill|sleep)
        log_command "$@"
        ;;
    *)
        printf 'Unsupported fake command name: %s\n' "$command_name" >&2
        exit 98
        ;;
esac
