                if [[ -n "${TEST_BUSCTL_FAIL_METHOD:-}" && \
                    "$method" == "$TEST_BUSCTL_FAIL_METHOD" ]]; then
                    printf 'Configured busctl failure for method: %s\n' "$method" >&2
