            if ! dpms_output=$(property_value "${2:-}" monitor); then
                printf 'Fake could not identify a DPMS monitor in: %s\n' \
                    "${2:-}" >&2
                exit 96
            fi
            if configured_recovery_dpms_failure_pending \
                "$dpms_output"; then
                printf 'Configured recovery DPMS rejection\n'
                exit 0
            else
                failure_status=$?
                if (( failure_status != 1 )); then
                    exit "$failure_status"
                fi
            fi
            printf 'dpms\toutput=%s\tstate=on\n' "$dpms_output" >> "$TEST_EFFECT_LOG"
            if configured_failure_pending \
                "${TEST_HYPRCTL_DPMS_FAILURES:-0}" \
                "${TEST_HYPRCTL_DPMS_COUNTER:-}" dpms; then
                printf 'Configured targeted DPMS failure\n' >&2
                exit 94
            else
                failure_status=$?
                if (( failure_status != 1 )); then
                    exit "$failure_status"
                fi
            fi
            dpms_output_value=${TEST_HYPRCTL_DPMS_OUTPUT:-ok}
            if [[ "$dpms_output_value" == ok ]]; then
                if configured_no_awake_output_dpms_accepted_noop; then
                    :
                else
                    failure_status=$?
                    if (( failure_status != 1 )); then
                        exit "$failure_status"
                    fi
                    apply_dpms_effect_to_structured_state \
                        "$dpms_output" || exit $?
                    arm_post_child_dpms_off_observation \
                        "$dpms_output" || exit $?
                fi
            fi
            printf '%s\n' "$dpms_output_value"
        elif [[ "${1:-}" == "eval" ]]; then
            log_command "$@"
            if [[ -n "${TEST_HYPRCTL_EVAL_DELAY_SECONDS:-}" ]]; then
                "${TEST_REAL_SLEEP_BIN:?}" "$TEST_HYPRCTL_EVAL_DELAY_SECONDS"
            fi
            if configured_failure_pending \
                "${TEST_HYPRCTL_EVAL_FAILURES:-0}" \
                "${TEST_HYPRCTL_EVAL_COUNTER:-}" eval; then
                printf 'Configured monitor apply failure\n' >&2
                exit 94
            else
                failure_status=$?
                if (( failure_status != 1 )); then
                    exit "$failure_status"
                fi
            fi
            IFS=';' read -r -a monitor_expressions <<< "${2:-}"
            for expression in "${monitor_expressions[@]}"; do
                emit_monitor_effect "$expression"
                monitor_accepted_noop=false
                if configured_last_output_restore_accepted_noop "$expression"; then
                    monitor_accepted_noop=true
                else
                    accepted_noop_status=$?
                    if (( accepted_noop_status != 1 )); then
                        exit "$accepted_noop_status"
                    fi
                    if configured_recovery_internal_restore_accepted_noop \
                        "$expression"; then
                        monitor_accepted_noop=true
                    else
                        accepted_noop_status=$?
                        if (( accepted_noop_status != 1 )); then
                            exit "$accepted_noop_status"
                        fi
                    fi
                fi
                if [[ "$monitor_accepted_noop" != true && \
                    "${TEST_HYPRCTL_EVAL_OUTPUT:-ok}" == ok ]]; then
                    apply_monitor_effect_to_structured_state "$expression" || exit $?
                fi
            done
            printf '%s\n' "${TEST_HYPRCTL_EVAL_OUTPUT:-ok}"
        else
            log_command "$@"
            printf 'Unsupported fake hyprctl operation: %s\n' "${1:-}" >&2
            exit 98
        fi
        ;;
    systemctl)
        log_command "$@"
        initialize_systemctl_state
        deferred_systemctl_failure=false
        failure_operation=${2:-}
        if [[ ( "$failure_operation" == is-active || \
            "$failure_operation" == show ) && \
            "${TEST_SYSTEMCTL_FAIL_OPERATION:-}" == health && \
            -e "$(systemctl_state_directory)/.candidate-started" ]]; then
            failure_operation=health
        fi
        if [[ "$failure_operation" == daemon-reload && \
            -n "${TEST_SYSTEMCTL_FAIL_DAEMON_RELOAD_CALL:-}" ]]; then
            exact_failure_count=0
            if [[ -r "${TEST_SYSTEMCTL_FAILURE_COUNTER:?}" ]]; then
                read -r exact_failure_count < "$TEST_SYSTEMCTL_FAILURE_COUNTER"
            fi
            exact_failure_count=$((exact_failure_count + 1))
            printf '%s\n' "$exact_failure_count" \
                > "$TEST_SYSTEMCTL_FAILURE_COUNTER"
            if (( exact_failure_count == TEST_SYSTEMCTL_FAIL_DAEMON_RELOAD_CALL )); then
                printf 'Configured systemctl daemon-reload call %d failure\n' \
                    "$exact_failure_count" >&2
                exit 94
            fi
        fi
        if [[ "$failure_operation" == show && \
            -n "${TEST_SYSTEMCTL_FAIL_SHOW_RESTART_NUMBER:-}" && \
            "$(systemctl_restart_number "${9:-}")" == \
                "$TEST_SYSTEMCTL_FAIL_SHOW_RESTART_NUMBER" ]]; then
            if configured_failure_pending \
                "${TEST_SYSTEMCTL_SHOW_FAILURES:-1}" \
                "${TEST_SYSTEMCTL_SHOW_FAILURE_COUNTER:?}" systemctl-show; then
                printf 'Configured candidate systemctl show failure\n' >&2
                exit 94
            else
                failure_status=$?
                if (( failure_status != 1 )); then
                    exit "$failure_status"
                fi
            fi
        fi
        if [[ -n "${TEST_SYSTEMCTL_FAIL_OPERATION:-}" && \
            "$failure_operation" == "$TEST_SYSTEMCTL_FAIL_OPERATION" ]]; then
            if configured_failure_pending \
                "${TEST_SYSTEMCTL_FAILURES:-1}" \
                "${TEST_SYSTEMCTL_FAILURE_COUNTER:?}" systemctl-operation; then
                if [[ "${TEST_SYSTEMCTL_MUTATE_THEN_FAIL_OPERATION:-}" == \
                    "$failure_operation" ]]; then
                    deferred_systemctl_failure=true
                else
                    printf 'Configured systemctl %s failure\n' \
                        "$failure_operation" >&2
                    exit 94
                fi
            else
                failure_status=$?
                if (( failure_status != 1 )); then
                    exit "$failure_status"
                fi
            fi
        fi
        if [[ "${1:-}" == --user && "${2:-}" == kill ]]; then
            if configured_failure_pending \
                "${TEST_SYSTEMCTL_KILL_FAILURES:-0}" \
                "${TEST_SYSTEMCTL_KILL_COUNTER:-}" systemctl-kill; then
                printf 'Configured systemctl kill failure\n' >&2
                exit 94
            else
                failure_status=$?
                if (( failure_status != 1 )); then
                    exit "$failure_status"
                fi
            fi
        fi
        if [[ "${1:-}" == "--user" && "${2:-}" == "disable" && "${3:-}" == "--now" && \
            -n "${TEST_REQUIRED_PATHS_BEFORE_DISABLE:-}" ]]; then
            IFS=':' read -r -a required_paths <<< "$TEST_REQUIRED_PATHS_BEFORE_DISABLE"
            for required_path in "${required_paths[@]}"; do
                if [[ ! -e "$required_path" ]]; then
                    printf 'Required preparation was missing before service disable: %s\n' \
                        "$required_path" >&2
                    exit 95
                fi
            done
        fi
        if [[ "${1:-}" == --user ]]; then
            case "${2:-}" in
                is-enabled)
                    if [[ "${3:-}" == lid-monitor.service && \
                        -n "${TEST_SYSTEMCTL_MAIN_ENABLEMENT:-}" ]]; then
                        printf '%s\n' "$TEST_SYSTEMCTL_MAIN_ENABLEMENT"
                        [[ "$TEST_SYSTEMCTL_MAIN_ENABLEMENT" == enabled ]]
                        exit $?
                    fi
                    if [[ "${3:-}" == lid-resume-monitor.service && \
                        -n "${TEST_SYSTEMCTL_RESUME_ENABLEMENT:-}" ]]; then
                        printf '%s\n' "$TEST_SYSTEMCTL_RESUME_ENABLEMENT"
                        [[ "$TEST_SYSTEMCTL_RESUME_ENABLEMENT" == enabled ]]
                        exit $?
                    fi
                    if systemctl_has_state enabled "${3:-}"; then
                        printf 'enabled\n'
                        exit 0
                    fi
                    if [[ "${3:-}" == lid-resume-monitor.service && \
                        -f "${HOME:?}/.config/systemd/user/lid-resume-monitor.service" ]]; then
                        printf 'static\n'
                    elif [[ "${3:-}" == lid-monitor.service && \
                        -f "${HOME:?}/.config/systemd/user/lid-monitor.service" ]]; then
                        printf 'disabled\n'
                    else
                        printf 'not-found\n'
                    fi
                    exit 1
                    ;;
                is-active)
                    unit=${4:-${3:-}}
                    if systemctl_has_state active "$unit"; then
                        exit 0
                    fi
                    exit 3
                    ;;
                show)
                    if [[ "${3:-}" != --no-pager || \
                        "${4:-}" != --property=LoadState || \
                        "${5:-}" != --property=ActiveState || \
                        "${6:-}" != --property=SubState || \
                        "${7:-}" != --property=MainPID || \
                        "${8:-}" != --property=InvocationID || \
                        -z "${9:-}" ]]; then
                        printf 'Malformed fake systemctl show invocation\n' >&2
                        exit 98
                    fi
                    emit_systemctl_show "${9}"
                    ;;
                enable)
                    systemctl_set_state enabled "${3:-}" true
                    ;;
                disable)
                    if [[ "${3:-}" == --now ]]; then
                        unit=${4:-}
                        systemctl_set_state enabled "$unit" false
                        systemctl_set_state active "$unit" false
                    else
                        systemctl_set_state enabled "${3:-}" false
                    fi
                    ;;
                start)
                    unit=${3:-}
                    if [[ "$unit" == lid-monitor.service || \
                        "$unit" == lid-resume-monitor.service ]]; then
                        if ! systemctl_has_state active "$unit"; then
                            systemctl_activate_unit_raw "$unit" \
                                "$(systemctl_restart_number "$unit")"
                        fi
                    else
                        systemctl_set_state active "$unit" true
                    fi
                    : > "$(systemctl_state_directory)/.candidate-started"
                    ;;
                restart)
                    restart_number=$(next_systemctl_restart_number)
                    for unit in "${@:3}"; do
                        systemctl_activate_unit_raw "$unit" "$restart_number"
                    done
                    : > "$(systemctl_state_directory)/.candidate-started"
                    ;;
                stop)
                    unit=${3:-}
                    if [[ "$unit" == lid-monitor.service || \
                        "$unit" == lid-resume-monitor.service ]]; then
                        systemctl_deactivate_unit_raw "$unit"
                    else
                        systemctl_set_state active "$unit" false
                    fi
                    ;;
            esac
        fi
        if [[ "$deferred_systemctl_failure" == true ]]; then
            printf 'Configured post-mutation systemctl %s failure\n' \
                "$failure_operation" >&2
            exit 94
        fi
        for argument in "$@"; do
            case "$argument" in
                hibernate|hybrid-sleep|poweroff|reboot|suspend|suspend-then-hibernate)
                    printf 'Refusing real or simulated power action: %s\n' "$argument" >&2
                    exit 97
                    ;;
            esac
        done
        ;;
    systemd-analyze)
        log_command "$@"
        if [[ "${TEST_SYSTEMD_ANALYZE_FAIL:-0}" == 1 ]]; then
            printf 'Configured staged unit verification failure\n' >&2
            exit 94
        fi
        if [[ -n "${TEST_EXPECT_SYSTEMD_ANALYZE_RUNTIME_DIR:-}" && \
            ( "${XDG_RUNTIME_DIR:-}" != \
                "$TEST_EXPECT_SYSTEMD_ANALYZE_RUNTIME_DIR" || \
              ! -d "$TEST_EXPECT_SYSTEMD_ANALYZE_RUNTIME_DIR" ) ]]; then
            printf 'Unexpected staged unit verification runtime: expected=%s actual=%s\n' \
                "$TEST_EXPECT_SYSTEMD_ANALYZE_RUNTIME_DIR" \
                "${XDG_RUNTIME_DIR:-<unset>}" >&2
            exit 98
        fi
        if [[ "${SYSTEMD_UNIT_PATH:-}" != *: || \
            -z "${XDG_RUNTIME_DIR:-}" || \
            "$XDG_RUNTIME_DIR" != /* || \
            ! -d "$XDG_RUNTIME_DIR" || -L "$XDG_RUNTIME_DIR" || \
            ! -O "$XDG_RUNTIME_DIR" || ! -w "$XDG_RUNTIME_DIR" || \
            "${1:-}" != --user || "${2:-}" != --generators=no || \
            "${3:-}" != --man=no || "${4:-}" != --recursive-errors=yes || \
            "${5:-}" != verify ]]; then
            printf 'Malformed staged systemd-analyze invocation\n' >&2
            exit 98
        fi
        for unit_file in "${@:6}"; do
            if [[ ! -r "$unit_file" ]]; then
                printf 'Unreadable staged unit: %s\n' "$unit_file" >&2
                exit 98
            fi
        done
        ;;
    luac)
        log_command "$@"
        if [[ "${TEST_LUAC_ACTIVATE_UNITS:-0}" == 1 && \
            ! -e "${TEST_LUAC_ACTIVATE_MARKER:?}" ]]; then
            systemctl_set_state active lid-monitor.service true
            systemctl_set_state active lid-resume-monitor.service true
            : > "$TEST_LUAC_ACTIVATE_MARKER"
        fi
        if [[ -n "${TEST_LUAC_MUTATE_CONFIG:-}" && \
            ! -e "${TEST_LUAC_MUTATE_MARKER:?}" ]]; then
            printf '%s\n' '-- concurrent user edit during installation' \
                >> "$TEST_LUAC_MUTATE_CONFIG"
            : > "$TEST_LUAC_MUTATE_MARKER"
        fi
        ;;
    cp)
        log_command "$@"
        arguments=("$@")
        argument_count=${#arguments[@]}
        if (( argument_count < 2 )); then
            exit 98
        fi
        source_path=${arguments[$((argument_count - 2))]}
        destination_path=${arguments[$((argument_count - 1))]}
        if [[ "${ARCH_LIDSWITCH_ATOMIC_CONTEXT:-}" == rollback-* && \
            "${TEST_ROLLBACK_FILE_FAILURE:-}" == cp ]]; then
            printf 'Configured rollback cp failure\n' >&2
            exit 94
        fi
        "${TEST_REAL_CP_BIN:?}" "$@" || exit $?
        if [[ "${ARCH_LIDSWITCH_ATOMIC_CONTEXT:-}" == rollback-* && \
            -n "${TEST_ROLLBACK_FILE_MARKER:-}" ]]; then
            : > "$TEST_ROLLBACK_FILE_MARKER"
        fi
        if [[ -n "${TEST_CP_MUTATE_SOURCE_AFTER_COPY:-}" && \
            "$source_path" == "$TEST_CP_MUTATE_SOURCE_AFTER_COPY" && \
            ! -e "${TEST_CP_MUTATE_MARKER:?}" ]]; then
            printf '%s\n' '-- concurrent edit after snapshot copy' >> "$source_path"
            : > "$TEST_CP_MUTATE_MARKER"
        fi
        ;;
    chmod)
        log_command "$@"
        if [[ "${ARCH_LIDSWITCH_ATOMIC_CONTEXT:-}" == rollback-* && \
            "${TEST_ROLLBACK_FILE_FAILURE:-}" == chmod && \
            -e "${TEST_ROLLBACK_FILE_MARKER:?}" ]]; then
            printf 'Configured rollback chmod failure\n' >&2
            exit 94
        fi
        exec "${TEST_REAL_CHMOD_BIN:?}" "$@"
        ;;
    mv)
        log_command "$@"
        if [[ -n "${ARCH_LIDSWITCH_ATOMIC_CONTEXT:-}" ]]; then
            printf 'mv-context\t%s\n' "$ARCH_LIDSWITCH_ATOMIC_CONTEXT" \
                >> "$TEST_EFFECT_LOG"
        fi
        if [[ "${ARCH_LIDSWITCH_ATOMIC_CONTEXT:-}" == install-config && \
            -n "${TEST_MV_EDIT_CONFIG_BEFORE_EXCHANGE:-}" && \
            ! -e "${TEST_MV_EDIT_CONFIG_MARKER:?}" ]]; then
            printf '%s\n' '-- concurrent edit immediately before exchange' \
                >> "$TEST_MV_EDIT_CONFIG_BEFORE_EXCHANGE"
            : > "$TEST_MV_EDIT_CONFIG_MARKER"
        fi
        if [[ -n "${TEST_MV_RACE_CONTEXT:-}" && \
            "${ARCH_LIDSWITCH_ATOMIC_CONTEXT:-}" == \
                "$TEST_MV_RACE_CONTEXT" && \
            ! -e "${TEST_MV_RACE_MARKER:?}" ]]; then
            case "${TEST_MV_RACE_MODE:?}" in
                append)
                    printf '%s\n' "${TEST_MV_RACE_CONTENT:?}" \
                        >> "${TEST_MV_RACE_DESTINATION:?}"
                    ;;
                create)
                    printf '%s\n' "${TEST_MV_RACE_CONTENT:?}" \
                        > "${TEST_MV_RACE_DESTINATION:?}"
                    chmod "${TEST_MV_RACE_MODE_BITS:-0640}" \
                        "${TEST_MV_RACE_DESTINATION:?}"
                    ;;
                symlink)
                    rm -f -- "${TEST_MV_RACE_DESTINATION:?}"
                    "${TEST_REAL_LN_BIN:?}" -s -- "${TEST_MV_RACE_CONTENT:?}" \
                        "$TEST_MV_RACE_DESTINATION"
                    ;;
                directory)
                    rm -f -- "${TEST_MV_RACE_DESTINATION:?}"
                    mkdir -- "$TEST_MV_RACE_DESTINATION"
                    printf '%s\n' "${TEST_MV_RACE_CONTENT:?}" \
                        > "$TEST_MV_RACE_DESTINATION/concurrent-entry"
                    ;;
                *)
                    printf 'Unknown configured mv race mode: %s\n' \
                        "$TEST_MV_RACE_MODE" >&2
                    exit 98
                    ;;
            esac
            : > "$TEST_MV_RACE_MARKER"
        fi
        if [[ "${ARCH_LIDSWITCH_ATOMIC_CONTEXT:-}" == \
            "${TEST_MV_REMOVE_SOURCE_BEFORE_CONTEXT:-__not-configured__}" ]]; then
            arguments=("$@")
            argument_count=${#arguments[@]}
            source_path=${arguments[$((argument_count - 2))]}
            rm -f -- "$source_path"
        fi
        if [[ "${ARCH_LIDSWITCH_ATOMIC_CONTEXT:-}" == \
            "${TEST_MV_MUTATE_BACKUP_CHILD_AFTER_CONTEXT:-__not-configured__}" ]]; then
            arguments=("$@")
            argument_count=${#arguments[@]}
            destination_path=${arguments[$((argument_count - 1))]}
            "${TEST_REAL_MV_BIN:?}" "$@" || exit $?
            case "${TEST_MV_BACKUP_CHILD_MUTATION:?}" in
                append)
                    printf '%s\n' 'post-promotion child corruption' \
                        >> "$destination_path/${TEST_MV_BACKUP_CHILD_RELATIVE:?}"
                    ;;
                delete)
                    rm -f -- \
                        "$destination_path/${TEST_MV_BACKUP_CHILD_RELATIVE:?}"
                    ;;
                directory-symlink)
                    child_path="$destination_path/${TEST_MV_BACKUP_CHILD_RELATIVE:?}"
                    "${TEST_REAL_MV_BIN:?}" -T -- "$child_path" \
                        "${TEST_MV_BACKUP_DIRECTORY_CAPTURE:?}" || exit $?
                    "${TEST_REAL_LN_BIN:?}" -s -- \
                        "$TEST_MV_BACKUP_DIRECTORY_CAPTURE" "$child_path" \
                        || exit $?
                    ;;
                *)
                    printf 'Unknown backup child mutation: %s\n' \
                        "$TEST_MV_BACKUP_CHILD_MUTATION" >&2
                    exit 98
                    ;;
            esac
            printf 'Configured post-promotion backup child %s\n' \
                "$TEST_MV_BACKUP_CHILD_MUTATION" >&2
            exit 94
        fi
        if [[ "${ARCH_LIDSWITCH_ATOMIC_CONTEXT:-}" == \
            "${TEST_MV_REPLACE_DESTINATION_AFTER_CONTEXT:-__not-configured__}" ]]; then
            arguments=("$@")
            argument_count=${#arguments[@]}
            destination_path=${arguments[$((argument_count - 1))]}
            "${TEST_REAL_MV_BIN:?}" "$@" || exit $?
            "${TEST_REAL_MV_BIN:?}" -T -- "$destination_path" \
                "${TEST_MV_REPLACED_DESTINATION_CAPTURE:?}" || exit $?
            mkdir -- "$destination_path" || exit $?
            chmod 0700 -- "$destination_path" || exit $?
            printf 'Configured replaced post-mutation destination: %s\n' \
                "$ARCH_LIDSWITCH_ATOMIC_CONTEXT" >&2
            exit 94
        fi
        if [[ -n "${TEST_MV_MUTATE_THEN_FAIL_CONTEXT:-}" && \
            "${ARCH_LIDSWITCH_ATOMIC_CONTEXT:-}" == \
                "$TEST_MV_MUTATE_THEN_FAIL_CONTEXT" ]]; then
            "${TEST_REAL_MV_BIN:?}" "$@" || exit $?
            printf 'Configured post-mutation mv failure: %s\n' \
                "$ARCH_LIDSWITCH_ATOMIC_CONTEXT" >&2
            exit 94
        fi
        if [[ "${ARCH_LIDSWITCH_ATOMIC_CONTEXT:-}" == rollback-* && \
            "${TEST_ROLLBACK_FILE_FAILURE:-}" == mv && \
            -e "${TEST_ROLLBACK_FILE_MARKER:?}" ]]; then
            printf 'Configured rollback mv failure\n' >&2
            exit 94
        fi
        if [[ "${ARCH_LIDSWITCH_ATOMIC_CONTEXT:-}" == \
            "${TEST_MV_REMOVE_SOURCE_AFTER_CONTEXT:-__not-configured__}" || \
            "${ARCH_LIDSWITCH_ATOMIC_CONTEXT:-}" == \
            "${TEST_MV_ACTIVATE_UNITS_AFTER_CONTEXT:-__not-configured__}" ]]; then
            arguments=("$@")
            argument_count=${#arguments[@]}
            source_path=${arguments[$((argument_count - 2))]}
            "${TEST_REAL_MV_BIN:?}" "$@" || exit $?
            if [[ "${ARCH_LIDSWITCH_ATOMIC_CONTEXT:-}" == \
                "${TEST_MV_REMOVE_SOURCE_AFTER_CONTEXT:-__not-configured__}" ]]; then
                rm -f -- "$source_path"
            fi
            if [[ "${ARCH_LIDSWITCH_ATOMIC_CONTEXT:-}" == \
                "${TEST_MV_ACTIVATE_UNITS_AFTER_CONTEXT:-__not-configured__}" ]]; then
                systemctl_activate_unit_raw lid-monitor.service \
                    "$(systemctl_restart_number lid-monitor.service)"
                systemctl_activate_unit_raw lid-resume-monitor.service \
                    "$(systemctl_restart_number lid-resume-monitor.service)"
                printf 'external-activation\t%s\n' \
                    "$ARCH_LIDSWITCH_ATOMIC_CONTEXT" >> "$TEST_EFFECT_LOG"
            fi
            exit 0
        fi
        exec "${TEST_REAL_MV_BIN:?}" "$@"
        ;;
    pgrep)
        log_command "$@"
        # Keep any forbidden legacy Waybar probe observable and harmless.
        exit 0
        ;;
    post-layout-hook|'post hook;false;#')
        log_command "$@"
        case "${TEST_POST_LAYOUT_HOOK_MODE:-success}" in
            success)
                ;;
            fail)
                exit 42
                ;;
            hang)
                exec "${TEST_POST_LAYOUT_HOOK_SLEEP_BIN:?}" 10
                ;;
            *)
                printf 'Unsupported post-layout hook mode: %s\n' \
                    "$TEST_POST_LAYOUT_HOOK_MODE" >&2
                exit 98
                ;;
        esac
        ;;
    pkill|sleep)
        log_command "$@"
        ;;
    *)
        printf 'Unsupported fake command name: %s\n' "$command_name" >&2
        exit 98
        ;;
esac
