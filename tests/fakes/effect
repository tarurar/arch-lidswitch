            fi
        elif [[ "${1:-}" == "output" && "${2:-}" == "create" && \
            "${3:-}" == "headless" && $# == 4 && \
            "${4:-}" == ARCH-LIDSWITCH-RECOVERY ]]; then
            log_command "$@"
            if [[ "${TEST_HYPRCTL_HEADLESS_CREATE_FOREIGN_COLLISION:-0}" == 1 ]]; then
                create_headless_output_in_structured_state "$4" || exit $?
                printf 'Name already taken\n'
                exit 0
            fi
            if [[ "${TEST_HYPRCTL_HEADLESS_CREATE_FAIL:-0}" == 1 ]]; then
                printf 'no backend replied\n'
                exit 0
            fi
            if [[ "${TEST_HYPRCTL_HEADLESS_CREATE_ACCEPTED_NOOP:-0}" != 1 ]]; then
                create_headless_output_in_structured_state "$4" || exit $?
            fi
            if [[ "${TEST_HYPRCTL_HEADLESS_CREATE_MUTATE_THEN_FAIL:-0}" == 1 ]]; then
                printf 'Configured headless output post-create failure\n' >&2
                exit 94
            fi
            hotplug_dp2_in_structured_state || exit $?
            change_generation_at_headless_creation || exit $?
            if [[ -n "${TEST_HYPRCTL_HEADLESS_CREATE_READY_FILE:-}" || \
                -n "${TEST_HYPRCTL_HEADLESS_CREATE_RELEASE_FIFO:-}" ]]; then
                if [[ -z "${TEST_HYPRCTL_HEADLESS_CREATE_READY_FILE:-}" || \
                    -z "${TEST_HYPRCTL_HEADLESS_CREATE_RELEASE_FIFO:-}" || \
                    ! -p "$TEST_HYPRCTL_HEADLESS_CREATE_RELEASE_FIFO" ]]; then
                    printf 'Invalid configured headless create gate\n' >&2
                    exit 99
