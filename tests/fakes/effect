                printf 'ready\n' \
                    > "$TEST_HYPRCTL_HEADLESS_CREATE_READY_FILE"
                gate=""
                if ! IFS= read -r gate \
                    < "$TEST_HYPRCTL_HEADLESS_CREATE_RELEASE_FIFO" || \
