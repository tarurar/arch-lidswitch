#!/bin/bash

set -u

command_name=${0##*/}
: "${TEST_EFFECT_LOG:?TEST_EFFECT_LOG must name the fake-effects log}"

log_command() {
    {
        printf '%s' "$command_name"
        printf '\t%s' "$@"
        printf '\n'
    } >> "$TEST_EFFECT_LOG"
}

property_value() {
    local expression=$1
    local property=$2
    local pattern

    pattern="$property"'[[:space:]]*=[[:space:]]*"([^"]*)"'
    if [[ "$expression" =~ $pattern ]]; then
        printf '%s\n' "${BASH_REMATCH[1]}"
        return 0
    fi

    pattern="$property"'[[:space:]]*=[[:space:]]*([^,}[:space:]]+)'
    if [[ "$expression" =~ $pattern ]]; then
        printf '%s\n' "${BASH_REMATCH[1]}"
        return 0
    fi

    return 1
}

emit_monitor_effect() {
    local expression=$1
    local output property value

    if ! output=$(property_value "$expression" output); then
        printf 'Fake could not identify a monitor output in: %s\n' "$expression" >&2
        return 96
    fi

    printf 'monitor\toutput=%s' "$output" >> "$TEST_EFFECT_LOG"
    for property in disabled mode position scale transform mirror; do
        if value=$(property_value "$expression" "$property"); then
            printf '\t%s=%s' "$property" "$value" >> "$TEST_EFFECT_LOG"
        fi
    done
    printf '\n' >> "$TEST_EFFECT_LOG"
}

configured_failure_pending() {
    local failure_limit=$1
    local counter_file=$2
    local failure_label=$3
    local failure_count=0

    if [[ ! "$failure_limit" =~ ^[0-9]+$ ]]; then
        printf 'Invalid configured %s failure count: %s\n' \
            "$failure_label" "$failure_limit" >&2
        return 99
    fi
    if (( failure_limit == 0 )); then
        return 1
    fi
    if [[ -z "$counter_file" ]]; then
        printf 'Missing configured %s failure counter\n' "$failure_label" >&2
        return 99
    fi
    if [[ -r "$counter_file" ]]; then
        read -r failure_count < "$counter_file"
    fi
    if [[ ! "$failure_count" =~ ^[0-9]+$ ]]; then
        printf 'Invalid configured %s failure counter: %s\n' \
            "$failure_label" "$failure_count" >&2
        return 99
    fi
    printf '%s\n' "$((failure_count + 1))" > "$counter_file"
    (( failure_count < failure_limit ))
}

configured_recovery_dpms_failure_pending() {
    local output=$1
    local state_file

    [[ "${TEST_HYPRCTL_RECOVERY_DPMS_FAILURES:-0}" != 0 ]] \
        || return 1
    if [[ -n "${TEST_HYPRCTL_MONITORS_SEQUENCE_DIR:-}" || \
        -z "${TEST_HYPRCTL_MONITORS_JSON+x}" ]]; then
        return 1
    fi
    state_file=$(prepare_structured_monitor_state) || return 99
    jq -e --arg output "$output" '
        any(.[]; .name == "ARCH-LIDSWITCH-RECOVERY" and
            .disabled == false) and
        any(.[]; .name == $output and .disabled == false)
    ' "$state_file" >/dev/null || return 1
    configured_failure_pending \
        "${TEST_HYPRCTL_RECOVERY_DPMS_FAILURES:-0}" \
        "${TEST_HYPRCTL_RECOVERY_DPMS_COUNTER:-}" \
        recovery-dpms
}

systemctl_state_directory() {
    printf '%s\n' "${TEST_SYSTEMCTL_STATE_DIR:-$TEST_EFFECT_LOG.systemctl-state}"
}

systemctl_state_file() {
    local state_kind=$1
    local unit=$2
    local state_dir safe_unit

    state_dir=$(systemctl_state_directory)
    safe_unit=${unit//[^A-Za-z0-9_.-]/_}
    printf '%s/%s.%s\n' "$state_dir" "$safe_unit" "$state_kind"
}

systemctl_unit_script_path() {
    local unit=$1

    case "$unit" in
        lid-monitor.service)
            printf '%s\n' "${HOME:?}/.config/hypr/scripts/lid-monitor.sh"
            ;;
        lid-resume-monitor.service)
            printf '%s\n' "${HOME:?}/.config/hypr/scripts/lid-resume-monitor.sh"
            ;;
        *)
            return 1
            ;;
    esac
}

systemctl_activate_unit_raw() {
    local unit=$1
    local restart_number=$2
    local state_dir generation_counter generation pid invocation script hash

    state_dir=$(systemctl_state_directory)
    generation_counter="$state_dir/.generation-counter"
    generation=0
    if [[ -r "$generation_counter" ]]; then
        read -r generation < "$generation_counter"
    fi
    generation=$((generation + 1))
    printf '%s\n' "$generation" > "$generation_counter"
    pid=$((20000 + generation))
    printf -v invocation '%032x' "$generation"
    : > "$(systemctl_state_file active "$unit")"
    printf '%s\n' "$pid" > "$(systemctl_state_file main-pid "$unit")"
    printf '%s\n' "$invocation" \
        > "$(systemctl_state_file invocation-id "$unit")"
    printf '%s\n' "$restart_number" \
        > "$(systemctl_state_file restart-number "$unit")"
    if script=$(systemctl_unit_script_path "$unit") && [[ -f "$script" ]]; then
        hash=$(sha256sum "$script") || exit $?
        hash=${hash%% *}
    else
        hash=missing
    fi
    printf '%s\n' "$hash" \
        > "$(systemctl_state_file loaded-sha256 "$unit")"
}

systemctl_deactivate_unit_raw() {
    local unit=$1
    local state_kind

    for state_kind in active main-pid invocation-id restart-number loaded-sha256; do
        rm -f "$(systemctl_state_file "$state_kind" "$unit")"
    done
}

next_systemctl_restart_number() {
    local state_dir counter_file count=0

    state_dir=$(systemctl_state_directory)
    counter_file="$state_dir/.restart-command-counter"
    if [[ -r "$counter_file" ]]; then
        read -r count < "$counter_file"
    fi
    count=$((count + 1))
    printf '%s\n' "$count" > "$counter_file"
    printf '%s\n' "$count"
}

initialize_systemctl_state() {
    local state_dir marker

    state_dir=$(systemctl_state_directory)
    marker="$state_dir/.initialized"
    mkdir -p "$state_dir"
    if [[ -e "$marker" ]]; then
        return 0
    fi
    : > "$marker"
    if [[ "${TEST_SYSTEMCTL_MAIN_ENABLED:-0}" == 1 ]]; then
        : > "$(systemctl_state_file enabled lid-monitor.service)"
    fi
    if [[ "${TEST_SYSTEMCTL_RESUME_ENABLED:-0}" == 1 ]]; then
        : > "$(systemctl_state_file enabled lid-resume-monitor.service)"
    fi
    if [[ "${TEST_SYSTEMCTL_MAIN_ACTIVE:-0}" == 1 ]]; then
        systemctl_activate_unit_raw lid-monitor.service 0
    fi
    if [[ "${TEST_SYSTEMCTL_RESUME_ACTIVE:-0}" == 1 ]]; then
        systemctl_activate_unit_raw lid-resume-monitor.service 0
    fi
}

systemctl_set_state() {
    local state_kind=$1
    local unit=$2
    local value=$3
    local state_file

    initialize_systemctl_state
    state_file=$(systemctl_state_file "$state_kind" "$unit")
    if [[ "$value" == true ]]; then
        : > "$state_file"
    else
        rm -f "$state_file"
    fi
}

systemctl_has_state() {
    local state_kind=$1
    local unit=$2

    initialize_systemctl_state
    [[ -e "$(systemctl_state_file "$state_kind" "$unit")" ]]
}

systemctl_restart_number() {
    local unit=$1
    local path

    path=$(systemctl_state_file restart-number "$unit")
    if [[ -r "$path" ]]; then
        cat "$path"
    else
        printf '0\n'
    fi
}

emit_systemctl_show() {
    local unit=$1
    local restart_number load_state active_state sub_state main_pid invocation
    local churn_unit=${TEST_SYSTEMCTL_CHURN_UNIT:-}
    local churn_count=0 churn_counter churn_limit=${TEST_SYSTEMCTL_CHURN_SHOWS:-0}
    local show_count=0 show_counter
    local unhealthy=${TEST_SYSTEMCTL_UNHEALTHY_MODE:-}

    restart_number=$(systemctl_restart_number "$unit")
    show_counter=$(systemctl_state_file show-count "$unit")
    if [[ -r "$show_counter" ]]; then
        read -r show_count < "$show_counter"
    fi
    show_count=$((show_count + 1))
    printf '%s\n' "$show_count" > "$show_counter"
    if [[ -n "${TEST_SYSTEMCTL_REPLACE_ON_SHOW_CALL:-}" && \
        "$show_count" == "$TEST_SYSTEMCTL_REPLACE_ON_SHOW_CALL" && \
        "$unit" == "${TEST_SYSTEMCTL_REPLACE_ON_SHOW_UNIT:-}" ]]; then
        systemctl_activate_unit_raw "$unit" "$restart_number"
    fi
    if [[ -n "${TEST_SYSTEMCTL_CHURN_RESTART_NUMBER:-}" && \
        "$restart_number" == "$TEST_SYSTEMCTL_CHURN_RESTART_NUMBER" && \
        "$unit" == "$churn_unit" ]]; then
        churn_counter=$(systemctl_state_file churn-show-count "$unit")
        if [[ -r "$churn_counter" ]]; then
            read -r churn_count < "$churn_counter"
        fi
        if (( churn_limit == 0 || churn_count < churn_limit )); then
            systemctl_activate_unit_raw "$unit" "$restart_number"
            printf '%s\n' "$((churn_count + 1))" > "$churn_counter"
        fi
    fi

    if systemctl_has_state active "$unit"; then
        load_state=loaded
        active_state=active
        sub_state=running
        main_pid=$(<"$(systemctl_state_file main-pid "$unit")")
        invocation=$(<"$(systemctl_state_file invocation-id "$unit")")
    else
        if [[ -f "${HOME:?}/.config/systemd/user/$unit" ]]; then
            load_state=loaded
        else
            load_state=not-found
        fi
        active_state=inactive
        sub_state=dead
        main_pid=0
        invocation=00000000000000000000000000000000
    fi

    if [[ -n "${TEST_SYSTEMCTL_UNHEALTHY_RESTART_NUMBER:-}" && \
        "$restart_number" == "$TEST_SYSTEMCTL_UNHEALTHY_RESTART_NUMBER" ]]; then
        case "$unhealthy" in
            pid-zero)
                main_pid=0
                ;;
            invocation-zero)
                invocation=00000000000000000000000000000000
                ;;
            substate-failed)
                sub_state=failed
                ;;
            inactive)
                active_state=inactive
                sub_state=dead
                ;;
            malformed)
                printf '%s\n' 'MainPID=not-a-pid'
                return 0
                ;;
        esac
    fi

    # Deliberately emit a non-request order so installer parsing cannot rely on
    # systemctl's property ordering.
    printf 'InvocationID=%s\n' "$invocation"
    printf 'SubState=%s\n' "$sub_state"
    printf 'LoadState=%s\n' "$load_state"
    printf 'MainPID=%s\n' "$main_pid"
    printf 'ActiveState=%s\n' "$active_state"
}

structured_monitor_state_file() {
    printf '%s\n' "${TEST_HYPRCTL_MONITORS_STATE_FILE:-$TEST_EFFECT_LOG.monitors-state.json}"
}

structured_recovery_rule_file() {
    local state_file=$1

    printf '%s.recovery-rule.json\n' "$state_file"
}

remember_structured_recovery_rule() {
    local expression=$1
    local output mode position scale state_file rule_file placement
    local width height refresh x y mode_dimensions

    output=$(property_value "$expression" output) || return 0
    [[ "$output" == ARCH-LIDSWITCH-RECOVERY ]] || return 0
    mode=$(property_value "$expression" mode) || return 0
    position=$(property_value "$expression" position) || return 0
    scale=$(property_value "$expression" scale) || return 0
    mode_dimensions=${mode%%@*}
    width=${mode_dimensions%%x*}
    height=${mode_dimensions#*x}
    refresh=${mode#*@}
    placement=explicit
    if [[ "$position" == auto-right ]]; then
        placement=auto-right
        x=0
        y=0
    else
        x=${position%%x*}
        y=${position#*x}
    fi
    if [[ ! "$width" =~ ^[0-9]+$ || ! "$height" =~ ^[0-9]+$ ||
        ! "$refresh" =~ ^[0-9]+([.][0-9]+)?$ ||
        ! "$x" =~ ^-?[0-9]+$ || ! "$y" =~ ^-?[0-9]+$ ||
        ! "$scale" =~ ^[0-9]+([.][0-9]+)?$ ]]; then
        printf 'Invalid structured recovery rule: %s\n' "$expression" >&2
        return 99
    fi
    state_file=$(prepare_structured_monitor_state) || return 99
    rule_file=$(structured_recovery_rule_file "$state_file")
    jq -nc --argjson width "$width" --argjson height "$height" \
        --argjson refresh "$refresh" --argjson x "$x" --argjson y "$y" \
        --argjson scale "$scale" --arg placement "$placement" \
        '{width: $width, height: $height, refreshRate: $refresh,
            x: $x, y: $y, scale: $scale, placement: $placement}' \
        > "$rule_file" || return 99
}

arrange_structured_auto_right_recovery() {
    local state_file=$1
    local rule_file temporary_state placement_status

    rule_file=$(structured_recovery_rule_file "$state_file")
    [[ -r "$rule_file" ]] || return 0
    if jq -e '.placement == "auto-right"' "$rule_file" >/dev/null; then
        :
    else
        placement_status=$?
        (( placement_status == 1 )) && return 0
        return "$placement_status"
    fi
    temporary_state="$state_file.tmp"
    jq -c '
        ([.[] | select(.name != "ARCH-LIDSWITCH-RECOVERY" and
                .disabled == false) |
            (.x + (.width / .scale))] | max // 0) as $right |
        map(if .name == "ARCH-LIDSWITCH-RECOVERY" and
                .disabled == false then
            .x = $right | .y = 0
        else . end)
    ' "$state_file" > "$temporary_state" || return 99
    mv -f "$temporary_state" "$state_file"
}

observe_configured_internal_recovery_overlap() {
    local state_file=$1
    local observation_file=${TEST_HYPRCTL_OVERLAP_OBSERVATION_FILE:-}
    local overlap_status

    [[ -n "$observation_file" ]] || return 0
    jq -ce '
        def enabled($name):
            first(.[] | select(.name == $name and .disabled == false));
        (enabled("eDP-1")) as $internal |
        (enabled("ARCH-LIDSWITCH-RECOVERY")) as $recovery |
        select(
            ($internal.x < ($recovery.x +
                ($recovery.width / $recovery.scale))) and
            ($recovery.x < ($internal.x +
                ($internal.width / $internal.scale))) and
            ($internal.y < ($recovery.y +
                ($recovery.height / $recovery.scale))) and
            ($recovery.y < ($internal.y +
                ($internal.height / $internal.scale)))) |
        [$internal, $recovery] | map({
            name, disabled, x, y, width, height, scale, dpmsStatus
        })
    ' "$state_file" >> "$observation_file" || {
        overlap_status=$?
        (( overlap_status == 4 )) && return 0
        return "$overlap_status"
    }
}

prepare_structured_monitor_state() {
    local state_file request_file requested_state previous_request=""

    state_file=$(structured_monitor_state_file)
    request_file="$state_file.requested"
    requested_state=${TEST_HYPRCTL_MONITORS_JSON:?}
    if [[ -r "$request_file" ]]; then
        previous_request=$(<"$request_file")
    fi
    if [[ ! -r "$state_file" || "$previous_request" != "$requested_state" ]]; then
        printf '%s\n' "$requested_state" > "$state_file"
        printf '%s\n' "$requested_state" > "$request_file"
    fi
    printf '%s\n' "$state_file"
}

apply_monitor_effect_to_structured_state() {
    local expression=$1
    local output disabled state_file temporary_state

    if [[ -n "${TEST_HYPRCTL_MONITORS_SEQUENCE_DIR:-}" || \
        -z "${TEST_HYPRCTL_MONITORS_JSON+x}" ]]; then
        return 0
    fi
    output=$(property_value "$expression" output) || return 0
    disabled=$(property_value "$expression" disabled) || return 0
    remember_structured_recovery_rule "$expression" || return $?
    state_file=$(prepare_structured_monitor_state)
    temporary_state="$state_file.tmp"
    jq -c --arg output "$output" --argjson disabled "$disabled" \
        'map(if .name == $output then .disabled = $disabled else . end)' \
        "$state_file" > "$temporary_state" || return 99
    mv -f "$temporary_state" "$state_file"
    arrange_structured_auto_right_recovery "$state_file" || return $?
    observe_configured_internal_recovery_overlap "$state_file" || return $?
}

configured_last_output_restore_accepted_noop() {
    local expression=$1
    local property disabled state_file enabled_count

    [[ "${TEST_HYPRCTL_LAST_OUTPUT_RESTORE_ACCEPTED_NOOP:-0}" == 1 ]] \
        || return 1
    [[ "${TEST_HYPRCTL_EVAL_OUTPUT:-ok}" == ok ]] || return 1
    disabled=$(property_value "$expression" disabled) || return 1
    [[ "$disabled" == false ]] || return 1
    for property in mode position scale transform mirror; do
        property_value "$expression" "$property" > /dev/null || return 1
    done
    if [[ -n "${TEST_HYPRCTL_MONITORS_SEQUENCE_DIR:-}" || \
        -z "${TEST_HYPRCTL_MONITORS_JSON+x}" ]]; then
        return 1
    fi
    state_file=$(prepare_structured_monitor_state) || return 99
    enabled_count=$(jq -er \
        '[.[] | select(.disabled == false)] | length' "$state_file") \
        || return 99
    (( enabled_count == 0 ))
}

configured_recovery_internal_restore_accepted_noop() {
    local expression=$1
    local output disabled state_file

    [[ "${TEST_HYPRCTL_RECOVERY_INTERNAL_RESTORE_ACCEPTED_NOOP:-0}" == 1 ]] \
        || return 1
    [[ "${TEST_HYPRCTL_EVAL_OUTPUT:-ok}" == ok ]] || return 1
    output=$(property_value "$expression" output) || return 1
    [[ "$output" != ARCH-LIDSWITCH-RECOVERY ]] || return 1
    disabled=$(property_value "$expression" disabled) || return 1
    [[ "$disabled" == false ]] || return 1
    for property in mode position scale transform mirror; do
        property_value "$expression" "$property" > /dev/null || return 1
    done
    if [[ -n "${TEST_HYPRCTL_MONITORS_SEQUENCE_DIR:-}" || \
        -z "${TEST_HYPRCTL_MONITORS_JSON+x}" ]]; then
        return 1
    fi
    state_file=$(prepare_structured_monitor_state) || return 99
    jq -e --arg output "$output" '
        any(.[]; .name == "ARCH-LIDSWITCH-RECOVERY" and
            .disabled == false) and
        any(.[]; .name == $output and .disabled == true)
    ' "$state_file" >/dev/null || return 1
}

apply_dpms_effect_to_structured_state() {
    local output=$1
    local state_file temporary_state

    if [[ -n "${TEST_HYPRCTL_MONITORS_SEQUENCE_DIR:-}" || \
        -z "${TEST_HYPRCTL_MONITORS_JSON+x}" ]]; then
        return 0
    fi
    state_file=$(prepare_structured_monitor_state)
    temporary_state="$state_file.tmp"
    jq -c --arg output "$output" \
        'map(if .name == $output then .dpmsStatus = true else . end)' \
        "$state_file" > "$temporary_state" || return 99
    mv -f "$temporary_state" "$state_file"
}

arm_post_child_dpms_off_observation() {
    local output=$1
    local phase_file=${TEST_HYPRCTL_POST_CHILD_DPMS_OFF_STATE_FILE:-}

    [[ -n "$phase_file" ]] || return 0
    [[ "$output" == "${TEST_HYPRCTL_POST_CHILD_DPMS_OFF_OUTPUT:-eDP-1}" ]] \
        || return 0
    if [[ ! -e "$phase_file" ]]; then
        printf '%s\n' armed > "$phase_file"
    fi
}

inject_post_child_dpms_off_observation() {
    local phase_file=${TEST_HYPRCTL_POST_CHILD_DPMS_OFF_STATE_FILE:-}
    local output=${TEST_HYPRCTL_POST_CHILD_DPMS_OFF_OUTPUT:-eDP-1}
    local phase state_file temporary_state

    [[ -n "$phase_file" ]] || return 0
    [[ -r "$phase_file" ]] || return 0
    read -r phase < "$phase_file"
    case "$phase" in
        armed)
            # The child owns the first observation after its successful DPMS
            # request and must still see the output awake.
            printf '%s\n' child-verified > "$phase_file"
            ;;
        child-verified)
            if [[ -n "${TEST_HYPRCTL_MONITORS_SEQUENCE_DIR:-}" || \
                -z "${TEST_HYPRCTL_MONITORS_JSON+x}" ]]; then
                printf 'Post-child DPMS observation requires structured state\n' >&2
                return 99
            fi
            state_file=$(prepare_structured_monitor_state) || return 99
            temporary_state="$state_file.tmp"
            jq -c --arg output "$output" '
                map(if .name == $output then .dpmsStatus = false else . end)
            ' "$state_file" > "$temporary_state" || return 99
            mv -f "$temporary_state" "$state_file"
            printf '%s\n' injected > "$phase_file"
            printf 'monitor-observation-race\toutput=%s\tdpms=false\n' \
                "$output" >> "$TEST_EFFECT_LOG"
            ;;
        injected)
            ;;
        *)
            printf 'Invalid post-child DPMS observation phase: %s\n' \
                "$phase" >&2
            return 99
            ;;
    esac
}

configured_no_awake_output_dpms_accepted_noop() {
    local state_file awake_output_count

    [[ "${TEST_HYPRCTL_NO_AWAKE_OUTPUT_DPMS_ACCEPTED_NOOP:-0}" == 1 ]] \
        || return 1
    if [[ -n "${TEST_HYPRCTL_MONITORS_SEQUENCE_DIR:-}" || \
        -z "${TEST_HYPRCTL_MONITORS_JSON+x}" ]]; then
        return 1
    fi
    state_file=$(prepare_structured_monitor_state) || return 99
    awake_output_count=$(jq -er '
        [.[] | select(.disabled == false and .dpmsStatus == true)] | length
    ' "$state_file") || return 99
    (( awake_output_count == 0 ))
}

create_headless_output_in_structured_state() {
    local output=$1
    local state_file temporary_state rule_file recovery_rule

    if [[ -n "${TEST_HYPRCTL_MONITORS_SEQUENCE_DIR:-}" || \
        -z "${TEST_HYPRCTL_MONITORS_JSON+x}" ]]; then
        return 0
    fi
    state_file=$(prepare_structured_monitor_state)
    if jq -e --arg output "$output" \
        'any(.[]; .name == $output)' "$state_file" >/dev/null; then
        printf 'Fake headless output already exists: %s\n' "$output" >&2
        return 99
    fi
    temporary_state="$state_file.tmp"
    rule_file=$(structured_recovery_rule_file "$state_file")
    recovery_rule='{"width":1280,"height":720,"refreshRate":60,
        "x":0,"y":0,"scale":1}'
    if [[ -r "$rule_file" ]]; then
        recovery_rule=$(<"$rule_file")
    fi
    jq -c --arg output "$output" --argjson rule "$recovery_rule" '. + [{
        id: 999,
        name: $output,
        width: $rule.width,
        height: $rule.height,
        refreshRate: $rule.refreshRate,
        x: $rule.x,
        y: $rule.y,
        scale: $rule.scale,
        transform: 0,
        disabled: false,
        mirrorOf: "none",
        dpmsStatus: true
    }]' "$state_file" > "$temporary_state" || return 99
    mv -f "$temporary_state" "$state_file"
    arrange_structured_auto_right_recovery "$state_file" || return $?
}

publish_delayed_recovery_output_after_structured_query() {
    local counter_file=${TEST_HYPRCTL_DELAYED_RECOVERY_PUBLICATION_COUNTER:-}
    local publication_count=0

    [[ -n "$counter_file" ]] || return 0
    if [[ -n "${TEST_HYPRCTL_MONITORS_SEQUENCE_DIR:-}" || \
        -z "${TEST_HYPRCTL_MONITORS_JSON+x}" ]]; then
        printf 'Delayed recovery publication requires structured state\n' >&2
        return 99
    fi
    if [[ -r "$counter_file" ]]; then
        read -r publication_count < "$counter_file"
    fi
    if [[ ! "$publication_count" =~ ^[0-9]+$ ]]; then
        printf 'Invalid delayed recovery publication count: %s\n' \
            "$publication_count" >&2
        return 99
    fi
    if (( publication_count == 0 )); then
        printf '%s\n' 1 > "$counter_file"
        create_headless_output_in_structured_state \
            ARCH-LIDSWITCH-RECOVERY || return $?
    fi
}

hotplug_dp2_in_structured_state() {
    local state_file temporary_state match_count

    [[ "${TEST_HYPRCTL_HEADLESS_CREATE_HOTPLUG_DP2:-0}" == 1 ]] \
        || return 0
    if [[ -n "${TEST_HYPRCTL_MONITORS_SEQUENCE_DIR:-}" || \
        -z "${TEST_HYPRCTL_MONITORS_JSON+x}" ]]; then
        return 0
    fi
    state_file=$(prepare_structured_monitor_state)
    match_count=$(jq -er \
        '[.[] | select(.name == "DP-2")] | length' "$state_file") \
        || return 99
    if (( match_count != 0 )); then
        printf 'Fake DP-2 hotplug requires DP-2 to be absent\n' >&2
        return 99
    fi
    temporary_state="$state_file.tmp"
    jq -c '. + [{
        id: 1,
        name: "DP-2",
        width: 3840,
        height: 2160,
        refreshRate: 59.997,
        x: 1440,
        y: -180,
        scale: 1.25,
        transform: 3,
        disabled: false,
        mirrorOf: "none",
        dpmsStatus: true
    }]' "$state_file" > "$temporary_state" || return 99
    mv -f "$temporary_state" "$state_file"
    printf 'external-hotplug\toutput=DP-2\tenabled=true\tdpms=true\n' \
        >> "$TEST_EFFECT_LOG"
}

change_generation_at_headless_creation() {
    local scenario=${TEST_HYPRCTL_HEADLESS_CREATE_GENERATION_CHANGE:-}
    local lid_state_file state_file temporary_state match_count current_lid

    case "$scenario" in
        "")
            return 0
            ;;
        inactive-dp3)
            if [[ -n "${TEST_HYPRCTL_MONITORS_SEQUENCE_DIR:-}" || \
                -z "${TEST_HYPRCTL_MONITORS_JSON+x}" ]]; then
                printf 'Inactive connector publication requires structured state\n' >&2
                return 99
            fi
            state_file=$(prepare_structured_monitor_state)
            match_count=$(jq -er \
                '[.[] | select(.name == "DP-3")] | length' "$state_file") \
                || return 99
            if (( match_count == 1 )); then
                return 0
            fi
            if (( match_count != 0 )); then
                printf 'Fake DP-3 is not uniquely represented\n' >&2
                return 99
            fi
            temporary_state="$state_file.tmp"
            jq -c '. + [{
                id: 2,
                name: "DP-3",
                disabled: true,
                dpmsStatus: true
            }]' "$state_file" > "$temporary_state" || return 99
            mv -f "$temporary_state" "$state_file"
            printf 'connector-represented\toutput=DP-3\tenabled=false\tdpms=true\n' \
                >> "$TEST_EFFECT_LOG"
            ;;
        lid-closed)
            lid_state_file=${TEST_HYPRCTL_HEADLESS_CREATE_LID_STATE_FILE:-}
            if [[ "$lid_state_file" != /* || ! -f "$lid_state_file" || \
                -L "$lid_state_file" ]]; then
                printf 'Invalid headless-create lid state file\n' >&2
                return 99
            fi
            current_lid=$(<"$lid_state_file")
            case "$current_lid" in
                'state: open')
                    printf '%s\n' 'state: closed' > "$lid_state_file"
                    printf 'lid-change\tstate=closed\n' >> "$TEST_EFFECT_LOG"
                    ;;
                'state: closed')
                    ;;
                *)
                    printf 'Invalid configured lid state: %s\n' \
                        "$current_lid" >&2
                    return 99
                    ;;
            esac
            ;;
        *)
            printf 'Unknown headless-create generation change: %s\n' \
                "$scenario" >&2
            return 99
            ;;
    esac
}

remove_headless_output_from_structured_state() {
    local output=$1
    local state_file temporary_state match_count

    if [[ -n "${TEST_HYPRCTL_MONITORS_SEQUENCE_DIR:-}" || \
        -z "${TEST_HYPRCTL_MONITORS_JSON+x}" ]]; then
        return 0
    fi
    state_file=$(prepare_structured_monitor_state)
    match_count=$(jq -er --arg output "$output" \
        '[.[] | select(.name == $output)] | length' "$state_file") \
        || return 99
    if (( match_count != 1 )); then
        printf 'Fake headless output is not uniquely represented: %s\n' \
            "$output" >&2
        return 99
    fi
    temporary_state="$state_file.tmp"
    jq -c --arg output "$output" \
        '[.[] | select(.name != $output)]' "$state_file" \
        > "$temporary_state" || return 99
    mv -f "$temporary_state" "$state_file"
}

