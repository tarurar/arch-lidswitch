#!/bin/bash

set -u

command_name=${0##*/}
: "${TEST_EFFECT_LOG:?TEST_EFFECT_LOG must name the fake-effects log}"

log_command() {
    {
        printf '%s' "$command_name"
        printf '\t%s' "$@"
        printf '\n'
    } >> "$TEST_EFFECT_LOG"
}

property_value() {
    local expression=$1
    local property=$2
    local pattern

    pattern="$property"'[[:space:]]*=[[:space:]]*"([^"]*)"'
    if [[ "$expression" =~ $pattern ]]; then
        printf '%s\n' "${BASH_REMATCH[1]}"
        return 0
    fi

    pattern="$property"'[[:space:]]*=[[:space:]]*([^,}[:space:]]+)'
    if [[ "$expression" =~ $pattern ]]; then
        printf '%s\n' "${BASH_REMATCH[1]}"
        return 0
    fi

    return 1
}

emit_monitor_effect() {
    local expression=$1
    local output property value

    if ! output=$(property_value "$expression" output); then
        printf 'Fake could not identify a monitor output in: %s\n' "$expression" >&2
        return 96
    fi

    printf 'monitor\toutput=%s' "$output" >> "$TEST_EFFECT_LOG"
    for property in disabled mode position scale transform mirror; do
        if value=$(property_value "$expression" "$property"); then
            printf '\t%s=%s' "$property" "$value" >> "$TEST_EFFECT_LOG"
        fi
    done
    printf '\n' >> "$TEST_EFFECT_LOG"
}

configured_failure_pending() {
    local failure_limit=$1
    local counter_file=$2
    local failure_label=$3
    local failure_count=0

    if [[ ! "$failure_limit" =~ ^[0-9]+$ ]]; then
        printf 'Invalid configured %s failure count: %s\n' \
            "$failure_label" "$failure_limit" >&2
        return 99
    fi
    if (( failure_limit == 0 )); then
        return 1
    fi
    if [[ -z "$counter_file" ]]; then
        printf 'Missing configured %s failure counter\n' "$failure_label" >&2
        return 99
    fi
    if [[ -r "$counter_file" ]]; then
        read -r failure_count < "$counter_file"
    fi
    if [[ ! "$failure_count" =~ ^[0-9]+$ ]]; then
        printf 'Invalid configured %s failure counter: %s\n' \
            "$failure_label" "$failure_count" >&2
        return 99
    fi
    printf '%s\n' "$((failure_count + 1))" > "$counter_file"
    (( failure_count < failure_limit ))
}

structured_monitor_state_file() {
    printf '%s\n' "${TEST_HYPRCTL_MONITORS_STATE_FILE:-$TEST_EFFECT_LOG.monitors-state.json}"
}

prepare_structured_monitor_state() {
    local state_file request_file requested_state previous_request=""

    state_file=$(structured_monitor_state_file)
    request_file="$state_file.requested"
    requested_state=${TEST_HYPRCTL_MONITORS_JSON:?}
    if [[ -r "$request_file" ]]; then
        previous_request=$(<"$request_file")
    fi
    if [[ ! -r "$state_file" || "$previous_request" != "$requested_state" ]]; then
        printf '%s\n' "$requested_state" > "$state_file"
        printf '%s\n' "$requested_state" > "$request_file"
    fi
    printf '%s\n' "$state_file"
}

apply_monitor_effect_to_structured_state() {
    local expression=$1
    local output disabled state_file temporary_state

    if [[ -n "${TEST_HYPRCTL_MONITORS_SEQUENCE_DIR:-}" || \
        -z "${TEST_HYPRCTL_MONITORS_JSON+x}" ]]; then
        return 0
    fi
    output=$(property_value "$expression" output) || return 0
    disabled=$(property_value "$expression" disabled) || return 0
    state_file=$(prepare_structured_monitor_state)
    temporary_state="$state_file.tmp"
    jq -c --arg output "$output" --argjson disabled "$disabled" \
        'map(if .name == $output then .disabled = $disabled else . end)' \
        "$state_file" > "$temporary_state" || return 99
    mv -f "$temporary_state" "$state_file"
}

apply_dpms_effect_to_structured_state() {
    local output=$1
    local state_file temporary_state

    if [[ -n "${TEST_HYPRCTL_MONITORS_SEQUENCE_DIR:-}" || \
        -z "${TEST_HYPRCTL_MONITORS_JSON+x}" ]]; then
        return 0
    fi
    state_file=$(prepare_structured_monitor_state)
    temporary_state="$state_file.tmp"
    jq -c --arg output "$output" \
        'map(if .name == $output then .dpmsStatus = true else . end)' \
        "$state_file" > "$temporary_state" || return 99
    mv -f "$temporary_state" "$state_file"
}

case "$command_name" in
    busctl)
        log_command "$@"
        case "${1:-}" in
            --version)
                printf 'systemd %s (test)\n' "${TEST_BUSCTL_VERSION:-261}"
                ;;
            --system)
                if [[ "${2:-}" == --json=short && \
                    "${3:-}" == --limit-messages=* && \
                    "${4:-}" == wait ]]; then
                    if [[ "${TEST_BUSCTL_WAIT_FAIL:-0}" == 1 ]]; then
                        printf 'Configured busctl wait failure\n' >&2
                        exit 94
                    fi
                    wait_output=${TEST_BUSCTL_WAIT_OUTPUT:-}
                    if [[ -z "$wait_output" ]]; then
                        wait_output='{"type":"b","data":[false]}'
                    fi
                    printf '%s\n' "$wait_output"
                else
                    printf 'Unsupported fake system busctl operation: %s %s %s\n' \
                        "${2:-}" "${3:-}" "${4:-}" >&2
                    exit 98
                fi
                ;;
            get-property)
                property=${5:-}
                if [[ -n "${TEST_BUSCTL_FAIL_PROPERTY:-}" && \
                    "$property" == "$TEST_BUSCTL_FAIL_PROPERTY" ]]; then
                    printf 'Configured busctl failure for property: %s\n' "$property" >&2
                    exit 94
                fi
                case "$property" in
                    HandleLidSwitch)
                        printf 's "%s"\n' "${TEST_LOGIND_HANDLE_LID_SWITCH:-suspend}"
                        ;;
                    HandleLidSwitchDocked)
                        printf 's "%s"\n' "${TEST_LOGIND_HANDLE_LID_SWITCH_DOCKED:-ignore}"
                        ;;
                    HandleLidSwitchExternalPower)
                        printf 's "%s"\n' "${TEST_LOGIND_HANDLE_LID_SWITCH_EXTERNAL_POWER:-}"
                        ;;
                    *)
                        printf 'Unsupported fake logind property: %s\n' "$property" >&2
                        exit 98
                        ;;
                esac
                ;;
            call)
                method=${5:-}
                if [[ -n "${TEST_BUSCTL_FAIL_METHOD:-}" && \
                    "$method" == "$TEST_BUSCTL_FAIL_METHOD" ]]; then
                    printf 'Configured busctl failure for method: %s\n' "$method" >&2
                    exit 94
                fi
                if [[ -n "${TEST_BUSCTL_MALFORMED_METHOD:-}" && \
                    "$method" == "$TEST_BUSCTL_MALFORMED_METHOD" ]]; then
                    printf '%s\n' malformed
                    exit 0
                fi
                case "$method" in
                    CanSuspend)
                        printf 's "%s"\n' "${TEST_LOGIND_CAN_SUSPEND:-yes}"
                        ;;
                    CanHibernate)
                        printf 's "%s"\n' "${TEST_LOGIND_CAN_HIBERNATE:-na}"
                        ;;
                    *)
                        printf 'Unsupported fake logind method: %s\n' "$method" >&2
                        exit 98
                        ;;
                esac
                ;;
            *)
                printf 'Unsupported fake busctl operation: %s\n' "${1:-}" >&2
                exit 98
                ;;
        esac
        ;;
    systemd-inhibit)
        log_command "$@"
        if [[ "${TEST_SYSTEMD_INHIBIT_FAIL:-0}" == 1 ]]; then
            printf 'Configured systemd-inhibit failure\n' >&2
            exit 93
        fi
        if [[ "${1:-}" != "--list" ]]; then
            printf 'Unsupported fake systemd-inhibit operation: %s\n' "${1:-}" >&2
            exit 98
        fi
        if [[ -n "${TEST_LID_SWITCH_INHIBITOR:-}" ]]; then
            printf '%s\n' "$TEST_LID_SWITCH_INHIBITOR"
        fi
        ;;
    hyprctl)
        if [[ "${1:-}" == "-j" && "${2:-}" == "version" ]]; then
            log_command "$@"
            if [[ "${TEST_HYPRCTL_VERSION_FAIL:-0}" == 1 ]]; then
                printf 'Configured Hyprland version query failure\n' >&2
                exit 94
            fi
            if [[ -n "${TEST_HYPRCTL_VERSION_JSON+x}" ]]; then
                printf '%s\n' "$TEST_HYPRCTL_VERSION_JSON"
            else
                printf '%s\n' '{"version":"0.55.0","tag":"unknown"}'
            fi
        elif [[ "${1:-}" == "-j" && "${2:-}" == "instances" ]]; then
            log_command "$@"
            if [[ -n "${TEST_HYPRCTL_INSTANCES_JSON+x}" ]]; then
                printf '%s\n' "$TEST_HYPRCTL_INSTANCES_JSON"
            else
                printf '%s\n' '[{"instance":"test-instance","time":0,"pid":42,"wl_socket":"wayland-test"}]'
            fi
        elif [[ "${1:-}" == "-j" && "${2:-}" == "status" ]]; then
            log_command "$@"
            if [[ -n "${TEST_HYPRCTL_STATUS_JSON+x}" ]]; then
                printf '%s\n' "$TEST_HYPRCTL_STATUS_JSON"
            else
                printf '%s\n' '{"configProvider":"lua","backend":"drm"}'
            fi
        elif [[ "${1:-}" == "-j" && "${2:-}" == "monitors" && \
            "${3:-}" == "all" ]]; then
            log_command "$@"
            if [[ -n "${TEST_HYPRCTL_MONITORS_SEQUENCE_DIR:-}" ]]; then
                sequence_counter=${TEST_HYPRCTL_MONITORS_SEQUENCE_COUNTER:?}
                sequence_index=0
                if [[ -r "$sequence_counter" ]]; then
                    read -r sequence_index < "$sequence_counter"
                fi
                if [[ ! "$sequence_index" =~ ^[0-9]+$ ]]; then
                    printf 'Invalid structured monitor sequence counter: %s\n' \
                        "$sequence_index" >&2
                    exit 99
                fi
                sequence_file="$TEST_HYPRCTL_MONITORS_SEQUENCE_DIR/$sequence_index.json"
                if [[ ! -r "$sequence_file" ]]; then
                    sequence_file="$TEST_HYPRCTL_MONITORS_SEQUENCE_DIR/final.json"
                fi
                if [[ ! -r "$sequence_file" ]]; then
                    printf 'Structured monitor sequence fixture is not readable: %s\n' \
                        "$sequence_file" >&2
                    exit 99
                fi
                printf '%s\n' "$((sequence_index + 1))" > "$sequence_counter"
                sequence_value=$(<"$sequence_file")
                if [[ "$sequence_value" == __FAIL__ ]]; then
                    printf 'Configured structured monitor query failure\n' >&2
                    exit 94
                fi
                printf '%s\n' "$sequence_value"
            elif [[ "${TEST_HYPRCTL_MONITORS_JSON_FAIL:-0}" == 1 ]]; then
                printf 'Configured structured monitor query failure\n' >&2
                exit 94
            elif [[ -n "${TEST_HYPRCTL_MONITORS_JSON+x}" ]]; then
                structured_state_file=$(prepare_structured_monitor_state)
                cat "$structured_state_file"
            else
                printf '%s\n' '[{"id":0,"name":"eDP-1","width":2880,"height":1920,"refreshRate":120,"x":0,"y":0,"scale":2,"transform":0,"disabled":false,"mirrorOf":"none"},{"id":1,"name":"DP-2","width":3840,"height":2160,"refreshRate":60,"x":1440,"y":0,"scale":1,"transform":0,"disabled":false,"mirrorOf":"none"}]'
            fi
        elif [[ "${1:-}" == "eval" && \
            "${2:-}" == assert\(type\(hl\)* ]]; then
            log_command "$@"
            if [[ "${TEST_HYPRCTL_CAPABILITY_EVAL_FAIL:-0}" == 1 ]]; then
                printf 'Configured Hyprland Lua capability failure\n' >&2
                exit 94
            fi
            printf '%s\n' "${TEST_HYPRCTL_CAPABILITY_EVAL_OUTPUT:-ok}"
        elif [[ "${1:-}" == "monitors" ]]; then
            log_command "$@"
            if [[ -z "${TEST_MONITORS_FIXTURE:-}" || ! -r "$TEST_MONITORS_FIXTURE" ]]; then
                printf 'Monitor fixture is not readable: %s\n' \
                    "${TEST_MONITORS_FIXTURE:-<unset>}" >&2
                exit 99
            fi
            cat "$TEST_MONITORS_FIXTURE"
        elif [[ "${1:-}" == "eval" && \
            "${2:-}" == 'hl.dispatch(hl.dsp.dpms({ action = "enable", monitor = "'* ]]; then
            log_command "$@"
            if ! dpms_output=$(property_value "${2:-}" monitor); then
                printf 'Fake could not identify a DPMS monitor in: %s\n' \
                    "${2:-}" >&2
                exit 96
            fi
            printf 'dpms\toutput=%s\tstate=on\n' "$dpms_output" >> "$TEST_EFFECT_LOG"
            if configured_failure_pending \
                "${TEST_HYPRCTL_DPMS_FAILURES:-0}" \
                "${TEST_HYPRCTL_DPMS_COUNTER:-}" dpms; then
                printf 'Configured targeted DPMS failure\n' >&2
                exit 94
            else
                failure_status=$?
                if (( failure_status != 1 )); then
                    exit "$failure_status"
                fi
            fi
            dpms_output_value=${TEST_HYPRCTL_DPMS_OUTPUT:-ok}
            if [[ "$dpms_output_value" == ok ]]; then
                apply_dpms_effect_to_structured_state "$dpms_output" || exit $?
            fi
            printf '%s\n' "$dpms_output_value"
        elif [[ "${1:-}" == "eval" ]]; then
            log_command "$@"
            if [[ -n "${TEST_HYPRCTL_EVAL_DELAY_SECONDS:-}" ]]; then
                "${TEST_REAL_SLEEP_BIN:?}" "$TEST_HYPRCTL_EVAL_DELAY_SECONDS"
            fi
            if configured_failure_pending \
                "${TEST_HYPRCTL_EVAL_FAILURES:-0}" \
                "${TEST_HYPRCTL_EVAL_COUNTER:-}" eval; then
                printf 'Configured monitor apply failure\n' >&2
                exit 94
            else
                failure_status=$?
                if (( failure_status != 1 )); then
                    exit "$failure_status"
                fi
            fi
            IFS=';' read -r -a monitor_expressions <<< "${2:-}"
            for expression in "${monitor_expressions[@]}"; do
                emit_monitor_effect "$expression"
                if [[ "${TEST_HYPRCTL_EVAL_OUTPUT:-ok}" == ok ]]; then
                    apply_monitor_effect_to_structured_state "$expression" || exit $?
                fi
            done
            printf '%s\n' "${TEST_HYPRCTL_EVAL_OUTPUT:-ok}"
        else
            log_command "$@"
            printf 'Unsupported fake hyprctl operation: %s\n' "${1:-}" >&2
            exit 98
        fi
        ;;
    systemctl)
        log_command "$@"
        if [[ "${1:-}" == --user && "${2:-}" == kill ]]; then
            if configured_failure_pending \
                "${TEST_SYSTEMCTL_KILL_FAILURES:-0}" \
                "${TEST_SYSTEMCTL_KILL_COUNTER:-}" systemctl-kill; then
                printf 'Configured systemctl kill failure\n' >&2
                exit 94
            else
                failure_status=$?
                if (( failure_status != 1 )); then
                    exit "$failure_status"
                fi
            fi
        fi
        if [[ "${1:-}" == "--user" && "${2:-}" == "disable" && "${3:-}" == "--now" && \
            -n "${TEST_REQUIRED_PATHS_BEFORE_DISABLE:-}" ]]; then
            IFS=':' read -r -a required_paths <<< "$TEST_REQUIRED_PATHS_BEFORE_DISABLE"
            for required_path in "${required_paths[@]}"; do
                if [[ ! -e "$required_path" ]]; then
                    printf 'Required preparation was missing before service disable: %s\n' \
                        "$required_path" >&2
                    exit 95
                fi
            done
        fi
        for argument in "$@"; do
            case "$argument" in
                hibernate|hybrid-sleep|poweroff|reboot|suspend|suspend-then-hibernate)
                    printf 'Refusing real or simulated power action: %s\n' "$argument" >&2
                    exit 97
                    ;;
            esac
        done
        ;;
    pgrep)
        log_command "$@"
        # Keep any forbidden legacy Waybar probe observable and harmless.
        exit 0
        ;;
    post-layout-hook|'post hook;false;#')
        log_command "$@"
        case "${TEST_POST_LAYOUT_HOOK_MODE:-success}" in
            success)
                ;;
            fail)
                exit 42
                ;;
            hang)
                exec "${TEST_POST_LAYOUT_HOOK_SLEEP_BIN:?}" 10
                ;;
            *)
                printf 'Unsupported post-layout hook mode: %s\n' \
                    "$TEST_POST_LAYOUT_HOOK_MODE" >&2
                exit 98
                ;;
        esac
        ;;
    pkill|sleep)
        log_command "$@"
        ;;
    *)
        printf 'Unsupported fake command name: %s\n' "$command_name" >&2
        exit 98
        ;;
esac
