        elif [[ "${1:-}" == "output" && "${2:-}" == "remove" && \
            "${3:-}" == ARCH-LIDSWITCH-RECOVERY && $# == 3 ]]; then
            log_command "$@"
            if configured_failure_pending \
                "${TEST_HYPRCTL_HEADLESS_REMOVE_FAILURES:-0}" \
                "${TEST_HYPRCTL_HEADLESS_REMOVE_COUNTER:-}" \
                headless-remove; then
